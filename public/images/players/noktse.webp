			<script>
		(function () {
			var slots = document.querySelectorAll('.ps-supporter-slot');
			if (!slots.length) return;

			var update = function (slot) {
				var hasAd = !!slot.querySelector('.pro-feature iframe');
				if (hasAd) {
					slot.classList.add('ps-supporter-slot--filled');
				} else {
					slot.classList.remove('ps-supporter-slot--filled');
				}
			};

			slots.forEach(function (slot) {
				var target = slot.querySelector('.pro-feature');
				if (!target) return;
				update(slot);
				var observer = new MutationObserver(function () {
					update(slot);
				});
				observer.observe(target, { childList: true, subtree: true });
			});
		})();
		</script>
