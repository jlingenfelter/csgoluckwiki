<style id='prosettings-critical-inline-css'>
html body,
html input,
html button,
html select,
html textarea {
  line-height: 1.5;
  color: var(--root-d-2);
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  text-rendering: optimizeLegibility;
}
body,
input,
button,
select,
textarea,
tr,
td,
a,
div,
span,
time,
text,
li,
dt,
dd,
h1,
h2,
h3,
h4,
h5,
h6,
.heading {
  font-family: "Inter", -apple-system, BlinkMacSystemFont, avenir next, avenir, segoe ui, helvetica neue, helvetica, Ubuntu, roboto, noto, arial, sans-serif;
}
html {
  font-size: 1.01rem;
}
html h1,
html h2,
html h3,
html h4,
html h5,
html h6,
html .heading {
  font-weight: 700;
  text-wrap: balance;
  color: var(--root-d-0);
}
html h1 > a,
html h2 > a,
html h3 > a,
html h4 > a,
html h5 > a,
html h6 > a,
html .heading > a {
  text-wrap: balance;
  color: var(--root-d-0);
}
html body,
html p,
html ul,
html li,
html span,
html a,
html button,
html td,
html th {
  text-wrap: pretty;
}
.visually-hidden {
  position: absolute;
  width: 1px;
  height: 1px;
  padding: 0;
  margin: -1px;
  overflow: hidden;
  clip: rect(0, 0, 0, 0);
  white-space: nowrap;
  border: 0;
}
body {
  overflow-x: hidden !important;
  overflow-y: scroll;
  scroll-behavior: smooth;
  text-rendering: optimizeSpeed;
}
article.category-blog {
  max-width: 970px;
  margin: 0 auto;
}
@media only screen and (max-width: 1120px) {
  .desktop-only {
    display: none;
  }
}
@media only screen and (min-width: 1120px) {
  .mobile-only {
    display: none;
  }
}
body:not(.wp-core-ui) #wpadminbar #wp-admin-bar-my-account.with-avatar > .ab-empty-item img,
#wpadminbar #wp-admin-bar-my-account.with-avatar > a img {
  border: none;
  background: transparent;
  margin: 0;
  display: block;
}
#wpadminbar #wp-admin-bar-my-account.with-avatar > .ab-empty-item picture,
#wpadminbar #wp-admin-bar-my-account.with-avatar > a picture {
  width: auto;
  height: 16px;
  padding: 0;
  border: 1px solid #8c8f94;
  background: #f0f0f1;
  line-height: 1.84615384;
  vertical-align: middle;
  margin: -4px 0 0 6px;
  float: none;
  display: inline-block;
}

/*# sourceURL=https://prosettings.net/wp-content/themes/pro-theme/styles/build/critical.min.css */
