---
/**
 * ExploreMore — contextual internal linking component
 * Shows related content from different categories based on current page context.
 * Usage: <ExploreMore context="tools" /> or <ExploreMore context="skins" />
 */
interface Props {
  context?: 'tools' | 'skins' | 'maps' | 'guides' | 'weapons' | 'players' | 'general';
  exclude?: string[]; // slugs to exclude from links
}

const { context = 'general', exclude = [] } = Astro.props;

// Define link groups
const toolLinks = [
  { href: '/damage-calculator/', label: 'Damage Calculator', desc: 'Calculate exact damage' },
  { href: '/sensitivity-converter/', label: 'Sensitivity Converter', desc: 'Convert between games' },
  { href: '/crosshair-generator/', label: 'Crosshair Generator', desc: 'Build your crosshair' },
  { href: '/crosshair-codes/', label: 'Crosshair Codes', desc: 'Pro player presets' },
  { href: '/bind-generator/', label: 'Bind Generator', desc: 'Utility & buy binds' },
  { href: '/economy-calculator/', label: 'Economy Calculator', desc: 'Plan your buys' },
  { href: '/edpi-calculator/', label: 'eDPI Calculator', desc: 'Effective DPI' },
  { href: '/resolution-calculator/', label: 'Resolution Calculator', desc: 'Compare ratios' },
  { href: '/weapon-compare/', label: 'Compare Weapons', desc: 'Side-by-side stats' },
  { href: '/spray-trainer/', label: 'Spray Trainer', desc: 'Practice patterns' },
];

const skinLinks = [
  { href: '/cs2-skins/', label: 'All Skins', desc: '2,000+ skins with prices' },
  { href: '/skin-compare/', label: 'Compare Skins', desc: 'Side-by-side comparison' },
  { href: '/price-tracker/', label: 'Price Tracker', desc: 'Track price trends' },
  { href: '/float-checker/', label: 'Float Checker', desc: 'Check float values' },
  { href: '/tradeup-calculator/', label: 'Trade-Up Calculator', desc: 'Plan trade-ups' },
  { href: '/inventory-lookup/', label: 'Inventory Lookup', desc: 'Check inventory value' },
  { href: '/cs2-cases/', label: 'Cases & Collections', desc: 'Browse all cases' },
  { href: '/market-trends/', label: 'Market Trends', desc: 'Market analysis' },
];

const mapLinks = [
  { href: '/cs2-maps/', label: 'All Maps', desc: 'Map callouts & radar' },
  { href: '/cs2-maps/mirage/', label: 'Mirage', desc: 'Callouts & lineups' },
  { href: '/cs2-maps/inferno/', label: 'Inferno', desc: 'Callouts & lineups' },
  { href: '/cs2-maps/dust2/', label: 'Dust 2', desc: 'Callouts & lineups' },
  { href: '/cs2-maps/anubis/', label: 'Anubis', desc: 'Callouts & lineups' },
  { href: '/lineups/mirage/', label: 'Mirage Lineups', desc: 'Smokes, flashes, mollys' },
  { href: '/lineups/inferno/', label: 'Inferno Lineups', desc: 'Smokes, flashes, mollys' },
  { href: '/workshop-maps/', label: 'Workshop Maps', desc: 'Practice maps' },
];

const guideLinks = [
  { href: '/cs2-guides/', label: 'All Guides', desc: 'Learn CS2' },
  { href: '/economy-guide/', label: 'Economy Guide', desc: 'Money management' },
  { href: '/cs2-rank-distribution/', label: 'Rank Distribution', desc: 'Where you stand' },
  { href: '/cs2-guides/trading-guide/', label: 'Trading Guide', desc: 'Trade profitably' },
  { href: '/cs2-guides/float-guide/', label: 'Float Guide', desc: 'Understand floats' },
  { href: '/cs2-guides/skins-investing-guide/', label: 'Investing Guide', desc: 'Long-term strategies' },
  { href: '/cs2-guides/fps-optimization-guide/', label: 'FPS Guide', desc: 'Maximize framerate' },
  { href: '/pro-players/', label: 'Pro Settings', desc: '860+ pro configs' },
];

// Pick which sections to show based on context
const currentPath = Astro.url.pathname;
const filterOut = (links: typeof toolLinks) =>
  links.filter(l => l.href !== currentPath && !exclude.includes(l.href));

type Section = { title: string; links: typeof toolLinks };
let sections: Section[] = [];

if (context === 'tools') {
  sections = [
    { title: 'More Tools', links: filterOut(toolLinks).slice(0, 5) },
    { title: 'Skin Market', links: filterOut(skinLinks).slice(0, 3) },
    { title: 'Learn & Improve', links: filterOut(guideLinks).slice(0, 3) },
  ];
} else if (context === 'skins') {
  sections = [
    { title: 'Skin Tools', links: filterOut(skinLinks).slice(0, 5) },
    { title: 'Utility Tools', links: filterOut(toolLinks).slice(0, 3) },
    { title: 'Maps & Lineups', links: filterOut(mapLinks).slice(0, 3) },
  ];
} else if (context === 'maps') {
  sections = [
    { title: 'More Maps', links: filterOut(mapLinks).slice(0, 5) },
    { title: 'Practice Tools', links: filterOut(toolLinks).slice(0, 3) },
    { title: 'Skin Market', links: filterOut(skinLinks).slice(0, 3) },
  ];
} else if (context === 'guides') {
  sections = [
    { title: 'More Guides', links: filterOut(guideLinks).slice(0, 5) },
    { title: 'Tools & Calculators', links: filterOut(toolLinks).slice(0, 3) },
    { title: 'Maps & Lineups', links: filterOut(mapLinks).slice(0, 3) },
  ];
} else if (context === 'weapons') {
  sections = [
    { title: 'Combat Tools', links: filterOut(toolLinks).slice(0, 4) },
    { title: 'Skin Market', links: filterOut(skinLinks).slice(0, 3) },
    { title: 'Maps & Lineups', links: filterOut(mapLinks).slice(0, 3) },
  ];
} else if (context === 'players') {
  sections = [
    { title: 'Settings Tools', links: filterOut([
      { href: '/crosshair-generator/', label: 'Crosshair Generator', desc: 'Build your crosshair' },
      { href: '/sensitivity-converter/', label: 'Sensitivity Converter', desc: 'Convert between games' },
      { href: '/edpi-calculator/', label: 'eDPI Calculator', desc: 'Effective DPI' },
      { href: '/crosshair-codes/', label: 'Crosshair Codes', desc: 'Pro player presets' },
      { href: '/pro-players/', label: 'All Pro Players', desc: '860+ pro configs' },
    ]).slice(0, 4) },
    { title: 'Learn & Improve', links: filterOut(guideLinks).slice(0, 3) },
    { title: 'Skin Market', links: filterOut(skinLinks).slice(0, 3) },
  ];
} else {
  sections = [
    { title: 'Tools', links: filterOut(toolLinks).slice(0, 4) },
    { title: 'Skins', links: filterOut(skinLinks).slice(0, 3) },
    { title: 'Guides', links: filterOut(guideLinks).slice(0, 3) },
  ];
}
---

<div class="xplr">
  <h2 class="xplr-title">More on CSGOLuck Wiki</h2>
  <div class="xplr-cols">
    {sections.map(section => (
      <div class="xplr-col">
        <h3>{section.title}</h3>
        <div class="xplr-items">
          {section.links.map(link => (
            <a href={link.href} class="xplr-item">
              <span class="xplr-name">{link.label}</span>
              <span class="xplr-desc">{link.desc}</span>
            </a>
          ))}
        </div>
      </div>
    ))}
  </div>
</div>

<style is:inline>
.xplr{background:var(--bg2);border:1px solid var(--border);border-radius:4px;border-left:4px solid var(--accent);padding:1.2rem;margin:2rem 0}
.xplr-title{margin:0 0 1rem;font-size:1rem;font-weight:700}
.xplr-cols{display:grid;grid-template-columns:repeat(3,1fr);gap:1.5rem}
@media(max-width:768px){.xplr-cols{grid-template-columns:1fr}}
.xplr-col h3{font-size:.75rem;text-transform:uppercase;letter-spacing:.06em;color:var(--text2);margin:0 0 .5rem;font-weight:600}
.xplr-items{display:flex;flex-direction:column;gap:.25rem}
.xplr-item{display:flex;justify-content:space-between;align-items:center;padding:.35rem .5rem;background:var(--bg3);border:1px solid var(--border);border-radius:4px;text-decoration:none;transition:border-left .15s;gap:.5rem}
.xplr-item:hover{border-left:3px solid var(--accent)}
.xplr-name{font-size:.82rem;font-weight:600;color:var(--text);white-space:nowrap}
.xplr-item:hover .xplr-name{color:var(--accent)}
.xplr-desc{font-size:.7rem;color:var(--text2);text-align:right;white-space:nowrap}
</style>
