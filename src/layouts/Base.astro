.sw-viewport::before,.sw-viewport::after{content:'';position:absolute;top:0;bottom:0;width:20px;z-index:3;pointer-events:none}
.sw-viewport::before{left:0;background:linear-gradient(to right,var(--bg),transparent)}
.sw-viewport::after{right:0;background:linear-gradient(to left,var(--bg),transparent)}
.sw-center-line{position:absolute;top:0;bottom:0;left:50%;width:2px;background:#ffd700;z-index:4;transform:translateX(-50%);box-shadow:0 0 8px rgba(255,215,0,.4)}
.sw-strip{display:flex;position:absolute;top:0;left:0;height:100%;will-change:transform}
.sw-item{width:60px;height:50px;flex-shrink:0;display:flex;flex-direction:column;align-items:center;justify-content:center;border-right:1px solid rgba(255,255,255,.04);gap:1px}
