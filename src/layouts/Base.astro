body{background:var(--bg);color:var(--text);font-family:'Montserrat',sans-serif;-webkit-font-smoothing:antialiased;-moz-osx-font-smoothing:grayscale;line-height:1.7;min-height:100vh}
a{color:var(--accent);text-decoration:none;transition:color .2s,text-shadow .2s}
a:hover{color:var(--accent2)}
::selection{background:rgba(46,204,113,0.25);color:var(--text)}
header{background:rgba(26,26,36,0.88);backdrop-filter:blur(12px);border-bottom:1px solid var(--border);box-shadow:0 2px 12px rgba(0,0,0,0.3);position:sticky;top:0;z-index:1000}
header::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,var(--green),var(--accent2),var(--green));z-index:1001}
nav{max-width:1200px;margin:0 auto;padding:.7rem 1.5rem;display:flex;align-items:center;gap:1.5rem;flex-wrap:wrap}
.logo{display:inline-flex;align-items:center;text-decoration:none;flex-shrink:0}
.logo-img{height:25px;width:auto;display:block}
.nav-links{display:flex;gap:.25rem;flex-wrap:wrap}
.nav-links>a{padding:.35rem .7rem;border-radius:6px;font-size:.85rem;font-weight:500;color:var(--text2);white-space:nowrap;position:relative;transition:color .2s,background-color .2s}
.nav-links>a::after{content:'';position:absolute;bottom:0;left:0;width:0;height:2px;background:var(--accent);transition:width .3s cubic-bezier(.25,.46,.45,.94)}
.nav-links>a:hover::after,.nav-links>a.active::after{width:100%}
.nav-links>a:hover,.nav-links>a.active{background:var(--bg3);color:var(--accent)}
.nav-dropdown{position:relative}
.nav-dropdown-btn{background:none;border:none;padding:.35rem .7rem;border-radius:6px;font-size:.85rem;font-weight:500;color:var(--text2);cursor:pointer;white-space:nowrap;font-family:inherit;transition:color .2s,background-color .2s}
.nav-dropdown-btn:hover,.nav-dropdown.open .nav-dropdown-btn{background:var(--bg3);color:var(--accent)}
.nav-dropdown-menu{display:none;position:absolute;top:100%;left:0;margin-top:.35rem;background:var(--bg2);border:1px solid var(--border);border-radius:4px;min-width:220px;box-shadow:0 8px 24px rgba(0,0,0,.5);z-index:1100;padding:.35rem 0;overflow:hidden;opacity:0;transform:translateY(-8px);transition:opacity .2s,transform .2s cubic-bezier(.25,.46,.45,.94),display .2s}
.nav-dropdown.open .nav-dropdown-menu{display:block;opacity:1;transform:translateY(0)}
.nav-dropdown-menu a{display:flex;align-items:center;gap:.5rem;padding:.5rem 1rem;font-size:.85rem;color:var(--text2);white-space:nowrap;text-decoration:none}
.nav-icon{width:16px;height:16px;flex-shrink:0;opacity:.7;transition:opacity .2s}
.nav-dropdown-menu a:hover .nav-icon{opacity:1}
.nav-dropdown-menu a:hover{background:var(--bg3);color:var(--accent)}
/* Mega Menu */
.nav-mega-menu{display:none;position:absolute;top:100%;left:50%;transform:translateX(-50%) translateY(-8px);margin-top:.35rem;background:var(--bg2);border:1px solid var(--border);border-radius:4px;box-shadow:0 12px 40px rgba(0,0,0,.6);z-index:1100;padding:1rem;opacity:0;transition:opacity .2s,transform .2s cubic-bezier(.25,.46,.45,.94),display .2s;width:max-content;max-width:720px}
.nav-mega.open .nav-mega-menu{display:grid;grid-template-columns:repeat(4,1fr);gap:.75rem;opacity:1;transform:translateX(-50%) translateY(0)}
.mega-col{display:flex;flex-direction:column;gap:.15rem;min-width:140px}
.mega-heading{display:block;font-size:.78rem;font-weight:700;color:var(--accent);text-transform:uppercase;letter-spacing:.06em;padding:.3rem .5rem;margin-bottom:.2rem;text-decoration:none;border-radius:4px;transition:background .2s}
.mega-heading:hover{background:var(--bg3)}
.mega-heading-static{cursor:default}
.mega-heading-static:hover{background:transparent}
.mega-link{display:flex;justify-content:space-between;align-items:center;padding:.3rem .5rem;font-size:.82rem;color:var(--text2);text-decoration:none;border-radius:4px;transition:all .15s;gap:.5rem}
.mega-link:hover{background:var(--bg3);color:var(--text)}
.mega-cat-link{font-weight:600;color:var(--text)}
.mega-cat-link:hover{color:var(--accent)}
.mega-count{font-size:.7rem;color:var(--text2);opacity:.6;font-weight:600}
.mega-view-all{display:block;font-size:.75rem;font-weight:700;color:var(--accent);text-decoration:none;padding:.35rem .5rem;margin-top:.2rem;border-top:1px solid var(--border);transition:color .2s}
.mega-view-all:hover{color:var(--accent2)}
.mega-divider{height:1px;background:var(--border);margin:.35rem 0}
.nav-mega-3col.open .nav-mega-menu{grid-template-columns:repeat(3,1fr)}
.nav-mega-2col.open .nav-mega-menu{grid-template-columns:repeat(2,1fr)}
.nav-dropdown-btn.active{color:var(--accent)}
@media(max-width:768px){.nav-mega-menu{left:0;transform:translateX(0) translateY(-8px);max-width:calc(100vw - 2rem)}.nav-mega.open .nav-mega-menu,.nav-mega-3col.open .nav-mega-menu,.nav-mega-2col.open .nav-mega-menu{grid-template-columns:repeat(2,1fr);transform:translateX(0) translateY(0)}}
.nav-search{margin-left:auto}
.nav-search input{background:var(--bg3);color:var(--text);border:1px solid var(--border);padding:.35rem .7rem;border-radius:6px;font-size:.85rem;width:140px;transition:width .3s,border-color .3s}
.nav-search input:focus{width:200px;border-color:var(--accent);outline:none}
main{max-width:1200px;margin:0 auto;padding:2rem 1.5rem;position:relative;z-index:1}
h1{font-size:2rem;font-weight:800;margin-bottom:1rem;color:var(--text);line-height:1.2;letter-spacing:-.02em}
h2{font-size:1.5rem;font-weight:700;margin:2rem 0 .75rem;color:var(--text);letter-spacing:-.01em}
h3{font-size:1.15rem;font-weight:600;margin:1.5rem 0 .5rem;color:var(--text);letter-spacing:-.005em}
p{margin-bottom:1rem;color:var(--text2)}
footer{margin-top:4rem;padding:2rem 1.5rem;background:var(--bg2);border-top:1px solid var(--border);text-align:center;position:relative}
footer::before{content:'';position:absolute;top:0;left:0;right:0;height:40px;background:linear-gradient(to bottom,transparent,rgba(18,19,25,1));pointer-events:none}
.footer-inner{max-width:1200px;margin:0 auto}
.footer-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:1.5rem;text-align:left;margin-bottom:2rem;max-width:1000px}
.footer-col h4{color:var(--accent);font-size:.82rem;text-transform:uppercase;letter-spacing:.08em;margin:0 0 .75rem;font-weight:700;transition:color .2s}
.footer-col{display:flex;flex-direction:column;gap:.35rem}
.footer-col a{font-size:.82rem;color:var(--text2);text-decoration:none}
.footer-col a:hover{color:var(--accent)}
footer p{font-size:.78rem;color:var(--text2);opacity:.7}
.breadcrumb{font-size:.82rem;color:var(--text2);margin-bottom:1rem;letter-spacing:.02em}
.breadcrumb a{color:var(--accent);font-weight:500}
.breadcrumb span.sep{margin:0 .4rem;color:var(--border);font-size:.75rem}
.card-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:1rem;margin:1.5rem 0}
.card{background:var(--bg2);border:1px solid var(--border);border-radius:4px;padding:1.25rem;transition:border-color .2s,border-left .2s,box-shadow .2s;box-shadow:0 2px 8px rgba(0,0,0,0.2)}
.card:hover{border-color:var(--accent);border-left:3px solid var(--accent);box-shadow:0 4px 16px rgba(0,0,0,0.3)}
.card h3{margin:0 0 .4rem;font-size:1.05rem}
.card p{font-size:.88rem;margin:0;color:var(--text2)}
.card a{display:block;text-decoration:none;color:inherit}
.card .card-meta{font-size:.78rem;color:var(--text2);margin-top:.5rem;display:flex;gap:.75rem;flex-wrap:wrap}
.tag{display:inline-block;padding:.2rem .6rem;border-radius:4px;font-size:.75rem;font-weight:600;background:var(--bg3);color:var(--text2);border:1px solid var(--border)}
.tag.rifle{border-color:var(--red);color:var(--red)}
.tag.smg{border-color:var(--accent);color:var(--accent)}
.tag.pistol{border-color:var(--blue);color:var(--blue)}
.tag.heavy{border-color:var(--purple);color:var(--purple)}
.tag.ct{border-color:var(--ct);color:var(--ct)}
.tag.t{border-color:var(--t);color:var(--t)}
.tag.both{border-color:var(--green);color:var(--green)}
table{width:100%;border-collapse:collapse;margin:1rem 0;font-size:.9rem}
th,td{padding:.6rem .8rem;text-align:left;border-bottom:1px solid var(--border)}
th{background:var(--bg2);color:var(--text);font-weight:600;font-size:.82rem;text-transform:uppercase;letter-spacing:.03em}
td{color:var(--text2)}
tr:hover td{background:var(--bg2)}
tr:hover td:first-child{border-left:2px solid var(--accent)}
.stats-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(160px,1fr));gap:.75rem;margin:1rem 0}
.stat-card{background:var(--bg2);border:1px solid var(--border);border-radius:4px;padding:.75rem;text-align:center;transition:border-color .2s,border-left .2s,box-shadow .2s;box-shadow:0 2px 8px rgba(0,0,0,0.2)}
.stat-card:hover{border-color:var(--accent);border-left:3px solid var(--green);box-shadow:0 4px 12px rgba(46,204,113,0.12)}
.stat-card .val{font-size:1.5rem;font-weight:800;color:var(--accent)}
.stat-card .label{font-size:.78rem;color:var(--text2);margin-top:.2rem}
.calc-section{background:var(--bg2);border:1px solid var(--border);border-radius:4px;padding:1.5rem;margin:1.5rem 0}
.calc-row{display:flex;gap:1rem;align-items:center;margin:.75rem 0;flex-wrap:wrap}
.calc-row label{font-weight:600;min-width:120px;font-size:.9rem}
.calc-row select,.calc-row input[type="number"]{background:var(--bg3);color:var(--text);border:1px solid var(--border);padding:.5rem .75rem;border-radius:4px;font-size:.9rem;transition:border-color .2s,box-shadow .2s}
.calc-row select:focus,.calc-row input[type="number"]:focus{outline:none;border-color:var(--accent);box-shadow:0 0 0 3px rgba(46,204,113,0.1)}
.calc-row input[type="range"]{flex:1;accent-color:var(--accent)}
.result-box{background:var(--bg3);border:none;border-left:2px solid var(--accent);border-radius:4px;padding:1.25rem;margin:1rem 0;box-shadow:0 4px 12px rgba(46,204,113,0.1);transition:box-shadow .2s}
.result-box .big{font-size:2rem;font-weight:800;color:var(--accent)}
.tip-list{list-style:none;padding:0;margin:1rem 0}
.tip-list li{padding:.5rem 0 .5rem 1.5rem;position:relative;font-size:.9rem;color:var(--text2);border-bottom:1px solid var(--border)}
.tip-list li::before{content:'';position:absolute;left:0;top:.75rem;width:8px;height:8px;border-radius:50%;background:var(--accent);opacity:.6}
.faq{margin:2rem 0}
.faq dt{font-weight:700;color:var(--text);padding:.75rem 0 .25rem;border-top:1px solid var(--border)}
.faq dd{color:var(--text2);padding-bottom:.75rem;font-size:.92rem}
.internal-links{display:flex;gap:.75rem;flex-wrap:wrap;margin:2rem 0;padding:1rem;background:var(--bg2);border-radius:4px;border:1px solid var(--border)}
.internal-links a{padding:.35rem .75rem;background:var(--bg3);border-radius:4px;font-size:.85rem;color:var(--text2);border:1px solid var(--border);transition:border-color .2s,color .2s,background-color .2s}
.internal-links a:hover{border-color:var(--accent);color:var(--accent);background:var(--bg)}
.filter-btn{background:var(--bg3);color:var(--text2);border:1px solid var(--border);padding:.35rem .75rem;border-radius:4px;cursor:pointer;font-size:.82rem;font-family:inherit;transition:all .2s,text-shadow .2s}
.filter-btn:hover,.filter-btn.active{background:var(--accent);color:var(--bg);border-color:var(--accent);font-weight:600}
/* Hamburger button */
.hamburger{display:none;background:none;border:none;cursor:pointer;padding:6px;margin-left:auto;flex-direction:column;gap:5px;z-index:1001}
.hamburger span{display:block;width:22px;height:2px;background:var(--text);border-radius:2px;transition:all .3s}
.hamburger.active span:nth-child(1){transform:rotate(45deg) translate(5px,5px)}
.hamburger.active span:nth-child(2){opacity:0}
.hamburger.active span:nth-child(3){transform:rotate(-45deg) translate(5px,-5px)}
/* Mobile drawer */
.mobile-drawer{position:fixed;top:0;right:-320px;width:300px;max-width:85vw;height:100vh;background:var(--bg2);border-left:1px solid var(--border);z-index:1200;overflow-y:auto;transition:right .3s cubic-bezier(.25,.46,.45,.94);padding:0}
.mobile-drawer.open{right:0}
.mobile-drawer-header{display:flex;align-items:center;justify-content:space-between;padding:1rem 1.25rem;border-bottom:1px solid var(--border)}
.mobile-close{background:none;border:none;color:var(--text);font-size:1.8rem;cursor:pointer;padding:0;line-height:1}
.mobile-drawer-search{padding:.75rem 1.25rem;border-bottom:1px solid var(--border)}
.mobile-drawer-search input{width:100%;background:var(--bg3);color:var(--text);border:1px solid var(--border);padding:.5rem .75rem;border-radius:6px;font-size:.9rem}
.mobile-drawer-search input:focus{border-color:var(--accent);outline:none}
.mobile-drawer-links{padding:.5rem 0}
.mobile-drawer-links>a{display:block;padding:.75rem 1.25rem;font-size:.95rem;color:var(--text2);text-decoration:none;border-bottom:1px solid rgba(45,45,60,.5);transition:background .2s,color .2s}
.mobile-drawer-links>a:hover,.mobile-drawer-links>a.active{background:var(--bg3);color:var(--accent)}
.mobile-section{border-bottom:1px solid rgba(45,45,60,.5)}
.mobile-section summary{display:block;padding:.75rem 1.25rem;font-size:.95rem;font-weight:600;color:var(--text);cursor:pointer;list-style:none;position:relative;transition:background .2s}
.mobile-section summary::-webkit-details-marker{display:none}
.mobile-section summary::after{content:'▸';position:absolute;right:1.25rem;top:.75rem;color:var(--text2);transition:transform .2s}
.mobile-section[open] summary::after{transform:rotate(90deg)}
.mobile-section summary:hover{background:var(--bg3)}
.mobile-sub{display:flex;flex-direction:column;padding:0 0 .5rem}
.mobile-sub a{padding:.45rem 1.25rem .45rem 2rem;font-size:.88rem;color:var(--text2);text-decoration:none;transition:background .2s,color .2s}
.mobile-sub a:hover{background:var(--bg3);color:var(--accent)}
.mobile-divider{height:1px;background:var(--border);margin:.25rem 2rem}
.mobile-overlay{display:none;position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,.6);z-index:1199;backdrop-filter:blur(2px)}
.mobile-overlay.open{display:block}
@media(max-width:768px){
  nav{padding:.5rem 1rem;flex-wrap:nowrap}
  .nav-links,.nav-search{display:none}
  .hamburger{display:flex}
  main{padding:1.5rem 1rem}
  h1{font-size:1.6rem}
  .card-grid{grid-template-columns:1fr}
  .stats-grid{grid-template-columns:repeat(2,1fr)}
  .footer-grid{grid-template-columns:repeat(2,1fr)!important}
}
</style>
<script is:inline>
document.addEventListener('DOMContentLoaded',function(){
  var dropdowns=document.querySelectorAll('.nav-dropdown');
  dropdowns.forEach(function(dd){
    var btn=dd.querySelector('.nav-dropdown-btn');
    if(!btn)return;
    btn.addEventListener('click',function(e){
      e.stopPropagation();
      dropdowns.forEach(function(other){if(other!==dd){other.classList.remove('open');var ob=other.querySelector('.nav-dropdown-btn');if(ob)ob.setAttribute('aria-expanded','false');}});
      dd.classList.toggle('open');
      btn.setAttribute('aria-expanded',dd.classList.contains('open'));
    });
    var menu=dd.querySelector('.nav-dropdown-menu') || dd.querySelector('.nav-mega-menu');
    if(menu)menu.addEventListener('click',function(e){e.stopPropagation();});
  });
  document.addEventListener('click',function(){dropdowns.forEach(function(dd){dd.classList.remove('open');var b=dd.querySelector('.nav-dropdown-btn');if(b)b.setAttribute('aria-expanded','false');});});
  // Mobile hamburger menu
  var hamburger=document.getElementById('hamburgerBtn');
  var drawer=document.getElementById('mobileDrawer');
  var overlay=document.getElementById('mobileOverlay');
  var closeBtn=document.getElementById('mobileClose');
  function openDrawer(){drawer.classList.add('open');overlay.classList.add('open');hamburger.classList.add('active');hamburger.setAttribute('aria-expanded','true');document.body.style.overflow='hidden';}
  function closeDrawer(){drawer.classList.remove('open');overlay.classList.remove('open');hamburger.classList.remove('active');hamburger.setAttribute('aria-expanded','false');document.body.style.overflow='';}
  if(hamburger){hamburger.addEventListener('click',function(e){e.stopPropagation();drawer.classList.contains('open')?closeDrawer():openDrawer();});}
  if(closeBtn)closeBtn.addEventListener('click',closeDrawer);
  if(overlay)overlay.addEventListener('click',closeDrawer);
});
</script>
</body>
</html>
