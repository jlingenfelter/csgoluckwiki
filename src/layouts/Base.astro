.sw-header{display:flex;align-items:center;gap:.5rem}
.sw-logo{width:20px;height:20px;object-fit:contain}
.sw-title{font-size:.82rem;font-weight:800;color:#ffd700;flex:1;letter-spacing:.02em}
.sw-close{background:none;border:none;color:var(--text2);font-size:1.1rem;cursor:pointer;padding:0;line-height:1;opacity:.5;transition:opacity .2s}.sw-close:hover{opacity:1;color:var(--text)}
.sw-reel-wrap{position:relative}
.sw-pointer{width:0;height:0;border-left:6px solid transparent;border-right:6px solid transparent;border-top:8px solid #ffd700;margin:0 auto 3px;filter:drop-shadow(0 0 4px rgba(255,215,0,.6))}
