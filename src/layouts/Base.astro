@media(max-width:480px){.sw-popup-card{padding:1.5rem 1.25rem 1.25rem}.sw-popup-title{font-size:1.15rem}.sw-popup-prize{padding:1rem 1.25rem}.sw-popup-trust{gap:.4rem}.sw-popup-trust-item{font-size:.6rem;padding:.25rem .4rem}.sw-popup-cta{font-size:.82rem;padding:.6rem 1.6rem}}
