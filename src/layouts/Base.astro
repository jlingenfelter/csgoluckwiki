.sw-popup-cta{display:inline-block;background:linear-gradient(135deg,#ffd700,#ffaa00);color:#000;font-weight:800;font-size:.9rem;text-transform:uppercase;letter-spacing:.04em;padding:.7rem 2rem;border-radius:5px;text-decoration:none;transition:transform .15s,box-shadow .15s;box-shadow:0 4px 18px rgba(255,215,0,.35);margin-bottom:.65rem}
.sw-popup-cta:hover{transform:translateY(-2px);box-shadow:0 6px 25px rgba(255,215,0,.5);color:#000}
