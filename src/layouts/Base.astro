.sw-spin-btn{width:100%;background:linear-gradient(135deg,#ffd700,#ffaa00);color:#000;border:none;padding:.5rem;border-radius:5px;font-size:.82rem;font-weight:800;cursor:pointer;font-family:inherit;text-transform:uppercase;letter-spacing:.04em;transition:all .2s;box-shadow:0 2px 12px rgba(255,215,0,.3)}
