.sw-cta:hover{box-shadow:0 4px 18px rgba(46,204,113,.45);transform:translateY(-1px)}
@media(max-width:900px){.sw-widget{display:none}}
/* ── Bonus Interstitial Popup ──────────────────────────── */
.sw-popup{position:fixed;inset:0;z-index:10000;display:flex;align-items:center;justify-content:center;padding:1rem;opacity:0;pointer-events:none;transition:opacity .25s ease}
