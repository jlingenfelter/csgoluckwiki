---
import { getWeaponsInCategory, getCategoryCount } from '../lib/skins';
import { WEAPONS } from '../lib/weapons';
import { allRanks } from '../lib/ranks';
import { MAP_CALLOUTS } from '../lib/map-callouts';
import CurrencySelector from '../components/CurrencySelector.astro';

interface Props { title: string; description: string; currentNav?: string; ogImage?: string; }
const { title, description, currentNav = '/', ogImage } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImageUrl = ogImage || new URL('/og-default.png', Astro.site).href;

// Skins mega menu data
const rifleWeapons = getWeaponsInCategory('rifle').slice(0, 7);
const pistolWeapons = getWeaponsInCategory('pistol').slice(0, 7);
const smgWeapons = getWeaponsInCategory('smg').slice(0, 5);
const knifeCount = getCategoryCount('knife');
const gloveCount = getCategoryCount('glove');
const heavyCount = getCategoryCount('heavy');
const smgCount = getCategoryCount('smg');

// Weapons mega menu data
const rifles = WEAPONS.filter(w => w.category === 'rifle');
const smgs = WEAPONS.filter(w => w.category === 'smg');
const pistols = WEAPONS.filter(w => w.category === 'pistol');
const heavies = WEAPONS.filter(w => w.category === 'heavy');
const grenades = WEAPONS.filter(w => w.category === 'grenade');

// Ranks mega menu data
const silverRanks = allRanks.filter(r => r.tier === 'Silver');
const goldRanks = allRanks.filter(r => r.tier === 'Gold Nova');
const guardianRanks = allRanks.filter(r => r.tier === 'Master Guardian');
const eliteRanks = allRanks.filter(r => ['Distinguished', 'Legendary', 'Supreme', 'Global Elite'].includes(r.tier));
