      "foundingDate": "2024",
      "founder": {
        "@type": "Person",
        "name": "Josh Lingenfelter",
        "url": "https://www.linkedin.com/in/josh-lingenfelter-8157274b/",
        "jobTitle": "Director",
        "worksFor": {
          "@type": "Organization",
          "name": "Bettor Media"
        }
      },
      "sameAs": []
    },
    {
      "@type": "WebSite",
      "@id": "https://csdb.gg/#website",
      "name": "CSDB.gg",
      "url": "https://csdb.gg",
      "publisher": {"@id": "https://csdb.gg/#organization"},
      "description": "CS2 Skin Database — prices, tools, calculators, guides, and pro player settings.",
      "potentialAction": {
        "@type": "SearchAction",
        "target": {
          "@type": "EntryPoint",
          "urlTemplate": "https://csdb.gg/search/?q={search_term_string}"
        },
        "query-input": "required name=search_term_string"
      },
      "inLanguage": "en-US"
    }
  ]
}</script>
