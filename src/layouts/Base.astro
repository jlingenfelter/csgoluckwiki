<script is:inline>
document.addEventListener('DOMContentLoaded',function(){
  var dropdowns=document.querySelectorAll('.nav-dropdown');
  dropdowns.forEach(function(dd){
    var btn=dd.querySelector('.nav-dropdown-btn');
    if(!btn)return;
    btn.addEventListener('click',function(e){
      e.stopPropagation();
      dropdowns.forEach(function(other){if(other!==dd){other.classList.remove('open');var ob=other.querySelector('.nav-dropdown-btn');if(ob)ob.setAttribute('aria-expanded','false');}});
      dd.classList.toggle('open');
      btn.setAttribute('aria-expanded',dd.classList.contains('open'));
    });
    var menu=dd.querySelector('.nav-dropdown-menu') || dd.querySelector('.nav-mega-menu');
    if(menu)menu.addEventListener('click',function(e){e.stopPropagation();});
  });
  document.addEventListener('click',function(){dropdowns.forEach(function(dd){dd.classList.remove('open');var b=dd.querySelector('.nav-dropdown-btn');if(b)b.setAttribute('aria-expanded','false');});});
  // Mobile hamburger menu
  var hamburger=document.getElementById('hamburgerBtn');
  var drawer=document.getElementById('mobileDrawer');
  var overlay=document.getElementById('mobileOverlay');
  var closeBtn=document.getElementById('mobileClose');
  function openDrawer(){drawer.classList.add('open');overlay.classList.add('open');hamburger.classList.add('active');hamburger.setAttribute('aria-expanded','true');document.body.style.overflow='hidden';}
  function closeDrawer(){drawer.classList.remove('open');overlay.classList.remove('open');hamburger.classList.remove('active');hamburger.setAttribute('aria-expanded','false');document.body.style.overflow='';}
  if(hamburger){hamburger.addEventListener('click',function(e){e.stopPropagation();drawer.classList.contains('open')?closeDrawer():openDrawer();});}
  if(closeBtn)closeBtn.addEventListener('click',closeDrawer);
  if(overlay)overlay.addEventListener('click',closeDrawer);

  // Theme Toggle
  var themeBtn=document.getElementById('themeToggle');
  if(themeBtn){themeBtn.addEventListener('click',function(){
    document.documentElement.classList.toggle('light-mode');
    localStorage.setItem('theme',document.documentElement.classList.contains('light-mode')?'light':'dark');
  });}

  // Cmd+K Quick Search
  var QK_PAGES=[
    {g:'Tools',icon:'wrench',items:[
      {t:'Crosshair Generator',u:'/crosshair-generator/'},{t:'Damage Calculator',u:'/damage-calculator/'},{t:'Economy Calculator',u:'/economy-calculator/'},
      {t:'eDPI Calculator',u:'/edpi-calculator/'},{t:'Sensitivity Converter',u:'/sensitivity-converter/'},{t:'cm/360 Calculator',u:'/cm360-calculator/'},
      {t:'Resolution Calculator',u:'/resolution-calculator/'},{t:'Bind Generator',u:'/bind-generator/'},{t:'Autoexec Generator',u:'/autoexec-generator/'},
      {t:'Spray Trainer',u:'/spray-trainer/'},{t:'Float Checker',u:'/float-checker/'},{t:'Trade-Up Calculator',u:'/tradeup-calculator/'},
      {t:'Case Simulator',u:'/case-simulator/'},{t:'Loadout Builder',u:'/loadout-builder/'},{t:'Inventory Lookup',u:'/inventory-lookup/'},
      {t:'Case Odds Calculator',u:'/case-odds-calculator/'},{t:'Weapon Compare',u:'/weapon-compare/'},{t:'Skin Compare',u:'/skin-compare/'},
      {t:'Console Commands',u:'/cs2-commands/'},{t:'Launch Options',u:'/launch-options/'},{t:'Practice Config',u:'/practice-config/'}
    ]},
    {g:'Database',icon:'database',items:[
      {t:'All Skins',u:'/cs2-skins/'},{t:'All Weapons',u:'/cs2-weapons/'},{t:'Cases & Collections',u:'/cs2-cases/'},
      {t:'Stickers',u:'/cs2-stickers/'},{t:'Agents',u:'/cs2-agents/'},{t:'Market Trends',u:'/market-trends/'},
      {t:'Price Tracker',u:'/price-tracker/'},{t:'Best Deals',u:'/cs2-skins/best-deals/'},{t:'Pattern Database',u:'/pattern-database/'},
      {t:'Rifle Skins',u:'/cs2-skins/rifles/'},{t:'Pistol Skins',u:'/cs2-skins/pistols/'},{t:'Knife Skins',u:'/cs2-skins/knives/'},
      {t:'Glove Skins',u:'/cs2-skins/gloves/'},{t:'SMG Skins',u:'/cs2-skins/smgs/'},{t:'Heavy Skins',u:'/cs2-skins/heavy/'}
    ]},
    {g:'Maps',icon:'map',items:[
      {t:'All Maps',u:'/cs2-maps/'},{t:'Mirage',u:'/cs2-maps/mirage/'},{t:'Inferno',u:'/cs2-maps/inferno/'},
      {t:'Dust 2',u:'/cs2-maps/dust2/'},{t:'Nuke',u:'/cs2-maps/nuke/'},{t:'Ancient',u:'/cs2-maps/ancient/'},
      {t:'Anubis',u:'/cs2-maps/anubis/'},{t:'Vertigo',u:'/cs2-maps/vertigo/'},{t:'Overpass',u:'/cs2-maps/overpass/'},
      {t:'Workshop Maps',u:'/workshop-maps/'}
    ]},
    {g:'Esports',icon:'trophy',items:[
      {t:'Live Matches',u:'/matches/'},{t:'Tournaments',u:'/tournaments/'},{t:"Pick'Ems",u:'/pickems/'}
    ]},
    {g:'Pro Scene',icon:'trophy',items:[
      {t:'All Pro Players',u:'/pro-players/'},{t:'Teams',u:'/pro-teams/'},{t:'Pro Gaming Gear',u:'/pro-gaming-gear/'},
      {t:'Crosshair Codes',u:'/crosshair-codes/'},{t:'Rank Distribution',u:'/cs2-rank-distribution/'}
    ]},
    {g:'Learn',icon:'book',items:[
      {t:'All Guides',u:'/cs2-guides/'},{t:"Beginner's Guide",u:'/cs2-guides/beginners-guide/'},{t:'Aim Guide',u:'/cs2-guides/aim-guide/'},
      {t:'Economy Guide',u:'/economy-guide/'},{t:'Patch Notes',u:'/patch-notes/'},{t:'FAQ',u:'/faq/'},
      {t:'Search (Full)',u:'/search/'}
    ]}
  ];
  var ICONS={wrench:'\u{1F527}',database:'\u{1F4BE}',map:'\u{1F5FA}',trophy:'\u{1F3C6}',book:'\u{1F4DA}'};
  var qkOv=document.getElementById('qkOverlay'),qkIn=document.getElementById('qkInput'),qkRes=document.getElementById('qkResults');
  var qkIdx=-1,qkItems=[];
  function qkOpen(){qkOv.classList.add('open');qkIn.value='';qkRender('');qkIn.focus();}
  function qkClose(){qkOv.classList.remove('open');qkIdx=-1;}
  function qkRender(q){
    q=q.toLowerCase().trim();
    var html='',count=0;
    QK_PAGES.forEach(function(g){
      var matches=g.items.filter(function(i){return !q||i.t.toLowerCase().includes(q);});
      if(!matches.length)return;
      html+='<div class="qk-group-label">'+g.g+'</div>';
      matches.forEach(function(i){
        html+='<a class="qk-item" href="'+i.u+'" data-qk="'+count+'"><span class="qk-item-icon">'+ICONS[g.icon]+'</span><span class="qk-item-text">'+i.t+'</span></a>';
        count++;
      });
    });
    if(!count&&q){html='<div class="qk-empty">No results for "'+q+'"<br><a href="/search/?q='+encodeURIComponent(q)+'" style="color:var(--accent);font-weight:600">Search all skins →</a></div>';}
    qkRes.innerHTML=html;
    qkItems=qkRes.querySelectorAll('.qk-item');
    qkIdx=-1;
    if(qkItems.length>0){qkIdx=0;qkItems[0].classList.add('qk-active');}
  }
  function qkHighlight(n){
    if(!qkItems.length)return;
    if(qkItems[qkIdx])qkItems[qkIdx].classList.remove('qk-active');
    qkIdx=((n%qkItems.length)+qkItems.length)%qkItems.length;
    qkItems[qkIdx].classList.add('qk-active');
    qkItems[qkIdx].scrollIntoView({block:'nearest'});
  }
  document.addEventListener('keydown',function(e){
    if((e.metaKey||e.ctrlKey)&&e.key==='k'){e.preventDefault();qkOv.classList.contains('open')?qkClose():qkOpen();}
    if(!qkOv.classList.contains('open'))return;
    if(e.key==='Escape'){e.preventDefault();qkClose();}
    if(e.key==='ArrowDown'){e.preventDefault();qkHighlight(qkIdx+1);}
    if(e.key==='ArrowUp'){e.preventDefault();qkHighlight(qkIdx-1);}
    if(e.key==='Enter'&&qkItems[qkIdx]){e.preventDefault();window.location.href=qkItems[qkIdx].getAttribute('href');}
  });
  if(qkIn)qkIn.addEventListener('input',function(){qkRender(this.value);});
  if(qkOv)qkOv.addEventListener('click',function(e){if(e.target===qkOv)qkClose();});
});
</script>
<script is:inline>
(function(){
  var widget = document.getElementById('sideWidget');
  var swClose = document.getElementById('swClose');
  var swSpinBtn = document.getElementById('swSpinBtn');
  var swStrip = document.getElementById('swStrip');
  var swResult = document.getElementById('swResult');
  var swCta = document.getElementById('swCta');
  if (!widget || !swStrip) return;

  var REFERRAL = 'https://csgoluck.com/r/WIKIPEDIA';

  // Don't show on homepage or go page
  var path = window.location.pathname;
  if (path === '/' || path === '/go/' || path === '/go') { widget.style.display = 'none'; return; }

  // Check dismissal (24hr cooldown)
  var dismissed = localStorage.getItem('sw-dismissed');
  var isDismissed = false;
  if (dismissed) {
    var ts = parseInt(dismissed, 10);
    if (Date.now() - ts < 86400000) { isDismissed = true; }
  }

  // Skin pool
  var skins = [
    { n:'Sand Dune', r:'industrial', img:'https://community.cloudflare.steamstatic.com/economy/image/-9a81dlWLwJ2UUGcVs_nsVtzdOEdtWwKGZZLQHTxDZ7I56KU0Zwwo4NUX4oFJZEHLbXH5ApeO4YmlhxYQknCRvCo04DEVlxkKgposbaqKAxfwPz3YjxM6OO0hoGdmMj4OrzZgiVTvZUk27iU99Xw31XnrkVoa2n1LYHDcgQ4YwzX_AK3xO_n1pC56ZjJ1zI97Z-o7L5L' },
    { n:'Tornado', r:'consumer', img:'https://steamcommunity-a.akamaihd.net/economy/image/-9a81dlWLwJ2UUGcVs_nsVtzdOEdtWwKGZZLQHTxDZ7I56KU0Zwwo4NUX4oFJZEHLbXH5ApeO4YmlhxYQknCRvCo04DEVlxkKgpou7umeldfwPz3ZTJQ4t2ym7-GkvP9JraflTtV6ZEmjuqQ9o70jQXm8xZvYmD1LdTGIQVraVCG81K6w-nth8e7uoOJlyV6R_U6uA' },
    { n:'Hot Rod', r:'milspec', img:'https://steamcommunity-a.akamaihd.net/economy/image/-9a81dlWLwJ2UUGcVs_nsVtzdOEdtWwKGZZLQHTxDZ7I56KU0Zwwo4NUX4oFJZEHLbXH5ApeO4YmlhxYQknCRvCo04DEVlxkKgpot6-iFAZu7OHNdQJO5du-gM7SlvP2a-KFkDsD6cN33b6Z84rz0QXs8xJuZzymdYfDclU2M17W_Fm7366x0jzU3_8y' },
    { n:'Blaze', r:'restricted', img:'https://community.cloudflare.steamstatic.com/economy/image/-9a81dlWLwJ2UUGcVs_nsVtzdOEdtWwKGZZLQHTxDZ7I56KU0Zwwo4NUX4oFJZEHLbXH5ApeO4YmlhxYQknCRvCo04DEVlxkKgposr-kLAtl7PLJTjtO7dGzh7-HnvD8J_XVkjoFuMYiiLqUrI-k3le3r0s5amj7d9eTI1I-M1rW-Fm_xO-50Jfvot2XnhS4_w8U' },
    { n:'Fade', r:'restricted', img:'https://steamcommunity-a.akamaihd.net/economy/image/-9a81dlWLwJ2UUGcVs_nsVtzdOEdtWwKGZZLQHTxDZ7I56KU0Zwwo4NUX4oFJZEHLbXH5ApeO4YmlhxYQknCRvCo04DEVlxkKgposbaqKAxf0vL3dzxG6eO6nYeDg7miYr7VlWgHscN32LyT8dmm31XgrxdtZzvzJYDGIFM2Y16D-FfvlOu9m9bi66Oq9HyE' },
    { n:'Hydroponic', r:'classified', img:'https://community.cloudflare.steamstatic.com/economy/image/-9a81dlWLwJ2UUGcVs_nsVtzdOEdtWwKGZZLQHTxDZ7I56KU0Zwwo4NUX4oFJZEHLbXH5ApeO4YmlhxYQknCRvCo04DEVlxkKgpot7HxfDhh3szKcDBA49OJnpWFkPvxDLbUkmJE5YsoibiSrY6m2lbi_Ec4Y2z0dY6ccgJsaF3Q-gK_k-e9h5_qtMnOnSM1pGB8svbIhxYt' },
    { n:'Dragon Lore', r:'covert', img:'https://steamcommunity-a.akamaihd.net/economy/image/-9a81dlWLwJ2UUGcVs_nsVtzdOEdtWwKGZZLQHTxDZ7I56KU0Zwwo4NUX4oFJZEHLbXH5ApeO4YmlhxYQknCRvCo04DEVlxkKgpot621FAR17P7NdTRH-t26q4SZlvD7PYTQgXtu5Mx2gv2P9o6migzl_Us5ZmCmLYDDJgU9NA6B81S5yezvg8e-7cycnXJgvHZx5WGdwUJqz1Tl4g' },
    { n:'Moss Quartz', r:'industrial', img:'https://steamcommunity-a.akamaihd.net/economy/image/-9a81dlWLwJ2UUGcVs_nsVtzdOEdtWwKGZZLQHTxDZ7I56KU0Zwwo4NUX4oFJZEHLbXH5ApeO4YmlhxYQknCRvCo04DEVlxkKgpou-6kejhz2v_Nfz5H_uO3mb-Ihe7nJ7rdmmJL7cFOjujT_rPymlGxpSw0Nji1bZiRcFJsYl6D8wO9yb-5h8XqvZXJnXtq7iIj5H7dmhy21B1EZ7NugvHLVxzAUGZ4JKG4' },
    { n:'Fallout Warning', r:'industrial', img:'https://steamcommunity-a.akamaihd.net/economy/image/-9a81dlWLwJ2UUGcVs_nsVtzdOEdtWwKGZZLQHTxDZ7I56KU0Zwwo4NUX4oFJZEHLbXH5ApeO4YmlhxYQknCRvCo04DEVlxkKgpopuP1FBRw7P3dejhR-M6_hIW0mvbmPLTfqWdY781lxOqSrN2gjQPm-BFkYWigJNKVcVBtMA7V-le_w-e9h5XqvZubnSQ1unY8pSGKsV7vdWM' },
  ];

  var goldSvg = '<svg class="sw-item-gold" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg"><defs><radialGradient id="swgg" cx="50%" cy="45%" r="50%"><stop offset="0%" stop-color="#fff3a0"/><stop offset="40%" stop-color="#ffd700"/><stop offset="100%" stop-color="#b8860b"/></radialGradient><radialGradient id="swgc" cx="50%" cy="40%" r="45%"><stop offset="0%" stop-color="#ffe066"/><stop offset="100%" stop-color="#c8960c"/></radialGradient></defs><circle cx="50" cy="50" r="42" fill="none" stroke="url(#swgg)" stroke-width="4" opacity=".7"/><circle cx="50" cy="50" r="30" fill="url(#swgc)" opacity=".9"/><circle cx="50" cy="50" r="30" fill="none" stroke="#b8860b" stroke-width="1.5"/><text x="50" y="58" text-anchor="middle" font-family="Montserrat,sans-serif" font-size="30" font-weight="900" fill="#1a1400" opacity=".85">?</text><polygon points="50,6 52,12 58,12 53,16 55,22 50,18 45,22 47,16 42,12 48,12" fill="#ffd700"/></svg>';

  // Strip config: gold items placed so we spin 2 full passes then land on gold
  // Items per "loop" = 9 skins + 1 gold = 10; we do 2 loops + partial = ~25 items, gold at end
  var ITEM_W = 60, SPIN_MS = 5000;
  var GOLD_IDX = 24; // ~2.5 loops of 10
  var TOTAL = 28;
  var spinning = false;

  // Build strip with gold every 10 items
  for (var i = 0; i < TOTAL; i++) {
    var d = document.createElement('div');
    d.className = 'sw-item';
    if (i === GOLD_IDX) {
      d.setAttribute('data-r', 'gold');
      d.innerHTML = goldSvg + '<span class="sw-item-lbl">\u2605 BONUS \u2605</span>';
    } else if (i > 0 && i % 10 === 0) {
      // Additional gold markers to show during spin
      d.setAttribute('data-r', 'gold');
      d.innerHTML = goldSvg + '<span class="sw-item-lbl">\u2605 BONUS \u2605</span>';
    } else {
      var s = skins[i % skins.length];
      d.setAttribute('data-r', s.r);
      d.innerHTML = '<img class="sw-item-img" src="' + s.img + '" alt="" loading="lazy" /><span class="sw-item-lbl">' + s.n + '</span>';
    }
    swStrip.appendChild(d);
  }

  // Dismiss
  swClose.addEventListener('click', function() {
    localStorage.setItem('sw-dismissed', String(Date.now()));
    widget.classList.add('sw-dismissed');
    isDismissed = true;
  });

  // Easing — steep deceleration at end
  function easeOutQuint(t) { return 1 - Math.pow(1 - t, 5); }

  // Full-page confetti
  var confettiOverlay = document.getElementById('swConfettiOverlay');
  function popConfetti() {
    if (!confettiOverlay) return;
    var colors = ['#ffd700','#ffaa00','#2ecc71','#fff','#e4ae39','#eb4b4b','#4b69ff','#d32ce6','#ff6b6b'];
    for (var i = 0; i < 80; i++) {
      var c = document.createElement('div');
      c.className = 'sw-confetti';
      c.style.left = Math.random() * 100 + '%';
      c.style.top = '-10px';
      c.style.width = (6 + Math.random() * 8) + 'px';
      c.style.height = (4 + Math.random() * 6) + 'px';
      c.style.borderRadius = Math.random() > 0.5 ? '50%' : '2px';
      c.style.background = colors[Math.floor(Math.random() * colors.length)];
      c.style.animationDelay = (Math.random() * 0.8) + 's';
      c.style.animationDuration = (2 + Math.random() * 2) + 's';
      confettiOverlay.appendChild(c);
    }
    setTimeout(function() {
      confettiOverlay.innerHTML = '';
    }, 5000);
  }

  // Spin — always lands on gold
  swSpinBtn.addEventListener('click', function() {
    if (spinning) return;
    spinning = true;
    swSpinBtn.disabled = true;
    swSpinBtn.textContent = 'Spinning...';
    swResult.innerHTML = '';

    var vpW = document.querySelector('.sw-viewport').offsetWidth;
    var offset = (GOLD_IDX * ITEM_W) + (ITEM_W / 2) - (vpW / 2) + (Math.random() * 8 - 4);
    var start = null;
    swStrip.style.transform = 'translateX(0px)';

    function animate(ts) {
      if (!start) start = ts;
      var p = Math.min((ts - start) / SPIN_MS, 1);
      swStrip.style.transform = 'translateX(' + (-(offset * easeOutQuint(p))) + 'px)';
      if (p < 1) {
        requestAnimationFrame(animate);
      } else {
        setTimeout(showWin, 300);
      }
    }
    requestAnimationFrame(animate);
  });

  function showWin() {
    spinning = false;
    swSpinBtn.style.display = 'none';

    // Full-page confetti
    popConfetti();

    // Show bonus result
    swResult.innerHTML =
      '<div class="sw-bonus">' +
        '<div class="sw-bonus-title">BONUS UNLOCKED!</div>' +
        '<div class="sw-bonus-desc">100% up to 100 Coins + 5 Free Cases</div>' +
      '</div>';

    // Reveal the CTA button — opens interstitial popup instead of direct link
    swCta.classList.remove('sw-cta-hidden');
    swCta.textContent = 'Claim Your Bonus \u2192';
    swCta.style.background = 'linear-gradient(135deg,#ffd700,#ffaa00)';
    swCta.style.color = '#000';
    swCta.style.fontWeight = '800';
    swCta.removeAttribute('href');
    swCta.style.cursor = 'pointer';
    swCta.addEventListener('click', function(e) {
      e.preventDefault();
      openBonusPopup();
    });
  }

  // ── Bonus Interstitial Popup ──────────────────────────
  var swPopup = document.getElementById('swPopup');
  var swPopupBackdrop = document.getElementById('swPopupBackdrop');
  var swPopupX = document.getElementById('swPopupX');
  var swPopupSkip = document.getElementById('swPopupSkip');

  function openBonusPopup() {
    if (!swPopup) return;
    swPopup.classList.add('open');
    document.body.style.overflow = 'hidden';
  }

  function closeBonusPopup() {
    if (!swPopup) return;
    swPopup.classList.remove('open');
    document.body.style.overflow = '';
  }

  if (swPopupBackdrop) swPopupBackdrop.addEventListener('click', closeBonusPopup);
  if (swPopupX) swPopupX.addEventListener('click', closeBonusPopup);
  if (swPopupSkip) swPopupSkip.addEventListener('click', closeBonusPopup);

  // Close popup on Escape key
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && swPopup && swPopup.classList.contains('open')) {
      closeBonusPopup();
    }
  });

  // Show widget when user scrolls down 300px
  if (!isDismissed) {
    var shown = false;
    function checkScroll() {
      if (isDismissed) return;
      var shouldShow = window.scrollY > 300;
      if (shouldShow && !shown) {
        widget.classList.add('sw-visible');
        shown = true;
      } else if (!shouldShow && shown) {
        widget.classList.remove('sw-visible');
        shown = false;
      }
    }
    window.addEventListener('scroll', checkScroll, { passive: true });
    checkScroll();
  }
})();
</script>
</body>
</html>
