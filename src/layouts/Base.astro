@keyframes swPopupGlow{0%,100%{box-shadow:0 0 12px rgba(255,215,0,.15),inset 0 0 10px rgba(255,215,0,.03)}50%{box-shadow:0 0 28px rgba(255,215,0,.35),inset 0 0 18px rgba(255,215,0,.08)}}
.sw-popup-prize{animation:swPopupGlow 2.5s ease-in-out infinite}
