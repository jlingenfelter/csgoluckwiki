.mobile-divider{height:1px;background:var(--border);margin:.25rem 2rem}
.mobile-overlay{display:none;position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,.6);z-index:1199;backdrop-filter:blur(2px)}
.mobile-overlay.open{display:block}
@media(max-width:768px){
  nav{padding:.5rem 1rem;flex-wrap:nowrap}
  .nav-links,.nav-search,.theme-toggle{display:none}
  .hamburger{display:flex}
  main{padding:1.5rem 1rem}
  h1{font-size:1.6rem}
  .card-grid{grid-template-columns:1fr}
  .stats-grid{grid-template-columns:repeat(2,1fr)}
  .footer-grid{grid-template-columns:repeat(2,1fr)!important}
}
/* Theme Toggle */
.theme-toggle{background:none;border:1px solid var(--border);border-radius:6px;padding:4px 6px;cursor:pointer;color:var(--text2);display:flex;align-items:center;transition:color .2s,border-color .2s}
.theme-toggle:hover{color:var(--accent);border-color:var(--accent)}
.theme-icon-light{display:none}
.logo-light{display:none}
html.light-mode .theme-icon-dark{display:none}
html.light-mode .theme-icon-light{display:block}
html.light-mode .logo-dark{display:none}
html.light-mode .logo-light{display:inline}
/* Light Mode */
html.light-mode{--bg:#f5f5f7;--bg2:#ffffff;--bg3:#ebedf0;--text:#1a1a2e;--text2:#555570;--accent:#1a9f4a;--accent2:#15803d;--border:#d4d6dc}
html.light-mode body{background:var(--bg)!important;color:var(--text)!important}
html.light-mode header{background:rgba(255,255,255,.92);border-bottom-color:var(--border)}
html.light-mode ::selection{background:rgba(26,159,74,.2)}
html.light-mode ::-webkit-scrollbar-track{background:var(--bg)}
html.light-mode ::-webkit-scrollbar-thumb{background:var(--border)}
/* Cmd+K Modal */
.qk-overlay{display:none;position:fixed;inset:0;z-index:9999;background:rgba(0,0,0,.55);backdrop-filter:blur(4px);align-items:flex-start;justify-content:center;padding-top:min(20vh,160px)}
.qk-overlay.open{display:flex}
.qk-modal{background:var(--bg2);border:1px solid var(--border);border-radius:12px;width:560px;max-width:92vw;max-height:70vh;display:flex;flex-direction:column;box-shadow:0 20px 60px rgba(0,0,0,.5);overflow:hidden}
.qk-header{display:flex;align-items:center;gap:.6rem;padding:.75rem 1rem;border-bottom:1px solid var(--border)}
.qk-icon{color:var(--text2);flex-shrink:0}
.qk-input{flex:1;background:none;border:none;color:var(--text);font-size:1rem;font-family:inherit;outline:none}
.qk-input::placeholder{color:var(--text2);opacity:.6}
.qk-kbd{background:var(--bg3);border:1px solid var(--border);border-radius:4px;padding:2px 6px;font-size:.7rem;color:var(--text2);font-family:inherit}
.qk-results{flex:1;overflow-y:auto;padding:.5rem}
.qk-group-label{font-size:.7rem;font-weight:700;color:var(--text2);text-transform:uppercase;letter-spacing:.06em;padding:.4rem .75rem .2rem}
.qk-item{display:flex;align-items:center;gap:.6rem;padding:.55rem .75rem;border-radius:6px;color:var(--text);text-decoration:none;cursor:pointer;font-size:.88rem;transition:background .1s}
.qk-item:hover,.qk-item.qk-active{background:var(--bg3);color:var(--accent)}
.qk-item-icon{font-size:1rem;width:24px;text-align:center;flex-shrink:0;opacity:.6}
.qk-item-text{flex:1;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.qk-item-hint{font-size:.72rem;color:var(--text2);flex-shrink:0}
.qk-empty{text-align:center;padding:2rem 1rem;color:var(--text2);font-size:.88rem}
.qk-footer{display:flex;gap:1.5rem;padding:.5rem 1rem;border-top:1px solid var(--border);font-size:.72rem;color:var(--text2)}
.qk-footer kbd{background:var(--bg3);border:1px solid var(--border);border-radius:3px;padding:1px 4px;font-family:inherit;font-size:.68rem}

/* Sticky Side Spinner Widget */
.sw-widget{position:fixed;right:-280px;top:50%;transform:translateY(-50%);width:250px;background:var(--bg2);border:1px solid rgba(255,215,0,.2);border-right:none;border-radius:10px 0 0 10px;box-shadow:-4px 0 30px rgba(0,0,0,.5);z-index:1050;padding:1rem;transition:right .4s cubic-bezier(.25,.46,.45,.94);display:flex;flex-direction:column;gap:.6rem}
.sw-widget.sw-visible{right:0}
