.sw-confetti-overlay{position:fixed;inset:0;pointer-events:none;z-index:9999;overflow:hidden}
.sw-confetti{position:absolute;width:10px;height:10px;border-radius:2px;opacity:0;animation:sw-fall linear forwards;pointer-events:none}
@keyframes sw-fall{0%{opacity:1;transform:translateY(0) rotate(0) scale(1)}60%{opacity:1}100%{opacity:0;transform:translateY(100vh) rotate(1080deg) scale(.5)}}
.sw-bonus{background:linear-gradient(135deg,rgba(255,215,0,.1),rgba(255,170,0,.05));border:1px solid rgba(255,215,0,.3);border-radius:6px;padding:.6rem;text-align:center}
