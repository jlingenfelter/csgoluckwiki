.sw-item[data-r="gold"]{background:linear-gradient(180deg,rgba(255,215,0,.06),rgba(255,215,0,.15))}.sw-item[data-r="gold"] .sw-item-lbl{color:#ffd700;font-weight:800;font-size:.45rem}
