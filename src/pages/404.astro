---
import Base from '../layouts/Base.astro';
---

<Base title="Page Not Found — CSDB.gg" description="The page you're looking for doesn't exist. Browse CS2 skins, weapons, tools, and guides on CSDB.gg.">

<div class="not-found">
  <h1>404</h1>
  <p class="nf-sub">Page not found</p>
  <p>The page you're looking for doesn't exist or has been moved.</p>

  <div class="nf-links">
    <a href="/" class="nf-btn nf-primary">Back to Home</a>
    <a href="/skins/" class="nf-btn">Browse Skins</a>
    <a href="/weapons/" class="nf-btn">Weapons</a>
    <a href="/tools/" class="nf-btn">Tools</a>
  </div>

  <div class="nf-search">
    <p>Or try searching:</p>
    <form action="/search/" method="get">
      <input type="search" name="q" placeholder="Search skins, weapons, tools..." autocomplete="off" />
      <button type="submit">Search</button>
    </form>
  </div>

  <div class="nf-popular">
    <h2>Popular Pages</h2>
    <div class="nf-grid">
      <a href="/skins/">All Skins</a>
      <a href="/pro-players/">Pro Settings</a>
      <a href="/damage-calculator/">Damage Calculator</a>
      <a href="/sensitivity-converter/">Sensitivity Converter</a>
      <a href="/crosshair-generator/">Crosshair Generator</a>
      <a href="/maps/">Maps & Callouts</a>
      <a href="/cases/">Cases</a>
      <a href="/guides/">Guides</a>
    </div>
  </div>
</div>

<style>
.not-found {
  text-align: center;
  padding: 3rem 1rem;
  max-width: 600px;
  margin: 0 auto;
}

.not-found h1 {
  font-size: 6rem;
  font-weight: 900;
  background: linear-gradient(135deg, var(--accent), #00d4ff);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  margin-bottom: 0;
  line-height: 1;
}

.nf-sub {
  font-size: 1.4rem;
  font-weight: 700;
  color: var(--text);
  margin-bottom: 0.5rem;
}

.nf-links {
  display: flex;
  gap: 0.75rem;
  justify-content: center;
  flex-wrap: wrap;
  margin: 2rem 0;
}

.nf-btn {
  padding: 0.6rem 1.2rem;
  border-radius: 8px;
  font-weight: 700;
  font-size: 0.9rem;
  text-decoration: none;
  border: 2px solid var(--border);
  color: var(--text2);
  transition: all 0.2s;
}

.nf-btn:hover {
  border-color: var(--accent);
  color: var(--accent);
}

.nf-primary {
  background: var(--accent);
  color: #000;
  border-color: var(--accent);
}

.nf-primary:hover {
  opacity: 0.9;
  color: #000;
}

.nf-search {
  margin: 2rem 0;
}

.nf-search form {
  display: flex;
  max-width: 400px;
  margin: 0.75rem auto 0;
}

.nf-search input {
  flex: 1;
  background: var(--bg2);
  border: 1px solid var(--border);
  border-right: none;
  border-radius: 8px 0 0 8px;
  padding: 0.6rem 1rem;
  color: var(--text);
  font-size: 0.9rem;
  outline: none;
}

.nf-search input:focus {
  border-color: var(--accent);
}

.nf-search button {
  background: var(--accent);
  color: #000;
  border: none;
  padding: 0.6rem 1.2rem;
  border-radius: 0 8px 8px 0;
  font-weight: 700;
  cursor: pointer;
  font-size: 0.9rem;
}

.nf-popular {
  margin-top: 3rem;
}

.nf-popular h2 {
  font-size: 1.1rem;
  margin-bottom: 1rem;
}

.nf-grid {
  display: flex;
  gap: 0.5rem;
  flex-wrap: wrap;
  justify-content: center;
}

.nf-grid a {
  padding: 0.4rem 0.8rem;
  background: var(--bg2);
  border: 1px solid var(--border);
  border-radius: 6px;
  font-size: 0.85rem;
  color: var(--text2);
  text-decoration: none;
  transition: all 0.2s;
}

.nf-grid a:hover {
  border-color: var(--accent);
  color: var(--accent);
}
</style>
</Base>
