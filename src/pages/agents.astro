---
import Base from '../layouts/Base.astro';
import ExploreMore from '../components/ExploreMore.astro';
import { breadcrumbSchema, faqSchema } from '../lib/weapons';

const title = 'CS2 Agents & Music Kits — Full Database | CSDB.gg';
const description = 'Complete Counter-Strike 2 agents and music kits database. Browse all CT and T agents with lore, factions, and all available music kit artists.';

const ctAgents = [
  { name: 'Cmdr. Frank "Wet Sox" Baroud', faction: 'SEAL Frogman', operation: 'Operation Shattered Web', tier: 'Elite' },
  { name: 'Operator', faction: 'SEAL Frogman', operation: 'Base', tier: 'Distinguished' },
  { name: 'SEAL Frogman', faction: 'SEAL Frogman', operation: 'Base', tier: 'Exceptional' },
  { name: 'Cmdr. Lee', faction: 'SEAL Frogman', operation: 'Hydra', tier: 'Superior' },
  { name: 'Ava', faction: 'KSK', operation: 'Shattered Web', tier: 'Elite' },
  { name: 'Eniqma', faction: 'KSK', operation: 'Shattered Web', tier: 'Exceptional' },
  { name: 'John', faction: 'KSK', operation: 'Hydra', tier: 'Superior' },
  { name: 'Anja', faction: 'KSK', operation: 'Riptide', tier: 'Exceptional' },
  { name: 'Lerxst', faction: 'Sabre', operation: 'Shattered Web', tier: 'Elite' },
  { name: 'Vypa Sista of Mercy', faction: 'Sabre', operation: 'Shattered Web', tier: 'Superior' },
  { name: 'Dr. Romak "Twinkles" Kearsley', faction: 'Sabre', operation: 'Riptide', tier: 'Exceptional' },
  { name: 'Stefan', faction: 'Sabre', operation: 'Hydra', tier: 'Distinguished' },
  { name: 'Chem-Haz Cyberspace', faction: 'Professional', operation: 'Broken Fang', tier: 'Elite' },
  { name: 'Trapper', faction: 'Professional', operation: 'Broken Fang', tier: 'Exceptional' },
  { name: 'Operator', faction: 'Professional', operation: 'Broken Fang', tier: 'Superior' },
  { name: 'Screech', faction: 'Professional', operation: 'Riptide', tier: 'Distinguished' },
];

const tAgents = [
  { name: 'Vypa Sista of Mercy', faction: 'Sabre', operation: 'Shattered Web', tier: 'Elite' },
  { name: 'Sabre', faction: 'Sabre', operation: 'Base', tier: 'Exceptional' },
  { name: 'Sabre Capo', faction: 'Sabre', operation: 'Shattered Web', tier: 'Superior' },
  { name: 'Sabre Intruder', faction: 'Sabre', operation: 'Hydra', tier: 'Distinguished' },
  { name: 'Sabre Connoisseur', faction: 'Sabre', operation: 'Riptide', tier: 'Exceptional' },
  { name: 'Ground Rebel', faction: 'Phoenix Connexion', operation: 'Shattered Web', tier: 'Elite' },
  { name: 'Phoenix', faction: 'Phoenix Connexion', operation: 'Base', tier: 'Exceptional' },
  { name: 'Bloodhound', faction: 'Phoenix Connexion', operation: 'Shattered Web', tier: 'Superior' },
  { name: 'Elite Crew', faction: 'Phoenix Connexion', operation: 'Broken Fang', tier: 'Distinguished' },
  { name: 'Soldier', faction: 'Balkans', operation: 'Shattered Web', tier: 'Elite' },
  { name: 'Street Soldier', faction: 'Balkans', operation: 'Base', tier: 'Exceptional' },
  { name: 'Balkan Captain', faction: 'Balkans', operation: 'Shattered Web', tier: 'Superior' },
  { name: 'Balkan Swag', faction: 'Balkans', operation: 'Riptide', tier: 'Distinguished' },
  { name: 'Diplomat', faction: 'The Doctor', operation: 'Broken Fang', tier: 'Elite' },
  { name: 'The Doctor', faction: 'The Doctor', operation: 'Broken Fang', tier: 'Exceptional' },
  { name: 'Ghoul', faction: 'The Doctor', operation: 'Riptide', tier: 'Superior' },
];

const musicKits = [
  { artist: 'Valve', kits: ['Default', 'Operators', 'Cyberspace'], count: 3 },
  { artist: 'Austin Wintory', kits: ['Arroword', 'Golden Knife', 'Ancient Chest'], count: 3 },
  { artist: 'HeatleyBRO', kits: ['Earmuff Guardians', 'Legend', 'Snowglobe'], count: 3 },
  { artist: 'Noisia', kits: ['Breakthrough', 'Fallout', 'Grit'], count: 3 },
  { artist: 'Poul Henningsen', kits: ['Danish Joker', 'Embers', 'Riptide'], count: 3 },
  { artist: 'Knife Party', kits: ['Clutch', 'Fanfare', 'Sleepover'], count: 3 },
  { artist: 'Flashmob', kits: ['By the Numbers', 'Floss Mafioso', 'Supernova'], count: 3 },
  { artist: 'Benn Down', kits: ['Main Stage', 'Phantom Poet', 'Thawed'], count: 3 },
  { artist: 'Mike Morasky', kits: ['Half Dead', 'Jasmine Tea', 'Ozone'], count: 3 },
  { artist: 'Flatbed Flowers', kits: ['Barricade', 'Blurred Lenses', 'Day Ones'], count: 3 },
  { artist: 'Boneworks', kits: ['Aggression', 'Bloom', 'Chop Shop'], count: 3 },
  { artist: 'Cataklysm', kits: ['Cold Steel', 'Dangerous', 'Ignition'], count: 3 },
];

const tiers = [
  { name: 'Distinguished', icon: '🥉', description: 'Standard operatives from established operations' },
  { name: 'Exceptional', icon: '🥈', description: 'Experienced soldiers and specialists' },
  { name: 'Superior', icon: '🥇', description: 'Elite operatives from various factions' },
  { name: 'Elite', icon: '👑', description: 'Top-tier commanders and leaders' },
];

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Agents', url: '/agents/' },
];

const faqs = [
  { q: 'How do I equip an agent?', a: 'You can equip agents from the main menu under "Agents." Counter-Terrorist agents are only available for the CT side, and Terrorist agents are only for the T side. You must own the agent before equipping it. Each side can have a different agent equipped.' },
  { q: 'How much do agents cost?', a: 'Most agents cost between $8-20 USD in the Steam Community Market. Some older or rarer agents may be more expensive due to limited availability. You can also find agents in agent collections which provide multiple skins.' },
  { q: 'Can I use any agent on any map?', a: 'Yes! Agents are cosmetic items and can be used on any map and in any game mode. There are no gameplay advantages to using specific agents—it\'s purely a visual customization choice.' },
  { q: 'What are Master Agents?', a: 'Master Agents are exclusive, high-tier operatives with unique designs and lore. They are typically more expensive and come from premium operations. Elite tier agents are considered Master Agents and command premium prices on the market.' },
  { q: 'How do I get music kits?', a: 'Music kits can be obtained from the Steam Community Market, operations, or by purchasing them directly. Many music kits are included in operation pass rewards or can be purchased as standalone items for $5-8 USD.' },
  { q: 'What do music kits affect?', a: 'Music kits customize the audio for menu navigation, weapon buys, round start/end, and other in-game events. Each kit has unique compositions for different scenarios. Only you hear your selected music kit in casual matches.' },
  { q: 'Are there limited edition agents?', a: 'Yes! Operation-exclusive agents are limited and become rarer over time. Old operation agents, especially from early operations like Wildfire and Hydra, are now collectible and expensive due to limited supply.' },
  { q: 'Can I trade agents and music kits?', a: 'Yes, agents and music kits can be traded through the Steam Community Market, but they must be tradeable (not from store-exclusive or operation-exclusive drops). Some items have trading restrictions that prevent immediate resale.' },
];
---

<Base title={title} description={description} currentNav="/skins/">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema(breadcrumbs))} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema(faqs))} />
  </Fragment>
  <nav class="breadcrumb">
    <a href="/">Home</a> / <a href="/skins/">Skins</a> / <span>Agents & Music Kits</span>
  </nav>

  <div class="hero-section">
    <div class="hero-content">
      <h1>CS2 Agents & Music Kits</h1>
      <p>Explore the complete database of Counter-Strike 2 agents and music kits. Customize your character with iconic operatives from multiple factions, and personalize your audio experience with music kits from legendary artists.</p>
      <div class="hero-stats">
        <div class="stat">
          <span class="stat-value">30+</span>
          <span class="stat-label">CT Agents</span>
        </div>
        <div class="stat">
          <span class="stat-value">30+</span>
          <span class="stat-label">T Agents</span>
        </div>
        <div class="stat">
          <span class="stat-value">40+</span>
          <span class="stat-label">Music Kits</span>
        </div>
      </div>
    </div>
    <div class="hero-gradient"></div>
  </div>

  <!-- Tier System Info -->
  <section class="tier-system">
    <h2>Agent Tier System</h2>
    <div class="tier-grid">
      {tiers.map(tier => (
        <div class="tier-card">
          <div class="tier-icon">{tier.icon}</div>
          <h3>{tier.name}</h3>
          <p>{tier.description}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- CT Agents Section -->
  <section class="agents-section">
    <div class="section-header">
      <h2>Counter-Terrorist Agents</h2>
      <p>Professional counter-terrorist operatives from around the world. Each agent brings unique lore and personality to your gameplay.</p>
    </div>

    <div class="agents-container">
      <div class="agents-list">
        {ctAgents.map(agent => (
          <div class="agent-card ct-agent">
            <div class="agent-tier" style={`--tier-color: ${
              agent.tier === 'Elite' ? 'var(--purple)' :
              agent.tier === 'Superior' ? 'var(--gold)' :
              agent.tier === 'Exceptional' ? 'var(--accent)' :
              'var(--blue)'
            }`}>
              {agent.tier === 'Elite' && '👑'}
              {agent.tier === 'Superior' && '🥇'}
              {agent.tier === 'Exceptional' && '🥈'}
              {agent.tier === 'Distinguished' && '🥉'}
            </div>
            <h3>{agent.name}</h3>
            <div class="agent-info">
              <span class="faction-badge ct">{agent.faction}</span>
              <span class="operation-badge">{agent.operation}</span>
            </div>
            <div class="agent-meta">
              <span class="tier-label">{agent.tier}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- T Agents Section -->
  <section class="agents-section">
    <div class="section-header">
      <h2>Terrorist Agents</h2>
      <p>Diverse terrorist operatives from the Sabre, Phoenix Connexion, Balkans, and The Doctor factions.</p>
    </div>

    <div class="agents-container">
      <div class="agents-list">
        {tAgents.map(agent => (
          <div class="agent-card t-agent">
            <div class="agent-tier" style={`--tier-color: ${
              agent.tier === 'Elite' ? 'var(--purple)' :
              agent.tier === 'Superior' ? 'var(--gold)' :
              agent.tier === 'Exceptional' ? 'var(--accent)' :
              'var(--blue)'
            }`}>
              {agent.tier === 'Elite' && '👑'}
              {agent.tier === 'Superior' && '🥇'}
              {agent.tier === 'Exceptional' && '🥈'}
              {agent.tier === 'Distinguished' && '🥉'}
            </div>
            <h3>{agent.name}</h3>
            <div class="agent-info">
              <span class="faction-badge t">{agent.faction}</span>
              <span class="operation-badge">{agent.operation}</span>
            </div>
            <div class="agent-meta">
              <span class="tier-label">{agent.tier}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Music Kits Section -->
  <section class="music-section">
    <div class="section-header">
      <h2>Music Kits</h2>
      <p>Customize your audio experience with music kits from world-renowned artists. Each kit includes unique sounds for menu, buy, and round end.</p>
    </div>

    <div class="music-grid">
      {musicKits.map(kit => (
        <div class="music-card">
          <div class="music-header">
            <h3>🎵 {kit.artist}</h3>
            <span class="kit-count">{kit.count} kits</span>
          </div>
          <div class="music-kits">
            {kit.kits.map(musicKit => (
              <span class="music-kit-item">{musicKit}</span>
            ))}
          </div>
          <p class="music-description">Original music compositions and themes</p>
          <a href="#" class="music-link">View Details →</a>
        </div>
      ))}
    </div>
  </section>

  <!-- Agent Factions Info -->
  <section class="factions-section">
    <h2>Agent Factions</h2>
    <div class="factions-grid">
      <div class="faction-card">
        <h3>🛡️ SEAL Frogman</h3>
        <p>U.S. Navy elite special forces unit. Known for their amphibious warfare expertise and advanced tactical training.</p>
        <ul>
          <li>Cmdr. Frank "Wet Sox" Baroud</li>
          <li>Operator</li>
          <li>SEAL Frogman</li>
        </ul>
      </div>
      <div class="faction-card">
        <h3>🎖️ KSK</h3>
        <p>German Army special operations command. Elite counterterrorism specialists with advanced urban warfare training.</p>
        <ul>
          <li>Ava</li>
          <li>Eniqma</li>
          <li>John</li>
          <li>Anja</li>
        </ul>
      </div>
      <div class="faction-card">
        <h3>⚔️ Sabre</h3>
        <p>Private military contractor known for tactical excellence and diverse field operatives across multiple roles.</p>
        <ul>
          <li>Lerxst</li>
          <li>Vypa Sista of Mercy</li>
          <li>Dr. Romak "Twinkles" Kearsley</li>
        </ul>
      </div>
      <div class="faction-card">
        <h3>🏢 Professional</h3>
        <p>Modern corporate security specialists with cutting-edge equipment and tactical training.</p>
        <ul>
          <li>Chem-Haz Cyberspace</li>
          <li>Trapper</li>
          <li>Operator</li>
        </ul>
      </div>
      <div class="faction-card">
        <h3>☠️ Sabre (Terrorist)</h3>
        <p>Independent criminal organization with global reach. Street operatives and seasoned soldiers.</p>
        <ul>
          <li>Vypa Sista of Mercy</li>
          <li>Sabre Capo</li>
          <li>Sabre Intruder</li>
        </ul>
      </div>
      <div class="faction-card">
        <h3>🔥 Phoenix Connexion</h3>
        <p>International criminal syndicate. Experienced operatives with military backgrounds and street smarts.</p>
        <ul>
          <li>Ground Rebel</li>
          <li>Bloodhound</li>
          <li>Elite Crew</li>
        </ul>
      </div>
      <div class="faction-card">
        <h3>💪 Balkans</h3>
        <p>Regional mercenary group from the Balkans. Rugged operatives with street-level experience.</p>
        <ul>
          <li>Soldier</li>
          <li>Balkan Captain</li>
          <li>Balkan Swag</li>
        </ul>
      </div>
      <div class="faction-card">
        <h3>🎭 The Doctor</h3>
        <p>Mysterious criminal faction led by an enigmatic leader. Eccentric but deadly operatives.</p>
        <ul>
          <li>Diplomat</li>
          <li>The Doctor</li>
          <li>Ghoul</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="faq-section">
    <h2>Agents & Music Kits FAQ</h2>
    <dl class="faq">
      <dt>How do I equip an agent?</dt>
      <dd>You can equip agents from the main menu under "Agents." Counter-Terrorist agents are only available for the CT side, and Terrorist agents are only for the T side. You must own the agent before equipping it. Each side can have a different agent equipped.</dd>

      <dt>How much do agents cost?</dt>
      <dd>Most agents cost between $8-20 USD in the Steam Community Market. Some older or rarer agents may be more expensive due to limited availability. You can also find agents in agent collections which provide multiple skins.</dd>

      <dt>Can I use any agent on any map?</dt>
      <dd>Yes! Agents are cosmetic items and can be used on any map and in any game mode. There are no gameplay advantages to using specific agents—it's purely a visual customization choice.</dd>

      <dt>What are Master Agents?</dt>
      <dd>Master Agents are exclusive, high-tier operatives with unique designs and lore. They are typically more expensive and come from premium operations. Elite tier agents are considered Master Agents and command premium prices on the market.</dd>

      <dt>How do I get music kits?</dt>
      <dd>Music kits can be obtained from the Steam Community Market, operations, or by purchasing them directly. Many music kits are included in operation pass rewards or can be purchased as standalone items for $5-8 USD.</dd>

      <dt>What do music kits affect?</dt>
      <dd>Music kits customize the audio for menu navigation, weapon buys, round start/end, and other in-game events. Each kit has unique compositions for different scenarios. Only you hear your selected music kit in casual matches.</dd>

      <dt>Are there limited edition agents?</dt>
      <dd>Yes! Operation-exclusive agents are limited and become rarer over time. Old operation agents, especially from early operations like Wildfire and Hydra, are now collectible and expensive due to limited supply.</dd>

      <dt>Can I trade agents and music kits?</dt>
      <dd>Yes, agents and music kits can be traded through the Steam Community Market, but they must be tradeable (not from store-exclusive or operation-exclusive drops). Some items have trading restrictions that prevent immediate resale.</dd>

      <dt>Which agent is the most popular?</dt>
      <dd>SEAL Frogman agents are traditionally popular due to their sleek military aesthetic. Sabre operatives are also fan favorites. Popularity varies by region and playstyle preferences.</dd>

      <dt>Can I mix and match agents in my loadout?</dt>
      <dd>You can only equip one agent per side (CT and T). However, you can customize your loadout before each match to use different agents on different maps if you own multiple.</dd>
    </dl>
  </section>

  <!-- Related Links -->
  <section class="related-section">
    <h2>Related Resources</h2>
    <div class="internal-links">
      <a href="/skins/">Skin Database</a>
      <a href="/stickers/">Sticker Database</a>
      <a href="/cases/">Cases & Collections</a>
      <a href="/price-tracker/">Price Tracker</a>
      <a href="/guides/trading-guide/">Trading Guide</a>
    </div>
  </section>

  <ExploreMore context="skins" />
</Base>

<style>
  .breadcrumb {
    font-size: 0.85rem;
    color: var(--text2);
    margin-bottom: 1.5rem;
  }

  .breadcrumb a {
    color: var(--accent);
  }

  .hero-section {
    position: relative;
    margin: -2rem -1.5rem 3rem;
    padding: 3rem 1.5rem;
    background: linear-gradient(135deg, rgba(245, 166, 35, 0.1) 0%, rgba(66, 165, 245, 0.05) 100%);
    border-bottom: 2px solid var(--border);
    overflow: hidden;
  }

  .hero-gradient {
    position: absolute;
    top: 0;
    right: -200px;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(245, 166, 35, 0.08) 0%, transparent 70%);
    pointer-events: none;
  }

  .hero-content {
    position: relative;
    z-index: 1;
    max-width: 900px;
  }

  .hero-content h1 {
    font-size: 2.5rem;
    margin-bottom: 1rem;
    background: linear-gradient(135deg, var(--accent) 0%, var(--accent2) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-content > p {
    font-size: 1.05rem;
    color: var(--text2);
    margin-bottom: 2rem;
    max-width: 700px;
  }

  .hero-stats {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: 1.5rem;
    margin-top: 2rem;
  }

  .stat {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .stat-value {
    font-size: 1.8rem;
    font-weight: 800;
    color: var(--accent);
  }

  .stat-label {
    font-size: 0.85rem;
    color: var(--text2);
  }

  .tier-system {
    margin: 2.5rem 0;
    padding: 2rem;
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 12px;
  }

  .tier-system h2 {
    margin: 0 0 1.5rem;
    text-align: center;
  }

  .tier-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1.25rem;
  }

  .tier-card {
    background: var(--bg3);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 1.5rem;
    text-align: center;
    transition: all 0.2s;
  }

  .tier-card:hover {
    border-color: var(--accent);
    transform: translateY(-2px);
  }

  .tier-icon {
    font-size: 2rem;
    margin-bottom: 0.75rem;
  }

  .tier-card h3 {
    margin: 0 0 0.5rem;
    font-size: 1.05rem;
  }

  .tier-card p {
    margin: 0;
    font-size: 0.85rem;
    color: var(--text2);
    line-height: 1.5;
  }

  .agents-section {
    margin: 3rem 0;
  }

  .section-header {
    margin-bottom: 2rem;
  }

  .section-header h2 {
    margin: 0 0 0.5rem;
    font-size: 1.8rem;
  }

  .section-header p {
    color: var(--text2);
    font-size: 0.95rem;
  }

  .agents-container {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 1.5rem;
  }

  .agents-list {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem;
  }

  .agent-card {
    background: var(--bg3);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1.25rem;
    transition: all 0.2s;
    position: relative;
    overflow: hidden;
  }

  .agent-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--accent), transparent);
  }

  .ct-agent::before {
    background: linear-gradient(90deg, var(--blue), transparent);
  }

  .t-agent::before {
    background: linear-gradient(90deg, var(--red), transparent);
  }

  .agent-card:hover {
    border-color: var(--accent);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(245, 166, 35, 0.1);
  }

  .agent-tier {
    font-size: 1.5rem;
    margin-bottom: 0.5rem;
    color: var(--tier-color);
  }

  .agent-card h3 {
    margin: 0 0 0.75rem;
    font-size: 1rem;
    line-height: 1.3;
  }

  .agent-info {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-bottom: 0.75rem;
  }

  .faction-badge,
  .operation-badge {
    display: inline-block;
    padding: 0.25rem 0.6rem;
    border-radius: 4px;
    font-size: 0.7rem;
    font-weight: 600;
    white-space: nowrap;
  }

  .faction-badge {
    background: rgba(66, 165, 245, 0.2);
    color: var(--blue);
    border: 1px solid var(--blue);
  }

  .faction-badge.ct {
    background: rgba(93, 159, 212, 0.2);
    color: var(--ct);
    border-color: var(--ct);
  }

  .faction-badge.t {
    background: rgba(230, 200, 76, 0.2);
    color: var(--t);
    border-color: var(--t);
  }

  .operation-badge {
    background: rgba(245, 166, 35, 0.2);
    color: var(--accent);
    border: 1px solid var(--accent);
  }

  .agent-meta {
    padding-top: 0.75rem;
    border-top: 1px solid var(--border);
  }

  .tier-label {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--accent);
  }

  .music-section {
    margin: 3rem 0;
  }

  .music-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.25rem;
    margin: 1.5rem 0;
  }

  .music-card {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 1.5rem;
    transition: all 0.2s;
    display: flex;
    flex-direction: column;
  }

  .music-card:hover {
