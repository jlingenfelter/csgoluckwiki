---
import Base from '../layouts/Base.astro';
import ExploreMore from '../components/ExploreMore.astro';
import { breadcrumbSchema, faqSchema, toolAppSchema } from '../lib/weapons';

const currentNav = "/cs2-weapons/";

const trainingRoutines = [
  {
    level: "Beginner",
    description: "Perfect for new players learning the fundamentals",
    totalTime: "45 minutes",
    sections: [
      {
        name: "Warmup",
        duration: "5 min",
        drills: [
          "Practice crosshair placement in offline server",
          "Run around map focusing on head level positioning",
          "No aim practice yet, just positioning and awareness"
        ]
      },
      {
        name: "Aim Training",
        duration: "15 min",
        drills: [
          "Aim Botz map with 100% bot difficulty, standing position only",
          "Practice clicking heads from 5 meters distance",
          "Ensure you're moving between kills, not standing still",
          "Focus on consistency over speed"
        ]
      },
      {
        name: "Spray Control",
        duration: "10 min",
        drills: [
          "Spray Training map, slow-motion mode (0.5x speed)",
          "Practice AK-47 and M4A4 spray patterns with bots standing still",
          "Shoot 30 bullet sprays, aiming for tight grouping",
          "Don't worry about speed, focus on muscle memory"
        ]
      },
      {
        name: "Deathmatch",
        duration: "15 min",
        drills: [
          "Play 15 minutes of pistol-only deathmatch",
          "Focus on landing headshots with the USPS",
          "Practice pre-aiming common positions",
          "Improve your positioning and map awareness",
          "Don't rush; take your time engaging enemies"
        ]
      }
    ]
  },
  {
    level: "Intermediate",
    description: "For players with basic fundamentals looking to improve",
    totalTime: "45 minutes",
    sections: [
      {
        name: "Warmup",
        duration: "5 min",
        drills: [
          "Load into offline map with 8 bots on medium difficulty",
          "Do 2-3 minutes of movement between positions",
          "Practice shoulder peeking and taking fights",
          "Get comfortable with your sensitivity settings"
        ]
      },
      {
        name: "Aim Training",
        duration: "15 min",
        drills: [
          "Aim Lab (Steam workshop) - Micro Flick exercises, 10 minutes",
          "Aimbotz with moving bots, hard difficulty, strafing enabled",
          "Practice flicking between targets at different distances",
          "Record how many kills you get in each session for improvement tracking"
        ]
      },
      {
        name: "Spray Control",
        duration: "10 min",
        drills: [
          "Yprac's Spray Control map - full speed, live targets",
          "Practice AK spray from various ranges (close, medium, far)",
          "Do 20-30 sprays with consistency check",
          "Transition to moving targets for increased difficulty"
        ]
      },
      {
        name: "Deathmatch",
        duration: "15 min",
        drills: [
          "Play rifle deathmatch (AK/M4 default) for 15 minutes",
          "Focus on pre-aiming high-traffic choke points",
          "Practice holding angles and peeking",
          "Try to maintain 1.5+ KDR minimum",
          "Call out target positions to improve game sense"
        ]
      }
    ]
  },
  {
    level: "Advanced",
    description: "For competitive players looking to maintain high-level performance",
    totalTime: "50 minutes",
    sections: [
      {
        name: "Warmup",
        duration: "5 min",
        drills: [
          "Aim Botz with bots on expert, movement enabled",
          "Load your competitive config and crosshair settings",
          "Do rapid fire drills: 50 clicks in 30 seconds",
          "Focus on 100% consistency with your settings"
        ]
      },
      {
        name: "Aim Training",
        duration: "20 min",
        drills: [
          "Aim Lab Advanced - Micro Flick + Speed Focus, 10 minutes",
          "Reflex/Aim Training map with expert bots, all movement types",
          "Practice weapon-specific aim: AK, M4A4, M4A1-S separate sessions",
          "Focus on edge aiming and flick accuracy under pressure",
          "Aim for 60%+ accuracy in each weapon category"
        ]
      },
      {
        name: "Spray Control",
        duration: "10 min",
        drills: [
          "Yprac Advanced Spray Map - live moving targets",
          "Practice spray transfers between multiple enemies",
          "Do AK spray while moving and counter-strafing",
          "Practice spray recovery from movement (stop and spray)",
          "Maintain accuracy while pre-firing wall positions"
        ]
      },
      {
        name: "Deathmatch",
        duration: "15 min",
        drills: [
          "High-skill competitive deathmatch servers (ESEA/Faceit level)",
          "Focus on gamesense: rotations, timing, positioning",
          "Practice economy-specific loadouts (force buys, half buys)",
          "Maintain 2.0+ KDR target",
          "Review your demo after session to identify mistakes"
        ]
      }
    ]
  },
  {
    level: "Pro",
    description: "Elite training regimen for aspiring professional players",
    totalTime: "90 minutes",
    sections: [
      {
        name: "Warmup",
        duration: "10 min",
        drills: [
          "Aim Botz with expert bots, all movement types, rapid kills goal",
          "Aim for 50+ kills in 2 minutes to gauge daily form",
          "Load map smokes and utility positions for your team",
          "Verify your mouse settings and monitor Hz synchronization",
          "Do reaction time drills: random target flicks"
        ]
      },
      {
        name: "Aim Training",
        duration: "35 min",
        drills: [
          "Aim Lab Pro Rank scenarios - 15 minutes minimum",
          "Advanced Reflex training with 200% difficulty settings",
          "Pistol-specific aim: USP, Deagle, P250 separate, 10 minutes each",
          "Practice holding multiple angles while tracking movement",
          "Weapon-specific spray patterns under movement: 10 minutes",
          "Target consistency goal: 85%+ accuracy across all drills",
          "Review clip library: study pro player aim mechanics"
        ]
      },
      {
        name: "Spray Control",
        duration: "15 min",
        drills: [
          "Advanced spray maps with competitive match scenarios",
          "Full spray-transfer chains: 3-4 enemies in sequence",
          "Spray while rotating between positions rapidly",
          "Practice pre-fire and spam spray patterns on walls",
          "Spray accuracy from crouch, stand, and air positions",
          "Mental focus: spray 50 bullets and count accuracy percentage"
        ]
      },
      {
        name: "Deathmatch & Competitive",
        duration: "30 min",
        drills: [
          "10 min FaceIT/ESEA competitive queue",
          "20 min pro-level deathmatch (Aim Arena or equivalent)",
          "Focus on consistent multi-kill rounds (3+ kills per spawn)",
          "Maintain 2.5+ KDR and track stats session-to-session",
          "Practice specific utility combinations with teammates",
          "VOD review of professional players in your role"
        ]
      }
    ]
  }
];

const workshopMaps = [
  {
    name: "Aim Botz",
    description: "Essential aim training map with customizable bot difficulty, movement types, and no-kill zones. Perfect for beginner to advanced training.",
    features: ["Adjustable bot difficulty", "Multiple difficulty levels", "Movement enabled/disabled", "Kill counter and accuracy tracking"]
  },
  {
    name: "Aim Lab (Steam)",
    description: "Comprehensive aim training with ranked scenarios, detailed statistics, and progressive difficulty. Excellent for tracking improvement over time.",
    features: ["Ranked aim scenarios", "Detailed statistics", "Leaderboards", "Multiple game modes"]
  },
  {
    name: "Yprac Spray Control",
    description: "Dedicated spray pattern training with both moving and stationary targets. Essential for learning weapon spray patterns efficiently.",
    features: ["Slow-motion mode", "Live moving targets", "Multiple weapon types", "Accuracy feedback"]
  },
  {
    name: "Reflex/Aim Training",
    description: "Advanced aim mechanics training with realistic enemy movement and positioning. Great for intermediate to advanced players.",
    features: ["Expert bot AI", "Movement and strafing", "Multiple ranges", "Competitive settings"]
  },
  {
    name: "Prefire Training Maps",
    description: "Maps designed to teach common pre-fire positions and holding angles. Critical for competitive play and map knowledge.",
    features: ["Pre-fire spots", "Common positions", "Tutorial mode", "Multiple maps available"]
  },
  {
    name: "1v1 Arena Maps",
    description: "Competitive 1v1 scenarios for developing clutch plays and high-pressure situations. Excellent for decision-making under stress.",
    features: ["Realistic scenarios", "Clutch situations", "Economy management", "Competitive rules"]
  }
];

const faqs = [
  {
    question: "How often should I practice aim training?",
    answer: "Consistency is key. Aim for daily sessions of 30-60 minutes. Professional players often train 2-4 hours daily, but even 30 minutes daily will show significant improvement over weeks."
  },
  {
    question: "How long does it take to improve aim?",
    answer: "You can see noticeable improvement in 2-4 weeks of consistent training. Significant improvement takes 2-3 months. Developing professional-level aim typically takes 6-12 months of dedicated practice."
  },
  {
    question: "Should I use aim training maps in deathmatch?",
    answer: "Yes, alternate between both. Aim training maps develop specific mechanics in controlled environments. Deathmatch applies those skills against real players in realistic scenarios. Both are essential."
  },
  {
    question: "What sensitivity should I use for aim training?",
    answer: "Use the same sensitivity you use in competitive play. Consistency is crucial. Once you find a comfortable eDPI (sensitivity × DPI), stick with it to build muscle memory."
  },
  {
    question: "Can aim training replace competitive matchmaking?",
    answer: "No, aim training complements competitive play but doesn't replace it. Matchmaking teaches gamesense, positioning, and decision-making that aim training alone cannot develop."
  },
  {
    question: "How do I track progress in aim training?",
    answer: "Keep a practice log with dates, maps used, kills per session, and accuracy percentages. Most aim training maps track stats automatically. Review your progress weekly."
  },
  {
    question: "What's the difference between spray control and flick aim?",
    answer: "Spray control is maintaining accuracy while holding down the mouse button (sustained fire). Flick aim is quickly moving to a target and clicking precisely. Both are essential for different combat scenarios."
  }
];

const sensitivityLinks = [
  { name: "Sensitivity Converter", path: "/sensitivity-converter/" },
  { name: "eDPI Calculator", path: "/edpi-calculator/" }
];

const crosshairLinks = [
  { name: "Crosshair Generator", path: "/crosshair-generator/" },
  { name: "Crosshair Code Library", path: "/crosshair-codes/" }
];

const relatedLinks = [
  { name: "Spray Trainer", path: "/spray-trainer/" },
  { name: "Pro Player Setups", path: "/pro-players/" },
  { name: "Workshop Maps", path: "/workshop-maps/" },
  { name: "Sensitivity Guide", path: "/sensitivity-converter/" }
];

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Tools', url: '/cs2-tools/' },
  { name: 'Aim Training', url: '/aim-training/' },
];

const faqSchemaData = faqs.map(f => ({ q: f.question, a: f.answer }));
---

<Base title="CS2 Aim Training Routines — Practice Plans & Workshop Maps | CSGOLuck Wiki" description="Complete CS2 aim training routines for all skill levels. Learn workshop maps, spray patterns, sensitivity optimization, and crosshair tips from beginner to pro." currentNav={currentNav}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema(breadcrumbs))} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema(faqSchemaData))} />
    <script type="application/ld+json" set:html={JSON.stringify(toolAppSchema({ name: 'CS2 Aim Training Routines', url: 'https://wiki.csgoluck.com/aim-training/', description: 'Complete CS2 aim training routines for all skill levels. Learn workshop maps, spray patterns, sensitivity optimization, and crosshair tips from beginner to pro.' }))} />
  </Fragment>
  <nav class="breadcrumb"><a href="/">Home</a> <span>/</span> <a href="/cs2-tools/">Tools</a> <span>/</span> <span>Aim Training</span></nav>

  <div class="at-hero">
    <h1 class="at-title">CS2 Aim Training Routines</h1>
    <p class="at-desc">Master your aim with structured training routines for every skill level. Combine warmup drills, focused aim training, spray control practice, and competitive application.</p>
  </div>

  <section class="at-intro">
    <p>Consistent aim training is the foundation of CS2 mastery. Whether you are just starting out or competing at the professional level, these structured routines will help you develop precision, speed, and muscle memory. Dedicate 30-90 minutes daily and you will see measurable improvement within weeks.</p>
  </section>

  <!-- Build Your Routine Generator -->
  <section class="at-builder" id="routineBuilder">
    <h2 class="at-section-title">Build Your Routine</h2>
    <p class="at-builder-desc">Select your skill level and available time to get a customized training routine. Optionally pick a focus area to specialize your practice.</p>

    <div class="at-builder-controls">
      <div class="at-builder-group">
        <label class="at-builder-label">Skill Level</label>
        <div class="at-builder-pills" id="levelPills">
          <button class="at-pill active" data-level="beginner">Beginner</button>
          <button class="at-pill" data-level="intermediate">Intermediate</button>
          <button class="at-pill" data-level="advanced">Advanced</button>
        </div>
      </div>

      <div class="at-builder-group">
        <label class="at-builder-label">Time Available</label>
        <div class="at-builder-pills" id="timePills">
          <button class="at-pill" data-time="15">15 min</button>
          <button class="at-pill active" data-time="30">30 min</button>
          <button class="at-pill" data-time="45">45 min</button>
          <button class="at-pill" data-time="60">60 min</button>
        </div>
      </div>

      <div class="at-builder-group">
        <label class="at-builder-label">Focus Area <span class="at-optional">(optional)</span></label>
        <div class="at-builder-pills" id="focusPills">
          <button class="at-pill" data-focus="">Any</button>
          <button class="at-pill" data-focus="flicking">Flicking</button>
          <button class="at-pill" data-focus="tracking">Tracking</button>
          <button class="at-pill" data-focus="spray">Spray Control</button>
          <button class="at-pill" data-focus="crosshair">Crosshair Placement</button>
        </div>
      </div>
    </div>

    <button class="at-generate-btn" id="generateBtn">Generate Routine</button>

    <div class="at-routine-result" id="routineResult" style="display:none">
      <div class="at-result-header">
        <div class="at-result-meta">
          <span class="at-result-total" id="resultTotal">Total: 0 min</span>
          <span class="at-result-level" id="resultLevel">Beginner</span>
        </div>
        <button class="at-regenerate-btn" id="regenerateBtn">Generate New Routine</button>
      </div>
      <div class="at-result-timeline" id="resultTimeline">
        <!-- Populated by JS -->
      </div>
      <p class="at-result-note">Find the workshop maps mentioned above on our <a href="/workshop-maps/">Workshop Maps</a> page.</p>
    </div>
  </section>

  <div class="at-routines">
    {trainingRoutines.map((routine) => (
      <section class="at-routine">
        <div class="at-routine-head">
          <h2 class="at-routine-level">{routine.level}</h2>
          <p class="at-routine-desc">{routine.description}</p>
          <span class="at-routine-time">Total Time: {routine.totalTime}</span>
        </div>
        <div class="at-routine-body">
          {routine.sections.map((section) => (
            <div class="at-drill-section">
              <div class="at-drill-header">
                <h3 class="at-drill-name">{section.name}</h3>
                <span class="at-drill-dur">{section.duration}</span>
              </div>
              <ul class="at-drill-list">
                {section.drills.map(drill => <li>{drill}</li>)}
              </ul>
            </div>
          ))}
        </div>
      </section>
    ))}
  </div>

  <section class="at-section">
    <h2 class="at-section-title">Essential Workshop Maps</h2>
    <div class="at-maps-grid">
      {workshopMaps.map((map) => (
        <div class="at-map-card">
          <h3 class="at-map-name">{map.name}</h3>
          <p class="at-map-desc">{map.description}</p>
          <ul class="at-features">
            {map.features.map(feature => <li>{feature}</li>)}
          </ul>
        </div>
      ))}
    </div>
  </section>

  <section class="at-progress">
    <h2 class="at-section-title">Track Your Progress</h2>
    <ul class="at-tips">
      <li>Keep a practice log: date, maps played, kills per session, accuracy %</li>
      <li>Test your aim weekly with the same warmup routine to track improvement</li>
      <li>Review demos of your competitive games to identify weak areas</li>
      <li>Set specific goals: "reach 65% accuracy in Aim Lab" or "get 50+ kills in 2 minutes on Aimbotz"</li>
      <li>Share progress with teammates to stay motivated and accountable</li>
      <li>Adjust routines based on where you are weakest: spray, flicking, tracking, etc.</li>
    </ul>
  </section>

  <div class="at-opt-grid">
    <div class="at-opt-card">
      <h3 class="at-opt-title">Sensitivity Optimization</h3>
      <p class="at-opt-desc">Finding the right sensitivity is crucial for consistent aim. Use our tools to convert between different sensitivity scales and calculate your eDPI.</p>
      <ul class="at-opt-links">
        {sensitivityLinks.map(link => (
          <li><a href={link.path}>{link.name}</a></li>
        ))}
      </ul>
    </div>
    <div class="at-opt-card">
      <h3 class="at-opt-title">Crosshair Configuration</h3>
      <p class="at-opt-desc">Your crosshair should reflect your playstyle and preferences. Generate custom crosshairs or browse pro player configurations.</p>
      <ul class="at-opt-links">
        {crosshairLinks.map(link => (
          <li><a href={link.path}>{link.name}</a></li>
        ))}
      </ul>
    </div>
  </div>

  <div class="at-links">
    <span class="at-links-label">Related Resources:</span>
    {relatedLinks.map(link => (
      <a href={link.path}>{link.name}</a>
    ))}
    <a href="/cs2-tools/">All Tools</a>
  </div>

  <section class="at-section">
    <h2 class="at-section-title">Frequently Asked Questions</h2>
    {faqs.map((faq) => (
      <details class="at-faq-item">
        <summary class="at-faq-q">{faq.question}</summary>
        <div class="at-faq-a">{faq.answer}</div>
      </details>
    ))}
  </section>

  <ExploreMore context="tools" />
</Base>

<style>
  /* Hero */
  .at-hero{margin-bottom:1.5rem}
  .at-title{font-size:1.8rem;font-weight:800;margin:0 0 .5rem}
  .at-desc{color:var(--text2);font-size:.95rem;margin:0;line-height:1.6;max-width:700px}

  /* Sections */
  .at-section,.at-intro{background:var(--bg2);border:1px solid var(--border);border-radius:4px;padding:1.5rem;margin-bottom:1.5rem}
  .at-intro p{color:var(--text2);line-height:1.7;margin:0;font-size:.92rem}
  .at-section-title{font-size:1.15rem;font-weight:700;margin:0 0 1rem}

  /* Routines */
  .at-routines{display:flex;flex-direction:column;gap:1.5rem;margin-bottom:1.5rem}
  .at-routine{background:var(--bg2);border:1px solid var(--border);border-radius:4px;overflow:hidden}
  .at-routine-head{background:var(--bg3);padding:1.25rem 1.5rem;border-bottom:1px solid var(--border);border-left:3px solid var(--accent)}
  .at-routine-level{font-size:1.3rem;font-weight:800;margin:0 0 .3rem;color:var(--accent)}
  .at-routine-desc{color:var(--text2);margin:0 0 .5rem;font-size:.88rem}
  .at-routine-time{font-size:.82rem;color:var(--text2);font-weight:600}
  .at-routine-body{padding:1.5rem}

  /* Drill sections */
  .at-drill-section{margin-bottom:1.5rem}
  .at-drill-section:last-child{margin-bottom:0}
  .at-drill-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:.75rem;padding-bottom:.5rem;border-bottom:1px solid var(--border)}
  .at-drill-name{font-size:1rem;font-weight:700;color:var(--text);margin:0}
  .at-drill-dur{background:var(--bg3);color:var(--text2);padding:.25rem .6rem;border-radius:4px;font-size:.82rem;font-weight:600}
  .at-drill-list{list-style:none;padding:0;margin:0}
  .at-drill-list li{padding:.4rem 0 .4rem 1.25rem;position:relative;color:var(--text2);line-height:1.5;font-size:.88rem}
  .at-drill-list li::before{content:"-";position:absolute;left:0;color:var(--accent);font-weight:700}

  /* Maps */
  .at-maps-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:1rem}
  .at-map-card{background:var(--bg3);border:1px solid var(--border);border-radius:4px;padding:1.25rem;transition:border-left .2s}
  .at-map-card:hover{border-left:3px solid var(--accent)}
  .at-map-name{font-size:1rem;font-weight:700;color:var(--text);margin:0 0 .5rem}
  .at-map-desc{color:var(--text2);margin:0 0 .75rem;line-height:1.6;font-size:.85rem}
  .at-features{list-style:none;padding:0;margin:0}
  .at-features li{padding:.3rem 0 .3rem 1rem;position:relative;font-size:.82rem;color:var(--text2)}
  .at-features li::before{content:"+";position:absolute;left:0;color:var(--accent);font-weight:700}

  /* Progress */
  .at-progress{background:var(--bg2);border:1px solid var(--border);border-left:3px solid var(--accent);border-radius:4px;padding:1.5rem;margin-bottom:1.5rem}
  .at-tips{list-style:none;padding:0;margin:0}
  .at-tips li{padding:.4rem 0 .4rem 1.25rem;position:relative;color:var(--text2);font-size:.88rem;line-height:1.5}
  .at-tips li::before{content:"-";position:absolute;left:0;color:var(--accent);font-weight:700}

  /* Optimization */
  .at-opt-grid{display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:1.5rem}
  .at-opt-card{background:var(--bg2);border:1px solid var(--border);border-radius:4px;padding:1.25rem}
  .at-opt-title{font-size:1rem;font-weight:700;margin:0 0 .5rem;color:var(--text)}
  .at-opt-desc{color:var(--text2);margin:0 0 .75rem;font-size:.85rem;line-height:1.6}
  .at-opt-links{list-style:none;padding:0;margin:0}
  .at-opt-links li{margin-bottom:.4rem}
  .at-opt-links a{color:var(--accent);text-decoration:none;font-weight:600;font-size:.88rem}
  .at-opt-links a:hover{text-decoration:underline}

  /* Links */
  .at-links{display:flex;flex-wrap:wrap;gap:.5rem;align-items:center;margin-bottom:1.5rem;padding:1rem;background:var(--bg2);border:1px solid var(--border);border-radius:4px}
  .at-links-label{font-weight:700;font-size:.85rem;color:var(--text2);margin-right:.25rem}
  .at-links a{color:var(--accent);font-size:.85rem;text-decoration:none;padding:.25rem .5rem;border-radius:4px;border:1px solid var(--border);transition:border-color .2s}
  .at-links a:hover{border-color:var(--accent)}

  /* FAQ */
  .at-faq-item{background:var(--bg3);border:1px solid var(--border);border-radius:4px;margin-bottom:.5rem;overflow:hidden}
  .at-faq-q{padding:.8rem 1rem;cursor:pointer;font-weight:600;font-size:.9rem;color:var(--text);list-style:none;display:flex;align-items:center;justify-content:space-between}
  .at-faq-q::-webkit-details-marker{display:none}
  .at-faq-q::after{content:'+';font-size:1.1rem;color:var(--accent);font-weight:700}
  .at-faq-item[open] .at-faq-q::after{content:'-'}
  .at-faq-item[open]{border-left:3px solid var(--accent)}
  .at-faq-a{padding:0 1rem .8rem;font-size:.88rem;color:var(--text2);line-height:1.6}

  /* Routine Builder */
  .at-builder{background:var(--bg2);border:1px solid var(--border);border-radius:4px;padding:1.5rem;margin-bottom:1.5rem}
  .at-builder-desc{color:var(--text2);font-size:.9rem;margin:0 0 1.25rem;line-height:1.6}
  .at-builder-controls{display:flex;flex-direction:column;gap:1rem;margin-bottom:1.25rem}
  .at-builder-group{display:flex;flex-direction:column;gap:.5rem}
  .at-builder-label{font-weight:700;font-size:.85rem;color:var(--text);text-transform:uppercase;letter-spacing:.04em}
  .at-optional{font-weight:400;color:var(--text2);text-transform:none;letter-spacing:0;font-size:.8rem}
  .at-builder-pills{display:flex;gap:.4rem;flex-wrap:wrap}
  .at-pill{background:var(--bg3);border:1px solid var(--border);color:var(--text2);padding:.4rem .8rem;border-radius:4px;font-size:.82rem;cursor:pointer;transition:all .2s;font-family:inherit;font-weight:500}
  .at-pill:hover{border-color:var(--accent);color:var(--accent)}
  .at-pill.active{background:var(--accent);color:#0d0e12;border-color:var(--accent);font-weight:700}

  .at-generate-btn,.at-regenerate-btn{background:var(--accent);color:#0d0e12;border:none;padding:.6rem 1.5rem;border-radius:4px;font-size:.88rem;font-weight:700;cursor:pointer;font-family:inherit;transition:opacity .2s}
  .at-generate-btn:hover,.at-regenerate-btn:hover{opacity:.85}
  .at-regenerate-btn{background:var(--bg3);color:var(--accent);border:1px solid var(--accent);padding:.4rem 1rem;font-size:.8rem}

  .at-routine-result{margin-top:1.25rem}
  .at-result-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:1rem;flex-wrap:wrap;gap:.75rem}
  .at-result-meta{display:flex;align-items:center;gap:.75rem}
  .at-result-total{font-weight:800;font-size:1rem;color:var(--accent)}
  .at-result-level{font-size:.75rem;color:var(--text2);background:var(--bg3);padding:.25rem .6rem;border-radius:4px;font-weight:600;text-transform:uppercase;letter-spacing:.04em}

  .at-result-timeline{display:flex;flex-direction:column;gap:.5rem}
  .at-timeline-item{display:flex;align-items:flex-start;gap:.75rem;padding:.75rem 1rem;background:var(--bg3);border:1px solid var(--border);border-radius:4px;transition:border-left .2s}
  .at-timeline-item:hover{border-left:3px solid var(--accent)}
  .at-timeline-check{flex-shrink:0;margin-top:.15rem}
  .at-timeline-check input[type="checkbox"]{width:16px;height:16px;accent-color:var(--accent);cursor:pointer}
  .at-timeline-body{flex:1;min-width:0}
  .at-timeline-top{display:flex;align-items:center;gap:.5rem;flex-wrap:wrap;margin-bottom:.25rem}
  .at-timeline-name{font-weight:700;font-size:.92rem;color:var(--text)}
  .at-timeline-dur{background:var(--accent);color:#0d0e12;padding:.15rem .5rem;border-radius:4px;font-size:.7rem;font-weight:700;white-space:nowrap}
  .at-timeline-map{font-size:.78rem;color:var(--accent);font-weight:600}
  .at-timeline-desc{font-size:.82rem;color:var(--text2);line-height:1.5;margin:0}
  .at-timeline-item.checked .at-timeline-name,.at-timeline-item.checked .at-timeline-desc{opacity:.5;text-decoration:line-through}

  .at-result-note{margin-top:1rem;font-size:.82rem;color:var(--text2);line-height:1.5}
  .at-result-note a{color:var(--accent);font-weight:600}

  @media(max-width:768px){
    .at-title{font-size:1.4rem}
    .at-maps-grid{grid-template-columns:1fr}
    .at-opt-grid{grid-template-columns:1fr}
    .at-result-header{flex-direction:column;align-items:flex-start}
  }
</style>

<script>
(function() {
  const exercises = [
    { name: 'Aim_Botz Warmup', map: 'aim_botz', duration: 5, level: 'all', focus: 'warmup', desc: 'Kill 100 bots focusing on headshots' },
    { name: 'Spray Transfer', map: 'Recoil Master', duration: 10, level: 'intermediate', focus: 'spray', desc: 'Practice AK-47 and M4 spray patterns' },
    { name: 'Fast Aim/Reflex', map: 'Fast Aim / Reflex Training', duration: 10, level: 'all', focus: 'flicking', desc: 'Flick to targets appearing randomly' },
    { name: 'Prefire Practice', map: 'Prefire maps', duration: 10, level: 'advanced', focus: 'crosshair', desc: 'Clear common angles on competitive maps' },
    { name: 'DM FFA Headshot Only', map: 'Community DM', duration: 15, level: 'intermediate', focus: 'flicking', desc: 'Free-for-all deathmatch, headshots only' },
    { name: 'Retake Servers', map: 'Community Retake', duration: 15, level: 'advanced', focus: 'crosshair', desc: 'Practice site retakes and post-plant' },
    { name: 'Tracking Practice', map: 'aim_botz', duration: 10, level: 'all', focus: 'tracking', desc: 'Track moving bots smoothly without flicking' },
    { name: 'Movement Practice', map: 'KZ/Surf maps', duration: 10, level: 'beginner', focus: 'warmup', desc: 'Improve counter-strafing and movement' },
    { name: 'YPrac Utility', map: 'YPrac maps', duration: 10, level: 'intermediate', focus: 'crosshair', desc: 'Learn smoke and flash lineups' },
    { name: 'Clutch Practice', map: '1v1 Arena', duration: 10, level: 'advanced', focus: 'flicking', desc: 'Practice 1v1 aim duels' },
  ];

  let selectedLevel = 'beginner';
  let selectedTime = 30;
  let selectedFocus = '';

  // Pill selection helpers
  function setupPillGroup(containerId, callback) {
    const container = document.getElementById(containerId);
    if (!container) return;
    container.querySelectorAll('.at-pill').forEach(function(btn) {
      btn.addEventListener('click', function() {
        container.querySelectorAll('.at-pill').forEach(function(b) { b.classList.remove('active'); });
        btn.classList.add('active');
        callback(btn);
      });
    });
  }

  setupPillGroup('levelPills', function(btn) { selectedLevel = btn.dataset.level; });
  setupPillGroup('timePills', function(btn) { selectedTime = parseInt(btn.dataset.time, 10); });
  setupPillGroup('focusPills', function(btn) { selectedFocus = btn.dataset.focus; });

  function shuffleArray(arr) {
    var a = arr.slice();
    for (var i = a.length - 1; i > 0; i--) {
      var j = Math.floor(Math.random() * (i + 1));
      var temp = a[i];
      a[i] = a[j];
      a[j] = temp;
    }
    return a;
  }

  function generateRoutine() {
    // Filter exercises by level
    var eligible = exercises.filter(function(ex) {
      return ex.level === 'all' || ex.level === selectedLevel;
    });

    // Filter by focus if selected
    if (selectedFocus) {
      var focused = eligible.filter(function(ex) { return ex.focus === selectedFocus; });
      // If we have focused exercises, prioritize them but keep warmups available
      if (focused.length > 0) {
        var warmups = eligible.filter(function(ex) { return ex.focus === 'warmup'; });
        eligible = focused.concat(warmups);
        // Remove duplicates
        var seen = {};
        eligible = eligible.filter(function(ex) {
          if (seen[ex.name]) return false;
          seen[ex.name] = true;
          return true;
        });
      }
    }

    // Shuffle and fill time budget
    eligible = shuffleArray(eligible);
    var routine = [];
    var timeUsed = 0;

    for (var i = 0; i < eligible.length; i++) {
      if (timeUsed + eligible[i].duration <= selectedTime) {
        routine.push(eligible[i]);
        timeUsed += eligible[i].duration;
      }
      if (timeUsed >= selectedTime) break;
    }

    // If we still have time and haven't used all exercises, try filling remaining
    if (timeUsed < selectedTime) {
      var remaining = exercises.filter(function(ex) {
        return (ex.level === 'all' || ex.level === selectedLevel) &&
          !routine.some(function(r) { return r.name === ex.name; });
      });
      remaining = shuffleArray(remaining);
      for (var j = 0; j < remaining.length; j++) {
        if (timeUsed + remaining[j].duration <= selectedTime) {
          routine.push(remaining[j]);
          timeUsed += remaining[j].duration;
        }
        if (timeUsed >= selectedTime) break;
      }
    }

    return { routine: routine, totalTime: timeUsed };
  }

  function renderRoutine(result) {
    var resultEl = document.getElementById('routineResult');
    var timelineEl = document.getElementById('resultTimeline');
    var totalEl = document.getElementById('resultTotal');
    var levelEl = document.getElementById('resultLevel');

    if (result.routine.length === 0) {
      timelineEl.innerHTML = '<p style="color:var(--text2);font-size:.9rem;text-align:center;padding:1rem">No exercises match your criteria. Try adjusting the filters.</p>';
      resultEl.style.display = 'block';
      totalEl.textContent = 'Total: 0 min';
      levelEl.textContent = selectedLevel.charAt(0).toUpperCase() + selectedLevel.slice(1);
      return;
    }

    totalEl.textContent = 'Total: ' + result.totalTime + ' min';
    levelEl.textContent = selectedLevel.charAt(0).toUpperCase() + selectedLevel.slice(1);

    var html = '';
    for (var i = 0; i < result.routine.length; i++) {
      var ex = result.routine[i];
      html += '<div class="at-timeline-item" data-idx="' + i + '">' +
        '<div class="at-timeline-check"><input type="checkbox" aria-label="Mark ' + ex.name + ' as complete"></div>' +
        '<div class="at-timeline-body">' +
          '<div class="at-timeline-top">' +
            '<span class="at-timeline-name">' + ex.name + '</span>' +
            '<span class="at-timeline-dur">' + ex.duration + ' min</span>' +
            '<span class="at-timeline-map">' + ex.map + '</span>' +
          '</div>' +
          '<p class="at-timeline-desc">' + ex.desc + '</p>' +
        '</div>' +
      '</div>';
    }
    timelineEl.innerHTML = html;
    resultEl.style.display = 'block';

    // Add checkbox handlers
    timelineEl.querySelectorAll('input[type="checkbox"]').forEach(function(cb) {
      cb.addEventListener('change', function() {
        var item = cb.closest('.at-timeline-item');
        if (cb.checked) {
          item.classList.add('checked');
        } else {
          item.classList.remove('checked');
        }
      });
    });
  }

  // Generate and Regenerate buttons
  var generateBtn = document.getElementById('generateBtn');
  var regenerateBtn = document.getElementById('regenerateBtn');

  if (generateBtn) {
    generateBtn.addEventListener('click', function() {
      var result = generateRoutine();
      renderRoutine(result);
    });
  }
  if (regenerateBtn) {
    regenerateBtn.addEventListener('click', function() {
      var result = generateRoutine();
      renderRoutine(result);
    });
  }
})();
</script>
