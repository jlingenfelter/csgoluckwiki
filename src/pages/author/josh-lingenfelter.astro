---
import Base from '../../layouts/Base.astro';

const title = 'Josh Lingenfelter — Author & CS2 Expert | CSGOLuck Wiki';
const description = 'Articles and guides by Josh Lingenfelter, Director at CSGOLuck. CS player since 2013 covering skin trading, pro settings, marketplace analysis, and competitive CS2.';

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Author', url: '/author/josh-lingenfelter/' },
];

// All authored pages — grouped by category
const articles = [
  {
    category: 'Trading & Investing',
    pages: [
      { title: 'CS2 Skin Trading Guide', url: '/cs2-guides/trading-guide/', description: 'Comprehensive guide to marketplace comparison, scam prevention, and profitable trading strategies.' },
      { title: 'Skins Investing Guide', url: '/cs2-guides/skins-investing-guide/', description: 'How to identify undervalued skins, manage your portfolio, and build long-term value.' },
      { title: 'Case Hardened Pattern Guide', url: '/cs2-guides/case-hardened-guide/', description: 'Blue gem tiers, pattern IDs, and pricing for Case Hardened skins.' },
    ],
  },
  {
    category: 'Game Mechanics & Skills',
    pages: [
      { title: 'Crosshair Settings Guide', url: '/cs2-guides/crosshair-guide/', description: 'How to customize your crosshair for better aim and visibility in CS2.' },
      { title: 'CS2 Movement Guide', url: '/cs2-guides/movement-guide/', description: 'Counter-strafing, bunny hopping, and advanced movement techniques.' },
      { title: 'Grenade Lineup Guide', url: '/cs2-guides/grenade-guide/', description: 'Essential smoke, flash, and molotov lineups for competitive play.' },
      { title: 'Advanced Mechanics Guide', url: '/cs2-guides/advanced-mechanics-guide/', description: 'Spray control, peeking, positioning, and high-level gameplay concepts.' },
      { title: 'Audio Settings Guide', url: '/cs2-guides/audio-guide/', description: 'Optimize your audio setup for better sound positioning and callouts.' },
    ],
  },
  {
    category: 'Getting Started',
    pages: [
      { title: 'Beginner\'s Guide to CS2', url: '/cs2-guides/beginners-guide/', description: 'Everything new players need to know about Counter-Strike 2.' },
      { title: 'CS2 Ranks Guide', url: '/cs2-guides/ranks-guide/', description: 'Understanding the CS2 ranking system, Premier mode, and how to rank up.' },
      { title: 'CS2 Economy Guide', url: '/cs2-guides/economy-guide/', description: 'Buy rounds, eco rounds, and money management in competitive CS2.' },
    ],
  },
  {
    category: 'Technical & Configuration',
    pages: [
      { title: 'Float Values Explained', url: '/cs2-guides/float-guide/', description: 'How float values work, wear ranges, and their impact on skin prices.' },
      { title: 'FPS Optimization Guide', url: '/cs2-guides/fps-optimization-guide/', description: 'Launch options, video settings, and system tweaks for maximum FPS.' },
      { title: 'Config & Settings Guide', url: '/cs2-guides/config-guide/', description: 'autoexec.cfg setup, key binds, and recommended competitive settings.' },
      { title: 'Demo Review Guide', url: '/cs2-guides/demo-guide/', description: 'How to watch demos, analyze your gameplay, and learn from pros.' },
    ],
  },
  {
    category: 'Reference & Tools',
    pages: [
      { title: 'Frequently Asked Questions', url: '/faq/', description: 'Common questions about CS2, skins, trading, and CSGOLuck Wiki.' },
    ],
  },
];

const totalArticles = articles.reduce((sum, cat) => sum + cat.pages.length, 0);

const personSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "ProfilePage",
  "mainEntity": {
    "@type": "Person",
    "name": "Josh Lingenfelter",
    "url": "https://wiki.csgoluck.com/author/josh-lingenfelter/",
    "jobTitle": "Director",
    "worksFor": {
      "@type": "Organization",
      "name": "CSGOLuck"
    },
    "sameAs": [
      "https://www.linkedin.com/in/josh-lingenfelter-8157274b/"
    ],
    "description": "CS player since 2013. Covers skin trading, marketplace analysis, pro settings, and competitive CS2 strategy."
  }
});

import { breadcrumbSchema } from '../../lib/weapons';
---

<Base title={title} description={description} currentNav="">
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema(breadcrumbs))}></script>
  <script type="application/ld+json" set:html={personSchema}></script>

  <nav class="breadcrumb">
    <a href="/">Home</a> / <span>Author</span>
  </nav>

  <div class="author-profile">
    <div class="author-profile-header">
      <div class="author-profile-avatar">JL</div>
      <div class="author-profile-info">
        <h1>Josh Lingenfelter</h1>
        <p class="author-profile-role">Director at <strong>CSGOLuck</strong></p>
        <div class="author-profile-links">
          <a href="https://www.linkedin.com/in/josh-lingenfelter-8157274b/" target="_blank" rel="noopener" class="author-social-link">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            LinkedIn
          </a>
        </div>
      </div>
    </div>

    <div class="author-profile-bio">
      <h2>About</h2>
      <p>
        CS player since 2013, starting with CS:GO and transitioning to CS2. With over a decade of experience in the Counter-Strike ecosystem, I cover skin trading and marketplace analysis, professional player settings and configurations, competitive strategy and game mechanics, and the economics of the CS2 skin market.
      </p>
      <p>
        As Director at CSGOLuck, I focus on creating data-driven content that helps players make informed decisions — whether that's choosing the right trading platform, understanding skin float values, or optimising their gameplay settings.
      </p>
      <p>
        CSGOLuck Wiki is built to be the most comprehensive CS2 resource available, with real-time pricing data from 14+ marketplaces, settings from 860+ professional players, and in-depth guides covering every aspect of the game.
      </p>
    </div>

    <div class="author-profile-stats">
      <div class="ap-stat">
        <span class="ap-stat-value">{totalArticles}</span>
        <span class="ap-stat-label">Articles Written</span>
      </div>
      <div class="ap-stat">
        <span class="ap-stat-value">2013</span>
        <span class="ap-stat-label">Playing CS Since</span>
      </div>
      <div class="ap-stat">
        <span class="ap-stat-value">860+</span>
        <span class="ap-stat-label">Pro Configs Tracked</span>
      </div>
      <div class="ap-stat">
        <span class="ap-stat-value">2,062</span>
        <span class="ap-stat-label">Skins Catalogued</span>
      </div>
    </div>
  </div>

  <section class="author-articles">
    <h2>All Articles & Guides</h2>
    {articles.map(group => (
      <div class="article-group">
        <h3>{group.category}</h3>
        <div class="article-list">
          {group.pages.map(page => (
            <a href={page.url} class="article-card">
              <div class="article-card-title">{page.title}</div>
              <div class="article-card-desc">{page.description}</div>
            </a>
          ))}
        </div>
      </div>
    ))}
  </section>
</Base>

<style>
  .breadcrumb{font-size:0.85rem;color:var(--text2);margin-bottom:1.5rem}
  .breadcrumb a{color:var(--accent)}

  .author-profile{background:var(--bg2);border:1px solid var(--border);border-radius:4px;padding:2rem;margin-bottom:2rem}
  .author-profile-header{display:flex;gap:1.5rem;align-items:center;margin-bottom:1.5rem}
  .author-profile-avatar{width:80px;height:80px;border-radius:50%;background:var(--accent);color:var(--bg);display:flex;align-items:center;justify-content:center;font-weight:800;font-size:1.6rem;flex-shrink:0}
  .author-profile-info{flex:1}
  .author-profile-info h1{margin:0 0 0.3rem;font-size:1.8rem}
  .author-profile-role{color:var(--text2);font-size:0.95rem;margin:0 0 0.6rem}
  .author-profile-role strong{color:var(--text)}
  .author-profile-links{display:flex;gap:0.75rem}
  .author-social-link{display:inline-flex;align-items:center;gap:0.4rem;padding:0.4rem 0.8rem;background:var(--bg3);border:1px solid var(--border);border-radius:6px;font-size:0.82rem;color:var(--text2);transition:all 0.2s}
  .author-social-link:hover{border-color:var(--accent);color:var(--accent)}
  .author-social-link svg{opacity:0.8}

  .author-profile-bio h2{margin:0 0 0.75rem;font-size:1.1rem}
  .author-profile-bio p{color:var(--text2);font-size:0.9rem;line-height:1.7;margin:0 0 0.75rem}
  .author-profile-bio p:last-child{margin-bottom:0}

  .author-profile-stats{display:grid;grid-template-columns:repeat(4,1fr);gap:1rem;margin-top:1.5rem;padding-top:1.5rem;border-top:1px solid var(--border)}
  .ap-stat{text-align:center}
  .ap-stat-value{display:block;font-size:1.4rem;font-weight:800;color:var(--accent)}
  .ap-stat-label{display:block;font-size:0.75rem;color:var(--text2);margin-top:0.2rem}

  .author-articles{margin-bottom:2rem}
  .author-articles > h2{margin:0 0 1.5rem;font-size:1.4rem}
  .article-group{margin-bottom:2rem}
  .article-group h3{font-size:1rem;color:var(--accent);margin:0 0 0.75rem;padding-bottom:0.5rem;border-bottom:1px solid var(--border)}
  .article-list{display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:0.75rem}
  .article-card{display:block;background:var(--bg2);border:1px solid var(--border);border-radius:4px;padding:1rem 1.2rem;transition:all 0.2s;text-decoration:none}
  .article-card:hover{border-color:var(--accent)}
  .article-card-title{font-weight:600;font-size:0.95rem;color:var(--text);margin-bottom:0.3rem}
  .article-card-desc{font-size:0.82rem;color:var(--text2);line-height:1.5}

  @media(max-width:768px){
    .author-profile-header{flex-direction:column;align-items:flex-start;gap:1rem}
    .author-profile-avatar{width:64px;height:64px;font-size:1.3rem}
    .author-profile-info h1{font-size:1.4rem}
    .author-profile-stats{grid-template-columns:repeat(2,1fr)}
    .article-list{grid-template-columns:1fr}
  }
</style>
