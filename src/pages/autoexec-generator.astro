---
import Base from '../layouts/Base.astro';
import ExploreMore from '../components/ExploreMore.astro';
import { faqSchema, breadcrumbSchema } from '../lib/weapons';

const title = 'CS2 Autoexec Generator — Custom Config Builder | CSGOLuck Wiki';
const description = 'Generate a complete CS2 autoexec.cfg with optimised settings for FPS, network, competitive play, and practice. One-click download with full console command explanations.';

const faqs = [
  { question: 'What is an autoexec.cfg in CS2?', answer: 'An autoexec.cfg is a configuration file that automatically executes console commands every time CS2 launches. It ensures your preferred settings are always applied, even if the game resets them. Place it in your CS2 cfg folder.' },
  { question: 'Where do I put my autoexec.cfg?', answer: 'Place autoexec.cfg in: Steam/steamapps/common/Counter-Strike Global Offensive/game/csgo/cfg/. Create the file if it doesn\'t exist. The file must be named exactly "autoexec.cfg" and end with the command "host_writeconfig".' },
  { question: 'Will an autoexec improve my FPS?', answer: 'Yes, FPS-focused commands like disabling unnecessary visual effects (cl_forcepreload 1, r_drawtracers_firstperson 0) and optimizing rendering can improve frame rates by 10-30% depending on your hardware.' },
  { question: 'Is using an autoexec allowed in competitive?', answer: 'Absolutely. Autoexec files only adjust client-side settings that you could change manually through the console or settings menu. They do not provide any unfair advantage and are used by virtually every professional player.' },
  { question: 'What commands should every autoexec have?', answer: 'Essential commands include: rate 786432 (max network bandwidth), cl_interp_ratio 1 (network interpolation), sensitivity and crosshair settings, and host_writeconfig at the end to save changes.' },
];

const presets = [
  { id: 'fps', name: 'Maximum FPS', icon: '⚡', desc: 'Strip away visual effects for maximum frames per second' },
  { id: 'competitive', name: 'Competitive', icon: '🏆', desc: 'Optimised for ranked matchmaking with balanced visuals' },
  { id: 'network', name: 'Low Latency', icon: '🌐', desc: 'Minimize network delay and reduce perceived lag' },
  { id: 'practice', name: 'Practice/Warmup', icon: '🎯', desc: 'Server commands for aim training and grenade practice' },
  { id: 'streaming', name: 'Streaming', icon: '📺', desc: 'Balanced performance with clean visuals for content creation' },
  { id: 'beginner', name: 'Beginner Friendly', icon: '🎮', desc: 'Sensible defaults with helpful visual cues enabled' },
];

const toolSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": title,
  "description": description,
  "applicationCategory": "UtilityApplication",
  "operatingSystem": "Web",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
  "author": { "@type": "Organization", "name": "CSGOLuck Wiki", "url": "https://wiki.csgoluck.com" }
});
---

<Base title={title} description={description} currentNav="/cs2-tools/">
  <script type="application/ld+json" set:html={toolSchema}></script>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema([{name:'Home',url:'/'},{name:'Tools',url:'/autoexec-generator'},{name:'Autoexec Generator',url:'/autoexec-generator'}]))}></script>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema(faqs))}></script>

  <nav class="breadcrumb"><a href="/">Home</a> <span>/</span> <a href="/cs2-tools/">Tools</a> <span>/</span> <span>Autoexec Generator</span></nav>

  <div class="axg-hero">
    <h1 class="axg-title">CS2 Autoexec Generator</h1>
    <p class="axg-desc">Build a custom autoexec.cfg tailored to your priorities. Choose a preset or tweak individual settings, then download the ready-to-use config file.</p>
  </div>

  <section class="axg-section">
    <h2 class="axg-section-title">Choose Your Preset</h2>
    <div class="axg-preset-grid" id="presetGrid">
      {presets.map(p => (
        <div class="axg-preset-card" data-preset={p.id}>
          <h3 class="axg-preset-name">{p.name}</h3>
          <p class="axg-preset-desc">{p.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="axg-section">
    <h2 class="axg-section-title">Customise Settings</h2>
    <div class="axg-settings-grid">
      <div>
        <h3 class="axg-group-title">Network</h3>
        <div class="axg-field"><label class="axg-label">Rate</label><select id="cfgRate" class="axg-select"><option value="786432" selected>786432 (Max)</option><option value="524288">524288</option><option value="196608">196608</option></select></div>
        <div class="axg-field"><label class="axg-label">Interp Ratio</label><select id="cfgInterp" class="axg-select"><option value="1" selected>1 (Competitive)</option><option value="2">2 (Default)</option></select></div>
        <div class="axg-field"><label class="axg-label">Max FPS</label><input type="number" id="cfgFps" value="0" min="0" max="999" step="1" class="axg-input"><span class="axg-hint">0 = unlimited</span></div>

        <h3 class="axg-group-title">Audio</h3>
        <div class="axg-field"><label class="axg-label">Master Volume</label><input type="range" id="cfgVol" min="0" max="1" step="0.05" value="0.5" class="axg-range"><span id="cfgVolVal" class="axg-range-val">0.5</span></div>
        <div class="axg-field"><label class="axg-label">HRTF (3D Audio)</label><select id="cfgHRTF" class="axg-select"><option value="1" selected>On</option><option value="0">Off</option></select></div>
      </div>
      <div>
        <h3 class="axg-group-title">Visuals</h3>
        <div class="axg-field"><label class="axg-label">Show FPS Counter</label><select id="cfgShowFps" class="axg-select"><option value="1" selected>On</option><option value="0">Off</option></select></div>
        <div class="axg-field"><label class="axg-label">First-Person Tracers</label><select id="cfgTracers" class="axg-select"><option value="1" selected>On</option><option value="0">Off</option></select></div>
        <div class="axg-field"><label class="axg-label">Viewmodel</label><select id="cfgViewmodel" class="axg-select"><option value="classic">Classic</option><option value="desktop" selected>Desktop</option><option value="couch">Couch</option></select></div>

        <h3 class="axg-group-title">HUD</h3>
        <div class="axg-field"><label class="axg-label">HUD Scale</label><input type="range" id="cfgHudScale" min="0.5" max="1" step="0.05" value="0.85" class="axg-range"><span id="cfgHudScaleVal" class="axg-range-val">0.85</span></div>
        <div class="axg-field"><label class="axg-label">Net Graph</label><select id="cfgNetGraph" class="axg-select"><option value="1" selected>On</option><option value="0">Off</option></select></div>
      </div>
    </div>
  </section>

  <section class="axg-output">
    <h2 class="axg-section-title">Generated Autoexec.cfg</h2>
    <pre id="cfgOutput" class="axg-code"></pre>
    <div class="axg-actions">
      <button id="copyBtn" class="axg-btn-primary">Copy to Clipboard</button>
      <button id="downloadBtn" class="axg-btn-secondary">Download .cfg</button>
    </div>
  </section>

  <section class="axg-guide">
    <h2 class="axg-section-title">What Each Setting Does</h2>
    <p class="axg-guide-text"><strong>Rate</strong> controls the maximum bytes per second your client requests from the server. Setting this to 786432 (the maximum) ensures you receive the most game data possible -- essential on modern internet connections.</p>
    <p class="axg-guide-text"><strong>Interp ratio</strong> (cl_interp_ratio) determines how many server ticks of interpolation buffer your client uses. A value of 1 reduces input lag by minimizing the buffer, but requires a stable connection. Use 2 if you experience packet loss.</p>
    <p class="axg-guide-text"><strong>fps_max</strong> caps your frame rate. Setting it to 0 (unlimited) is generally recommended if your PC can maintain high framerates. Some players cap it slightly above their monitor refresh rate to reduce power consumption and heat.</p>
  </section>

  <div class="axg-links">
    <span class="axg-links-label">Related Tools & Guides:</span>
    <a href="/launch-options/">Launch Options</a>
    <a href="/crosshair-generator/">Crosshair Generator</a>
    <a href="/bind-generator/">Bind Generator</a>
    <a href="/sensitivity-converter/">Sensitivity Converter</a>
    <a href="/resolution-calculator/">Resolution Calculator</a>
    <a href="/pro-players/">Pro Player Settings</a>
    <a href="/cs2-tools/">All Tools</a>
  </div>

  <section class="axg-section">
    <h2 class="axg-section-title">Frequently Asked Questions</h2>
    {faqs.map(f => (
      <details class="axg-faq-item">
        <summary class="axg-faq-q">{f.question}</summary>
        <div class="axg-faq-a">{f.answer}</div>
      </details>
    ))}
  </section>

  <ExploreMore context="tools" />
</Base>

<style>
  /* Hero */
  .axg-hero{margin-bottom:1.5rem}
  .axg-title{font-size:1.8rem;font-weight:800;margin:0 0 .5rem}
  .axg-desc{color:var(--text2);font-size:.95rem;margin:0;line-height:1.6;max-width:700px}

  /* Sections */
  .axg-section{background:var(--bg2);border:1px solid var(--border);border-radius:4px;padding:1.5rem;margin-bottom:1.5rem}
  .axg-section-title{font-size:1.15rem;font-weight:700;margin:0 0 1rem}

  /* Preset grid */
  .axg-preset-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:.75rem}
  .axg-preset-card{background:var(--bg3);border:1px solid var(--border);border-radius:4px;padding:1rem;cursor:pointer;transition:border-left .2s}
  .axg-preset-card:hover{border-left:3px solid var(--accent)}
  .axg-preset-name{margin:0 0 .3rem;font-size:.95rem;font-weight:700}
  .axg-preset-desc{margin:0;font-size:.82rem;color:var(--text2);line-height:1.5}

  /* Settings */
  .axg-settings-grid{display:grid;grid-template-columns:1fr 1fr;gap:1.5rem}
  .axg-group-title{font-size:.95rem;font-weight:700;margin:1rem 0 .6rem;color:var(--text)}
  .axg-group-title:first-child{margin-top:0}
  .axg-field{display:flex;align-items:center;gap:.6rem;margin-bottom:.5rem;flex-wrap:wrap}
  .axg-label{font-size:.85rem;color:var(--text2);min-width:120px;font-weight:600}
  .axg-select,.axg-input{background:var(--bg3);border:1px solid var(--border);border-radius:4px;padding:.4rem .6rem;color:var(--text);font-size:.88rem;flex:1;min-width:80px}
  .axg-select:focus,.axg-input:focus{outline:none;border-color:var(--accent)}
  .axg-range{flex:1;min-width:80px}
  .axg-range-val{font-size:.85rem;color:var(--accent);font-weight:700;min-width:30px}
  .axg-hint{font-size:.78rem;color:var(--text2)}

  /* Output */
  .axg-output{background:var(--bg2);border:1px solid var(--border);border-radius:4px;padding:1.5rem;margin-bottom:1.5rem}
  .axg-code{background:var(--bg);padding:1rem;border-radius:4px;font-size:.82rem;color:var(--accent);overflow-x:auto;white-space:pre-wrap;max-height:400px;line-height:1.6;border:1px solid var(--border)}
  .axg-actions{display:flex;gap:.75rem;margin-top:1rem}
  .axg-btn-primary{padding:.5rem 1.5rem;background:linear-gradient(135deg,#2ecc71,#27ae60);color:#fff;border:none;border-radius:4px;cursor:pointer;font-weight:700;font-size:.88rem;box-shadow:0 4px 15px rgba(46,204,113,.3);transition:all .2s ease}
  .axg-btn-primary:hover{background:linear-gradient(135deg,#27ae60,#219a52);transform:translateY(-2px);box-shadow:0 6px 20px rgba(46,204,113,.45)}
  .axg-btn-secondary{padding:.5rem 1.5rem;background:var(--bg3);color:var(--text);border:1px solid rgba(46,204,113,.4);border-radius:4px;cursor:pointer;font-weight:700;font-size:.88rem;box-shadow:0 0 8px rgba(46,204,113,.1);transition:all .2s ease}
  .axg-btn-secondary:hover{border-color:#2ecc71;background:rgba(46,204,113,.08);box-shadow:0 0 12px rgba(46,204,113,.2)}

  /* Guide */
  .axg-guide{background:var(--bg2);border:1px solid var(--border);border-left:3px solid var(--accent);border-radius:4px;padding:1.5rem;margin-bottom:1.5rem}
  .axg-guide-text{color:var(--text2);font-size:.88rem;line-height:1.7;margin:0 0 .75rem}
  .axg-guide-text:last-child{margin-bottom:0}

  /* Links */
  .axg-links{display:flex;flex-wrap:wrap;gap:.5rem;align-items:center;margin-bottom:1.5rem;padding:1rem;background:var(--bg2);border:1px solid var(--border);border-radius:4px}
  .axg-links-label{font-weight:700;font-size:.85rem;color:var(--text2);margin-right:.25rem}
  .axg-links a{color:var(--accent);font-size:.85rem;text-decoration:none;padding:.25rem .5rem;border-radius:4px;border:1px solid var(--border);transition:border-color .2s}
  .axg-links a:hover{border-color:var(--accent)}

  /* FAQ */
  .axg-faq-item{background:var(--bg3);border:1px solid var(--border);border-radius:4px;margin-bottom:.5rem;overflow:hidden}
  .axg-faq-q{padding:.8rem 1rem;cursor:pointer;font-weight:600;font-size:.9rem;color:var(--text);list-style:none;display:flex;align-items:center;justify-content:space-between}
  .axg-faq-q::-webkit-details-marker{display:none}
  .axg-faq-q::after{content:'+';font-size:1.1rem;color:var(--accent);font-weight:700}
  .axg-faq-item[open] .axg-faq-q::after{content:'-'}
  .axg-faq-item[open]{border-left:3px solid var(--accent)}
  .axg-faq-a{padding:0 1rem .8rem;font-size:.88rem;color:var(--text2);line-height:1.6}

  @media(max-width:768px){
    .axg-settings-grid{grid-template-columns:1fr}
    .axg-title{font-size:1.4rem}
    .axg-preset-grid{grid-template-columns:1fr 1fr}
  }
</style>

<script is:inline>
(function(){
  var presets={
    fps:{rate:'786432',interp:'1',fps:'0',vol:'0.3',hrtf:'0',showFps:'1',tracers:'0',viewmodel:'desktop',hudScale:'0.85',netGraph:'1'},
    competitive:{rate:'786432',interp:'1',fps:'0',vol:'0.5',hrtf:'1',showFps:'1',tracers:'1',viewmodel:'desktop',hudScale:'0.85',netGraph:'1'},
    network:{rate:'786432',interp:'1',fps:'0',vol:'0.5',hrtf:'1',showFps:'1',tracers:'1',viewmodel:'desktop',hudScale:'0.85',netGraph:'1'},
    practice:{rate:'786432',interp:'1',fps:'0',vol:'0.3',hrtf:'0',showFps:'1',tracers:'1',viewmodel:'classic',hudScale:'0.85',netGraph:'0'},
    streaming:{rate:'786432',interp:'2',fps:'300',vol:'0.4',hrtf:'1',showFps:'0',tracers:'1',viewmodel:'desktop',hudScale:'0.9',netGraph:'0'},
    beginner:{rate:'786432',interp:'2',fps:'0',vol:'0.6',hrtf:'1',showFps:'0',tracers:'1',viewmodel:'couch',hudScale:'1',netGraph:'0'}
  };
  var ids={rate:'cfgRate',interp:'cfgInterp',fps:'cfgFps',vol:'cfgVol',hrtf:'cfgHRTF',showFps:'cfgShowFps',tracers:'cfgTracers',viewmodel:'cfgViewmodel',hudScale:'cfgHudScale',netGraph:'cfgNetGraph'};

  function applyPreset(name){
    var p=presets[name];if(!p)return;
    Object.keys(p).forEach(function(k){
      var el=document.getElementById(ids[k]);
      if(el){if(el.type==='checkbox')el.checked=p[k]==='1';else el.value=p[k];}
    });
    generate();
  }

  function generate(){
    document.getElementById('cfgVolVal').textContent=document.getElementById('cfgVol').value;
    document.getElementById('cfgHudScaleVal').textContent=document.getElementById('cfgHudScale').value;
    var vm=document.getElementById('cfgViewmodel').value;
    var vmCmd='';
    if(vm==='classic')vmCmd='viewmodel_presetpos 1';
    else if(vm==='desktop')vmCmd='viewmodel_presetpos 2';
    else vmCmd='viewmodel_presetpos 3';

    var cfg=[
      '// ═══════════════════════════════════════════════════',
      '// CS2 Autoexec — Generated by CSGOLuck Wiki',
      '// ═══════════════════════════════════════════════════','',
      '// ── Network ──────────────────────────────────────',
      'rate '+document.getElementById('cfgRate').value,
      'cl_interp_ratio '+document.getElementById('cfgInterp').value,
      'cl_updaterate 128',
      'cl_cmdrate 128','',
      '// ── Performance ──────────────────────────────────',
      'fps_max '+document.getElementById('cfgFps').value,
      'cl_showfps '+(document.getElementById('cfgShowFps').value),
      'net_graph '+document.getElementById('cfgNetGraph').value,
      'r_drawtracers_firstperson '+document.getElementById('cfgTracers').value,'',
      '// ── Audio ────────────────────────────────────────',
      'volume '+document.getElementById('cfgVol').value,
      'snd_headphone_pan_exponent 1.2',
      'snd_hrtf_enabled '+document.getElementById('cfgHRTF').value,'',
      '// ── Viewmodel ───────────────────────────────────',
      vmCmd,'',
      '// ── HUD ─────────────────────────────────────────',
      'hud_scaling '+document.getElementById('cfgHudScale').value,
      'cl_hud_color 0','',
      '// ── Save settings ───────────────────────────────',
      'host_writeconfig','',
      '// Generated at wiki.csgoluck.com/autoexec-generator'
    ].join('\n');
    document.getElementById('cfgOutput').textContent=cfg;
    return cfg;
  }

  document.getElementById('presetGrid').addEventListener('click',function(e){
    var card=e.target.closest('[data-preset]');
    if(card)applyPreset(card.dataset.preset);
  });

  Object.values(ids).forEach(function(id){
    var el=document.getElementById(id);
    if(el){el.addEventListener('input',generate);el.addEventListener('change',generate);}
  });

  document.getElementById('copyBtn').addEventListener('click',function(){
    navigator.clipboard.writeText(generate()).then(function(){
      document.getElementById('copyBtn').textContent='Copied!';
      setTimeout(function(){document.getElementById('copyBtn').textContent='Copy to Clipboard';},2000);
    });
  });

  document.getElementById('downloadBtn').addEventListener('click',function(){
    var blob=new Blob([generate()],{type:'text/plain'});
    var a=document.createElement('a');a.href=URL.createObjectURL(blob);a.download='autoexec.cfg';a.click();
  });

  generate();
})();
</script>
