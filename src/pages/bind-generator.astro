---
import Base from '../layouts/Base.astro';
import ExploreMore from '../components/ExploreMore.astro';
import { breadcrumbSchema, faqSchema } from '../lib/weapons';

const title = 'CS2 Bind Generator — Buy Binds, Jump Throw & Utility | CSGOLuck Wiki';
const description = 'Generate CS2 buy binds, jump throw binds, and utility binds instantly. Visual numpad builder, one-click copy, and downloadable .cfg files.';
const crumbs = [{ name: 'Home', url: '/' }, { name: 'Bind Generator', url: '/bind-generator/' }];
const faqs = [
  { question: 'How do I set up buy binds in CS2?', answer: 'You can add buy bind commands to your autoexec.cfg file or enter them in the console. The format is: bind "KEY" "buy weapon_ak47". Use our generator above to create binds for your preferred keys and weapons, then paste them into your config.' },
  { question: 'Does the jump throw bind still work in CS2?', answer: 'Yes, jump throw binds work in CS2. The alias method (alias +jumpthrow) is the most reliable. CS2 also has a built-in jump throw mechanic, but a bind gives you more consistency and control over the timing.' },
  { question: 'Where do I put CS2 bind commands?', answer: 'Put bind commands in your autoexec.cfg file located in your CS2 config folder (Steam/steamapps/common/Counter-Strike Global Offensive/game/csgo/cfg/). You can also paste them directly into the in-game console.' },
  { question: 'Can I bind multiple commands to one key?', answer: 'Yes, you can chain multiple commands using semicolons. For example: bind "F1" "buy weapon_ak47; buy item_assaultsuit; buy weapon_hegrenade". This will attempt to buy all items when you press the key.' },
  { question: 'What are the best keys for buy binds?', answer: 'Most players use the numpad (KP_0 through KP_SLASH) since these keys are not used during gameplay. F1-F8 keys are also popular. Avoid binding to keys you use for movement or common actions.' },
];

const WEAPONS = {
  'Rifles': [
    { name: 'AK-47', cmd: 'weapon_ak47' }, { name: 'M4A4', cmd: 'weapon_m4a1' }, { name: 'M4A1-S', cmd: 'weapon_m4a1_silencer' },
    { name: 'AWP', cmd: 'weapon_awp' }, { name: 'SSG 08', cmd: 'weapon_ssg08' }, { name: 'Galil AR', cmd: 'weapon_galilar' },
    { name: 'FAMAS', cmd: 'weapon_famas' }, { name: 'AUG', cmd: 'weapon_aug' }, { name: 'SG 553', cmd: 'weapon_sg556' },
  ],
  'SMGs': [
    { name: 'MAC-10', cmd: 'weapon_mac10' }, { name: 'MP9', cmd: 'weapon_mp9' }, { name: 'UMP-45', cmd: 'weapon_ump45' },
    { name: 'MP7', cmd: 'weapon_mp7' }, { name: 'P90', cmd: 'weapon_p90' }, { name: 'PP-Bizon', cmd: 'weapon_bizon' },
  ],
  'Pistols': [
    { name: 'USP-S', cmd: 'weapon_usp_silencer' }, { name: 'Glock', cmd: 'weapon_glock' }, { name: 'P250', cmd: 'weapon_p250' },
    { name: 'Desert Eagle', cmd: 'weapon_deagle' }, { name: 'Five-SeveN', cmd: 'weapon_fiveseven' }, { name: 'Tec-9', cmd: 'weapon_tec9' },
    { name: 'CZ75-Auto', cmd: 'weapon_cz75a' }, { name: 'Dual Berettas', cmd: 'weapon_elite' }, { name: 'R8 Revolver', cmd: 'weapon_revolver' },
  ],
  'Heavy': [
    { name: 'Nova', cmd: 'weapon_nova' }, { name: 'XM1014', cmd: 'weapon_xm1014' }, { name: 'MAG-7', cmd: 'weapon_mag7' },
    { name: 'Sawed-Off', cmd: 'weapon_sawedoff' }, { name: 'M249', cmd: 'weapon_m249' }, { name: 'Negev', cmd: 'weapon_negev' },
  ],
  'Grenades': [
    { name: 'HE Grenade', cmd: 'weapon_hegrenade' }, { name: 'Flashbang', cmd: 'weapon_flashbang' },
    { name: 'Smoke', cmd: 'weapon_smokegrenade' }, { name: 'Molotov', cmd: 'weapon_molotov' },
    { name: 'Incendiary', cmd: 'weapon_incgrenade' }, { name: 'Decoy', cmd: 'weapon_decoy' },
  ],
  'Equipment': [
    { name: 'Kevlar', cmd: 'item_kevlar' }, { name: 'Kevlar + Helmet', cmd: 'item_assaultsuit' },
    { name: 'Defuse Kit', cmd: 'item_defuser' }, { name: 'Zeus x27', cmd: 'weapon_taser' },
  ],
};

const NUMPAD_KEYS = [
  { label: 'NUM 7', bind: 'KP_HOME' }, { label: 'NUM 8', bind: 'KP_UPARROW' }, { label: 'NUM 9', bind: 'KP_PGUP' },
  { label: 'NUM 4', bind: 'KP_LEFTARROW' }, { label: 'NUM 5', bind: 'KP_5' }, { label: 'NUM 6', bind: 'KP_RIGHTARROW' },
  { label: 'NUM 1', bind: 'KP_END' }, { label: 'NUM 2', bind: 'KP_DOWNARROW' }, { label: 'NUM 3', bind: 'KP_PGDN' },
  { label: 'NUM 0', bind: 'KP_INS' }, { label: 'NUM .', bind: 'KP_DEL' }, { label: 'NUM +', bind: 'KP_PLUS' },
  { label: 'NUM -', bind: 'KP_MINUS' }, { label: 'NUM *', bind: 'KP_MULTIPLY' }, { label: 'NUM /', bind: 'KP_SLASH' },
  { label: 'F1', bind: 'F1' }, { label: 'F2', bind: 'F2' }, { label: 'F3', bind: 'F3' },
  { label: 'F4', bind: 'F4' }, { label: 'F5', bind: 'F5' }, { label: 'F6', bind: 'F6' },
];

const PRESETS = [
  { name: 'Pro Standard', desc: 'AK/M4 + AWP + utility', binds: { KP_HOME: 'weapon_ak47', KP_UPARROW: 'weapon_m4a1', KP_PGUP: 'weapon_awp', KP_LEFTARROW: 'weapon_deagle', KP_5: 'item_assaultsuit', KP_RIGHTARROW: 'item_defuser', KP_END: 'weapon_flashbang', KP_DOWNARROW: 'weapon_smokegrenade', KP_PGDN: 'weapon_hegrenade', KP_INS: 'weapon_molotov', KP_DEL: 'weapon_incgrenade' } },
  { name: 'Economy Round', desc: 'Budget weapons + pistols', binds: { KP_HOME: 'weapon_galilar', KP_UPARROW: 'weapon_famas', KP_PGUP: 'weapon_ssg08', KP_LEFTARROW: 'weapon_p250', KP_5: 'weapon_deagle', KP_RIGHTARROW: 'item_kevlar', KP_END: 'weapon_flashbang', KP_DOWNARROW: 'weapon_smokegrenade' } },
  { name: 'Full Buy CT', desc: 'CT-side full buy', binds: { KP_HOME: 'weapon_m4a1', KP_UPARROW: 'weapon_m4a1_silencer', KP_PGUP: 'weapon_awp', KP_LEFTARROW: 'weapon_usp_silencer', KP_5: 'item_assaultsuit', KP_RIGHTARROW: 'item_defuser', KP_END: 'weapon_flashbang', KP_DOWNARROW: 'weapon_smokegrenade', KP_PGDN: 'weapon_hegrenade', KP_INS: 'weapon_incgrenade' } },
  { name: 'Full Buy T', desc: 'T-side full buy', binds: { KP_HOME: 'weapon_ak47', KP_UPARROW: 'weapon_galilar', KP_PGUP: 'weapon_awp', KP_LEFTARROW: 'weapon_glock', KP_5: 'item_assaultsuit', KP_END: 'weapon_flashbang', KP_DOWNARROW: 'weapon_smokegrenade', KP_PGDN: 'weapon_hegrenade', KP_INS: 'weapon_molotov' } },
];

const ALL_WEAPONS_FLAT = Object.entries(WEAPONS).flatMap(([cat, items]) => items.map(w => ({ ...w, category: cat })));

const UTIL_KEYS = ['F7','F8','F9','F10','F11','F12','CAPSLOCK','SEMICOLON','INS','DEL','HOME','END','PGUP','PGDN'];

const toolSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": title,
  "description": description,
  "applicationCategory": "UtilityApplication",
  "operatingSystem": "Web",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
  "author": { "@type": "Organization", "name": "CSGOLuck Wiki", "url": "https://wiki.csgoluck.com" }
});

const howToSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "HowTo",
  "name": "How to Create CS2 Buy Binds and Utility Binds",
  "description": "Use the CSGOLuck Wiki Bind Generator to create buy binds, jump throw binds, and utility binds for Counter-Strike 2.",
  "step": [
    { "@type": "HowToStep", "name": "Select a key and weapon for buy binds", "text": "Click a numpad or function key in the visual keyboard, then choose a weapon from the dropdown. Repeat for each key you want to bind. You can also load a preset (Pro Standard, Economy Round, Full Buy CT/T) to auto-fill all keys." },
    { "@type": "HowToStep", "name": "Copy or download your buy binds", "text": "Once your keys are assigned, click 'Copy to Clipboard' to copy the generated bind commands, or 'Download .cfg File' to save them as a config file you can place in your CS2 cfg folder." },
    { "@type": "HowToStep", "name": "Set up a jump throw bind", "text": "Choose between the Alias method (recommended for consistency) or Simple method, select your preferred key, and copy the generated jump throw bind command." },
    { "@type": "HowToStep", "name": "Add utility binds", "text": "Configure quality-of-life binds such as clear decals, voice toggle, display damage, volume toggle, crosshair size toggle, and netgraph toggle. Select a key for each and copy the commands." },
    { "@type": "HowToStep", "name": "Apply binds in CS2", "text": "Paste the copied commands into your CS2 console (~) or add them to your autoexec.cfg file in Steam/steamapps/common/Counter-Strike Global Offensive/game/csgo/cfg/ for persistent binds." }
  ]
});
---

<Base title={title} description={description}>
  <script type="application/ld+json" set:html={toolSchema}></script>
  <script type="application/ld+json" set:html={howToSchema}></script>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema(crumbs))}></script>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema(faqs))}></script>

  <nav class="breadcrumb"><a href="/">Home</a> <span>/</span> <a href="/cs2-tools/">Tools</a> <span>/</span> <span>Bind Generator</span></nav>

  <div class="bng-hero">
    <h1 class="bng-title">CS2 Bind Generator</h1>
    <p class="bng-desc">Create buy binds, jump throw binds, and utility binds for CS2. Choose your keys, select weapons, and copy the commands directly to your config.</p>
  </div>

  <!-- Buy Bind Section -->
  <section class="bng-section">
    <h2 class="bng-section-title">Buy Bind Generator</h2>
    <p class="bng-subtitle">Assign weapons to numpad and function keys. Click a key, then select a weapon from the dropdown.</p>

    <div class="bng-presets">
      <span class="bng-presets-label">Presets:</span>
      {PRESETS.map((p, i) => (
        <button class="bng-preset-btn" data-preset={i}>{p.name}</button>
      ))}
      <button class="bng-preset-btn" id="clear-all-btn">Clear All</button>
    </div>

    <div class="bng-keyboard">
      {NUMPAD_KEYS.map(k => (
        <div class="bng-key" data-bind={k.bind}>
          <div class="bng-key-label">{k.label}</div>
          <select class="bng-key-select" data-bind={k.bind}>
            <option value="">-- None --</option>
            {Object.entries(WEAPONS).map(([cat, items]) => (
              <optgroup label={cat}>
                {items.map(w => (
                  <option value={w.cmd}>{w.name}</option>
                ))}
              </optgroup>
            ))}
          </select>
        </div>
      ))}
    </div>

    <div class="bng-output-section">
      <h3 class="bng-sub-title">Generated Commands</h3>
      <pre class="bng-code" id="buy-output">// Select weapons above to generate buy binds</pre>
      <div class="bng-actions">
        <button class="bng-btn-primary" id="copy-buy-btn">Copy to Clipboard</button>
        <button class="bng-btn-secondary" id="download-buy-btn">Download .cfg File</button>
      </div>
    </div>
  </section>

  <!-- Jump Throw Bind Section -->
  <section class="bng-section">
    <h2 class="bng-section-title">Jump Throw Bind</h2>
    <p class="bng-subtitle">A jump throw bind ensures consistent grenade throws by jumping and releasing the grenade simultaneously with a single key press.</p>

    <div class="bng-jt-options">
      <div class="bng-field">
        <label class="bng-label">Method:</label>
        <select id="jt-method" class="bng-select">
          <option value="alias">Alias Method (Recommended)</option>
          <option value="simple">Simple Method</option>
        </select>
      </div>
      <div class="bng-field">
        <label class="bng-label">Key:</label>
        <select id="jt-key" class="bng-select">
          {UTIL_KEYS.map(k => (
            <option value={k} selected={k === 'F8'}>{k}</option>
          ))}
        </select>
      </div>
    </div>

    <pre class="bng-code" id="jt-output"></pre>
    <button class="bng-btn-primary" id="copy-jt-btn">Copy Jump Throw Bind</button>

    <div class="bng-tip">
      <p><strong>How to use:</strong> Hold your grenade, hold left click to pull the pin, then press your bound key. The bind will jump and release the grenade at the optimal time for a consistent throw arc.</p>
    </div>
  </section>

  <!-- Utility Binds Section -->
  <section class="bng-section">
    <h2 class="bng-section-title">Utility Binds</h2>
    <p class="bng-subtitle">Essential quality-of-life binds that every CS2 player should have in their config.</p>

    <div class="bng-util-grid">
      <div class="bng-util-card">
        <h3 class="bng-util-name">Clear Decals</h3>
        <p class="bng-util-desc">Removes blood splatter and bullet holes for clearer visibility.</p>
        <div class="bng-field"><label class="bng-label">Key:</label>
          <select class="bng-util-key" data-util="decals">
            {UTIL_KEYS.map(k => <option value={k} selected={k === 'F7'}>{k}</option>)}
          </select>
        </div>
        <pre class="bng-util-output" data-util="decals"></pre>
        <button class="bng-btn-primary bng-util-copy" data-util="decals">Copy</button>
      </div>

      <div class="bng-util-card">
        <h3 class="bng-util-name">Voice Toggle</h3>
        <p class="bng-util-desc">Toggle teammate voice chat on/off with one key press.</p>
        <div class="bng-field"><label class="bng-label">Key:</label>
          <select class="bng-util-key" data-util="voice">
            {UTIL_KEYS.map(k => <option value={k} selected={k === 'F9'}>{k}</option>)}
          </select>
        </div>
        <pre class="bng-util-output" data-util="voice"></pre>
        <button class="bng-btn-primary bng-util-copy" data-util="voice">Copy</button>
      </div>

      <div class="bng-util-card">
        <h3 class="bng-util-name">Display Damage</h3>
        <p class="bng-util-desc">Show damage dealt to enemies in the console after each round.</p>
        <div class="bng-field"><label class="bng-label">Key:</label>
          <select class="bng-util-key" data-util="damage">
            {UTIL_KEYS.map(k => <option value={k} selected={k === 'F10'}>{k}</option>)}
          </select>
        </div>
        <pre class="bng-util-output" data-util="damage"></pre>
        <button class="bng-btn-primary bng-util-copy" data-util="damage">Copy</button>
      </div>

      <div class="bng-util-card">
        <h3 class="bng-util-name">Volume Toggle</h3>
        <p class="bng-util-desc">Quickly toggle game volume between normal and muted.</p>
        <div class="bng-field"><label class="bng-label">Key:</label>
          <select class="bng-util-key" data-util="volume">
            {UTIL_KEYS.map(k => <option value={k} selected={k === 'F11'}>{k}</option>)}
          </select>
        </div>
        <pre class="bng-util-output" data-util="volume"></pre>
        <button class="bng-btn-primary bng-util-copy" data-util="volume">Copy</button>
      </div>

      <div class="bng-util-card">
        <h3 class="bng-util-name">Crosshair Size Toggle</h3>
        <p class="bng-util-desc">Switch between two crosshair sizes for different situations.</p>
        <div class="bng-field"><label class="bng-label">Key:</label>
          <select class="bng-util-key" data-util="crosshair">
            {UTIL_KEYS.map(k => <option value={k} selected={k === 'F12'}>{k}</option>)}
          </select>
        </div>
        <pre class="bng-util-output" data-util="crosshair"></pre>
        <button class="bng-btn-primary bng-util-copy" data-util="crosshair">Copy</button>
      </div>

      <div class="bng-util-card">
        <h3 class="bng-util-name">Netgraph Toggle</h3>
        <p class="bng-util-desc">Show/hide network stats (ping, FPS, loss) on screen.</p>
        <div class="bng-field"><label class="bng-label">Key:</label>
          <select class="bng-util-key" data-util="netgraph">
            {UTIL_KEYS.map(k => <option value={k} selected={k === 'INS'}>{k}</option>)}
          </select>
        </div>
        <pre class="bng-util-output" data-util="netgraph"></pre>
        <button class="bng-btn-primary bng-util-copy" data-util="netgraph">Copy</button>
      </div>
    </div>
  </section>

  <div class="bng-links">
    <span class="bng-links-label">Related Tools:</span>
    <a href="/autoexec-generator/">Autoexec Generator</a>
    <a href="/launch-options/">Launch Options</a>
    <a href="/crosshair-generator/">Crosshair Generator</a>
    <a href="/crosshair-codes/">Crosshair Codes</a>
    <a href="/sensitivity-converter/">Sensitivity Converter</a>
    <a href="/resolution-calculator/">Resolution Calculator</a>
    <a href="/pro-players/">Pro Player Settings</a>
    <a href="/cs2-tools/">All Tools</a>
  </div>

  <section class="bng-section">
    <h2 class="bng-section-title">Frequently Asked Questions</h2>
    {faqs.map(f => (
      <details class="bng-faq-item">
        <summary class="bng-faq-q">{f.question}</summary>
        <div class="bng-faq-a">{f.answer}</div>
      </details>
    ))}
  </section>

  <ExploreMore context="tools" />
</Base>

<script is:inline>
(function(){
  var PRESETS = [
    { binds: { KP_HOME:'weapon_ak47',KP_UPARROW:'weapon_m4a1',KP_PGUP:'weapon_awp',KP_LEFTARROW:'weapon_deagle',KP_5:'item_assaultsuit',KP_RIGHTARROW:'item_defuser',KP_END:'weapon_flashbang',KP_DOWNARROW:'weapon_smokegrenade',KP_PGDN:'weapon_hegrenade',KP_INS:'weapon_molotov',KP_DEL:'weapon_incgrenade' } },
    { binds: { KP_HOME:'weapon_galilar',KP_UPARROW:'weapon_famas',KP_PGUP:'weapon_ssg08',KP_LEFTARROW:'weapon_p250',KP_5:'weapon_deagle',KP_RIGHTARROW:'item_kevlar',KP_END:'weapon_flashbang',KP_DOWNARROW:'weapon_smokegrenade' } },
    { binds: { KP_HOME:'weapon_m4a1',KP_UPARROW:'weapon_m4a1_silencer',KP_PGUP:'weapon_awp',KP_LEFTARROW:'weapon_usp_silencer',KP_5:'item_assaultsuit',KP_RIGHTARROW:'item_defuser',KP_END:'weapon_flashbang',KP_DOWNARROW:'weapon_smokegrenade',KP_PGDN:'weapon_hegrenade',KP_INS:'weapon_incgrenade' } },
    { binds: { KP_HOME:'weapon_ak47',KP_UPARROW:'weapon_galilar',KP_PGUP:'weapon_awp',KP_LEFTARROW:'weapon_glock',KP_5:'item_assaultsuit',KP_END:'weapon_flashbang',KP_DOWNARROW:'weapon_smokegrenade',KP_PGDN:'weapon_hegrenade',KP_INS:'weapon_molotov' } },
  ];

  var selects = document.querySelectorAll('.bng-key-select');

  function updateBuyOutput(){
    var lines = [];
    selects.forEach(function(sel){
      if(sel.value){
        lines.push('bind "'+sel.dataset.bind+'" "buy '+sel.value+'"');
      }
    });
    var out = document.getElementById('buy-output');
    out.textContent = lines.length > 0 ? lines.join('\n') : '// Select weapons above to generate buy binds';
  }

  selects.forEach(function(sel){
    sel.addEventListener('change', updateBuyOutput);
  });

  document.querySelectorAll('[data-preset]').forEach(function(btn){
    btn.addEventListener('click', function(){
      var idx = parseInt(btn.dataset.preset);
      var preset = PRESETS[idx];
      if(!preset) return;
      selects.forEach(function(sel){ sel.value = ''; });
      Object.keys(preset.binds).forEach(function(key){
        var sel = document.querySelector('.bng-key-select[data-bind="'+key+'"]');
        if(sel) sel.value = preset.binds[key];
      });
      updateBuyOutput();
    });
  });

  document.getElementById('clear-all-btn').addEventListener('click', function(){
    selects.forEach(function(sel){ sel.value = ''; });
    updateBuyOutput();
  });

  document.getElementById('copy-buy-btn').addEventListener('click', function(){
    var text = document.getElementById('buy-output').textContent;
    navigator.clipboard.writeText(text).then(function(){
      var btn = document.getElementById('copy-buy-btn');
      btn.textContent = 'Copied!';
      setTimeout(function(){ btn.textContent = 'Copy to Clipboard'; }, 1500);
    });
  });

  document.getElementById('download-buy-btn').addEventListener('click', function(){
    var text = '// CS2 Buy Binds - Generated by CSGOLuck Wiki\n' + document.getElementById('buy-output').textContent;
    var blob = new Blob([text], { type: 'text/plain' });
    var a = document.createElement('a');
    a.href = URL.createObjectURL(blob);
    a.download = 'buy_binds.cfg';
    a.click();
  });

  function updateJT(){
    var method = document.getElementById('jt-method').value;
    var key = document.getElementById('jt-key').value;
    var out = document.getElementById('jt-output');
    if(method === 'alias'){
      out.textContent = 'alias "+jumpthrow" "+jump;-attack"\nalias "-jumpthrow" "-jump"\nbind "'+key+'" "+jumpthrow"';
    } else {
      out.textContent = 'bind "'+key+'" "+jump; -attack; -jump"';
    }
  }
  document.getElementById('jt-method').addEventListener('change', updateJT);
  document.getElementById('jt-key').addEventListener('change', updateJT);
  updateJT();

  document.getElementById('copy-jt-btn').addEventListener('click', function(){
    navigator.clipboard.writeText(document.getElementById('jt-output').textContent).then(function(){
      var btn = document.getElementById('copy-jt-btn');
      btn.textContent = 'Copied!';
      setTimeout(function(){ btn.textContent = 'Copy Jump Throw Bind'; }, 1500);
    });
  });

  var utilCmds = {
    decals: function(k){ return 'bind "'+k+'" "r_cleardecals"'; },
    voice: function(k){ return 'bind "'+k+'" "toggle voice_enable 0 1"'; },
    damage: function(k){ return 'bind "'+k+'" "clear; con_filter_enable 2; con_filter_text_out \'Damage\'; con_filter_text \'Damage Given\'; developer 1; playvol buttons/blip1 0.5"'; },
    volume: function(k){ return 'bind "'+k+'" "toggle volume 0.5 0"'; },
    crosshair: function(k){ return 'bind "'+k+'" "toggle cl_crosshairsize 2 4"'; },
    netgraph: function(k){ return 'bind "'+k+'" "toggle cl_showfps 0 1"'; },
  };

  function updateUtil(name){
    var sel = document.querySelector('.bng-util-key[data-util="'+name+'"]');
    var out = document.querySelector('.bng-util-output[data-util="'+name+'"]');
    if(sel && out && utilCmds[name]){
      out.textContent = utilCmds[name](sel.value);
    }
  }

  document.querySelectorAll('.bng-util-key').forEach(function(sel){
    sel.addEventListener('change', function(){ updateUtil(sel.dataset.util); });
    updateUtil(sel.dataset.util);
  });

  document.querySelectorAll('.bng-util-copy').forEach(function(btn){
    btn.addEventListener('click', function(){
      var out = document.querySelector('.bng-util-output[data-util="'+btn.dataset.util+'"]');
      if(out){
        navigator.clipboard.writeText(out.textContent).then(function(){
          btn.textContent = 'Copied!';
          setTimeout(function(){ btn.textContent = 'Copy'; }, 1500);
        });
      }
    });
  });
})();
</script>

<style>
  /* Hero */
  .bng-hero{margin-bottom:1.5rem}
  .bng-title{font-size:1.8rem;font-weight:800;margin:0 0 .5rem}
  .bng-desc{color:var(--text2);font-size:.95rem;margin:0;line-height:1.6;max-width:700px}

  /* Sections */
  .bng-section{background:var(--bg2);border:1px solid var(--border);border-radius:4px;padding:1.5rem;margin-bottom:1.5rem}
