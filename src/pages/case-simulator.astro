  /* ── CTA Popup ──────────────────────────────────────────── */
  .cta-popup{position:fixed;inset:0;z-index:999;display:flex;align-items:center;justify-content:center;padding:1rem}
  .cta-popup.hidden{display:none!important}
  .cta-popup-backdrop{position:absolute;inset:0;background:rgba(0,0,0,.75);cursor:pointer}
