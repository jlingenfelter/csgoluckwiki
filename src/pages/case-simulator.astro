---
import Base from '../layouts/Base.astro';
import ExploreMore from '../components/ExploreMore.astro';
import { caseDatabase } from '../lib/cases';
import { SKINS } from '../lib/skins';
import { breadcrumbSchema, toolAppSchema } from '../lib/weapons';

// Build image lookup from existing skin database
// Match by weapon + skin name to get Steam CDN image URLs
const imageMap: Record<string, string> = {};
for (const skin of SKINS) {
  const key = `${skin.weapon}|${skin.name}`.toLowerCase();
  if (skin.image) imageMap[key] = skin.image;
}

// Common knife/glove finishes to add as special rarity items per case
const KNIFE_FINISHES = ['Fade', 'Doppler', 'Crimson Web', 'Slaughter', 'Tiger Tooth', 'Marble Fade'];
const GLOVE_FINISHES = ['Fade', 'Crimson Kimono', 'Emerald Web', 'Superconductor', 'Vice', 'Mogul'];

function getSpecialSkins(knifeField: string): { name: string; rarity: 'special'; weapon: string }[] {
  const isGloves = knifeField.toLowerCase().includes('glove');
  const finishes = isGloves ? GLOVE_FINISHES : KNIFE_FINISHES;

  // Parse the knife/glove types from the field (some have multiple separated by /)
  const types = knifeField
    .replace(/\s*\([^)]+\)\s*/g, '') // strip parenthetical like "(Chroma)"
    .split('/')
    .map(t => t.trim())
    .filter(Boolean);

  // Use the first type as the weapon name, add a few finishes
  const weapon = types[0] || knifeField;
  const prefix = isGloves ? '★' : '★';
  return finishes.slice(0, 3).map(finish => ({
    name: finish,
    rarity: 'special' as const,
    weapon: `${prefix} ${weapon}`,
  }));
}

// Enrich case skins with images and add special (knife/glove) items
const enrichedCases: Record<string, any> = {};
for (const [id, caseData] of Object.entries(caseDatabase)) {
  // Check if case already has special rarity skins
  const hasSpecials = caseData.skins.some(s => s.rarity === 'special');
  const specials = hasSpecials ? [] : getSpecialSkins(caseData.knife);
  const allSkins = [...caseData.skins, ...specials];

  enrichedCases[id] = {
    ...caseData,
    skins: allSkins.map(s => {
      const key = `${s.weapon}|${s.name}`.toLowerCase();
      return { ...s, image: imageMap[key] || null };
    }),
  };
}

const casesJson = JSON.stringify(enrichedCases);

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Skins', url: '/cs2-skins/' },
  { name: 'Case Simulator', url: '/case-simulator/' },
];
---

<Base title="CS2 Case Opening Simulator — Free Cases | CSGOLuck Wiki" description="Open CS2 cases for free with our realistic case opening simulator. Kilowatt, Gallery, Revolution and 20+ cases with real odds. Track stats and see if you'd profit!" currentNav="/cs2-skins/">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema(breadcrumbs))} />
    <script type="application/ld+json" set:html={JSON.stringify(toolAppSchema({ name: 'CS2 Case Opening Simulator', url: 'https://wiki.csgoluck.com/case-simulator/', description: 'Open CS2 cases for free with our realistic case opening simulator. Track stats and see if you\'d profit!' }))} />
  </Fragment>

  <nav class="breadcrumb"><a href="/">Home</a> <span>/</span> <a href="/cs2-cases/">Cases</a> <span>/</span> <span>Case Simulator</span></nav>

  <!-- ═══ State 1: Case Selection Grid ═══ -->
  <div id="selectState">
    <div class="cs-hero">
      <div class="cs-hero-top">
        <div>
          <h1 class="cs-title">Case Opening Simulator</h1>
          <p class="cs-desc">Open CS2 cases for free with realistic animations and real drop odds. Pick a case below to start opening.</p>
        </div>
        <a href="/go/" rel="nofollow" class="cs-hero-cta">
          <span class="cs-hero-cta-label">Open Real Cases</span>
          <span class="cs-hero-cta-bonus">🎁 100% to 100 Coins + 5 Free Cases</span>
        </a>
      </div>
    </div>

    <div class="cs-grid" id="caseGrid"></div>

    <div class="cs-odds-legend">
      <span><i class="dot mil-spec"></i>Mil-Spec 79.92%</span>
      <span><i class="dot restricted"></i>Restricted 15.98%</span>
      <span><i class="dot classified"></i>Classified 3.20%</span>
      <span><i class="dot covert"></i>Covert 0.64%</span>
      <span><i class="dot special"></i>Knife/Gloves 0.26%</span>
    </div>
  </div>

  <!-- ═══ State 2: Case Opening View ═══ -->
  <div id="openState" class="hidden">
    <!-- Top bar -->
    <div class="cs-topbar">
      <button id="backBtn" class="cs-back" title="Back to cases">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
        Back
      </button>
      <div class="cs-topbar-info">
        <h2 id="caseName" class="cs-topbar-name"></h2>
        <span id="casePrice" class="cs-topbar-price"></span>
      </div>
      <div class="cs-spin-options">
        <button class="cs-spin-count active" data-count="1">x1</button>
        <button class="cs-spin-count" data-count="3">x3</button>
        <button class="cs-spin-count" data-count="5">x5</button>
        <button class="cs-spin-count" data-count="10">x10</button>
      </div>
      <button id="openBtn" class="cs-open-btn">Open Case</button>
    </div>

    <!-- Roulette -->
    <div class="cs-reels-container" id="reelsContainer">
      <div class="cs-roulette-wrap">
        <div class="cs-pointer"></div>
        <div class="cs-roulette"><div class="cs-strip"></div></div>
      </div>
    </div>

    <!-- Result -->
    <div id="resultArea" class="cs-result hidden"></div>

    <!-- Stats bar -->
    <div class="cs-statsbar">
      <div class="cs-sb-item"><span class="cs-sb-val" id="statOpened">0</span><span class="cs-sb-lbl">Opened</span></div>
      <div class="cs-sb-item"><span class="cs-sb-val">$<span id="statSpent">0.00</span></span><span class="cs-sb-lbl">Spent</span></div>
      <div class="cs-sb-item"><span class="cs-sb-val">$<span id="statValue">0.00</span></span><span class="cs-sb-lbl">Value</span></div>
      <div class="cs-sb-item cs-sb-profit"><span class="cs-sb-val neutral" id="statProfit">$0.00</span><span class="cs-sb-lbl">Profit</span></div>
      <div class="cs-sb-item"><span class="cs-sb-val" id="statROI">0%</span><span class="cs-sb-lbl">ROI</span></div>
      <div class="cs-sb-rarity">
        <span><i class="dot mil-spec"></i><b id="rMilspec">0</b></span>
        <span><i class="dot restricted"></i><b id="rRestricted">0</b></span>
        <span><i class="dot classified"></i><b id="rClassified">0</b></span>
        <span><i class="dot covert"></i><b id="rCovert">0</b></span>
        <span><i class="dot special"></i><b id="rSpecial">0</b></span>
      </div>
      <button id="resetBtn" class="cs-reset-btn">Reset</button>
    </div>

    <!-- Best & Recent pulls -->
    <div class="cs-pulls-row">
      <div class="cs-pull-box">
        <h4>Best Pull</h4>
        <div id="bestPull"><p class="cs-empty">No pulls yet</p></div>
      </div>
      <div class="cs-pull-box cs-pull-recent">
        <h4>Recent Pulls</h4>
        <div id="recentPulls"><p class="cs-empty">No pulls yet</p></div>
      </div>
    </div>

    <!-- Case contents -->
    <div class="cs-contents">
      <h4>Case Contents</h4>
      <div id="caseContents" class="cs-contents-grid"></div>
    </div>

    <!-- CTA -->
    <div class="cs-cta-block">
      <div class="cs-cta-inner">
        <div class="cs-cta-text"><strong>Open Real Cases on CSGOLuck</strong><span>🎁 100% to 100 Coins + 5 Free Cases</span></div>
        <a href="/go/" rel="nofollow" class="cs-cta-btn">Open Cases</a>
      </div>
    </div>
  </div>

<ExploreMore context="skins" />

<style is:inline>
  .hidden{display:none!important}

  /* ── Hero ──────────────────────────────────────────────── */
  .cs-hero{padding:1.5rem 0 1rem}
  .cs-hero-top{display:flex;align-items:flex-start;justify-content:space-between;gap:1.5rem;flex-wrap:wrap}
  .cs-title{font-size:1.8rem;font-weight:800;margin:0 0 .4rem;color:var(--text)}
  .cs-desc{color:var(--text2);font-size:.9rem;margin:0;max-width:550px;line-height:1.6}
  .cs-hero-cta{display:flex;flex-direction:column;align-items:center;gap:.25rem;padding:.7rem 1.5rem;background:#2ecc71;border-radius:6px;text-decoration:none;transition:background .15s;flex-shrink:0}
  .cs-hero-cta:hover{background:#27ae60}
  .cs-hero-cta-label{font-weight:800;font-size:.95rem;color:#fff}
  .cs-hero-cta-bonus{font-size:.7rem;color:rgba(255,255,255,.85);font-weight:600}

  /* ── Case Grid ─────────────────────────────────────────── */
  .cs-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:.75rem;margin-bottom:1.5rem}
  .cs-card{background:var(--bg2);border:1px solid var(--border);border-radius:6px;padding:1rem;cursor:pointer;transition:border-color .15s,transform .15s;display:flex;flex-direction:column;align-items:center;text-align:center;gap:.5rem}
  .cs-card:hover{border-color:#2ecc71;transform:translateY(-2px)}
  .cs-card-img{width:100%;height:100px;display:flex;align-items:center;justify-content:center;background:var(--bg3);border-radius:4px;overflow:hidden;position:relative}
  .cs-card-img-items{display:flex;gap:4px;padding:4px}
  .cs-card-img-items img{width:40px;height:30px;object-fit:contain}
  .cs-card-knife{position:absolute;bottom:4px;right:4px;font-size:.55rem;background:rgba(228,174,57,.15);color:#e4ae39;padding:.1rem .35rem;border-radius:3px;font-weight:700}
  .cs-card-name{font-weight:700;font-size:.9rem;color:var(--text)}
  .cs-card-meta{font-size:.7rem;color:var(--text2)}
  .cs-card-price{font-size:.85rem;font-weight:800;color:#2ecc71}

  /* ── Odds legend ───────────────────────────────────────── */
  .cs-odds-legend{display:flex;flex-wrap:wrap;gap:.5rem 1.2rem;justify-content:center;font-size:.75rem;color:var(--text2);padding:.75rem 0;margin-bottom:1rem}
  .cs-odds-legend span{display:flex;align-items:center;gap:.3rem}
  .dot{width:8px;height:8px;border-radius:50%;display:inline-block;flex-shrink:0}
  .dot.mil-spec{background:#4b69ff}.dot.restricted{background:#8847ff}.dot.classified{background:#d32ce6}.dot.covert{background:#2ecc71}.dot.special{background:#ffd700}

  /* ── Top bar ───────────────────────────────────────────── */
  .cs-topbar{display:flex;align-items:center;gap:1rem;padding:.75rem 0;flex-wrap:wrap}
  .cs-back{display:flex;align-items:center;gap:.3rem;background:none;border:1px solid var(--border);color:var(--text2);border-radius:4px;padding:.4rem .7rem;font-size:.8rem;cursor:pointer;font-family:inherit;transition:border-color .15s}
  .cs-back:hover{border-color:#2ecc71;color:#2ecc71}
  .cs-topbar-info{flex:1;min-width:0}
  .cs-topbar-name{margin:0;font-size:1.15rem;font-weight:800;color:var(--text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
  .cs-topbar-price{font-size:.8rem;color:#2ecc71;font-weight:700}
  .cs-spin-options{display:flex;gap:.3rem}
  .cs-spin-count{background:var(--bg3);border:1px solid var(--border);border-radius:4px;padding:.4rem .7rem;font-size:.8rem;font-weight:700;color:var(--text2);cursor:pointer;transition:all .15s;font-family:inherit}
  .cs-spin-count:hover{border-color:#2ecc71}
  .cs-spin-count.active{background:rgba(46,204,113,.1);border-color:#2ecc71;color:#2ecc71}
  .cs-open-btn{background:#2ecc71;color:#fff;border:none;border-radius:20px;padding:.6rem 2.5rem;font-size:1rem;font-weight:800;cursor:pointer;transition:background .15s;font-family:inherit;white-space:nowrap}
  .cs-open-btn:hover:not(:disabled){background:#27ae60}
  .cs-open-btn:disabled{opacity:.4;cursor:not-allowed}

  /* ── Roulette ──────────────────────────────────────────── */
  .cs-reels-container{display:flex;flex-direction:column;gap:.5rem;margin:.5rem 0}
  .cs-roulette-wrap{position:relative}
  .cs-pointer{position:absolute;top:0;left:50%;transform:translateX(-50%);width:0;height:0;border-left:10px solid transparent;border-right:10px solid transparent;border-top:14px solid #2ecc71;z-index:5}
  .cs-roulette{background:var(--bg);border:2px solid var(--border);border-radius:6px;overflow:hidden;height:130px;display:flex;align-items:center;position:relative;width:100%}
  .cs-reels-container.multi .cs-roulette{height:95px}
  .cs-reels-container.multi .cs-item{width:85px;height:85px}
  .cs-reels-container.multi .cs-item-img{width:50px;height:38px}
  .cs-reels-container.multi .cs-item-weapon{font-size:.6rem}
  .cs-reels-container.multi .cs-item-skin{font-size:.5rem}
  .cs-roulette::before,.cs-roulette::after{content:'';position:absolute;top:0;bottom:0;width:80px;z-index:3;pointer-events:none}
  .cs-roulette::before{left:0;background:linear-gradient(to right,var(--bg),transparent)}
  .cs-roulette::after{right:0;background:linear-gradient(to left,var(--bg),transparent)}
  .cs-strip{display:flex;gap:8px;padding:0 8px;will-change:transform}
  .cs-strip.animating{transition:transform 4s cubic-bezier(.15,.3,.2,1)}
  .cs-reel-label{position:absolute;left:8px;top:50%;transform:translateY(-50%);background:rgba(0,0,0,.6);color:var(--text2);font-size:.6rem;font-weight:700;padding:.15rem .4rem;border-radius:4px;z-index:4}

  .cs-item{flex-shrink:0;width:110px;height:110px;border-radius:6px;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;padding:.3rem;border:2px solid;position:relative;overflow:hidden}
  .cs-item-img{width:65px;height:48px;object-fit:contain;margin-bottom:.15rem}
  .cs-item-placeholder{width:50px;height:38px;display:flex;align-items:center;justify-content:center;font-size:1.4rem;margin-bottom:.1rem;opacity:.7}
  .cs-item.mil-spec{background:rgba(75,105,255,.08);border-color:rgba(75,105,255,.4)}
  .cs-item.restricted{background:rgba(136,71,255,.08);border-color:rgba(136,71,255,.4)}
  .cs-item.classified{background:rgba(211,44,230,.08);border-color:rgba(211,44,230,.4)}
  .cs-item.covert{background:rgba(46,204,113,.08);border-color:rgba(46,204,113,.4)}
  .cs-item.special{background:rgba(228,174,57,.08);border-color:#e4ae39}
  .cs-item.special.winner{border-color:#ffd700!important;animation:goldPulse 1s ease-in-out infinite alternate!important}
  @keyframes goldPulse{from{box-shadow:0 0 20px rgba(228,174,57,.4)}to{box-shadow:0 0 35px rgba(255,215,0,.6)}}
  .cs-item-weapon{font-weight:700;font-size:.7rem;color:var(--text);margin-bottom:.15rem}
  .cs-item-skin{font-size:.6rem;color:var(--text2);line-height:1.2}
  .cs-item.winner{border-color:#2ecc71!important;animation:winPulse 1s ease-in-out infinite alternate}
  @keyframes winPulse{from{box-shadow:0 0 15px rgba(46,204,113,.3)}to{box-shadow:0 0 30px rgba(46,204,113,.6)}}

  /* ── Results ───────────────────────────────────────────── */
  .cs-result{display:flex;flex-wrap:wrap;gap:.75rem;justify-content:center;padding:.75rem 0}
  .cs-result-card{border:2px solid;border-radius:6px;padding:1rem 1.25rem;text-align:center;min-width:160px;background:var(--bg3);animation:resultPop .4s cubic-bezier(.34,1.56,.64,1)}
  @keyframes resultPop{from{opacity:0;transform:scale(.85)}to{opacity:1;transform:scale(1)}}
  .cs-result-card.mil-spec{border-color:#4b69ff}
  .cs-result-card.restricted{border-color:#8847ff}
  .cs-result-card.classified{border-color:#d32ce6}
  .cs-result-card.covert{border-color:#2ecc71}
  .cs-result-card.special{border-color:#ffd700;background:rgba(228,174,57,.06);position:relative;overflow:hidden}
  .cs-result-card.special::before{content:'';position:absolute;top:-50%;left:-50%;width:200%;height:200%;background:conic-gradient(from 0deg,transparent,rgba(255,215,0,.06),transparent,rgba(228,174,57,.06),transparent);animation:goldSpin 4s linear infinite}
  @keyframes goldSpin{from{transform:rotate(0deg)}to{transform:rotate(360deg)}}
  .cs-result-img{width:80px;height:60px;object-fit:contain;margin:.4rem 0}
  .cs-result-rarity{font-size:.65rem;font-weight:700;text-transform:uppercase;letter-spacing:.06em;margin-bottom:.3rem}
  .cs-result-rarity.mil-spec{color:#4b69ff}.cs-result-rarity.restricted{color:#8847ff}.cs-result-rarity.classified{color:#d32ce6}.cs-result-rarity.covert{color:#2ecc71}.cs-result-rarity.special{color:#e4ae39}
  .cs-result-weapon{font-size:1rem;font-weight:800;color:var(--text);margin-bottom:.15rem}
  .cs-result-skin{font-size:.85rem;color:var(--text2)}
  .cs-result-price{font-size:.85rem;font-weight:700;margin-top:.3rem}
  .cs-result-price.profit{color:#4ade80}
  .cs-result-price.loss{color:#ef4444}
  .cs-result-price.neutral{color:var(--text2)}

  /* ── Stats bar ─────────────────────────────────────────── */
  .cs-statsbar{display:flex;align-items:center;gap:.75rem;padding:.6rem 1rem;background:var(--bg2);border:1px solid var(--border);border-radius:6px;flex-wrap:wrap;margin:.5rem 0}
  .cs-sb-item{display:flex;flex-direction:column;align-items:center;gap:.1rem;min-width:55px}
  .cs-sb-val{font-size:.95rem;font-weight:800;color:#2ecc71}
  .cs-sb-lbl{font-size:.6rem;color:var(--text2);text-transform:uppercase;letter-spacing:.04em}
  .cs-sb-profit .cs-sb-val.profit{color:#4ade80}
  .cs-sb-profit .cs-sb-val.loss{color:#ef4444}
  .cs-sb-profit .cs-sb-val.neutral{color:var(--text2)}
  .cs-sb-rarity{display:flex;gap:.5rem;margin-left:auto;align-items:center}
  .cs-sb-rarity span{display:flex;align-items:center;gap:.2rem;font-size:.75rem;color:var(--text2)}
  .cs-sb-rarity b{font-weight:700;color:var(--text)}
  .cs-reset-btn{background:var(--bg3);border:1px solid var(--border);color:var(--text2);border-radius:4px;padding:.35rem .75rem;font-size:.75rem;cursor:pointer;font-family:inherit;transition:all .15s;margin-left:.5rem}
  .cs-reset-btn:hover{border-color:#2ecc71;color:#2ecc71}

  /* ── Pulls row ─────────────────────────────────────────── */
  .cs-pulls-row{display:grid;grid-template-columns:1fr 2fr;gap:.75rem;margin:.5rem 0}
  .cs-pull-box{background:var(--bg2);border:1px solid var(--border);border-radius:6px;padding:.75rem}
  .cs-pull-box h4{font-size:.8rem;color:var(--text);margin:0 0 .5rem;font-weight:700}
  .cs-empty{color:var(--text2);font-size:.8rem;margin:0;text-align:center}
  .cs-pull-recent{max-height:140px;overflow-y:auto}
  .cs-pull-recent::-webkit-scrollbar{width:3px}
  .cs-pull-recent::-webkit-scrollbar-thumb{background:var(--border);border-radius:3px}
  .cs-recent-item{font-size:.75rem;padding:.25rem 0;border-bottom:1px solid var(--border);display:flex;justify-content:space-between}
  .cs-recent-item:last-child{border:none}
  .bp-rarity{font-size:.6rem;font-weight:700;text-transform:uppercase;letter-spacing:.05em;margin-bottom:.15rem}
  .bp-weapon{font-size:.85rem;font-weight:700;color:var(--text)}
  .bp-skin{font-size:.7rem;color:var(--text2)}

  /* ── Case contents ─────────────────────────────────────── */
  .cs-contents{margin:.5rem 0}
  .cs-contents h4{font-size:.85rem;color:var(--text);margin:0 0 .5rem;font-weight:700}
  .cs-contents-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(140px,1fr));gap:.4rem}
  .cs-content-item{background:var(--bg3);border-radius:4px;padding:.4rem .55rem;font-size:.7rem;display:flex;align-items:center;gap:.4rem;border-left:3px solid}
  .cs-content-item.mil-spec{border-left-color:#4b69ff}
  .cs-content-item.restricted{border-left-color:#8847ff}
  .cs-content-item.classified{border-left-color:#d32ce6}
  .cs-content-item.covert{border-left-color:#2ecc71}
  .cs-content-item .ci-img{width:32px;height:24px;object-fit:contain;flex-shrink:0}
  .cs-content-item .ci-weapon{font-weight:600;color:var(--text);white-space:nowrap}
  .cs-content-item .ci-skin{color:var(--text2)}
  .cs-content-item .ci-price{color:#2ecc71;font-weight:600;font-size:.65rem;margin-left:auto;white-space:nowrap}

  /* ── CTA Block ─────────────────────────────────────────── */
  .cs-cta-block{background:var(--bg2);border:1px solid var(--border);border-left:3px solid #2ecc71;border-radius:6px;margin:1.5rem 0;overflow:hidden}
  .cs-cta-inner{display:flex;align-items:center;gap:1rem;padding:1rem 1.5rem;flex-wrap:wrap}
  .cs-cta-text{flex:1;min-width:200px}
  .cs-cta-text strong{display:block;color:var(--text);font-size:.95rem}
  .cs-cta-text span{color:#2ecc71;font-size:.82rem;font-weight:600}
  .cs-cta-btn{display:inline-flex;align-items:center;padding:.55rem 1.25rem;background:#2ecc71;color:#fff;border-radius:20px;font-weight:800;font-size:.85rem;text-decoration:none;white-space:nowrap;transition:background .15s}
  .cs-cta-btn:hover{background:#27ae60}

  /* ── Responsive ────────────────────────────────────────── */
  @media(max-width:768px){
    .cs-grid{grid-template-columns:repeat(auto-fill,minmax(150px,1fr))}
    .cs-topbar{gap:.5rem}
    .cs-open-btn{padding:.5rem 1.5rem;font-size:.9rem}
    .cs-pulls-row{grid-template-columns:1fr}
    .cs-hero-top{flex-direction:column}
  }
  @media(max-width:480px){
    .cs-grid{grid-template-columns:1fr 1fr;gap:.5rem}
    .cs-card{padding:.75rem}
    .cs-item{width:90px;height:90px}
    .cs-roulette{height:110px}
    .cs-statsbar{gap:.4rem;padding:.5rem .6rem}
    .cs-sb-item{min-width:45px}
    .cs-sb-val{font-size:.8rem}
    .cs-contents-grid{grid-template-columns:1fr 1fr}
  }
</style>

<script define:vars={{ casesJson }}>
  const cases = JSON.parse(casesJson);

  // State
  let currentCase = null;
  let spinCount = 1;
  let isSpinning = false;
  let stats = { opened: 0, spent: 0, value: 0, milspec: 0, restricted: 0, classified: 0, covert: 0, special: 0, bestPull: null, recent: [] };
  let skinPrices = {};

  // DOM refs
  const selectState = document.getElementById('selectState');
  const openState = document.getElementById('openState');
  const caseGrid = document.getElementById('caseGrid');
  const caseNameEl = document.getElementById('caseName');
  const casePriceEl = document.getElementById('casePrice');
  const reelsContainer = document.getElementById('reelsContainer');
  const openBtn = document.getElementById('openBtn');
  const resultArea = document.getElementById('resultArea');
  const caseContentsEl = document.getElementById('caseContents');

  const ITEM_W = 110;
  const ITEM_W_MULTI = 85;
  const GAP = 8;
  const STRIP_COUNT = 70;
  const WINNER_INDEX = 55;

  const rarityOrder = { 'mil-spec': 0, 'restricted': 1, 'classified': 2, 'covert': 3, 'special': 4 };
  const rarityColors = { 'mil-spec': '#4b69ff', 'restricted': '#8847ff', 'classified': '#d32ce6', 'covert': '#2ecc71', 'special': '#e4ae39' };

  function normalizeKey(weapon, name) {
    return `${weapon}|${name}`.toLowerCase().replace(/[^a-z0-9|]/g, '');
  }

  function getItemImgHtml(skin, imgClass) {
    if (skin.image) {
      return `<img class="${imgClass}" src="${skin.image}" alt="${skin.weapon} ${skin.name}" loading="lazy" onerror="this.remove()">`;
    }
    if (skin.rarity === 'special') return `<div class="cs-item-placeholder">🔪</div>`;
    return '';
  }

  function getSkinPrice(skin) {
    const key1 = `${skin.weapon}|${skin.name}`.toLowerCase();
    if (skinPrices[key1]) return skinPrices[key1];
    const key2 = normalizeKey(skin.weapon, skin.name);
    if (skinPrices[key2]) return skinPrices[key2];
    return null;
  }

  function formatPrice(cents) {
    if (!cents) return null;
    return '$' + (cents / 100).toFixed(2);
  }

  // ── Build case grid ──────────────────────────────────────
  Object.values(cases).forEach(c => {
    const el = document.createElement('div');
    el.className = 'cs-card';
    // Show up to 3 skin preview images
    const previewSkins = c.skins.filter(s => s.image).slice(0, 3);
    const previewHtml = previewSkins.length > 0
      ? previewSkins.map(s => `<img src="${s.image}" alt="" loading="lazy">`).join('')
      : `<span style="font-size:2rem;opacity:.3">📦</span>`;
    const knifeShort = c.knife.split('/')[0].trim();
    el.innerHTML = `
      <div class="cs-card-img">
        <div class="cs-card-img-items">${previewHtml}</div>
        <span class="cs-card-knife">🔪 ${knifeShort}</span>
      </div>
      <div class="cs-card-name">${c.name}</div>
      <div class="cs-card-meta">${c.year}</div>
      <div class="cs-card-price">$${c.keyPrice.toFixed(2)}</div>`;
    el.addEventListener('click', () => selectCase(c));
    caseGrid.appendChild(el);
  });

  // ── Select case ──────────────────────────────────────────
  function selectCase(c) {
    currentCase = c;
    selectState.classList.add('hidden');
    openState.classList.remove('hidden');
    caseNameEl.textContent = c.name;
    casePriceEl.textContent = `$${c.keyPrice.toFixed(2)} per open · ${c.knife}`;
    resultArea.classList.add('hidden');
    resultArea.innerHTML = '';
    resetReels();
    buildContents();
    openBtn.disabled = false;
  }

  // ── Build case contents ──────────────────────────────────
  function buildContents() {
    caseContentsEl.innerHTML = '';
    const sorted = [...currentCase.skins].sort((a, b) => rarityOrder[b.rarity] - rarityOrder[a.rarity]);
    sorted.forEach(s => {
      const el = document.createElement('div');
      el.className = `cs-content-item ${s.rarity}`;
      const imgHtml = s.image
        ? `<img class="ci-img" src="${s.image}" alt="" loading="lazy" onerror="this.style.display='none'">`
        : (s.rarity === 'special' ? '<span style="font-size:1rem;margin-right:.2rem">🔪</span>' : '');
      const price = getSkinPrice(s);
      const priceHtml = price ? `<span class="ci-price">${formatPrice(price)}</span>` : '';
      el.innerHTML = `${imgHtml}<span class="ci-weapon">${s.weapon}</span><span class="ci-skin">${s.name}</span>${priceHtml}`;
      caseContentsEl.appendChild(el);
    });
  }

  // ── Pick winner ──────────────────────────────────────────
  function pickWinner() {
    const rand = Math.random() * 100;
    let rarity;
    if (rand < 79.92) rarity = 'mil-spec';
    else if (rand < 95.90) rarity = 'restricted';
    else if (rand < 99.10) rarity = 'classified';
    else if (rand < 99.74) rarity = 'covert';
    else rarity = 'special';
    const pool = currentCase.skins.filter(s => s.rarity === rarity);
    if (pool.length === 0) {
      const fallback = currentCase.skins.filter(s => s.rarity === 'mil-spec');
      return fallback[Math.floor(Math.random() * fallback.length)];
    }
    return pool[Math.floor(Math.random() * pool.length)];
  }

  // ── Reel helpers ─────────────────────────────────────────
  function resetReels() {
    reelsContainer.classList.remove('multi');
    reelsContainer.innerHTML = `<div class="cs-roulette-wrap">
      <div class="cs-pointer"></div>
      <div class="cs-roulette"><div class="cs-strip"></div></div>
    </div>`;
    buildStripIn(reelsContainer.querySelector('.cs-strip'), null, false);
  }

  function buildStripIn(stripEl, winner, isMulti) {
    stripEl.innerHTML = '';
    stripEl.classList.remove('animating');
    stripEl.style.transform = 'translateX(0)';
    const weights = { 'mil-spec': 80, 'restricted': 16, 'classified': 3, 'covert': 1, 'special': 1 };
    const pool = [];
    currentCase.skins.forEach(s => { const w = weights[s.rarity] || 1; for (let i = 0; i < w; i++) pool.push(s); });
    for (let i = 0; i < STRIP_COUNT; i++) {
      let skin = (winner && i === WINNER_INDEX) ? winner : pool[Math.floor(Math.random() * pool.length)];
      const el = document.createElement('div');
      el.className = `cs-item ${skin.rarity}`;
      el.innerHTML = `${getItemImgHtml(skin, 'cs-item-img')}<div class="cs-item-weapon">${skin.weapon}</div><div class="cs-item-skin">${skin.name}</div>`;
      stripEl.appendChild(el);
    }
  }

  function animateStrip(stripEl, rouletteEl, isMulti) {
    return new Promise(resolve => {
      const itemW = isMulti ? ITEM_W_MULTI : ITEM_W;
      const itemTotal = itemW + GAP;
      const containerW = rouletteEl.offsetWidth;
      const stopX = (WINNER_INDEX * itemTotal) - (containerW / 2) + (itemW / 2) + (Math.random() * 40 - 20);
      void stripEl.offsetHeight;
      stripEl.classList.add('animating');
      stripEl.style.transform = `translateX(-${stopX}px)`;
      setTimeout(() => { if (stripEl.children[WINNER_INDEX]) stripEl.children[WINNER_INDEX].classList.add('winner'); resolve(); }, 4100);
    });
  }

  // ── Open case ────────────────────────────────────────────
  openBtn.addEventListener('click', async () => {
    if (isSpinning || !currentCase) return;
    isSpinning = true;
    openBtn.disabled = true;
    resultArea.classList.add('hidden');
    resultArea.innerHTML = '';

    const winners = [];
    for (let i = 0; i < spinCount; i++) winners.push(pickWinner());

    const isMulti = spinCount > 1;
    reelsContainer.classList.toggle('multi', isMulti);
    reelsContainer.innerHTML = '';
    const stripEls = [], rouletteEls = [];

    for (let i = 0; i < spinCount; i++) {
      const wrap = document.createElement('div');
      wrap.className = 'cs-roulette-wrap';
      wrap.innerHTML = `<div class="cs-pointer"></div><div class="cs-roulette"><div class="cs-strip"></div></div>${isMulti ? `<div class="cs-reel-label">#${i+1}</div>` : ''}`;
      reelsContainer.appendChild(wrap);
      const stripEl = wrap.querySelector('.cs-strip');
      const rouletteEl = wrap.querySelector('.cs-roulette');
      buildStripIn(stripEl, winners[i], isMulti);
      stripEls.push(stripEl);
      rouletteEls.push(rouletteEl);
    }

    const animPromises = stripEls.map((s, i) => new Promise(r => setTimeout(() => animateStrip(s, rouletteEls[i], isMulti).then(r), i * 150)));
    await Promise.all(animPromises);

    winners.forEach(w => {
      stats.opened++;
      stats.spent += currentCase.keyPrice;
      const price = getSkinPrice(w);
      if (price) stats.value += price / 100;
      const key = w.rarity === 'mil-spec' ? 'milspec' : w.rarity;
      stats[key] = (stats[key] || 0) + 1;
      if (!stats.bestPull || rarityOrder[w.rarity] > rarityOrder[stats.bestPull.rarity]) stats.bestPull = w;
      stats.recent.unshift({ ...w, price });
      if (stats.recent.length > 20) stats.recent.pop();
    });

    updateStats();
    showResults(winners);
    isSpinning = false;
    openBtn.disabled = false;
  });

  // ── Show results ─────────────────────────────────────────
  function showResults(winners) {
    resultArea.classList.remove('hidden');
    resultArea.innerHTML = winners.map(w => {
      const price = getSkinPrice(w);
      const priceDollars = price ? price / 100 : 0;
      const profit = priceDollars - currentCase.keyPrice;
      const priceClass = !price ? 'neutral' : profit >= 0 ? 'profit' : 'loss';
      const priceHtml = price ? `<div class="cs-result-price ${priceClass}">${formatPrice(price)} (${profit >= 0 ? '+' : ''}$${profit.toFixed(2)})</div>` : '';
      const rarityLabel = w.rarity === 'special' ? '🔪 Special' : w.rarity === 'mil-spec' ? 'Mil-Spec' : w.rarity.charAt(0).toUpperCase() + w.rarity.slice(1);
      return `<div class="cs-result-card ${w.rarity}"><div class="cs-result-rarity ${w.rarity}">${rarityLabel}</div>${getItemImgHtml(w, 'cs-result-img')}<div class="cs-result-weapon">${w.weapon}</div><div class="cs-result-skin">${w.name}</div>${priceHtml}</div>`;
    }).join('');
  }

  // ── Update stats ─────────────────────────────────────────
  function updateStats() {
    document.getElementById('statOpened').textContent = stats.opened;
    document.getElementById('statSpent').textContent = stats.spent.toFixed(2);
    document.getElementById('rMilspec').textContent = stats.milspec;
    document.getElementById('rRestricted').textContent = stats.restricted;
    document.getElementById('rClassified').textContent = stats.classified;
    document.getElementById('rCovert').textContent = stats.covert;
    document.getElementById('rSpecial').textContent = stats.special;

    const profit = stats.value - stats.spent;
    const profitEl = document.getElementById('statProfit');
    profitEl.textContent = `${profit >= 0 ? '+' : ''}$${profit.toFixed(2)}`;
    profitEl.className = `cs-sb-val ${profit >= 0 ? 'profit' : 'loss'}`;

    document.getElementById('statValue').textContent = stats.value.toFixed(2);
    const roi = stats.spent > 0 ? ((stats.value / stats.spent - 1) * 100).toFixed(1) : '0';
    document.getElementById('statROI').textContent = `${roi}%`;

    const bp = document.getElementById('bestPull');
    if (stats.bestPull) {
      const e = stats.bestPull.rarity === 'special' ? '🔪 ' : '';
      bp.innerHTML = `<div class="bp-rarity" style="color:${rarityColors[stats.bestPull.rarity]}">${e}${stats.bestPull.rarity}</div><div class="bp-weapon">${stats.bestPull.weapon}</div><div class="bp-skin">${stats.bestPull.name}</div>`;
    }

    const rp = document.getElementById('recentPulls');
    if (stats.recent.length) {
      rp.innerHTML = stats.recent.slice(0, 10).map(w => {
        const ps = w.price ? ` · ${formatPrice(w.price)}` : '';
        const e = w.rarity === 'special' ? '🔪 ' : '';
        return `<div class="cs-recent-item"><span style="color:${rarityColors[w.rarity]}">${e}${w.weapon}</span><span>${w.name}${ps}</span></div>`;
      }).join('');
    }
  }

  // ── Spin count buttons ───────────────────────────────────
  document.querySelectorAll('.cs-spin-count').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.cs-spin-count').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      spinCount = parseInt(btn.dataset.count);
    });
  });

  // ── Back button ──────────────────────────────────────────
  document.getElementById('backBtn').addEventListener('click', () => {
    currentCase = null;
    openState.classList.add('hidden');
    selectState.classList.remove('hidden');
  });

  // ── Reset ────────────────────────────────────────────────
  document.getElementById('resetBtn').addEventListener('click', () => {
    stats = { opened: 0, spent: 0, value: 0, milspec: 0, restricted: 0, classified: 0, covert: 0, special: 0, bestPull: null, recent: [] };
    updateStats();
    document.getElementById('statProfit').textContent = '$0.00';
    document.getElementById('statProfit').className = 'cs-sb-val neutral';
    document.getElementById('statValue').textContent = '0.00';
    document.getElementById('statROI').textContent = '0%';
    document.getElementById('bestPull').innerHTML = '<p class="cs-empty">No pulls yet</p>';
    document.getElementById('recentPulls').innerHTML = '<p class="cs-empty">No pulls yet</p>';
  });

  // ── Skin image + price fetching ──────────────────────────
  function stripWear(key) {
    return key.toLowerCase().replace(/^stattrak™?\s*/i, '').replace(/^souvenir\s*/i, '').replace(/\s*\([^)]+\)\s*$/, '').replace(/\s*\|\s*/g, '|');
  }

  (async function fetchSkinImages() {
    try {
      const res = await fetch('/api/skin-images');
      if (!res.ok) return;
      const data = await res.json();
      if (!data?.images) return;
      let enriched = 0;
      const baseSkinImages = {};
      for (const [k, v] of Object.entries(data.images)) {
        const bk = stripWear(k);
        if (!baseSkinImages[bk]) baseSkinImages[bk] = v;
        const nk = bk.replace(/[^a-z0-9|]/g, '');
        if (!baseSkinImages[nk]) baseSkinImages[nk] = v;
      }
      for (const c of Object.values(cases)) {
        for (const skin of c.skins) {
          if (!skin.image) {
            const k1 = `${skin.weapon}|${skin.name}`.toLowerCase();
            const k2 = normalizeKey(skin.weapon, skin.name);
            const img = baseSkinImages[k1] || baseSkinImages[k2];
            if (img) { skin.image = img; enriched++; }
          }
        }
      }
      if (enriched > 0 && currentCase) { buildContents(); resetReels(); }
    } catch (e) { /* optional */ }
  })();

  const RARITY_PRICES = { 'mil-spec': 15, 'restricted': 75, 'classified': 450, 'covert': 2500, 'special': 15000 };

  function applyFallbackPrices() {
    for (const c of Object.values(cases)) {
      for (const skin of c.skins) {
        const k1 = `${skin.weapon}|${skin.name}`.toLowerCase();
        const k2 = normalizeKey(skin.weapon, skin.name);
        if (!skinPrices[k1] && !skinPrices[k2]) {
          const est = RARITY_PRICES[skin.rarity] || 10;
          skinPrices[k1] = est;
          skinPrices[k2] = est;
        }
      }
    }
  }

  (async function fetchSkinPrices() {
    try {
      const res = await fetch('/api/skin-prices');
      if (!res.ok) { applyFallbackPrices(); if (currentCase) buildContents(); return; }
      const data = await res.json();
      if (!data?.prices || Object.keys(data.prices).length === 0) { applyFallbackPrices(); if (currentCase) buildContents(); return; }
      for (const [name, priceData] of Object.entries(data.prices)) {
        const baseKey = stripWear(name);
        const parts = baseKey.split('|');
        if (parts.length >= 2) {
          const k1 = parts.map(p => p.trim()).join('|');
          const k2 = k1.replace(/[^a-z0-9|]/g, '');
          const price = typeof priceData === 'number' ? priceData : (priceData.buff163 || priceData.steam || priceData.skinport || Object.values(priceData)[0] || 0);
          if (price > 0 && (!skinPrices[k1] || price < skinPrices[k1])) { skinPrices[k1] = price; skinPrices[k2] = price; }
        }
      }
      applyFallbackPrices();
      if (currentCase) buildContents();
    } catch (e) { applyFallbackPrices(); if (currentCase) buildContents(); }
  })();
</script>
