  .cs-img-placeholder.restricted{background:rgba(136,71,255,.15)}
  .cs-img-placeholder.classified{background:rgba(211,44,230,.15)}
  .cs-img-placeholder.covert{background:rgba(46,204,113,.15)}
  .cs-gold-emblem{width:50px;height:50px;margin-bottom:.1rem}
  .cs-result-gold-emblem{width:70px;height:70px;margin:.3rem 0}
  .cs-contents-gold-emblem{width:24px;height:24px;flex-shrink:0}
  .cs-item.consumer{background:rgba(176,195,217,.08);border-color:rgba(176,195,217,.4)}
  .cs-item.industrial{background:rgba(94,152,217,.08);border-color:rgba(94,152,217,.4)}
  .cs-item.mil-spec{background:rgba(75,105,255,.08);border-color:rgba(75,105,255,.4)}
  .cs-item.restricted{background:rgba(136,71,255,.08);border-color:rgba(136,71,255,.4)}
  .cs-item.classified{background:rgba(211,44,230,.08);border-color:rgba(211,44,230,.4)}
  .cs-item.covert{background:rgba(46,204,113,.08);border-color:rgba(46,204,113,.4)}
  .cs-item.special{background:rgba(228,174,57,.08);border-color:#e4ae39}
  .cs-item.special.winner{border-color:#ffd700!important;animation:goldPulse 1s ease-in-out infinite alternate!important}
  @keyframes goldPulse{from{box-shadow:0 0 20px rgba(228,174,57,.4)}to{box-shadow:0 0 35px rgba(255,215,0,.6)}}
  .cs-item-weapon{font-weight:700;font-size:.7rem;color:var(--text);margin-bottom:.15rem}
  .cs-item-skin{font-size:.6rem;color:var(--text2);line-height:1.2}
  .cs-item.winner{border-color:#2ecc71!important;animation:winPulse 1s ease-in-out infinite alternate}
  @keyframes winPulse{from{box-shadow:0 0 15px rgba(46,204,113,.3)}to{box-shadow:0 0 30px rgba(46,204,113,.6)}}

  /* ── Results ───────────────────────────────────────────── */
  .cs-result{display:flex;flex-wrap:wrap;gap:.75rem;justify-content:center;padding:.75rem 0}
  .cs-result-card{border:2px solid;border-radius:6px;padding:1rem 1.25rem;text-align:center;min-width:160px;background:var(--bg3);animation:resultPop .4s cubic-bezier(.34,1.56,.64,1)}
  @keyframes resultPop{from{opacity:0;transform:scale(.85)}to{opacity:1;transform:scale(1)}}
  .cs-result-card.consumer{border-color:#b0c3d9}
  .cs-result-card.industrial{border-color:#5e98d9}
  .cs-result-card.mil-spec{border-color:#4b69ff}
  .cs-result-card.restricted{border-color:#8847ff}
  .cs-result-card.classified{border-color:#d32ce6}
  .cs-result-card.covert{border-color:#2ecc71}
  .cs-result-card.special{border-color:#ffd700;background:rgba(228,174,57,.06);position:relative;overflow:hidden}
  .cs-result-card.special::before{content:'';position:absolute;top:-50%;left:-50%;width:200%;height:200%;background:conic-gradient(from 0deg,transparent,rgba(255,215,0,.06),transparent,rgba(228,174,57,.06),transparent);animation:goldSpin 4s linear infinite}
  @keyframes goldSpin{from{transform:rotate(0deg)}to{transform:rotate(360deg)}}
  .cs-result-img{width:80px;height:60px;object-fit:contain;margin:.4rem 0}
  .cs-result-rarity{font-size:.65rem;font-weight:700;text-transform:uppercase;letter-spacing:.06em;margin-bottom:.3rem}
  .cs-result-rarity.consumer{color:#b0c3d9}.cs-result-rarity.industrial{color:#5e98d9}.cs-result-rarity.mil-spec{color:#4b69ff}.cs-result-rarity.restricted{color:#8847ff}.cs-result-rarity.classified{color:#d32ce6}.cs-result-rarity.covert{color:#2ecc71}.cs-result-rarity.special{color:#e4ae39}
  .cs-result-weapon{font-size:1rem;font-weight:800;color:var(--text);margin-bottom:.15rem}
