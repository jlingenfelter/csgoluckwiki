  .cta-popup-viewport{width:100%;height:75px;overflow:hidden;position:relative;border:2px solid var(--border);border-radius:5px;background:var(--bg2)}
  .cta-popup-viewport::before,.cta-popup-viewport::after{content:'';position:absolute;top:0;bottom:0;width:50px;z-index:3;pointer-events:none}
  .cta-popup-viewport::before{left:0;background:linear-gradient(to right,#13141a,transparent)}
  .cta-popup-viewport::after{right:0;background:linear-gradient(to left,#13141a,transparent)}
  .cta-popup-center-line{position:absolute;top:0;bottom:0;left:50%;width:2px;background:#ffd700;z-index:4;transform:translateX(-50%);box-shadow:0 0 8px rgba(255,215,0,.3)}
  .cta-popup-strip{display:flex;position:absolute;top:0;left:0;height:100%;will-change:transform}
  .cta-popup-open-overlay{position:absolute;inset:0;z-index:10;display:flex;align-items:center;justify-content:center;background:rgba(0,0,0,.5);border-radius:5px;cursor:pointer;transition:background .2s}
  .cta-popup-open-overlay:hover{background:rgba(0,0,0,.35)}
  .cta-popup-open-overlay.hidden{display:none}
  .cta-popup-open-btn{background:linear-gradient(135deg,#ffd700,#ffaa00);color:#000;font-family:'Montserrat',sans-serif;font-weight:900;font-size:.95rem;text-transform:uppercase;letter-spacing:.05em;padding:.5rem 2rem;border:none;border-radius:5px;cursor:pointer;box-shadow:0 3px 15px rgba(255,215,0,.4)}
  .cta-popup-open-btn:hover{transform:scale(1.05)}
  .cta-popup-item{width:85px;height:75px;flex-shrink:0;display:flex;flex-direction:column;align-items:center;justify-content:center;border-right:1px solid rgba(255,255,255,.05);position:relative;overflow:hidden;gap:2px}
  .cta-popup-item::after{content:'';position:absolute;bottom:0;left:0;right:0;height:3px}
  .cta-popup-item[data-r="consumer"]{background:linear-gradient(180deg,transparent 50%,rgba(176,195,217,.06))}.cta-popup-item[data-r="consumer"]::after{background:#b0c3d9}
  .cta-popup-item[data-r="industrial"]{background:linear-gradient(180deg,transparent 50%,rgba(94,152,217,.06))}.cta-popup-item[data-r="industrial"]::after{background:#5e98d9}
  .cta-popup-item[data-r="milspec"]{background:linear-gradient(180deg,transparent 50%,rgba(75,105,255,.06))}.cta-popup-item[data-r="milspec"]::after{background:#4b69ff}
  .cta-popup-item[data-r="restricted"]{background:linear-gradient(180deg,transparent 50%,rgba(136,71,255,.08))}.cta-popup-item[data-r="restricted"]::after{background:#8847ff}
  .cta-popup-item[data-r="classified"]{background:linear-gradient(180deg,transparent 50%,rgba(211,44,230,.08))}.cta-popup-item[data-r="classified"]::after{background:#d32ce6}
  .cta-popup-item[data-r="covert"]{background:linear-gradient(180deg,transparent 50%,rgba(235,75,75,.1))}.cta-popup-item[data-r="covert"]::after{background:#eb4b4b}
  .cta-popup-item[data-r="gold"]{background:linear-gradient(180deg,rgba(255,215,0,.04),rgba(255,215,0,.12))}.cta-popup-item[data-r="gold"]::after{background:#ffd700;height:4px;box-shadow:0 0 10px rgba(255,215,0,.6)}
  .cta-popup-item-img{width:50px;height:38px;object-fit:contain;filter:drop-shadow(0 1px 3px rgba(0,0,0,.5))}
  .cta-popup-item-label{font-size:.45rem;text-transform:uppercase;letter-spacing:.02em;opacity:.5;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:80px}
  .cta-popup-item[data-r="gold"] .cta-popup-item-label{color:#ffd700;opacity:1;font-weight:800;font-size:.5rem}
  .cta-popup-gold-emblem{width:48px;height:48px}
  .cta-popup-reveal{text-align:center;margin-bottom:.75rem;animation:popupIn .4s ease}
  .cta-popup-reveal.hidden{display:none}
  .cta-popup-prize{background:linear-gradient(135deg,#1a1400,#2a2000,#1a1400);border:1px solid #ffd700;border-radius:6px;padding:1rem;position:relative;overflow:hidden}
  .cta-popup-prize::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at center,rgba(255,215,0,.08),transparent 70%);pointer-events:none}
  .cta-popup-prize-badge{display:inline-block;background:#ffd700;color:#000;font-weight:800;font-size:.55rem;text-transform:uppercase;letter-spacing:.06em;padding:.2rem .5rem;border-radius:3px;margin-bottom:.4rem}
  .cta-popup-prize-title{font-size:1.2rem;font-weight:900;color:#ffd700;text-shadow:0 0 20px rgba(255,215,0,.3)}
  .cta-popup-prize-plus{font-size:.8rem;color:#ffd700;font-weight:700}
  .cta-popup-cta{display:inline-block;background:linear-gradient(135deg,#ffd700,#ffaa00);color:#000;font-weight:800;font-size:.9rem;text-transform:uppercase;letter-spacing:.04em;padding:.65rem 2rem;border-radius:5px;text-decoration:none;transition:transform .15s,box-shadow .15s;box-shadow:0 4px 18px rgba(255,215,0,.35);margin-bottom:.5rem}
  .cta-popup-cta:hover{transform:translateY(-2px);box-shadow:0 6px 25px rgba(255,215,0,.5)}
