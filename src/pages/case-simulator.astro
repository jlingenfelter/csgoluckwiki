</style>

<script define:vars={{ casesJson, buffPriceMapJson }}>
  const cases = JSON.parse(casesJson);

  // State
  let currentCase = null;
  let spinCount = 1;
  let isSpinning = false;
  let stats = { opened: 0, spent: 0, value: 0, milspec: 0, restricted: 0, classified: 0, covert: 0, special: 0, bestPull: null, recent: [] };
  let skinPrices = JSON.parse(buffPriceMapJson || '{}');

  // DOM refs
  const selectState = document.getElementById('selectState');
  const openState = document.getElementById('openState');
  const caseGrid = document.getElementById('caseGrid');
  const caseNameEl = document.getElementById('caseName');
  const casePriceEl = document.getElementById('casePrice');
  const reelsContainer = document.getElementById('reelsContainer');
  const openBtn = document.getElementById('openBtn');
  const resultArea = document.getElementById('resultArea');
  const caseContentsEl = document.getElementById('caseContents');

  const ITEM_W = 110;
  const ITEM_W_MULTI = 85;
  const GAP = 8;
  const STRIP_COUNT = 70;
  const WINNER_INDEX = 55;

  const rarityOrder = { 'mil-spec': 0, 'restricted': 1, 'classified': 2, 'covert': 3, 'special': 4 };
  const rarityColors = { 'mil-spec': '#4b69ff', 'restricted': '#8847ff', 'classified': '#d32ce6', 'covert': '#2ecc71', 'special': '#e4ae39' };

  function normalizeKey(weapon, name) {
    return `${weapon}|${name}`.toLowerCase().replace(/[^a-z0-9|]/g, '');
  }

  // Gold emblem SVG from template
  const goldEmblemSvg = document.getElementById('goldEmblemTpl')?.innerHTML || '';

  function getItemImgHtml(skin, imgClass) {
    if (skin.image) {
      return `<img class="${imgClass}" src="${skin.image}" alt="${skin.weapon} ${skin.name}" loading="lazy" onerror="this.style.display='none'">`;
    }
    if (skin.rarity === 'special') return goldEmblemSvg;
    return `<span class="cs-img-placeholder ${skin.rarity}">${skin.weapon.charAt(0)}</span>`;
  }

  function getSkinPrice(skin) {
    // Check direct price first (sticker/music items have it)
    if (skin.price && skin.price > 0) return skin.price;
    const key1 = `${skin.weapon}|${skin.name}`.toLowerCase();
    if (skinPrices[key1]) return skinPrices[key1];
    const key2 = normalizeKey(skin.weapon, skin.name);
    if (skinPrices[key2]) return skinPrices[key2];
    return null;
  }

  function formatPrice(cents) {
    if (!cents) return null;
    return '$' + (cents / 100).toFixed(2);
  }

  // ── Build case grid ──────────────────────────────────────
  const weaponCases = Object.values(cases).filter(c => !c.isSouvenir && !c.isContainer);
  const souvenirCases = Object.values(cases).filter(c => c.isSouvenir);
  const stickerCases = Object.values(cases).filter(c => c.containerType === 'sticker');
  const autographCases = Object.values(cases).filter(c => c.containerType === 'autograph');
  const musicCases = Object.values(cases).filter(c => c.containerType === 'music');

  // Sticker data cache (loaded lazily)
  let stickerDataCache = null;
  async function loadStickerData() {
    if (stickerDataCache) return stickerDataCache;
    try {
      const res = await fetch('/data/sticker-data.json');
      if (res.ok) stickerDataCache = await res.json();
    } catch (e) { /* optional */ }
    return stickerDataCache;
  }

  // Category tabs & grids
  const categories = [
    { key: 'weapon', label: 'Weapon Cases', items: weaponCases },
    { key: 'souvenir', label: 'Souvenir Packages', items: souvenirCases },
    { key: 'sticker', label: 'Sticker Capsules', items: stickerCases },
    { key: 'autograph', label: 'Autographs', items: autographCases },
    { key: 'music', label: 'Music Kits', items: musicCases },
  ].filter(cat => cat.items.length > 0);

  const grids = {};
  const tabRow = document.createElement('div');
  tabRow.className = 'cs-sim-tabs';
  tabRow.innerHTML = categories.map((cat, i) =>
    `<button class="cs-sim-tab${i === 0 ? ' cs-sim-tab-active' : ''}" data-cat="${cat.key}">${cat.label} (${cat.items.length})</button>`
  ).join('');
  caseGrid.parentNode.insertBefore(tabRow, caseGrid);

  // Create grids for each category (weapon cases reuse caseGrid)
  grids['weapon'] = caseGrid;
  for (const cat of categories) {
    if (cat.key === 'weapon') continue;
    const grid = document.createElement('div');
    grid.className = 'cs-grid';
    grid.id = `${cat.key}Grid`;
    grid.style.display = 'none';
    caseGrid.parentNode.insertBefore(grid, caseGrid.nextSibling);
    grids[cat.key] = grid;
  }

  tabRow.addEventListener('click', e => {
    const btn = e.target.closest('.cs-sim-tab');
    if (!btn) return;
    tabRow.querySelectorAll('.cs-sim-tab').forEach(t => t.classList.remove('cs-sim-tab-active'));
    btn.classList.add('cs-sim-tab-active');
    const cat = btn.dataset.cat;
    for (const [key, grid] of Object.entries(grids)) {
      grid.style.display = key === cat ? 'grid' : 'none';
    }
  });

  function buildContainerCard(c, gridEl) {
    const el = document.createElement('div');
    el.className = `cs-card cs-card-${c.containerType || 'souvenir'}`;
    const imgHtml = c.image
      ? `<img src="${c.image}" alt="${c.name}" loading="lazy" class="cs-card-case-img">`
      : `<span class="cs-card-map">${c.tournament || c.name.charAt(0)}</span>`;
    const priceText = c.totalCost > 0 ? `$${c.totalCost.toFixed(2)}` : '';
    const meta = c.isSouvenir
      ? `${c.tournament || c.year} &middot; ${c.skins.length} skins`
      : (c.tournament || (c.year > 0 ? c.year : ''));
    el.innerHTML = `
      <div class="cs-card-img cs-card-img-${c.containerType || 'souvenir'}">
        ${imgHtml}
      </div>
      <div class="cs-card-name">${c.name}</div>
      ${meta ? `<div class="cs-card-meta">${meta}</div>` : ''}
      ${priceText ? `<div class="cs-card-price">${priceText}</div>` : ''}`;
    el.addEventListener('click', () => selectCase(c));
    gridEl.appendChild(el);
  }

  // Build souvenir grid
  souvenirCases.sort((a, b) => b.year - a.year || a.name.localeCompare(b.name));
  souvenirCases.forEach(c => buildContainerCard(c, grids['souvenir']));

  // Build sticker capsule grid
  if (grids['sticker']) {
    stickerCases.sort((a, b) => (b.year || 0) - (a.year || 0) || a.name.localeCompare(b.name));
    stickerCases.forEach(c => buildContainerCard(c, grids['sticker']));
  }

  // Build autograph grid
  if (grids['autograph']) {
    autographCases.sort((a, b) => (b.year || 0) - (a.year || 0) || a.name.localeCompare(b.name));
    autographCases.forEach(c => buildContainerCard(c, grids['autograph']));
  }

  // Build music kit grid
  if (grids['music']) {
    musicCases.sort((a, b) => a.name.localeCompare(b.name));
    musicCases.forEach(c => buildContainerCard(c, grids['music']));
  }

  // Build weapon cases grid
  weaponCases.forEach(c => {
    const el = document.createElement('div');
    el.className = 'cs-card';
    const caseImgHtml = c.image
      ? `<img src="${c.image}" alt="${c.name}" loading="lazy" class="cs-card-case-img">`
      : `<span style="font-size:2.5rem;opacity:.3">📦</span>`;
    el.innerHTML = `
      <div class="cs-card-img">
        ${caseImgHtml}
      </div>
      <div class="cs-card-name">${c.name}</div>
      <div class="cs-card-meta">${c.year}</div>
      <div class="cs-card-price">$${c.totalCost.toFixed(2)}</div>`;
    el.addEventListener('click', () => selectCase(c));
    caseGrid.appendChild(el);
  });

  // ── Select case ──────────────────────────────────────────
  async function selectCase(c) {
    currentCase = c;
    selectState.classList.add('hidden');
    openState.classList.remove('hidden');
    caseNameEl.textContent = c.name;

    // Build info text based on container type
    let infoText;
    if (c.isContainer) {
      infoText = c.totalCost > 0 ? `$${c.totalCost.toFixed(2)} per open` : '';
      if (c.tournament) infoText += (infoText ? ' · ' : '') + c.tournament;
    } else if (c.isSouvenir) {
      infoText = `${c.totalCost > 0 ? '$' + c.totalCost.toFixed(2) : 'Free to open'} · ${c.collection || c.tournament || ''}`;
    } else {
      infoText = `$${c.totalCost.toFixed(2)} per open · ${c.knife}`;
    }
    casePriceEl.textContent = infoText;

    // Lazy-load sticker/autograph/music kit items if needed
    if (c.isContainer && c.skins.length === 0) {
      openBtn.disabled = true;
      casePriceEl.textContent = 'Loading items...';
      const stickerData = await loadStickerData();
      if (stickerData) {
        const poolKey = stickerData.map?.[c.id];
        const pool = poolKey ? stickerData.pools?.[poolKey] : null;
        // For music kits, try the _music pool directly
        const musicPool = c.containerType === 'music' ? stickerData.pools?.['_music'] : null;
        const items = pool || musicPool || [];
        c.skins = items.map(item => ({
          name: item.n,
          weapon: 'Sticker',
          rarity: item.r || 'mil-spec',
          price: item.p || 0,
          image: item.i || null,
        }));
        // Also add to skinPrices
        for (const item of items) {
          const key = `sticker|${item.n}`.toLowerCase();
          if (item.p > 0) skinPrices[key] = item.p;
        }
      }
      casePriceEl.textContent = infoText;
      openBtn.disabled = false;
    }

    resultArea.classList.add('hidden');
    resultArea.innerHTML = '';
    resetReels();
    buildContents();
    openBtn.disabled = c.skins.length === 0;
    if (c.skins.length === 0) casePriceEl.textContent = 'No items available';
  }

  // ── Build case contents ──────────────────────────────────
  function buildContents() {
    caseContentsEl.innerHTML = '';
    const sorted = [...currentCase.skins].sort((a, b) => rarityOrder[b.rarity] - rarityOrder[a.rarity]);
    sorted.forEach(s => {
      const el = document.createElement('div');
      el.className = `cs-content-item ${s.rarity}`;
      const imgHtml = s.image
        ? `<img class="ci-img" src="${s.image}" alt="" loading="lazy" onerror="this.style.display='none'">`
        : (s.rarity === 'special' ? goldEmblemSvg.replace('cs-gold-emblem', 'cs-contents-gold-emblem') : '');
      const price = getSkinPrice(s);
      const priceHtml = price ? `<span class="ci-price">${formatPrice(price)}</span>` : '';
      el.innerHTML = `${imgHtml}<span class="ci-weapon">${s.weapon}</span><span class="ci-skin">${s.name}</span>${priceHtml}`;
      caseContentsEl.appendChild(el);
    });
  }

  // ── Pick winner ──────────────────────────────────────────
  function pickWinner() {
    const rand = Math.random() * 100;
    let rarity;

    if (currentCase.isSouvenir) {
      // Souvenir package odds: Consumer 80%, Industrial 16%, Mil-Spec 3.2%, Restricted 0.64%, Classified 0.128%, Covert 0.0256%
      if (rand < 80.0) rarity = 'consumer';
      else if (rand < 96.0) rarity = 'industrial';
      else if (rand < 99.2) rarity = 'mil-spec';
      else if (rand < 99.84) rarity = 'restricted';
      else if (rand < 99.968) rarity = 'classified';
      else rarity = 'covert';
    } else if (currentCase.isContainer) {
      // Sticker/autograph/music capsule odds: Base 79.92%, Restricted/Shimmer 15.98%, Classified/Embroidered 3.2%, Covert/Holo 0.64%, Gold 0.26%
      if (rand < 79.92) rarity = 'mil-spec';
      else if (rand < 95.90) rarity = 'restricted';
      else if (rand < 99.10) rarity = 'classified';
      else if (rand < 99.74) rarity = 'covert';
      else rarity = 'special';
    } else {
      // Standard weapon case odds
      if (rand < 79.92) rarity = 'mil-spec';
      else if (rand < 95.90) rarity = 'restricted';
      else if (rand < 99.10) rarity = 'classified';
      else if (rand < 99.74) rarity = 'covert';
      else rarity = 'special';
    }

    const pool = currentCase.skins.filter(s => s.rarity === rarity);
    if (pool.length === 0) {
      // Fallback: try common rarity first, then any available
      const fallbackRarity = currentCase.isSouvenir ? 'consumer' : 'mil-spec';
      const fallback = currentCase.skins.filter(s => s.rarity === fallbackRarity);
      if (fallback.length > 0) return fallback[Math.floor(Math.random() * fallback.length)];
      // Last resort: pick any skin
      return currentCase.skins[Math.floor(Math.random() * currentCase.skins.length)];
    }
    return pool[Math.floor(Math.random() * pool.length)];
  }

  // ── Reel helpers ─────────────────────────────────────────
  function resetReels() {
    reelsContainer.classList.remove('multi');
    reelsContainer.innerHTML = `<div class="cs-roulette-wrap">
      <div class="cs-pointer"></div>
      <div class="cs-roulette"><div class="cs-strip"></div></div>
    </div>`;
    buildStripIn(reelsContainer.querySelector('.cs-strip'), null, false);
  }

  function buildStripIn(stripEl, winner, isMulti) {
    stripEl.innerHTML = '';
    stripEl.classList.remove('animating');
    stripEl.style.transform = 'translateX(0)';
    const weights = currentCase.isSouvenir
      ? { 'consumer': 80, 'industrial': 16, 'mil-spec': 3, 'restricted': 1, 'classified': 1, 'covert': 1 }
      : { 'mil-spec': 80, 'restricted': 16, 'classified': 3, 'covert': 1, 'special': 1 };
    const pool = [];
    currentCase.skins.forEach(s => { const w = weights[s.rarity] || 1; for (let i = 0; i < w; i++) pool.push(s); });
    for (let i = 0; i < STRIP_COUNT; i++) {
      let skin = (winner && i === WINNER_INDEX) ? winner : pool[Math.floor(Math.random() * pool.length)];
      const el = document.createElement('div');
      el.className = `cs-item ${skin.rarity}`;
      el.innerHTML = `${getItemImgHtml(skin, 'cs-item-img')}<div class="cs-item-weapon">${skin.weapon}</div><div class="cs-item-skin">${skin.name}</div>`;
      stripEl.appendChild(el);
    }
  }

  function animateStrip(stripEl, rouletteEl, isMulti) {
    return new Promise(resolve => {
      const itemW = isMulti ? ITEM_W_MULTI : ITEM_W;
      const itemTotal = itemW + GAP;
      const containerW = rouletteEl.offsetWidth;
      const stopX = (WINNER_INDEX * itemTotal) - (containerW / 2) + (itemW / 2) + (Math.random() * 40 - 20);
      void stripEl.offsetHeight;
      stripEl.classList.add('animating');
      stripEl.style.transform = `translateX(-${stopX}px)`;
      setTimeout(() => { if (stripEl.children[WINNER_INDEX]) stripEl.children[WINNER_INDEX].classList.add('winner'); resolve(); }, 4100);
    });
  }

  // ── Open case ────────────────────────────────────────────
  openBtn.addEventListener('click', async () => {
    if (isSpinning || !currentCase) return;
    isSpinning = true;
    openBtn.disabled = true;
    resultArea.classList.add('hidden');
    resultArea.innerHTML = '';

    const winners = [];
    for (let i = 0; i < spinCount; i++) winners.push(pickWinner());

    const isMulti = spinCount > 1;
    reelsContainer.classList.toggle('multi', isMulti);
    reelsContainer.innerHTML = '';
    const stripEls = [], rouletteEls = [];

    for (let i = 0; i < spinCount; i++) {
      const wrap = document.createElement('div');
      wrap.className = 'cs-roulette-wrap';
      wrap.innerHTML = `<div class="cs-pointer"></div><div class="cs-roulette"><div class="cs-strip"></div></div>${isMulti ? `<div class="cs-reel-label">#${i+1}</div>` : ''}`;
      reelsContainer.appendChild(wrap);
      const stripEl = wrap.querySelector('.cs-strip');
      const rouletteEl = wrap.querySelector('.cs-roulette');
      buildStripIn(stripEl, winners[i], isMulti);
      stripEls.push(stripEl);
      rouletteEls.push(rouletteEl);
    }

    const animPromises = stripEls.map((s, i) => new Promise(r => setTimeout(() => animateStrip(s, rouletteEls[i], isMulti).then(r), i * 150)));
    await Promise.all(animPromises);

    // Confetti on gold/knife/glove win
    if (winners.some(w => w.rarity === 'special')) launchConfetti();

    winners.forEach(w => {
      stats.opened++;
      stats.spent += currentCase.totalCost;
      const price = getSkinPrice(w);
      if (price) stats.value += price / 100;
      const key = w.rarity === 'mil-spec' ? 'milspec' : w.rarity;
      stats[key] = (stats[key] || 0) + 1;
      if (!stats.bestPull || rarityOrder[w.rarity] > rarityOrder[stats.bestPull.rarity]) stats.bestPull = w;
      stats.recent.unshift({ ...w, price });
      if (stats.recent.length > 20) stats.recent.pop();
    });

    updateStats();
    showResults(winners);
    isSpinning = false;
    openBtn.disabled = false;
    // Check if we should show the CTA popup
    checkCtaPopup();
  });

  // ── Show results ─────────────────────────────────────────
  function showResults(winners) {
    resultArea.classList.remove('hidden');
    resultArea.innerHTML = winners.map(w => {
      const price = getSkinPrice(w);
      const priceDollars = price ? price / 100 : 0;
      const profit = priceDollars - currentCase.totalCost;
      const priceClass = !price ? 'neutral' : profit >= 0 ? 'profit' : 'loss';
      const priceHtml = price ? `<div class="cs-result-price ${priceClass}">${formatPrice(price)} (${profit >= 0 ? '+' : ''}$${profit.toFixed(2)})</div>` : '';
      const rarityLabel = w.rarity === 'special' ? '★ Special' : w.rarity === 'mil-spec' ? 'Mil-Spec' : w.rarity.charAt(0).toUpperCase() + w.rarity.slice(1);
      const resultImgHtml = w.rarity === 'special' && !w.image ? goldEmblemSvg.replace('cs-gold-emblem', 'cs-result-gold-emblem') : getItemImgHtml(w, 'cs-result-img');
      return `<div class="cs-result-card ${w.rarity}"><div class="cs-result-rarity ${w.rarity}">${rarityLabel}</div>${resultImgHtml}<div class="cs-result-weapon">${w.weapon}</div><div class="cs-result-skin">${w.name}</div>${priceHtml}</div>`;
    }).join('');
  }

  // ── Update stats ─────────────────────────────────────────
  function updateStats() {
    document.getElementById('statOpened').textContent = stats.opened;
    document.getElementById('statSpent').textContent = stats.spent.toFixed(2);
    document.getElementById('rMilspec').textContent = stats.milspec;
    document.getElementById('rRestricted').textContent = stats.restricted;
    document.getElementById('rClassified').textContent = stats.classified;
    document.getElementById('rCovert').textContent = stats.covert;
    document.getElementById('rSpecial').textContent = stats.special;

    const profit = stats.value - stats.spent;
    const profitEl = document.getElementById('statProfit');
    profitEl.textContent = `${profit >= 0 ? '+' : ''}$${profit.toFixed(2)}`;
    profitEl.className = `cs-ss-val ${profit >= 0 ? 'profit' : 'loss'}`;

    document.getElementById('statValue').textContent = stats.value.toFixed(2);
    const roi = stats.spent > 0 ? ((stats.value / stats.spent - 1) * 100).toFixed(1) : '0';
    document.getElementById('statROI').textContent = `${roi}%`;

    const bp = document.getElementById('bestPull');
    if (stats.bestPull) {
      const e = stats.bestPull.rarity === 'special' ? '★ ' : '';
      bp.innerHTML = `<div class="bp-rarity" style="color:${rarityColors[stats.bestPull.rarity]}">${e}${stats.bestPull.rarity}</div><div class="bp-weapon">${stats.bestPull.weapon}</div><div class="bp-skin">${stats.bestPull.name}</div>`;
    }

    const rp = document.getElementById('recentPulls');
    if (stats.recent.length) {
      rp.innerHTML = stats.recent.slice(0, 10).map(w => {
        const ps = w.price ? ` · ${formatPrice(w.price)}` : '';
        const e = w.rarity === 'special' ? '★ ' : '';
        return `<div class="cs-recent-item"><span style="color:${rarityColors[w.rarity]}">${e}${w.weapon}</span><span>${w.name}${ps}</span></div>`;
      }).join('');
    }
  }

  // ── Spin count buttons ───────────────────────────────────
  document.querySelectorAll('.cs-spin-count').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.cs-spin-count').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      spinCount = parseInt(btn.dataset.count);
    });
  });

  // ── Back button ──────────────────────────────────────────
  document.getElementById('backBtn').addEventListener('click', () => {
    currentCase = null;
    openState.classList.add('hidden');
    selectState.classList.remove('hidden');
  });

  // ── Reset ────────────────────────────────────────────────
  document.getElementById('resetBtn').addEventListener('click', () => {
    stats = { opened: 0, spent: 0, value: 0, milspec: 0, restricted: 0, classified: 0, covert: 0, special: 0, bestPull: null, recent: [] };
    updateStats();
    document.getElementById('statProfit').textContent = '$0.00';
    document.getElementById('statProfit').className = 'cs-ss-val neutral';
    document.getElementById('statValue').textContent = '0.00';
    document.getElementById('statROI').textContent = '0%';
    document.getElementById('bestPull').innerHTML = '<p class="cs-empty">No pulls yet</p>';
    document.getElementById('recentPulls').innerHTML = '<p class="cs-empty">No pulls yet</p>';
  });

  // ── Confetti ────────────────────────────────────────────
  function launchConfetti() {
    const canvas = document.getElementById('confettiCanvas');
    const ctx = canvas.getContext('2d');
    canvas.width = window.innerWidth;
    canvas.height = window.innerHeight;
    const COLORS = ['#ffd700','#eb4b4b','#2ecc71','#4b69ff','#d32ce6','#ff6b6b','#5e98d9','#ffaa00','#ff4444','#44ff44'];
    const pieces = [];
    function burst(count, originX, spreadX, startY) {
      for (let i = 0; i < count; i++) {
        pieces.push({
          x: originX + (Math.random() - 0.5) * spreadX,
          y: startY - Math.random() * 80,
          w: Math.random() * 10 + 5,
          h: Math.random() * 6 + 3,
          color: COLORS[Math.floor(Math.random() * COLORS.length)],
          vx: (Math.random() - 0.5) * 6,
          vy: Math.random() * 3 + 1.5,
          rot: Math.random() * 360,
          rotV: (Math.random() - 0.5) * 14,
          opacity: 1,
          decay: 0.003 + Math.random() * 0.003,
          shape: Math.random() > 0.35 ? 'rect' : 'circle',
        });
      }
    }
    burst(120, canvas.width / 2, canvas.width, -20);
    let running = true;
    function draw() {
      if (!running) return;
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      let alive = 0;
      for (const p of pieces) {
        if (p.opacity <= 0) continue;
        alive++;
        p.x += p.vx;
        p.y += p.vy;
        p.vy += 0.06;
        p.rot += p.rotV;
        p.opacity -= p.decay;
        if (p.opacity < 0) p.opacity = 0;
        ctx.save();
        ctx.translate(p.x, p.y);
        ctx.rotate(p.rot * Math.PI / 180);
        ctx.globalAlpha = p.opacity;
        ctx.fillStyle = p.color;
        if (p.shape === 'rect') { ctx.fillRect(-p.w / 2, -p.h / 2, p.w, p.h); }
        else { ctx.beginPath(); ctx.arc(0, 0, p.w / 2, 0, Math.PI * 2); ctx.fill(); }
        ctx.restore();
      }
      if (alive > 0) { requestAnimationFrame(draw); }
      else { running = false; ctx.clearRect(0, 0, canvas.width, canvas.height); }
    }
    requestAnimationFrame(draw);
    setTimeout(() => {
      burst(80, canvas.width / 2, canvas.width * 0.8, -10);
      if (!running) { running = true; requestAnimationFrame(draw); }
    }, 700);
  }

