  function buildCtaPopupReel() {
    const strip = document.getElementById('ctaPopupStrip');
    strip.innerHTML = '';
    strip.style.transform = 'translateX(0)';
    const popupGoldSvg = document.getElementById('goldEmblemTpl')?.innerHTML?.replace('cs-gold-emblem', 'cta-popup-gold-emblem') || '';
    const TOTAL = 30, GOLD_IDX = 25;
    const shuffled = [...ctaSkinPool].sort(() => Math.random() - 0.5);
    for (let i = 0; i < TOTAL; i++) {
      const div = document.createElement('div');
      div.className = 'cta-popup-item';
      if (i === GOLD_IDX) {
        div.setAttribute('data-r', 'gold');
        div.innerHTML = popupGoldSvg + '<span class="cta-popup-item-label">★ BONUS ★</span>';
      } else {
        const s = shuffled[i % shuffled.length];
        div.setAttribute('data-r', s.rarity);
        div.innerHTML = `<img class="cta-popup-item-img" src="${s.image}" alt="${s.weapon} ${s.name}" loading="eager"><span class="cta-popup-item-label">${s.name}</span>`;
      }
      strip.appendChild(div);
    }
    // Wire up open button — hide CTA/skip until after reveal
    const overlay = document.getElementById('ctaPopupOpenOverlay');
    overlay.classList.remove('hidden');
    document.getElementById('ctaPopupReveal').classList.add('hidden');
    document.getElementById('ctaPopupCta').classList.add('hidden');
    document.getElementById('ctaPopupSkip').classList.add('hidden');
    document.getElementById('ctaPopupOpenBtn').onclick = () => {
      overlay.classList.add('hidden');
      animateCtaReel(strip, GOLD_IDX);
    };
  }

  function animateCtaReel(strip, goldIdx) {
    const ITEM_W = window.innerWidth <= 480 ? 65 : 85;
    const SPIN_MS = 4500;
    const vpWidth = strip.parentElement.offsetWidth;
    const targetOffset = (goldIdx * ITEM_W) + (ITEM_W / 2) - (vpWidth / 2) + (Math.random() * 12 - 6);
    let startTime = null;
    function easeOutQuint(t) { return 1 - Math.pow(1 - t, 5); }
    function tick(ts) {
      if (!startTime) startTime = ts;
      const p = Math.min((ts - startTime) / SPIN_MS, 1);
      strip.style.transform = `translateX(-${targetOffset * easeOutQuint(p)}px)`;
      if (p < 1) {
        requestAnimationFrame(tick);
      } else {
        setTimeout(() => {
          document.getElementById('ctaPopupReveal').classList.remove('hidden');
          document.querySelector('.cta-popup-prize')?.classList.add('glow');
          launchConfetti();
          // Show CTA + skip after bonus reveals
          setTimeout(() => {
            document.getElementById('ctaPopupCta').classList.remove('hidden');
            document.getElementById('ctaPopupSkip').classList.remove('hidden');
          }, 600);
        }, 300);
      }
    }
    requestAnimationFrame(tick);
  }

  function checkCtaPopup() {
    if (ctaShown) return;
    if (stats.opened >= CTA_THRESHOLD) {
      ctaShown = true;
      setTimeout(() => {
        buildCtaPopupReel();
        document.getElementById('ctaPopup').classList.remove('hidden');
      }, 1500); // Small delay after spin finishes
    }
  }

  // Close popup handlers
  document.getElementById('ctaPopupClose').addEventListener('click', () => {
    document.getElementById('ctaPopup').classList.add('hidden');
  });
  document.getElementById('ctaPopupX').addEventListener('click', () => {
    document.getElementById('ctaPopup').classList.add('hidden');
  });
  document.getElementById('ctaPopupSkip').addEventListener('click', () => {
    document.getElementById('ctaPopup').classList.add('hidden');
  });

  // ── Skin image + price fetching ──────────────────────────
  function stripWear(key) {
    return key.toLowerCase().replace(/^stattrak™?\s*/i, '').replace(/^souvenir\s*/i, '').replace(/\s*\([^)]+\)\s*$/, '').replace(/\s*\|\s*/g, '|');
  }

  (async function fetchSkinImages() {
    try {
      const res = await fetch('/api/skin-images');
      if (!res.ok) return;
      const data = await res.json();
      if (!data?.images) return;
      let enriched = 0;
      const baseSkinImages = {};
      for (const [k, v] of Object.entries(data.images)) {
        const bk = stripWear(k);
        if (!baseSkinImages[bk]) baseSkinImages[bk] = v;
        const nk = bk.replace(/[^a-z0-9|]/g, '');
        if (!baseSkinImages[nk]) baseSkinImages[nk] = v;
      }
      for (const c of Object.values(cases)) {
        for (const skin of c.skins) {
          if (!skin.image) {
            const k1 = `${skin.weapon}|${skin.name}`.toLowerCase();
            const k2 = normalizeKey(skin.weapon, skin.name);
            const img = baseSkinImages[k1] || baseSkinImages[k2];
            if (img) { skin.image = img; enriched++; }
          }
        }
      }
      if (enriched > 0 && currentCase) { buildContents(); resetReels(); }
    } catch (e) { /* optional */ }
  })();

  const RARITY_PRICES = { 'mil-spec': 15, 'restricted': 75, 'classified': 450, 'covert': 2500, 'special': 10000 };

  function applyFallbackPrices() {
    for (const c of Object.values(cases)) {
      for (const skin of c.skins) {
        const k1 = `${skin.weapon}|${skin.name}`.toLowerCase();
        const k2 = normalizeKey(skin.weapon, skin.name);
        if (!skinPrices[k1] && !skinPrices[k2]) {
          const est = RARITY_PRICES[skin.rarity] || 10;
          skinPrices[k1] = est;
          skinPrices[k2] = est;
        }
      }
    }
  }

  (async function fetchSkinPrices() {
    try {
      const res = await fetch('/api/skin-prices');
      if (!res.ok) { applyFallbackPrices(); if (currentCase) buildContents(); return; }
      const data = await res.json();
      if (!data?.prices || Object.keys(data.prices).length === 0) { applyFallbackPrices(); if (currentCase) buildContents(); return; }
      for (const [name, priceData] of Object.entries(data.prices)) {
        const baseKey = stripWear(name);
        const parts = baseKey.split('|');
        if (parts.length >= 2) {
          const k1 = parts.map(p => p.trim()).join('|');
          const k2 = k1.replace(/[^a-z0-9|]/g, '');
          const price = typeof priceData === 'number' ? priceData : (priceData.buff163 || priceData.steam || priceData.skinport || Object.values(priceData)[0] || 0);
          if (price > 0 && (!skinPrices[k1] || price < skinPrices[k1])) { skinPrices[k1] = price; skinPrices[k2] = price; }
        }
      }
      applyFallbackPrices();
      if (currentCase) buildContents();
    } catch (e) { applyFallbackPrices(); if (currentCase) buildContents(); }
  })();
</script>
