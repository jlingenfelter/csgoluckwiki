---
import Base from '../layouts/Base.astro';
import ExploreMore from '../components/ExploreMore.astro';
import { caseDatabase } from '../lib/cases';
import { SKINS, getLowestPrice, RARITY_COLORS } from '../lib/skins';
import { breadcrumbSchema, toolAppSchema } from '../lib/weapons';
import caseSkinImages from '../lib/case-skin-images.json';
import casePricesData from '../lib/case-prices.json';
import { getSouvenirPackages, SOUVENIR_DROP_ODDS, STICKER_CAPSULES, AUTOGRAPH_CAPSULES, MUSIC_KIT_BOXES } from '../lib/containers';

// Build image lookup — comprehensive map from PriceEmpire + SKINS database
// case-skin-images.json is generated by scripts/fetch-case-images.mjs
const imageMap: Record<string, string> = { ...(caseSkinImages as Record<string, string>) };
// Also merge from SKINS database (overwrites with potentially better URLs)
for (const skin of SKINS) {
  const key = `${skin.weapon}|${skin.name}`.toLowerCase();
  if (skin.image) imageMap[key] = skin.image;
}

// Add a single special rarity item (Knife/Glove) per case
function getSpecialSkins(knifeField: string): { name: string; rarity: 'special'; weapon: string }[] {
  return [{
    name: '',
    rarity: 'special' as const,
    weapon: 'Knife/Glove',
  }];
}

// Build SKINS lookup by collection
const skinsByCollection = new Map<string, typeof SKINS>();
for (const skin of SKINS) {
  if (!skin.collection || skin.phase) continue;
  if (!skinsByCollection.has(skin.collection)) skinsByCollection.set(skin.collection, []);
  skinsByCollection.get(skin.collection)!.push(skin);
}

// Rarity mapping for SKINS data → case rarity
const RARITY_TO_CASE: Record<string, string> = {
  'Consumer': 'consumer', 'Industrial': 'industrial', 'Mil-Spec': 'mil-spec',
  'Restricted': 'restricted', 'Classified': 'classified', 'Covert': 'covert',
};

// Build a fast lookup map: weapon|name → price in cents (from buff163)
const skinPriceLookup = new Map<string, number>();
for (const skin of SKINS) {
  const key = `${skin.weapon}|${skin.name}`.toLowerCase();
  if (skinPriceLookup.has(key)) continue;
  const price = getLowestPrice(skin);
  if (price > 0) skinPriceLookup.set(key, Math.round(price * 100));
}

// Enrich case skins with images, prices, and add special (knife/glove) items
const casePrices = (casePricesData as any).cases || {};

function toSlug(name: string): string {
  return name.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
}
const enrichedCases: Record<string, any> = {};
for (const [id, caseData] of Object.entries(caseDatabase)) {
  // Check if case already has special rarity skins
  const hasSpecials = caseData.skins.some(s => s.rarity === 'special');
  const specials = hasSpecials ? [] : getSpecialSkins(caseData.knife);
  const allSkins = [...caseData.skins, ...specials];

  const casePrice = casePrices[id]?.price || 0;
  enrichedCases[id] = {
    ...caseData,
    casePrice,
    totalCost: casePrice + caseData.keyPrice,
    skins: allSkins.map(s => {
      const key = `${s.weapon}|${s.name}`.toLowerCase();
      const theKey = `${s.weapon}|the ${s.name}`.toLowerCase();
      const buffPrice = skinPriceLookup.get(key) || skinPriceLookup.get(theKey) || 0;
      return {
        ...s,
        image: imageMap[key] || imageMap[theKey] || null,
        price: buffPrice,
      };
    }),
  };
}

// Build souvenir packages as simulator-compatible cases
const souvenirPkgs = getSouvenirPackages();
for (const pkg of souvenirPkgs) {
  const collSkins = skinsByCollection.get(pkg.collection) || [];
  if (collSkins.length === 0) continue; // skip if no skins match
  const skins = collSkins.map(s => {
    const key = `${s.weapon}|${s.name}`.toLowerCase();
    const price = getLowestPrice(s);
    return {
      name: s.name,
      weapon: s.weapon,
      rarity: RARITY_TO_CASE[s.rarity] || 'mil-spec',
      image: imageMap[key] || s.image || null,
      price: price > 0 ? Math.round(price * 100) : 0,
    };
  });
  const pkgPriceData = casePrices[pkg.id] || casePrices[toSlug(pkg.name)];
  const pkgPrice = pkgPriceData?.price || 0;
  const pkgImage = pkgPriceData?.image || null;
  enrichedCases[pkg.id] = {
    id: pkg.id,
    name: pkg.name,
    year: pkg.year,
    type: 'souvenir',
    keyPrice: 0,
    casePrice: pkgPrice,
    totalCost: pkgPrice,
    description: `${pkg.tournament} souvenir package containing skins from ${pkg.collection}`,
    image: pkgImage,
    knife: '',
    isSouvenir: true,
    tournament: pkg.tournament,
    map: pkg.map,
    collection: pkg.collection,
    skins,
  };
}

// Build sticker capsule, autograph capsule, and music kit box entries
// Items are loaded lazily client-side from /data/sticker-data.json
const allOtherContainers = [
  ...STICKER_CAPSULES.map(c => ({ ...c, containerType: 'sticker' as const })),
  ...AUTOGRAPH_CAPSULES.map(c => ({ ...c, containerType: 'autograph' as const })),
  ...MUSIC_KIT_BOXES.map(c => ({ ...c, containerType: 'music' as const })),
];

for (const container of allOtherContainers) {
  const priceData = casePrices[container.id] || casePrices[toSlug(container.name)];
  const cPrice = priceData?.price || 0;
  const cImage = priceData?.image || null;
  enrichedCases[container.id] = {
    id: container.id,
    name: container.name,
    year: container.year || 0,
    type: container.type,
    containerType: container.containerType,
    keyPrice: 0,
    casePrice: cPrice,
    totalCost: cPrice,
    image: cImage,
    knife: '',
    isSouvenir: false,
    isContainer: true,
    tournament: container.tournament || '',
    skins: [], // loaded lazily client-side
  };
}

const casesJson = JSON.stringify(enrichedCases);

// Build buff163 skin price map (cents) for all skins in all cases — baked in at build time
const buffPriceMap: Record<string, number> = {};
for (const caseObj of Object.values(enrichedCases)) {
  for (const skin of (caseObj as any).skins || []) {
    const key = `${skin.weapon}|${skin.name}`.toLowerCase();
    if (skin.price && skin.price > 0 && !buffPriceMap[key]) {
      buffPriceMap[key] = skin.price;
    }
  }
}
const buffPriceMapJson = JSON.stringify(buffPriceMap);

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Skins', url: '/cs2-skins/' },
  { name: 'Case Simulator', url: '/case-simulator/' },
];
---

<Base title="CS2 Case Opening Simulator — Free Cases | CSGOLuck Wiki" description="Open CS2 cases for free with our realistic case opening simulator. Kilowatt, Gallery, Revolution and 20+ cases with real odds. Track stats and see if you'd profit!" currentNav="/cs2-skins/">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema(breadcrumbs))} />
    <script type="application/ld+json" set:html={JSON.stringify(toolAppSchema({ name: 'CS2 Case Opening Simulator', url: 'https://wiki.csgoluck.com/case-simulator/', description: 'Open CS2 cases for free with our realistic case opening simulator. Track stats and see if you\'d profit!' }))} />
  </Fragment>

  <nav class="breadcrumb"><a href="/">Home</a> <span>/</span> <a href="/cs2-cases/">Cases</a> <span>/</span> <span>Case Simulator</span></nav>

  <!-- ═══ State 1: Case Selection Grid ═══ -->
  <div id="selectState">
    <div class="cs-hero">
      <div class="cs-hero-top">
        <div>
          <h1 class="cs-title">CS2 Case Opening Simulator</h1>
          <p class="cs-desc">Open CS2 cases for free with realistic animations and real drop odds. Pick a case below to start opening.</p>
        </div>
        <a href="/go/" rel="nofollow" class="cs-hero-cta">
          <span class="cs-hero-cta-label">Open Real Cases</span>
          <span class="cs-hero-cta-bonus">🎁 100% to 100 Coins + 5 Free Cases</span>
        </a>
      </div>
    </div>

    <div class="cs-grid" id="caseGrid"></div>

    <div class="cs-odds-legend">
      <span><i class="dot mil-spec"></i>Mil-Spec 79.92%</span>
      <span><i class="dot restricted"></i>Restricted 15.98%</span>
      <span><i class="dot classified"></i>Classified 3.20%</span>
      <span><i class="dot covert"></i>Covert 0.64%</span>
      <span><i class="dot special"></i>Knife/Gloves 0.26%</span>
    </div>
  </div>

  <!-- ═══ State 2: Case Opening View ═══ -->
  <div id="openState" class="hidden">
    <!-- CTA -->
    <div class="cs-cta-block cs-cta-top">
      <div class="cs-cta-inner">
        <div class="cs-cta-text"><strong>Open Real Cases on CSGOLuck</strong><span>🎁 100% to 100 Coins + 5 Free Cases</span></div>
        <a href="/go/" rel="nofollow" class="cs-cta-btn">Open Cases</a>
      </div>
    </div>

    <!-- Top bar -->
    <div class="cs-topbar">
      <button id="backBtn" class="cs-back" title="Back to cases">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
        Back
      </button>
      <div class="cs-topbar-info">
        <h2 id="caseName" class="cs-topbar-name"></h2>
        <span id="casePrice" class="cs-topbar-price"></span>
      </div>
      <div class="cs-spin-options">
        <button class="cs-spin-count active" data-count="1">x1</button>
        <button class="cs-spin-count" data-count="3">x3</button>
        <button class="cs-spin-count" data-count="5">x5</button>
      </div>
      <button id="openBtn" class="cs-open-btn">Open Case</button>
    </div>

    <!-- Two-column layout: main + sidebar -->
    <div class="cs-opening-layout">
      <!-- Main column: reel + results + contents -->
      <div class="cs-main-col">
        <!-- Roulette -->
        <div class="cs-reels-container" id="reelsContainer">
          <div class="cs-roulette-wrap">
            <div class="cs-pointer"></div>
            <div class="cs-roulette"><div class="cs-strip"></div></div>
          </div>
        </div>

        <!-- Result -->
        <div id="resultArea" class="cs-result hidden"></div>

        <!-- Case contents -->
        <div class="cs-contents">
          <h4>Case Contents</h4>
          <div id="caseContents" class="cs-contents-grid"></div>
        </div>
      </div>

      <!-- Sidebar: stats + pulls -->
      <div class="cs-sidebar">
        <!-- Stats -->
        <div class="cs-sidebar-stats">
          <div class="cs-sidebar-stats-grid">
            <div class="cs-ss-item"><span class="cs-ss-val" id="statOpened">0</span><span class="cs-ss-lbl">Opened</span></div>
            <div class="cs-ss-item"><span class="cs-ss-val">$<span id="statSpent">0.00</span></span><span class="cs-ss-lbl">Spent</span></div>
            <div class="cs-ss-item"><span class="cs-ss-val">$<span id="statValue">0.00</span></span><span class="cs-ss-lbl">Value</span></div>
            <div class="cs-ss-item cs-ss-profit"><span class="cs-ss-val neutral" id="statProfit">$0.00</span><span class="cs-ss-lbl">Profit</span></div>
            <div class="cs-ss-item"><span class="cs-ss-val" id="statROI">0%</span><span class="cs-ss-lbl">ROI</span></div>
          </div>
          <div class="cs-ss-rarity">
            <span><i class="dot mil-spec"></i><b id="rMilspec">0</b></span>
            <span><i class="dot restricted"></i><b id="rRestricted">0</b></span>
            <span><i class="dot classified"></i><b id="rClassified">0</b></span>
            <span><i class="dot covert"></i><b id="rCovert">0</b></span>
            <span><i class="dot special"></i><b id="rSpecial">0</b></span>
          </div>
          <button id="resetBtn" class="cs-reset-btn" style="width:100%;margin-top:.5rem">Reset</button>
        </div>

        <!-- Best pull -->
        <div class="cs-pull-box">
          <h4>Best Pull</h4>
          <div id="bestPull"><p class="cs-empty">No pulls yet</p></div>
        </div>

        <!-- Recent pulls -->
        <div class="cs-pull-box cs-pull-recent">
          <h4>Recent Pulls</h4>
          <div id="recentPulls"><p class="cs-empty">No pulls yet</p></div>
        </div>
      </div>
    </div>

  </div>

<!-- ═══ CTA Popup — shows after 5-10 opens ═══ -->
<div id="ctaPopup" class="cta-popup hidden">
  <div class="cta-popup-backdrop" id="ctaPopupClose"></div>
  <div class="cta-popup-modal">
    <button class="cta-popup-x" id="ctaPopupX" aria-label="Close">&times;</button>
    <div class="cta-popup-header">Get Better Odds at CSGOLuck</div>
    <div class="cta-popup-reel-wrap">
      <div class="cta-popup-pointer"></div>
      <div class="cta-popup-viewport">
        <div class="cta-popup-center-line"></div>
        <div class="cta-popup-strip" id="ctaPopupStrip"></div>
        <div class="cta-popup-open-overlay" id="ctaPopupOpenOverlay">
          <button class="cta-popup-open-btn" id="ctaPopupOpenBtn">Open</button>
        </div>
      </div>
    </div>
    <div class="cta-popup-reveal hidden" id="ctaPopupReveal">
      <div class="cta-popup-prize">
        <div class="cta-popup-prize-badge">★ Exclusive Offer Unlocked ★</div>
        <div class="cta-popup-prize-title">100% Deposit Bonus</div>
        <div class="cta-popup-prize-plus">+ 5 Free Cases</div>
      </div>
    </div>
    <a href="https://csgoluck.com/r/WIKIPEDIA" rel="nofollow noopener" target="_blank" class="cta-popup-cta hidden" id="ctaPopupCta">Claim Now →</a>
    <span class="cta-popup-skip hidden" id="ctaPopupSkip">No thanks, keep simulating</span>
  </div>
</div>

<!-- Confetti canvas (fixed, full viewport, no pointer events) -->
<canvas id="confettiCanvas" style="position:fixed;top:0;left:0;width:100vw;height:100vh;pointer-events:none;z-index:99999;"></canvas>

<!-- Gold emblem SVG template (hidden) — same as interstitial page -->
<template id="goldEmblemTpl">
  <svg class="cs-gold-emblem" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
    <defs>
      <radialGradient id="gg" cx="50%" cy="45%" r="50%">
        <stop offset="0%" stop-color="#fff3a0"/>
        <stop offset="40%" stop-color="#ffd700"/>
        <stop offset="100%" stop-color="#b8860b"/>
      </radialGradient>
      <radialGradient id="gc" cx="50%" cy="40%" r="45%">
        <stop offset="0%" stop-color="#ffe066"/>
        <stop offset="100%" stop-color="#c8960c"/>
      </radialGradient>
    </defs>
    <circle cx="50" cy="50" r="42" fill="none" stroke="url(#gg)" stroke-width="4" opacity=".7"/>
    <circle cx="50" cy="50" r="30" fill="url(#gc)" opacity=".9"/>
    <circle cx="50" cy="50" r="30" fill="none" stroke="#b8860b" stroke-width="1.5"/>
    <text x="50" y="58" text-anchor="middle" font-family="Montserrat,sans-serif" font-size="30" font-weight="900" fill="#1a1400" opacity=".85">?</text>
    <g fill="#c8960c" opacity=".85">
      <ellipse cx="16" cy="60" rx="5" ry="10" transform="rotate(20 16 60)"/>
      <ellipse cx="12" cy="50" rx="4.5" ry="9" transform="rotate(10 12 50)"/>
      <ellipse cx="11" cy="40" rx="4" ry="8" transform="rotate(-5 11 40)"/>
      <ellipse cx="14" cy="31" rx="3.5" ry="7" transform="rotate(-20 14 31)"/>
      <ellipse cx="20" cy="24" rx="3" ry="6" transform="rotate(-35 20 24)"/>
    </g>
    <g fill="#c8960c" opacity=".85">
      <ellipse cx="84" cy="60" rx="5" ry="10" transform="rotate(-20 84 60)"/>
      <ellipse cx="88" cy="50" rx="4.5" ry="9" transform="rotate(-10 88 50)"/>
      <ellipse cx="89" cy="40" rx="4" ry="8" transform="rotate(5 89 40)"/>
      <ellipse cx="86" cy="31" rx="3.5" ry="7" transform="rotate(20 86 31)"/>
      <ellipse cx="80" cy="24" rx="3" ry="6" transform="rotate(35 80 24)"/>
    </g>
    <polygon points="50,6 52,12 58,12 53,16 55,22 50,18 45,22 47,16 42,12 48,12" fill="#ffd700"/>
  </svg>
</template>

<ExploreMore context="skins" />

<style is:inline>
  .hidden{display:none!important}

  /* ── Hero ──────────────────────────────────────────────── */
  .cs-hero{padding:1.5rem 0 1rem}
  .cs-hero-top{display:flex;align-items:flex-start;justify-content:space-between;gap:1.5rem;flex-wrap:wrap}
  .cs-title{font-size:1.8rem;font-weight:800;margin:0 0 .4rem;color:var(--text)}
  .cs-desc{color:var(--text2);font-size:.9rem;margin:0;max-width:550px;line-height:1.6}
  .cs-hero-cta{display:flex;flex-direction:column;align-items:center;gap:.25rem;padding:.7rem 1.5rem;background:#2ecc71;border-radius:6px;text-decoration:none;transition:background .15s;flex-shrink:0}
  .cs-hero-cta:hover{background:#27ae60}
  .cs-hero-cta-label{font-weight:800;font-size:.95rem;color:#fff}
  .cs-hero-cta-bonus{font-size:.7rem;color:rgba(255,255,255,.85);font-weight:600}

  /* ── Case Grid ─────────────────────────────────────────── */
  .cs-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:.75rem;margin-bottom:1.5rem}
  .cs-card{background:var(--bg2);border:1px solid var(--border);border-radius:6px;padding:1rem;cursor:pointer;transition:border-color .15s,transform .15s;display:flex;flex-direction:column;align-items:center;text-align:center;gap:.5rem}
  .cs-card:hover{border-color:#2ecc71;transform:translateY(-2px)}
  .cs-card-img{width:100%;height:100px;display:flex;align-items:center;justify-content:center;background:var(--bg3);border-radius:4px;overflow:hidden;position:relative}
  .cs-card-case-img{max-width:90%;max-height:85px;object-fit:contain}
  .cs-card-knife{position:absolute;bottom:4px;right:4px;font-size:.55rem;background:rgba(228,174,57,.15);color:#e4ae39;padding:.1rem .35rem;border-radius:3px;font-weight:700}
  .cs-card-name{font-weight:700;font-size:.9rem;color:var(--text)}
  .cs-card-meta{font-size:.7rem;color:var(--text2)}
  .cs-card-price{font-size:.85rem;font-weight:800;color:#2ecc71}

  /* Souvenir card styles */
  .cs-card-img-souvenir{background:linear-gradient(135deg,rgba(46,204,113,.08),var(--bg3));border-bottom:2px solid rgba(46,204,113,.2)}
  .cs-card-map{font-size:1rem;font-weight:700;color:var(--text2);opacity:.5}
  .cs-card-souvenir .cs-card-price{color:#2ecc71;font-weight:600;font-size:.75rem}

  /* Simulator category tabs */
  .cs-sim-tabs{display:flex;gap:.35rem;margin-bottom:1rem;flex-wrap:wrap}
  .cs-sim-tab{background:var(--bg2);border:1px solid var(--border);border-radius:4px;padding:.4rem .85rem;font-size:.82rem;font-weight:500;color:var(--text2);cursor:pointer;font-family:inherit;transition:color .15s,border-color .15s}
  .cs-sim-tab:hover{color:var(--text);border-color:#2ecc71}
  .cs-sim-tab-active{color:#2ecc71;border-color:#2ecc71;font-weight:600}

  /* ── Odds legend ───────────────────────────────────────── */
  .cs-odds-legend{display:flex;flex-wrap:wrap;gap:.5rem 1.2rem;justify-content:center;font-size:.75rem;color:var(--text2);padding:.75rem 0;margin-bottom:1rem}
  .cs-odds-legend span{display:flex;align-items:center;gap:.3rem}
  .dot{width:8px;height:8px;border-radius:50%;display:inline-block;flex-shrink:0}
  .dot.consumer{background:#b0c3d9}.dot.industrial{background:#5e98d9}.dot.mil-spec{background:#4b69ff}.dot.restricted{background:#8847ff}.dot.classified{background:#d32ce6}.dot.covert{background:#2ecc71}.dot.special{background:#ffd700}

  /* ── Top bar ───────────────────────────────────────────── */
  .cs-topbar{display:flex;align-items:center;gap:1rem;padding:.75rem 0;flex-wrap:wrap}
  .cs-back{display:flex;align-items:center;gap:.3rem;background:none;border:1px solid var(--border);color:var(--text2);border-radius:4px;padding:.4rem .7rem;font-size:.8rem;cursor:pointer;font-family:inherit;transition:border-color .15s}
  .cs-back:hover{border-color:#2ecc71;color:#2ecc71}
  .cs-topbar-info{flex:1;min-width:0}
  .cs-topbar-name{margin:0;font-size:1.15rem;font-weight:800;color:var(--text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
  .cs-topbar-price{font-size:.8rem;color:#2ecc71;font-weight:700}
  .cs-spin-options{display:flex;gap:.3rem}
  .cs-spin-count{background:var(--bg3);border:1px solid var(--border);border-radius:4px;padding:.4rem .7rem;font-size:.8rem;font-weight:700;color:var(--text2);cursor:pointer;transition:all .15s;font-family:inherit}
  .cs-spin-count:hover{border-color:#2ecc71}
  .cs-spin-count.active{background:rgba(46,204,113,.1);border-color:#2ecc71;color:#2ecc71}
  .cs-open-btn{background:#2ecc71;color:#fff;border:none;border-radius:20px;padding:.6rem 2.5rem;font-size:1rem;font-weight:800;cursor:pointer;transition:background .15s;font-family:inherit;white-space:nowrap}
  .cs-open-btn:hover:not(:disabled){background:#27ae60}
  .cs-open-btn:disabled{opacity:.4;cursor:not-allowed}

  /* ── Roulette ──────────────────────────────────────────── */
  .cs-reels-container{display:flex;flex-direction:column;gap:.5rem;margin:.5rem 0}
  .cs-roulette-wrap{position:relative}
  .cs-pointer{position:absolute;top:0;left:50%;transform:translateX(-50%);width:0;height:0;border-left:10px solid transparent;border-right:10px solid transparent;border-top:14px solid #2ecc71;z-index:5}
  .cs-roulette{background:var(--bg);border:2px solid var(--border);border-radius:6px;overflow:hidden;height:130px;display:flex;align-items:center;position:relative;width:100%}
  .cs-reels-container.multi .cs-roulette{height:95px}
  .cs-reels-container.multi .cs-item{width:85px;height:85px}
  .cs-reels-container.multi .cs-item-img{width:50px;height:38px}
  .cs-reels-container.multi .cs-item-weapon{font-size:.6rem}
  .cs-reels-container.multi .cs-item-skin{font-size:.5rem}
  .cs-roulette::before,.cs-roulette::after{content:'';position:absolute;top:0;bottom:0;width:80px;z-index:3;pointer-events:none}
  .cs-roulette::before{left:0;background:linear-gradient(to right,var(--bg),transparent)}
  .cs-roulette::after{right:0;background:linear-gradient(to left,var(--bg),transparent)}
  .cs-strip{display:flex;gap:8px;padding:0 8px;will-change:transform}
  .cs-strip.animating{transition:transform 4s cubic-bezier(.15,.3,.2,1)}
  .cs-reel-label{position:absolute;left:8px;top:50%;transform:translateY(-50%);background:rgba(0,0,0,.6);color:var(--text2);font-size:.6rem;font-weight:700;padding:.15rem .4rem;border-radius:4px;z-index:4}

  .cs-item{flex-shrink:0;width:110px;height:110px;border-radius:6px;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;padding:.3rem;border:2px solid;position:relative;overflow:hidden}
