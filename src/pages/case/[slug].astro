---
import Base from '../../layouts/Base.astro';
import ExploreMore from '../../components/ExploreMore.astro';
import { caseDatabase } from '../../lib/cases';
import { breadcrumbSchema } from '../../lib/weapons';

export function getStaticPaths() {
  return Object.keys(caseDatabase).map((slug) => ({
    params: { slug },
  }));
}

const { slug } = Astro.params;
const caseData = caseDatabase[slug];

if (!caseData) {
  return Astro.redirect('/cases/');
}

const rarityColors: Record<string, string> = {
  'mil-spec': '#4b7cf5',
  'restricted': '#8847ff',
  'classified': '#d32ce6',
  'covert': '#eb4b4b',
  'special': '#d4956e',
};

const rarityLabels: Record<string, string> = {
  'mil-spec': 'Mil-Spec',
  'restricted': 'Restricted',
  'classified': 'Classified',
  'covert': 'Covert',
  'special': 'Special',
};

// Group skins by rarity
const skinsByRarity = caseData.skins.reduce(
  (acc, skin) => {
    if (!acc[skin.rarity]) {
      acc[skin.rarity] = [];
    }
    acc[skin.rarity].push(skin);
    return acc;
  },
  {} as Record<string, typeof caseData.skins>,
);

const caseROI = caseData.keyPrice * (100 / 79.92) * -1;
const expectedValue = (caseData.keyPrice * 2) / 100;

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Cases', url: '/cases/' },
  { name: caseData.name, url: `/case/${slug}/` },
];
---

<Base
  title={`${caseData.name} | CS2 Case | CSDB.gg`}
  description={`${caseData.name} details: drop odds, notable skins, key price, and ROI analysis. Released ${caseData.releaseDate}.`}
  currentNav="/skins/"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema(breadcrumbs))} />
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'Product',
      name: caseData.name,
      description: caseData.description,
      image: caseData.image,
      brand: { '@type': 'Brand', name: 'Valve' },
      category: 'Video Game Item',
      offers: {
        '@type': 'Offer',
        priceCurrency: 'USD',
        price: caseData.keyPrice.toFixed(2),
        availability: 'https://schema.org/InStock',
        url: `https://csdb.gg/case/${slug}/`,
      },
    })} />
  </Fragment>
  <div class="case-detail-header">
    <a href="/cases/" class="breadcrumb">← Back to Cases</a>
    <h1>{caseData.name}</h1>
    <p class="case-tagline">{caseData.description}</p>
  </div>

  <div class="case-info-grid">
    <div class="info-card">
      <div class="info-label">Release Date</div>
      <div class="info-value">{caseData.releaseDate}</div>
    </div>
    <div class="info-card">
      <div class="info-label">Year</div>
      <div class="info-value">{caseData.year}</div>
    </div>
    <div class="info-card">
      <div class="info-label">Key Price</div>
      <div class="info-value">${caseData.keyPrice}</div>
    </div>
    <div class="info-card">
      <div class="info-label">Type</div>
      <div class="info-value">{caseData.type === 'weapon' ? '🎒 Weapon Case' : '🏆 Special Case'}</div>
    </div>
  </div>

  <section class="drop-odds-section">
    <h2>Drop Odds Breakdown</h2>
    <p style="font-size:.88rem;color:var(--text2);margin-bottom:1rem">See how these odds play out in practice with our <a href="/case-simulator/" style="color:var(--accent);font-weight:600">Case Simulator</a> or calculate expected costs with the <a href="/case-odds-calculator/" style="color:var(--accent);font-weight:600">Case Odds Calculator</a>.</p>
    <div class="odds-container">
      {[
        { tier: 'Mil-Spec', probability: '79.92%', percentage: 79.92 },
        { tier: 'Restricted', probability: '15.98%', percentage: 15.98 },
        { tier: 'Classified', probability: '3.20%', percentage: 3.2 },
        { tier: 'Covert', probability: '0.64%', percentage: 0.64 },
        { tier: 'Special', probability: '0.26%', percentage: 0.26 },
      ].map((odd) => (
        <div class="odd-bar">
          <div class="odd-label">
            <span class="tier-name">{odd.tier}</span>
            <span class="tier-probability">{odd.probability}</span>
          </div>
          <div class="odd-bar-background">
            <div class="odd-bar-fill" style={`width: ${odd.percentage}%; background: ${rarityColors[odd.tier.toLowerCase().replace(' ', '-')] || '#d4956e'}`}></div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <section class="roi-section">
    <h2>ROI Analysis</h2>
    <div class="roi-cards">
      <div class="roi-card">
        <div class="roi-label">Average Loss per Case</div>
        <div class="roi-value negative">${caseROI.toFixed(2)}</div>
        <p class="roi-note">Opening a case on average loses money</p>
      </div>
      <div class="roi-card">
        <div class="roi-label">Break-Even Price</div>
        <div class="roi-value">${(caseData.keyPrice * 2).toFixed(2)}</div>
        <p class="roi-note">Average item value to break even</p>
      </div>
      <div class="roi-card">
        <div class="roi-label">Recommendation</div>
        <div class="roi-value action">Trade Up</div>
        <p class="roi-note">
          <a href="/tradeup-calculator/">Use trade-up calculator</a> for better ROI
        </p>
      </div>
    </div>
  </section>

  <section class="skins-section">
    <h2>Case Contents</h2>
    <p class="skins-description">All {caseData.skins.length} possible weapon skins in this case, grouped by rarity:</p>

    {Object.keys(skinsByRarity)
      .sort((a, b) => {
        const order = ['covert', 'classified', 'restricted', 'mil-spec', 'special'];
        return order.indexOf(a) - order.indexOf(b);
      })
      .map((rarity) => (
        <div class="rarity-group">
          <h3 class="rarity-title" style={`border-left: 4px solid ${rarityColors[rarity]}`}>
            <span class="rarity-badge" style={`background: ${rarityColors[rarity]}`}></span>
            {rarityLabels[rarity]} ({skinsByRarity[rarity].length} items)
          </h3>
          <div class="skins-grid">
            {skinsByRarity[rarity].map((skin) => (
              <a href={`/skin/${skin.name.toLowerCase().replace(/ /g, '-')}/`} class="skin-item">
                <div class="skin-weapon">{skin.weapon}</div>
                <div class="skin-name">{skin.name}</div>
              </a>
            ))}
          </div>
        </div>
      ))}
  </section>

  <section class="case-tips">
    <h2>Case Opening Tips</h2>
    <ul class="tip-list">
      <li>Case opening has negative expected value on average — try the <a href="/case-simulator/">Case Simulator</a> risk-free first</li>
      <li>Invest in skins you love rather than opening for profit</li>
      <li>Consider float quality and condition when valuing items — use the <a href="/float-checker/">Float Checker</a> to analyse wear values</li>
      <li>StatTrak and Souvenir variants are rarer and more valuable</li>
      <li>Check live prices with the <a href="/price-tracker/">Price Tracker</a> and <a href="/market-trends/">Market Trends</a> before buying</li>
      <li>Keep keys on secure accounts and enable Steam Guard</li>
      <li>Use the <a href="/skin-compare/">Skin Compare</a> tool to compare similar skins before choosing</li>
      <li>Use the <a href="/tradeup-calculator/">Trade-Up Calculator</a> for better ROI than opening cases</li>
      <li>Check your current inventory value with the <a href="/inventory-lookup/">Inventory Lookup</a></li>
    </ul>
  </section>

  <div class="internal-links">
    <a href="/cases/">All Cases</a>
    <a href="/case-simulator/">Case Simulator</a>
    <a href="/case-odds-calculator/">Case Odds Calculator</a>
    <a href="/skins/">Skin Database</a>
    <a href="/skin-compare/">Skin Compare</a>
    <a href="/price-tracker/">Price Tracker</a>
    <a href="/market-trends/">Market Trends</a>
    <a href="/float-checker/">Float Checker</a>
    <a href="/tradeup-calculator/">Trade-Up Calculator</a>
    <a href="/inventory-lookup/">Inventory Lookup</a>
    <a href="/loadout-builder/">Loadout Builder</a>
    <a href="/weapons/">Weapon Database</a>
    <a href="/guides/skins-investing-guide/">Investing Guide</a>
  </div>

  <ExploreMore context="skins" />

  <style is:inline>
    .case-detail-header {
      margin-bottom: 2rem;
    }

    .case-detail-header .breadcrumb {
      display: inline-block;
      color: var(--text2);
      text-decoration: none;
      margin-bottom: 1rem;
      font-size: 0.9rem;
      transition: color 0.2s;
    }

    .case-detail-header .breadcrumb:hover {
      color: var(--accent);
    }

    .case-detail-header h1 {
      font-size: 2.5rem;
      background: linear-gradient(135deg, var(--accent), var(--accent2));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      margin-bottom: 0.5rem;
    }

    .case-tagline {
      font-size: 1.1rem;
      color: var(--text2);
    }

    .case-info-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 1rem;
      margin: 2rem 0;
    }

    .info-card {
      background: var(--bg2);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 1.5rem;
      transition: all 0.3s;
    }

    .info-card:hover {
      border-color: var(--accent);
      box-shadow: 0 8px 24px rgba(245, 166, 35, 0.1);
    }

    .info-label {
      color: var(--text2);
      font-size: 0.85rem;
      margin-bottom: 0.5rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    .info-value {
      font-size: 1.5rem;
      font-weight: 700;
      color: var(--accent);
    }

    .drop-odds-section {
      margin: 3rem 0;
      background: var(--bg2);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 2rem;
    }

    .odds-container {
      display: flex;
      flex-direction: column;
      gap: 1.25rem;
      margin-top: 1.5rem;
    }

    .odd-bar {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }

    .odd-label {
      display: flex;
      justify-content: space-between;
      align-items: center;
      font-size: 0.9rem;
    }

    .tier-name {
      font-weight: 600;
      color: var(--text);
    }

    .tier-probability {
      color: var(--accent);
      font-weight: 700;
    }

    .odd-bar-background {
      height: 24px;
      background: var(--bg3);
      border-radius: 6px;
      overflow: hidden;
      border: 1px solid var(--border);
    }

    .odd-bar-fill {
      height: 100%;
      min-width: 2px;
      transition: width 0.3s ease;
    }

    .roi-section {
      margin: 3rem 0;
    }

    .roi-cards {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 1rem;
      margin-top: 1.5rem;
    }

    .roi-card {
      background: var(--bg2);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 1.5rem;
      text-align: center;
      transition: all 0.3s;
    }

    .roi-card:hover {
      border-color: var(--accent);
      box-shadow: 0 8px 24px rgba(245, 166, 35, 0.1);
    }

    .roi-label {
      color: var(--text2);
      font-size: 0.85rem;
      margin-bottom: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    .roi-value {
      font-size: 1.8rem;
      font-weight: 800;
      margin-bottom: 0.5rem;
    }

    .roi-value.negative {
      color: #ef5350;
    }

    .roi-value.action {
      color: #4caf50;
    }

    .roi-note {
      font-size: 0.85rem;
      color: var(--text2);
      margin: 0;
    }

    .roi-note a {
      color: var(--accent);
      text-decoration: none;
      font-weight: 600;
    }

    .roi-note a:hover {
      color: var(--accent2);
    }

    .skins-section {
      margin: 3rem 0;
    }

    .skins-description {
      color: var(--text2);
      margin-bottom: 1.5rem;
    }

    .rarity-group {
      margin-bottom: 2rem;
    }

    .rarity-title {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      margin: 0 0 1rem;
      padding-left: 1rem;
      font-size: 1.1rem;
    }

    .rarity-badge {
      width: 12px;
      height: 12px;
      border-radius: 2px;
      flex-shrink: 0;
    }

    .skins-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
      gap: 0.75rem;
    }

    .skin-item {
      display: block;
      background: var(--bg3);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 1rem;
      text-decoration: none;
      color: inherit;
      transition: all 0.2s;
    }

    .skin-item:hover {
      border-color: var(--accent);
      transform: translateY(-2px);
      box-shadow: 0 8px 24px rgba(245, 166, 35, 0.15);
    }

    .skin-weapon {
      font-size: 0.75rem;
      color: var(--text2);
      text-transform: uppercase;
      letter-spacing: 0.05em;
      margin-bottom: 0.4rem;
    }

    .skin-name {
      font-size: 0.95rem;
      font-weight: 600;
      color: var(--text);
    }

    .case-tips {
      margin: 3rem 0;
      background: var(--bg2);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 2rem;
    }

    @media (max-width: 768px) {
      .case-detail-header h1 {
        font-size: 1.8rem;
      }

      .case-info-grid {
        grid-template-columns: 1fr;
      }

      .roi-cards {
        grid-template-columns: 1fr;
      }

      .skins-grid {
        grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
      }
    }
  </style>
</Base>
