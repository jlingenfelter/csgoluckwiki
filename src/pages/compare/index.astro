---
import Base from '../../layouts/Base.astro';
import ExploreMore from '../../components/ExploreMore.astro';
import { getWeaponComparisons, WEAPON_CATEGORIES, breadcrumbSchema, faqSchema } from '../../lib/weapons';

const comparisons = getWeaponComparisons();

// Group by category (use the first weapon's category)
const grouped: Record<string, typeof comparisons> = {};
for (const c of comparisons) {
  const cat = c.w1.category;
  if (!grouped[cat]) grouped[cat] = [];
  grouped[cat].push(c);
}

// Popular comparisons (cross-category + staple matchups)
const popular = comparisons.filter(c =>
  c.slug.includes('ak-47-vs-m4a4') || c.slug.includes('ak-47-vs-m4a1-s') ||
  c.slug.includes('awp-vs-ssg-08') || c.slug.includes('m4a4-vs-m4a1-s') ||
  c.slug.includes('ump-45-vs-mac-10') || c.slug.includes('desert-eagle-vs-r8-revolver') ||
  c.slug.includes('p250-vs-cz75-auto') || c.slug.includes('glock-18-vs-usp-s') ||
  c.w1.category !== c.w2.category
);

const title = 'CS2 Weapon Comparisons — Side-by-Side Stats | CSGOLuck Wiki';
const description = `Compare ${comparisons.length}+ CS2 weapon matchups side by side. Analyze damage, fire rate, accuracy, price, and recoil for every weapon pair in Counter-Strike 2.`;

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Weapons', url: '/cs2-weapons/' },
  { name: 'Comparisons', url: '/compare/' },
];

const faqs = [
  { question: 'AK-47 or M4A4 — which is better in CS2?', answer: 'The AK-47 deals more damage per shot and can one-shot headshot through helmets. The M4A4 has a larger magazine, easier spray pattern, and is available on CT-side. The AK-47 is generally considered the better weapon statistically.' },
  { question: 'M4A4 or M4A1-S — which should I use?', answer: 'The M4A1-S offers better accuracy, a silencer, and less recoil. The M4A4 has a 30-round magazine vs 20 and higher fire rate. Most pro players currently prefer the M4A1-S for its accuracy advantage.' },
  { question: 'Is the AWP worth the price over the SSG 08?', answer: 'The AWP ($4,750) one-shot kills to the body and head. The SSG 08 ($1,700) only one-shots to the head. The AWP is vastly more impactful but costs almost 3x more. Buy the Scout when you cannot afford an AWP or on eco rounds.' },
];
---

<Base title={title} description={description} currentNav="/cs2-weapons/">
<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema(breadcrumbs))} />
<script type="application/ld+json" set:html={JSON.stringify(faqSchema(faqs))} />

<nav class="breadcrumb">
  <a href="/">Home</a> / <a href="/cs2-weapons/">Weapons</a> / <span>Comparisons</span>
</nav>

<section class="cpi-hero">
  <h1>CS2 Weapon Comparisons</h1>
  <p class="cpi-hero-desc">Compare any two weapons side by side. Analyze damage, fire rate, accuracy, cost, and recoil to find the best weapon for your playstyle. {comparisons.length} matchups available.</p>
</section>

{popular.length > 0 && (
  <section class="cpi-section">
    <h2>Popular Comparisons</h2>
    <div class="cpi-list">
      {popular.slice(0, 12).map(c => (
        <a href={`/compare/${c.slug}/`} class="cpi-row cpi-row-hot">
          <span class="cpi-w1">{c.w1.name}</span>
          <span class="cpi-vs">vs</span>
          <span class="cpi-w2">{c.w2.name}</span>
          <span class="cpi-arrow">&rarr;</span>
        </a>
      ))}
    </div>
  </section>
)}

{WEAPON_CATEGORIES.filter(cat => grouped[cat.slug]?.length).map(cat => (
  <section class="cpi-section">
    <h2>{cat.name} Comparisons</h2>
    <div class="cpi-list">
      {grouped[cat.slug].map(c => (
        <a href={`/compare/${c.slug}/`} class="cpi-row">
          <span class="cpi-w1">{c.w1.name}</span>
          <span class="cpi-vs">vs</span>
          <span class="cpi-w2">{c.w2.name}</span>
          <span class="cpi-arrow">&rarr;</span>
        </a>
      ))}
    </div>
  </section>
))}

<section class="cpi-faq">
  <h2>Frequently Asked Questions</h2>
  {faqs.map(f => (
    <details class="cpi-faq-item">
      <summary>{f.question}</summary>
      <p>{f.answer}</p>
    </details>
  ))}
</section>

<ExploreMore context="weapons" />
</Base>

<style>
/* ── Hero ── */
.cpi-hero{background:var(--bg2);border:1px solid var(--border);border-radius:4px;padding:2rem;margin-bottom:1.5rem}
.cpi-hero h1{font-family:'Montserrat',sans-serif;font-size:2rem;font-weight:800;margin:0 0 .5rem;color:var(--text)}
.cpi-hero-desc{color:var(--text2);font-size:.95rem;line-height:1.6;margin:0}

/* ── Sections ── */
.cpi-section{margin-bottom:2rem}
.cpi-section h2{font-family:'Montserrat',sans-serif;font-size:1.15rem;font-weight:700;color:var(--text);margin:0 0 .75rem}

/* ── Comparison Rows ── */
.cpi-list{display:flex;flex-direction:column;gap:2px}
.cpi-row{display:flex;align-items:center;gap:.75rem;text-decoration:none;color:inherit;background:var(--bg2);border:1px solid var(--border);border-left:3px solid transparent;border-radius:4px;padding:.7rem 1rem;transition:border-color .15s,background .15s}
.cpi-row:hover{border-left-color:var(--accent);background:var(--bg3)}
.cpi-row-hot{background:var(--bg2);border-left-color:rgba(46,204,113,.2)}
.cpi-row-hot:hover{border-left-color:var(--accent)}
.cpi-w1,.cpi-w2{font-weight:700;font-size:.9rem;color:var(--text)}
.cpi-vs{color:var(--text2);font-size:.72rem;text-transform:uppercase;font-weight:600}
.cpi-arrow{margin-left:auto;color:var(--text2);font-size:.82rem}

/* ── FAQ ── */
.cpi-faq{margin-bottom:2rem}
.cpi-faq h2{font-family:'Montserrat',sans-serif;font-size:1.15rem;font-weight:700;color:var(--text);margin:0 0 .75rem}
.cpi-faq-item{background:var(--bg2);border:1px solid var(--border);border-radius:4px;margin-bottom:.35rem;overflow:hidden}
.cpi-faq-item summary{padding:.75rem 2.5rem .75rem 1rem;font-weight:700;font-size:.9rem;color:var(--text);cursor:pointer;list-style:none;position:relative;transition:background .15s}
.cpi-faq-item summary::after{content:'+';position:absolute;right:1.25rem;top:50%;transform:translateY(-50%);font-size:1.2rem;color:var(--accent);font-weight:700}
.cpi-faq-item[open] summary::after{content:'\2212'}
.cpi-faq-item summary:hover{background:var(--bg3)}
.cpi-faq-item summary::-webkit-details-marker{display:none}
.cpi-faq-item p{padding:0 1rem .85rem 1rem;margin:0;color:var(--text2);font-size:.88rem;line-height:1.6}

/* ── Breadcrumb ── */
.breadcrumb{font-size:.82rem;color:var(--text2);margin-bottom:1.25rem;display:flex;gap:.35rem;flex-wrap:wrap}
.breadcrumb a{color:var(--accent);text-decoration:none}
.breadcrumb a:hover{text-decoration:underline}

/* ── Responsive ── */
@media(max-width:768px){
  .cpi-hero h1{font-size:1.5rem}
  .cpi-row{flex-wrap:wrap;gap:.4rem}
}
</style>
