---

<Base title={title} description={description} currentNav="/crosshair-codes/">
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJson)}></script>
  <script type="application/ld+json" set:html={JSON.stringify(faqJson)}></script>
  <script type="application/ld+json" set:html={JSON.stringify(toolAppSchema({ name: 'CS2 Pro Crosshair Codes Library', url: 'https://csdb.gg/crosshair-codes/', description }))}></script>

  <nav class="breadcrumb">
    <a href="/">Home</a> / <a href="/crosshair-codes/">Tools</a> / <span>Pro Crosshair Codes</span>
  </nav>

  <h1>CS2 Pro Crosshair Codes</h1>
  <p>Browse and copy crosshair codes from 860+ professional Counter-Strike 2 players. Learn from the pros and import their exact settings into your game.</p>

  <div class="filter-section">
    <div class="filters">
      <button class="filter-btn active" data-role="All">All Roles</button>
      {roles.slice(1).map(role => (
        <button class="filter-btn" data-role={role}>{role}</button>
      ))}
    </div>
    <input 
      type="text" 
      id="searchInput" 
      class="search-input" 
      placeholder="Search player name..." 
      aria-label="Search players"
    />
  </div>

  <div class="crosshair-grid" id="crosshairGrid">
    {CROSSHAIRS.map(ch => (
      <div class="crosshair-card" data-role={ch.role} data-player={ch.player.toLowerCase()}>
        <div class="crosshair-preview">
          <div class="crosshair-container">
            <div class="crosshair-vertical" style={`background-color: ${colorMap[ch.color] || ch.color}; width: ${ch.thickness}px; height: ${ch.size * 4}px; position: absolute; left: 50%; top: 50%; transform: translate(-50%, -50%);`}></div>
            <div class="crosshair-horizontal" style={`background-color: ${colorMap[ch.color] || ch.color}; width: ${ch.size * 4}px; height: ${ch.thickness}px; position: absolute; left: 50%; top: 50%; transform: translate(-50%, -50%);`}></div>
            {ch.gap > 0 && (
              <>
                <div class="crosshair-top-vertical" style={`background-color: ${colorMap[ch.color] || ch.color}; width: ${ch.thickness}px; height: ${ch.size * 2}px; position: absolute; left: 50%; top: ${50 - ch.gap - ch.size}%; transform: translate(-50%, -50%);`}></div>
                <div class="crosshair-bottom-vertical" style={`background-color: ${colorMap[ch.color] || ch.color}; width: ${ch.thickness}px; height: ${ch.size * 2}px; position: absolute; left: 50%; top: ${50 + ch.gap + ch.size}%; transform: translate(-50%, -50%);`}></div>
                <div class="crosshair-left-horizontal" style={`background-color: ${colorMap[ch.color] || ch.color}; width: ${ch.size * 2}px; height: ${ch.thickness}px; position: absolute; left: ${50 - ch.gap - ch.size}%; top: 50%; transform: translate(-50%, -50%);`}></div>
                <div class="crosshair-right-horizontal" style={`background-color: ${colorMap[ch.color] || ch.color}; width: ${ch.size * 2}px; height: ${ch.thickness}px; position: absolute; left: ${50 + ch.gap + ch.size}%; top: 50%; transform: translate(-50%, -50%);`}></div>
              </>
            )}
            {ch.dot && (
              <div class="crosshair-dot" style={`background-color: ${colorMap[ch.color] || ch.color}; width: ${ch.thickness * 2}px; height: ${ch.thickness * 2}px; border-radius: 50%; position: absolute; left: 50%; top: 50%; transform: translate(-50%, -50%);`}></div>
            )}
          </div>
        </div>
        <div class="card-content">
          <div class="player-info">
            <h3>{ch.player}</h3>
            <div class="team">{ch.team}</div>
          </div>
          <div class="role-badge" data-role-badge={ch.role}>{ch.role}</div>
          <div class="code-section">
            <code class="crosshair-code">{ch.code}</code>
            <button class="copy-btn" data-code={ch.code} title="Copy crosshair code">
              <span class="copy-icon">📋</span> Copy
            </button>
          </div>
          <div class="settings">
            <div class="setting-item">
              <span class="setting-label">Size:</span>
              <span class="setting-value">{ch.size}</span>
            </div>
            <div class="setting-item">
              <span class="setting-label">Gap:</span>
              <span class="setting-value">{ch.gap}</span>
            </div>
            <div class="setting-item">
              <span class="setting-label">Thickness:</span>
              <span class="setting-value">{ch.thickness}</span>
            </div>
            {ch.dot && <div class="setting-item"><span class="setting-badge">Dot</span></div>}
            {ch.outline && <div class="setting-item"><span class="setting-badge">Outline</span></div>}
          </div>
        </div>
      </div>
    ))}
  </div>

  <h2>Frequently Asked Questions</h2>
  <dl class="faq">
    {faqs.map(item => (
      <>
        <dt>{item.q}</dt>
        <dd>{item.a}</dd>
      </>
    ))}
  </dl>

  <div class="internal-links">
    <a href="/crosshair-generator/">Crosshair Generator</a>
    <a href="/edpi-calculator/">eDPI Calculator</a>
    <a href="/sensitivity-converter/">Sensitivity Converter</a>
    <a href="/launch-options/">Launch Options</a>
    <a href="/weapons/">Weapons Database</a>
  </div>

  <style is:inline>
    .filter-section {
      background: var(--bg2);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 1.25rem;
      margin: 1.5rem 0;
      display: flex;
      gap: 1rem;
      flex-wrap: wrap;
      align-items: center;
    }
    
    .filters {
      display: flex;
      gap: 0.5rem;
      flex-wrap: wrap;
    }
    
    .search-input {
      flex: 1;
      min-width: 200px;
      background: var(--bg3);
      color: var(--text);
      border: 1px solid var(--border);
      padding: 0.5rem 0.75rem;
      border-radius: 6px;
      font-size: 0.9rem;
      font-family: inherit;
    }
    
    .search-input:focus {
      outline: none;
      border-color: var(--accent);
      box-shadow: 0 0 0 2px rgba(245, 166, 35, 0.2);
    }
    
    .crosshair-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
      gap: 1.25rem;
      margin: 2rem 0;
    }
    
    .crosshair-card {
      background: var(--bg2);
      border: 1px solid var(--border);
      border-radius: 10px;
      overflow: hidden;
      transition: border-color 0.2s, transform 0.2s, box-shadow 0.2s;
      display: flex;
      flex-direction: column;
    }
    
    .crosshair-card:hover {
      border-color: var(--accent);
      transform: translateY(-4px);
      box-shadow: 0 8px 20px rgba(245, 166, 35, 0.15);
    }
    
    .crosshair-card.hidden {
      display: none;
    }
    
    .crosshair-preview {
      background: linear-gradient(135deg, #0a0a0e 0%, #131318 100%);
      border-bottom: 1px solid var(--border);
      padding: 1.5rem;
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 120px;
    }
    
    .crosshair-container {
      position: relative;
      width: 80px;
      height: 80px;
      border: 1px solid var(--border);
      border-radius: 4px;
      background: rgba(0, 0, 0, 0.5);
    }
    
    .card-content {
      padding: 1.25rem;
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
      flex: 1;
    }
    
    .player-info {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 0.75rem;
    }
    
    .player-info h3 {
      margin: 0;
      font-size: 1.1rem;
      color: var(--text);
      flex: 1;
    }
    
    .team {
      font-size: 0.75rem;
      color: var(--text2);
      opacity: 0.8;
      text-align: right;
    }
    
    .role-badge {
      display: inline-block;
