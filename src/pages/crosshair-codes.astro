  player: string;
  team: string;
  role: 'Rifler' | 'AWPer' | 'IGL' | 'Entry' | 'Support';
  code: string;
  style: number;
  color: string;
  size: number;
  gap: number;
  thickness: number;
  dot: boolean;
  outline: boolean;
}

