---
import Base from '../layouts/Base.astro';
import ExploreMore from '../components/ExploreMore.astro';
import { breadcrumbSchema, faqSchema, toolAppSchema } from '../lib/weapons';
import { PRO_PLAYERS } from '../lib/pro-players';

const title = 'CS2 Pro Crosshair Codes — 860+ Players Library | CSGOLuck Wiki';
const description = 'Browse and copy crosshair codes from 860+ professional CS2 players including s1mple, ZywOo, NiKo, and more. Find your favorite pro\'s crosshair settings and playstyle.';

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Tools', url: '/crosshair-codes' },
  { name: 'Pro Crosshair Codes', url: '/crosshair-codes' },
];

const faqs = [
  {
    q: 'How do I import a CS2 crosshair code?',
    a: 'Copy the crosshair code (starts with "CSGO-"), go to Settings → Game → Crosshair → Import Shared Code, paste it, and click "Import". Your crosshair will update instantly.'
  },
  {
    q: 'What makes a good crosshair?',
    a: 'A good crosshair balances visibility and minimal obstruction. Most pros use small gaps and thin lines to see through to their target. The dot helps track recoil while the outline aids visibility in bright areas.'
  },
  {
    q: 'Should I use a crosshair code or customize my own?',
    a: 'Starting with a pro\'s code is great for learning their playstyle, but personalization matters. Tweak opacity, size, and gap to what feels natural for your eyes and monitor. Many pros fine-tune their crosshairs regularly.'
  },
  {
    q: 'What\'s the difference between crosshair styles?',
    a: 'Styles 0-2 are static lines, style 3 is dynamic (expands on shoot), style 4 is a dot, and style 5 is a crosshair with a larger outline. Most pros use styles 1-2 for clean, static visibility.'
  },
  {
    q: 'Do crosshair codes transfer between CS:GO and CS2?',
    a: 'Yes! Crosshair codes from CS:GO work in CS2. The sharing format remained the same, so you can use classic crosshairs from competitive history.'
  },
];

interface Crosshair {
  player: string;
  team: string;
  role: 'Rifler' | 'AWPer' | 'IGL' | 'Entry' | 'Support';
  code: string;
  style: number;
  color: string;
  size: number;
  gap: number;
  thickness: number;
  dot: boolean;
  outline: boolean;
}

// Map crosshair style strings to numeric values
function mapCrosshairStyle(style: string): number {
  const styleMap: Record<string, number> = {
    'Default': 0,
    'Default Static': 1,
    'Legacy': 2,
    'Classic': 3,
    'Classic Dynamic': 3,
    'Classic Static': 4,
    'Classic Static (1.6 Style)': 5,
  };
  return styleMap[style] ?? 4;
}

// Normalize role names to the display categories used on this page
function normalizeRole(role: string): 'Rifler' | 'AWPer' | 'IGL' | 'Entry' | 'Support' {
  const roleMap: Record<string, 'Rifler' | 'AWPer' | 'IGL' | 'Entry' | 'Support'> = {
    'Rifler': 'Rifler',
    'AWPer': 'AWPer',
    'IGL': 'IGL',
    'Entry Fragger': 'Entry',
    'Entry': 'Entry',
    'Support': 'Support',
    'Lurker': 'Rifler',
    'Coach': 'Support',
  };
  return roleMap[role] ?? 'Rifler';
}

// Resolve crosshair color — prefer crosshairSettings.color, fall back to top-level crosshairColor
function resolveColor(p: typeof PRO_PLAYERS[number]): string {
  const csColor = p.crosshairSettings?.color;
  if (csColor && csColor !== '') return csColor;
  if (p.crosshairColor && p.crosshairColor !== '') return p.crosshairColor;
  return 'Green';
}

// Build crosshair data from canonical player JSON files
const CROSSHAIRS: Crosshair[] = PRO_PLAYERS
  .filter(p => p.crosshairCode && p.crosshairCode.trim() !== '')
  .map(p => ({
    player: p.name,
    team: p.team,
    role: normalizeRole(p.role),
    code: p.crosshairCode,
    style: mapCrosshairStyle(p.crosshairStyle),
    color: resolveColor(p),
    size: p.crosshairSize,
    gap: p.crosshairGap,
    thickness: p.crosshairThickness,
    dot: p.crosshairDot,
    outline: p.crosshairOutline,
  }));

const faqItems = faqs.map(f => ({ q: f.q, a: f.a }));
const breadcrumbJson = breadcrumbSchema(breadcrumbs);
const faqJson = faqSchema(faqItems);

const roles = ['All', 'Rifler', 'AWPer', 'IGL', 'Entry', 'Support'] as const;

const colorMap: Record<string, string> = {
  'Green': '#4caf50',
  'Cyan': '#26a69a',
  'Yellow': '#d4956e',
  'White': '#e4e4ec',
  'Custom': '#ab47bc',
};
---

<Base title={title} description={description} currentNav="/pro-crosshair-codes/">
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJson)}></script>
  <script type="application/ld+json" set:html={JSON.stringify(faqJson)}></script>
  <script type="application/ld+json" set:html={JSON.stringify(toolAppSchema({ name: 'CS2 Pro Crosshair Codes Library', url: 'https://wiki.csgoluck.com/crosshair-codes/', description }))}></script>

  <nav class="breadcrumb"><a href="/">Home</a> <span>/</span> <a href="/cs2-tools/">Tools</a> <span>/</span> <span>Pro Crosshair Codes</span></nav>

  <div class="xc-hero">
    <h1 class="xc-title">CS2 Pro Crosshair Codes</h1>
    <p class="xc-desc">Browse and copy crosshair codes from 860+ professional Counter-Strike 2 players. Learn from the pros and import their exact settings into your game.</p>
  </div>

  <div class="xc-filter-bar">
    <div class="xc-filters">
      <button class="xc-filter-btn xc-filter-active" data-role="All">All Roles</button>
      {roles.slice(1).map(role => (
        <button class="xc-filter-btn" data-role={role}>{role}</button>
      ))}
    </div>
    <input type="text" id="searchInput" class="xc-search" placeholder="Search player name..." aria-label="Search players" />
  </div>

  <div class="xc-grid" id="crosshairGrid">
    {CROSSHAIRS.map(ch => (
      <div class="xc-card" data-role={ch.role} data-player={ch.player.toLowerCase()}>
        <div class="xc-card-preview">
          <div class="xc-ch-container">
            <div style={`background-color: ${colorMap[ch.color] || ch.color}; width: ${ch.thickness}px; height: ${ch.size * 4}px; position: absolute; left: 50%; top: 50%; transform: translate(-50%, -50%);`}></div>
            <div style={`background-color: ${colorMap[ch.color] || ch.color}; width: ${ch.size * 4}px; height: ${ch.thickness}px; position: absolute; left: 50%; top: 50%; transform: translate(-50%, -50%);`}></div>
            {ch.gap > 0 && (
              <>
                <div style={`background-color: ${colorMap[ch.color] || ch.color}; width: ${ch.thickness}px; height: ${ch.size * 2}px; position: absolute; left: 50%; top: ${50 - ch.gap - ch.size}%; transform: translate(-50%, -50%);`}></div>
                <div style={`background-color: ${colorMap[ch.color] || ch.color}; width: ${ch.thickness}px; height: ${ch.size * 2}px; position: absolute; left: 50%; top: ${50 + ch.gap + ch.size}%; transform: translate(-50%, -50%);`}></div>
                <div style={`background-color: ${colorMap[ch.color] || ch.color}; width: ${ch.size * 2}px; height: ${ch.thickness}px; position: absolute; left: ${50 - ch.gap - ch.size}%; top: 50%; transform: translate(-50%, -50%);`}></div>
                <div style={`background-color: ${colorMap[ch.color] || ch.color}; width: ${ch.size * 2}px; height: ${ch.thickness}px; position: absolute; left: ${50 + ch.gap + ch.size}%; top: 50%; transform: translate(-50%, -50%);`}></div>
              </>
            )}
            {ch.dot && (
              <div style={`background-color: ${colorMap[ch.color] || ch.color}; width: ${ch.thickness * 2}px; height: ${ch.thickness * 2}px; border-radius: 50%; position: absolute; left: 50%; top: 50%; transform: translate(-50%, -50%);`}></div>
            )}
          </div>
        </div>
        <div class="xc-card-body">
          <div class="xc-card-top">
            <h3 class="xc-player-name">{ch.player}</h3>
            <span class="xc-team">{ch.team}</span>
          </div>
          <span class={`xc-role xc-role-${ch.role.toLowerCase()}`}>{ch.role}</span>
          <div class="xc-code-row">
            <code class="xc-code">{ch.code}</code>
            <button class="xc-copy-btn" data-code={ch.code}>Copy</button>
          </div>
          <div class="xc-stats">
            <span class="xc-stat"><strong>Size:</strong> {ch.size}</span>
            <span class="xc-stat"><strong>Gap:</strong> {ch.gap}</span>
            <span class="xc-stat"><strong>Thick:</strong> {ch.thickness}</span>
            {ch.dot && <span class="xc-badge">Dot</span>}
            {ch.outline && <span class="xc-badge">Outline</span>}
          </div>
        </div>
      </div>
    ))}
  </div>

  <section class="xc-faq">
    <h2 class="xc-section-title">Frequently Asked Questions</h2>
    {faqs.map(item => (
      <details class="xc-faq-item">
        <summary class="xc-faq-q">{item.q}</summary>
        <p class="xc-faq-a">{item.a}</p>
      </details>
    ))}
  </section>

  <div class="xc-links-block">
    <h2 class="xc-section-title">Related Tools</h2>
    <div class="xc-link-list">
      <a href="/crosshair-generator/" class="xc-link">Crosshair Generator</a>
      <a href="/edpi-calculator/" class="xc-link">eDPI Calculator</a>
      <a href="/sensitivity-converter/" class="xc-link">Sensitivity Converter</a>
      <a href="/launch-options/" class="xc-link">Launch Options</a>
      <a href="/cs2-weapons/" class="xc-link">Weapons Database</a>
      <a href="/cs2-tools/" class="xc-link">All Tools</a>
    </div>
  </div>

  <ExploreMore context="tools" />
</Base>

<style>
  .xc-hero{padding:1.5rem 0;margin-bottom:1.5rem}
  .xc-title{font-size:2rem;font-weight:800;margin:0 0 .5rem;color:var(--text)}
  .xc-desc{color:var(--text2);font-size:.95rem;margin:0;max-width:600px;line-height:1.6}

  .xc-filter-bar{background:var(--bg2);border:1px solid var(--border);border-radius:4px;padding:1rem;margin-bottom:1.5rem;display:flex;gap:1rem;flex-wrap:wrap;align-items:center}
  .xc-filters{display:flex;gap:.4rem;flex-wrap:wrap}
  .xc-filter-btn{padding:.45rem .85rem;background:var(--bg3);border:1px solid var(--border);border-radius:4px;color:var(--text2);cursor:pointer;font-weight:500;font-size:.82rem;font-family:inherit;transition:all .15s}
  .xc-filter-btn:hover{border-color:var(--accent);color:var(--text)}
  .xc-filter-active{background:var(--accent);border-color:var(--accent);color:#000}
  .xc-search{flex:1;min-width:200px;background:var(--bg3);color:var(--text);border:1px solid var(--border);padding:.5rem .75rem;border-radius:4px;font-size:.9rem;font-family:inherit}
  .xc-search:focus{outline:none;border-color:var(--accent)}

  .xc-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(320px,1fr));gap:1rem;margin-bottom:2rem}

  .xc-card{background:var(--bg2);border:1px solid var(--border);border-left:3px solid transparent;border-radius:4px;overflow:hidden;transition:border-left-color .15s;display:flex;flex-direction:column}
  .xc-card:hover{border-left-color:var(--accent)}
  .xc-card.xc-hidden{display:none}

  .xc-card-preview{background:linear-gradient(135deg,#0a0a0e 0%,#131318 100%);border-bottom:1px solid var(--border);padding:1.25rem;display:flex;align-items:center;justify-content:center;min-height:100px}
  .xc-ch-container{position:relative;width:80px;height:80px;border:1px solid var(--border);border-radius:4px;background:rgba(0,0,0,.5)}

  .xc-card-body{padding:1rem;display:flex;flex-direction:column;gap:.6rem;flex:1}
  .xc-card-top{display:flex;justify-content:space-between;align-items:flex-start;gap:.5rem}
  .xc-player-name{margin:0;font-size:1rem;font-weight:700;color:var(--text)}
  .xc-team{font-size:.72rem;color:var(--text2);text-align:right}

  .xc-role{display:inline-block;padding:.25rem .5rem;border-radius:4px;font-size:.72rem;font-weight:600;width:fit-content;border:1px solid var(--border)}
  .xc-role-rifler{background:rgba(239,83,80,.1);color:#ef5350;border-color:#ef5350}
  .xc-role-awper{background:rgba(255,193,7,.1);color:#e8b992;border-color:#e8b992}
  .xc-role-igl{background:rgba(66,165,245,.1);color:#42a5f5;border-color:#42a5f5}
  .xc-role-entry{background:rgba(171,71,188,.1);color:#ab47bc;border-color:#ab47bc}
  .xc-role-support{background:rgba(38,166,154,.1);color:#26a69a;border-color:#26a69a}

  .xc-code-row{display:flex;gap:.4rem;align-items:stretch}
  .xc-code{flex:1;background:var(--bg3);color:var(--accent);padding:.4rem .6rem;border-radius:4px;font-size:.72rem;font-family:'Courier New',monospace;font-weight:600;border:1px solid var(--border);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;display:flex;align-items:center}
  .xc-copy-btn{background:var(--accent);color:#000;border:none;padding:.4rem .65rem;border-radius:4px;font-size:.72rem;font-weight:600;cursor:pointer;white-space:nowrap;font-family:inherit;transition:opacity .15s}
  .xc-copy-btn:hover{opacity:.9}
  .xc-copy-btn.xc-copied{background:#4caf50}

  .xc-stats{display:flex;flex-wrap:wrap;gap:.5rem;padding-top:.6rem;border-top:1px solid var(--border);font-size:.78rem;color:var(--text2)}
  .xc-stat strong{color:var(--text)}
  .xc-badge{display:inline-block;background:var(--accent);color:#000;padding:.1rem .35rem;border-radius:4px;font-size:.68rem;font-weight:700}

  .xc-section-title{font-size:1.1rem;font-weight:700;color:var(--text);margin:0 0 1rem}

  .xc-faq{margin-bottom:2rem}
  .xc-faq-item{background:var(--bg2);border:1px solid var(--border);border-radius:4px;margin-bottom:.5rem;overflow:hidden}
  .xc-faq-q{padding:.8rem 1rem;cursor:pointer;font-weight:600;font-size:.9rem;color:var(--text);list-style:none;display:flex;align-items:center;justify-content:space-between}
  .xc-faq-q::-webkit-details-marker{display:none}
  .xc-faq-q::after{content:'+';font-size:1.1rem;color:var(--accent);font-weight:700}
  .xc-faq-item[open] .xc-faq-q::after{content:'-'}
  .xc-faq-item[open]{border-left:3px solid var(--accent)}
  .xc-faq-a{padding:0 1rem .8rem;margin:0;font-size:.88rem;color:var(--text2);line-height:1.6}

  .xc-links-block{background:var(--bg2);border:1px solid var(--border);border-radius:4px;padding:1.5rem;margin-bottom:2rem}
  .xc-link-list{display:flex;flex-direction:column;gap:.4rem}
  .xc-link{display:block;padding:.5rem .75rem;background:var(--bg3);border:1px solid var(--border);border-left:3px solid transparent;border-radius:4px;color:var(--accent);text-decoration:none;font-size:.85rem;transition:border-left-color .15s}
  .xc-link:hover{border-left-color:var(--accent)}

  @media(max-width:768px){
    .xc-filter-bar{flex-direction:column;align-items:stretch}
    .xc-search{width:100%;min-width:unset}
    .xc-grid{grid-template-columns:1fr}
  }
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', function() {
    const grid = document.getElementById('crosshairGrid');
    const filterBtns = document.querySelectorAll('.xc-filter-btn');
    const searchInput = document.getElementById('searchInput');
    let activeRole = 'All';
    let searchTerm = '';

    function filterCards() {
      const cards = grid.querySelectorAll('.xc-card');
      cards.forEach(card => {
        const cardRole = card.dataset.role;
        const cardPlayer = card.dataset.player;

        const roleMatch = activeRole === 'All' || cardRole === activeRole;
        const searchMatch = cardPlayer.includes(searchTerm.toLowerCase());

        if (roleMatch && searchMatch) {
          card.classList.remove('xc-hidden');
        } else {
          card.classList.add('xc-hidden');
        }
      });
    }

    filterBtns.forEach(btn => {
      btn.addEventListener('click', function() {
        filterBtns.forEach(b => b.classList.remove('xc-filter-active'));
        this.classList.add('xc-filter-active');
        activeRole = this.dataset.role;
        filterCards();
      });
    });

    searchInput.addEventListener('input', function() {
      searchTerm = this.value;
      filterCards();
    });

    const copyBtns = document.querySelectorAll('.xc-copy-btn');
    copyBtns.forEach(btn => {
      btn.addEventListener('click', function() {
        const code = this.dataset.code;
        navigator.clipboard.writeText(code).then(() => {
          const originalText = this.textContent;
          this.classList.add('xc-copied');
          this.textContent = 'Copied!';
          setTimeout(() => {
            this.classList.remove('xc-copied');
            this.textContent = originalText;
          }, 2000);
        }).catch(() => {
          alert('Failed to copy: ' + code);
        });
      });
    });
  });
</script>
