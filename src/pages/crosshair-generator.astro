---
import Base from '../layouts/Base.astro';
import ExploreMore from '../components/ExploreMore.astro';
import { faqSchema, breadcrumbSchema } from '../lib/weapons';

const title = 'CS2 Crosshair Generator — Build & Preview Custom Crosshairs | CSGOLuck Wiki';
const description = 'Create your perfect CS2 crosshair with our visual generator. Real-time preview, pro player presets, and instant console commands. Export your crosshair code with one click.';

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Tools', url: '/crosshair-generator' },
  { name: 'Crosshair Generator', url: '/crosshair-generator' },
];

const faqs = [
  { question: 'How do I apply a custom crosshair in CS2?', answer: 'Open the console with ~ and paste the crosshair commands. Alternatively, go to Settings → Game → Crosshair and adjust each setting manually. You can also share crosshair codes via the in-game crosshair menu.' },
  { question: 'What crosshair do most CS2 pros use?', answer: 'Most professionals use small, static crosshairs. The most common setup is: Size 2, Gap -2, Thickness 0, no dot, Style 4 (static), Color 1 (green). However, preferences vary widely — some pros use dot-only crosshairs while others prefer larger crosses.' },
  { question: 'Should I use a dynamic or static crosshair?', answer: 'Static crosshairs (Style 4 or 5) are preferred by competitive players because they don\'t move during shooting. Dynamic crosshairs expand to show weapon inaccuracy, which can be helpful for beginners learning spray control.' },
  { question: 'What is the best crosshair color for visibility?', answer: 'Bright green (Color 1) is the most popular because it contrasts well against most map environments. Cyan and yellow are also popular choices. Avoid red and dark colors as they blend into common map textures.' },
  { question: 'Can I use a dot crosshair in CS2?', answer: 'Yes, set cl_crosshairsize 0 and cl_crosshairdot 1. Many AWPers prefer dot crosshairs for precise positioning. You can adjust dot size with cl_crosshairthickness.' },
];

const proPresets = [
  { name: 's1mple', style: 4, size: 2, gap: -2, thickness: 0, dot: false, color: 1, outline: 0, alpha: 255 },
  { name: 'ZywOo', style: 4, size: 1.5, gap: -3, thickness: 0, dot: false, color: 1, outline: 0, alpha: 255 },
  { name: 'NiKo', style: 4, size: 1, gap: -3, thickness: 0, dot: false, color: 4, outline: 0, alpha: 255 },
  { name: 'donk', style: 4, size: 2, gap: -2, thickness: 0, dot: false, color: 1, outline: 1, alpha: 255 },
  { name: 'ropz', style: 4, size: 2, gap: -2, thickness: 0.5, dot: false, color: 1, outline: 0, alpha: 200 },
  { name: 'device', style: 5, size: 1, gap: -3, thickness: 0, dot: true, color: 1, outline: 0, alpha: 255 },
];

const colorMap: Record<number, string> = {
  0: '#ff0000', 1: '#00ff00', 2: '#ffff00', 3: '#2020ff', 4: '#00ffff',
};

const toolSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": title,
  "description": description,
  "applicationCategory": "UtilityApplication",
  "operatingSystem": "Web",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
  "author": { "@type": "Organization", "name": "CSGOLuck Wiki", "url": "https://wiki.csgoluck.com" }
});

const howToSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "HowTo",
  "name": "How to Create a Custom CS2 Crosshair",
  "description": "Use the CSGOLuck Wiki Crosshair Generator to design, preview, and export a custom crosshair for Counter-Strike 2.",
  "step": [
    { "@type": "HowToStep", "name": "Choose a crosshair style", "text": "Select a crosshair style from the dropdown. Style 4 (Static Classic) and Style 5 (Static 1.6) are recommended for competitive play as they remain fixed during movement and shooting." },
    { "@type": "HowToStep", "name": "Adjust size, gap, and thickness", "text": "Use the sliders to set crosshair size (arm length), gap (distance from center), and thickness (arm width). Most pros use Size 1-2, Gap -2 to -3, and Thickness 0-0.5." },
    { "@type": "HowToStep", "name": "Set color and visibility options", "text": "Pick a crosshair color (green is most popular), adjust alpha for transparency, toggle the center dot, and set outline thickness for better contrast." },
    { "@type": "HowToStep", "name": "Preview your crosshair in real time", "text": "Watch the live preview update as you make changes. You can also load pro player presets (s1mple, ZywOo, NiKo, etc.) to start from a known configuration." },
    { "@type": "HowToStep", "name": "Copy the console commands", "text": "Click 'Copy Commands' to copy the generated console commands to your clipboard. Paste them into the CS2 console (~) to apply your crosshair in-game." }
  ]
});
---

<Base title={title} description={description} currentNav="/cs2-tools/">
  <script type="application/ld+json" set:html={toolSchema}></script>
  <script type="application/ld+json" set:html={howToSchema}></script>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema(breadcrumbs))}></script>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema(faqs))}></script>

  <nav class="breadcrumb"><a href="/">Home</a> <span>/</span> <a href="/cs2-tools/">Tools</a> <span>/</span> <span>Crosshair Generator</span></nav>

  <div class="cxg-hero">
    <h1 class="cxg-title">CS2 Crosshair Generator</h1>
    <p class="cxg-desc">Design your ideal crosshair with real-time visual preview. Adjust every parameter, load <a href="/pro-players/" style="color:var(--accent)">pro player</a> presets, and copy the <a href="/cs2-commands/" style="color:var(--accent)">console commands</a> instantly.</p>
  </div>

  <div class="cxg-panel">
    <div class="cxg-layout">
      <div class="cxg-settings">
        <h2 class="cxg-section-title">Settings</h2>
        <div class="cxg-field">
          <label class="cxg-label" for="chStyle">Style</label>
          <select id="chStyle" class="cxg-select">
            <option value="4">4 — Static (Classic)</option>
            <option value="5">5 — Static (1.6 Style)</option>
            <option value="2">2 — Classic Dynamic</option>
            <option value="3">3 — Classic Static Dot</option>
          </select>
        </div>
        <div class="cxg-field">
          <label class="cxg-label" for="chSize">Size <span class="cxg-range-val" id="chSizeVal">2</span></label>
          <input type="range" id="chSize" min="0" max="10" step="0.5" value="2" class="cxg-slider">
        </div>
        <div class="cxg-field">
          <label class="cxg-label" for="chGap">Gap <span class="cxg-range-val" id="chGapVal">-2</span></label>
          <input type="range" id="chGap" min="-5" max="5" step="0.5" value="-2" class="cxg-slider">
        </div>
        <div class="cxg-field">
          <label class="cxg-label" for="chThick">Thickness <span class="cxg-range-val" id="chThickVal">0</span></label>
          <input type="range" id="chThick" min="0" max="6" step="0.5" value="0" class="cxg-slider">
        </div>
        <div class="cxg-field">
          <label class="cxg-label" for="chColor">Color</label>
          <select id="chColor" class="cxg-select">
            <option value="0">Red</option>
            <option value="1" selected>Green</option>
            <option value="2">Yellow</option>
            <option value="3">Blue</option>
            <option value="4">Cyan</option>
          </select>
        </div>
        <div class="cxg-field cxg-field-row">
          <label class="cxg-label" for="chDot">Center Dot</label>
          <input type="checkbox" id="chDot" class="cxg-checkbox">
        </div>
        <div class="cxg-field">
          <label class="cxg-label" for="chOutline">Outline <span class="cxg-range-val" id="chOutlineVal">0</span></label>
          <input type="range" id="chOutline" min="0" max="3" step="0.5" value="0" class="cxg-slider">
        </div>
        <div class="cxg-field">
          <label class="cxg-label" for="chAlpha">Alpha <span class="cxg-range-val" id="chAlphaVal">255</span></label>
          <input type="range" id="chAlpha" min="0" max="255" step="5" value="255" class="cxg-slider">
        </div>

        <h3 class="cxg-preset-title">Pro Player Presets</h3>
        <div class="cxg-preset-btns" id="presetBtns">
          {proPresets.map(p => (
            <button class="cxg-preset-btn" data-preset={JSON.stringify(p)}>{p.name}</button>
          ))}
        </div>
      </div>

      <div class="cxg-preview-col">
        <h2 class="cxg-section-title">Preview</h2>
        <div class="cxg-preview-box" id="chPreview">
          <div id="crosshair" style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%)"></div>
        </div>
        <div class="cxg-commands-box">
          <span class="cxg-commands-label">Console Commands</span>
          <code class="cxg-commands-code" id="chCommands"></code>
          <button class="cxg-copy-btn" id="copyBtn">Copy Commands</button>
        </div>
      </div>
    </div>
  </div>

  <div class="cxg-two-col">
    <div class="cxg-info-block">
      <h2 class="cxg-section-title">Understanding Crosshair Parameters</h2>
      <ul class="cxg-info-list">
        <li><strong>Style:</strong> Determines whether your crosshair expands during movement/shooting. Styles 4 and 5 are static and preferred by competitive players.</li>
        <li><strong>Size:</strong> Controls the length of the four crosshair arms.</li>
        <li><strong>Gap:</strong> Sets the distance between the centre point and where arms begin. Negative values create a tighter crosshair.</li>
        <li><strong>Thickness:</strong> Adjusts the width of each arm. Most pros use 0 or 0.5.</li>
        <li><strong>Color & Alpha:</strong> Green (Color 1) dominates professional play. Alpha controls transparency (255 = fully opaque).</li>
      </ul>
    </div>

    <div class="cxg-info-block">
      <h2 class="cxg-section-title">Related Tools & Guides</h2>
      <div class="cxg-link-list">
        <a href="/cs2-guides/crosshair-guide/" class="cxg-link">Crosshair Guide</a>
        <a href="/sensitivity-converter/" class="cxg-link">Sensitivity Converter</a>
        <a href="/edpi-calculator/" class="cxg-link">eDPI Calculator</a>
        <a href="/autoexec-generator/" class="cxg-link">Autoexec Generator</a>
        <a href="/launch-options/" class="cxg-link">Launch Options</a>
        <a href="/crosshair-codes/" class="cxg-link">Crosshair Codes</a>
        <a href="/cs2-tools/" class="cxg-link">All Tools</a>
        <a href="/pro-players/" class="cxg-link">Pro Player Settings</a>
        <a href="/cs2-commands/" class="cxg-link">Console Commands</a>
        <a href="/cs2-guides/config-guide/" class="cxg-link">Config & Settings Guide</a>
      </div>
    </div>
  </div>

  <section class="cxg-faq">
    <h2 class="cxg-section-title">Frequently Asked Questions</h2>
    {faqs.map(f => (
      <details class="cxg-faq-item">
        <summary class="cxg-faq-q">{f.question}</summary>
        <p class="cxg-faq-a">{f.answer}</p>
      </details>
    ))}
  </section>

  <ExploreMore context="tools" />
</Base>

<style>
  .cxg-hero{padding:1.5rem 0;margin-bottom:1.5rem}
  .cxg-title{font-size:2rem;font-weight:800;margin:0 0 .5rem;color:var(--text)}
  .cxg-desc{color:var(--text2);font-size:.95rem;margin:0;max-width:600px;line-height:1.6}

  .cxg-panel{background:var(--bg2);border:1px solid var(--border);border-radius:4px;padding:1.5rem;margin-bottom:2rem}
  .cxg-layout{display:grid;grid-template-columns:1fr 1fr;gap:2rem;align-items:start}
  .cxg-settings{display:flex;flex-direction:column;gap:.75rem}
  .cxg-section-title{font-size:1.1rem;font-weight:700;color:var(--text);margin:0 0 .5rem}

  .cxg-field{display:flex;flex-direction:column;gap:.3rem}
  .cxg-field-row{flex-direction:row;align-items:center;gap:.75rem}
  .cxg-label{font-weight:600;color:var(--text2);font-size:.82rem;text-transform:uppercase;letter-spacing:.04em}
  .cxg-range-val{color:var(--accent);font-weight:700}

  .cxg-select,.cxg-slider{padding:.5rem;background:var(--bg3);border:1px solid var(--border);border-radius:4px;color:var(--text);font-size:.9rem;font-family:inherit}
  .cxg-select:focus,.cxg-slider:focus{outline:none;border-color:var(--accent)}
  .cxg-checkbox{width:18px;height:18px;accent-color:var(--accent)}

  .cxg-preset-title{font-size:.95rem;font-weight:700;color:var(--text);margin:.75rem 0 .4rem}
  .cxg-preset-btns{display:flex;gap:.4rem;flex-wrap:wrap}
  .cxg-preset-btn{padding:.45rem .85rem;background:var(--bg3);border:1px solid var(--border);border-radius:4px;color:var(--text2);cursor:pointer;font-weight:500;font-size:.82rem;font-family:inherit;transition:all .15s}
  .cxg-preset-btn:hover{border-color:var(--accent);color:var(--text)}

  .cxg-preview-col{display:flex;flex-direction:column;gap:.75rem}
  .cxg-preview-box{width:100%;aspect-ratio:16/9;background:#333;border-radius:4px;position:relative;overflow:hidden;border:1px solid var(--border)}

  .cxg-commands-box{background:var(--bg);border:1px solid var(--border);border-radius:4px;padding:1rem;display:flex;flex-direction:column;gap:.5rem}
  .cxg-commands-label{font-weight:700;color:var(--text);font-size:.85rem}
  .cxg-commands-code{display:block;background:var(--bg3);padding:.6rem;border-radius:4px;font-size:.78rem;color:var(--accent);word-break:break-all;line-height:1.6;font-family:'Courier New',monospace}
  .cxg-copy-btn{padding:.5rem 1rem;background:linear-gradient(135deg,#2ecc71,#27ae60);color:#fff;border:none;border-radius:4px;cursor:pointer;font-weight:700;font-size:.85rem;font-family:inherit;box-shadow:0 2px 8px rgba(46,204,113,.2);transition:all .2s ease}
  .cxg-copy-btn:hover{transform:translateY(-1px);box-shadow:0 3px 12px rgba(46,204,113,.35)}

  .cxg-two-col{display:grid;grid-template-columns:1fr 1fr;gap:1.5rem;margin-bottom:2rem}
  .cxg-info-block{background:var(--bg2);border:1px solid var(--border);border-radius:4px;padding:1.5rem}
  .cxg-info-list{list-style:none;padding:0;margin:0}
  .cxg-info-list li{padding:.6rem 0;border-bottom:1px solid var(--border);color:var(--text2);font-size:.88rem;line-height:1.5}
  .cxg-info-list li:last-child{border-bottom:none}
  .cxg-info-list strong{color:var(--text)}

  .cxg-link-list{display:flex;flex-direction:column;gap:.4rem}
  .cxg-link{display:block;padding:.5rem .75rem;background:var(--bg3);border:1px solid var(--border);border-left:3px solid transparent;border-radius:4px;color:var(--accent);text-decoration:none;font-size:.85rem;transition:border-left-color .15s}
  .cxg-link:hover{border-left-color:var(--accent)}

  .cxg-faq{margin-bottom:2rem}
  .cxg-faq-item{background:var(--bg2);border:1px solid var(--border);border-radius:4px;margin-bottom:.5rem;overflow:hidden}
  .cxg-faq-q{padding:.8rem 1rem;cursor:pointer;font-weight:600;font-size:.9rem;color:var(--text);list-style:none;display:flex;align-items:center;justify-content:space-between}
  .cxg-faq-q::-webkit-details-marker{display:none}
  .cxg-faq-q::after{content:'+';font-size:1.1rem;color:var(--accent);font-weight:700}
  .cxg-faq-item[open] .cxg-faq-q::after{content:'-'}
  .cxg-faq-item[open]{border-left:3px solid var(--accent)}
  .cxg-faq-a{padding:0 1rem .8rem;margin:0;font-size:.88rem;color:var(--text2);line-height:1.6}

  @media(max-width:768px){
    .cxg-layout{grid-template-columns:1fr}
    .cxg-two-col{grid-template-columns:1fr}
  }
</style>

<script is:inline>
(function(){
  var colorMap={0:'#ff0000',1:'#00ff00',2:'#ffff00',3:'#2020ff',4:'#00ffff'};
  var els={style:document.getElementById('chStyle'),size:document.getElementById('chSize'),gap:document.getElementById('chGap'),thick:document.getElementById('chThick'),color:document.getElementById('chColor'),dot:document.getElementById('chDot'),outline:document.getElementById('chOutline'),alpha:document.getElementById('chAlpha')};

  function render(){
    var s=parseFloat(els.size.value);
    var g=parseFloat(els.gap.value);
    var t=Math.max(parseFloat(els.thick.value),0.5);
    var c=colorMap[parseInt(els.color.value)]||'#00ff00';
    var a=parseInt(els.alpha.value)/255;
    var ol=parseFloat(els.outline.value);
    var showDot=els.dot.checked;

    document.getElementById('chSizeVal').textContent=els.size.value;
    document.getElementById('chGapVal').textContent=els.gap.value;
    document.getElementById('chThickVal').textContent=els.thick.value;
    document.getElementById('chOutlineVal').textContent=els.outline.value;
    document.getElementById('chAlphaVal').textContent=els.alpha.value;

    var px=function(v){return Math.round(v*3)+'px';};
    var ch=document.getElementById('crosshair');
    var armLen=px(s*2);
    var gapPx=Math.round((g+5)*3);
    var thickPx=Math.max(Math.round(t*2),1);
    var shadow=ol>0?'0 0 0 '+Math.round(ol)+'px rgba(0,0,0,0.8)':'none';

    ch.innerHTML='';
    var arms=[
      {x:-gapPx-s*6,y:-thickPx/2,w:s*6,h:thickPx},
      {x:gapPx,y:-thickPx/2,w:s*6,h:thickPx},
      {x:-thickPx/2,y:-gapPx-s*6,w:thickPx,h:s*6},
      {x:-thickPx/2,y:gapPx,w:thickPx,h:s*6},
    ];
    arms.forEach(function(arm){
      var d=document.createElement('div');
      d.style.cssText='position:absolute;left:50%;top:50%;background:'+c+';opacity:'+a+';box-shadow:'+shadow+';transform:translate('+arm.x+'px,'+arm.y+'px);width:'+arm.w+'px;height:'+arm.h+'px;';
      ch.appendChild(d);
    });
    if(showDot){
      var dotEl=document.createElement('div');
      var dotSize=Math.max(thickPx+2,3);
      dotEl.style.cssText='position:absolute;left:50%;top:50%;background:'+c+';opacity:'+a+';width:'+dotSize+'px;height:'+dotSize+'px;transform:translate(-50%,-50%);box-shadow:'+shadow;
      ch.appendChild(dotEl);
    }

    var cmds='cl_crosshairstyle '+els.style.value+'; cl_crosshairsize '+els.size.value+'; cl_crosshairgap '+els.gap.value+'; cl_crosshairthickness '+els.thick.value+'; cl_crosshaircolor '+els.color.value+'; cl_crosshairdot '+(showDot?1:0)+'; cl_crosshair_outlinethickness '+els.outline.value+'; cl_crosshairalpha '+els.alpha.value+'; cl_crosshair_drawoutline '+(ol>0?1:0);
    document.getElementById('chCommands').textContent=cmds;
  }

  Object.values(els).forEach(function(el){
    el.addEventListener('input',render);
    el.addEventListener('change',render);
  });

  document.getElementById('presetBtns').addEventListener('click',function(e){
    var btn=e.target.closest('[data-preset]');
    if(!btn)return;
    var p=JSON.parse(btn.dataset.preset);
    els.style.value=p.style;
    els.size.value=p.size;
    els.gap.value=p.gap;
    els.thick.value=p.thickness;
    els.color.value=p.color;
    els.dot.checked=p.dot;
    els.outline.value=p.outline;
    els.alpha.value=p.alpha;
    render();
  });

  document.getElementById('copyBtn').addEventListener('click',function(){
    var text=document.getElementById('chCommands').textContent;
    navigator.clipboard.writeText(text).then(function(){
      document.getElementById('copyBtn').textContent='Copied!';
      setTimeout(function(){document.getElementById('copyBtn').textContent='Copy Commands';},2000);
    });
  });

  render();
})();
</script>
