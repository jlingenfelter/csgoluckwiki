---
import Base from '../layouts/Base.astro';
import ExploreMore from '../components/ExploreMore.astro';
import { faqSchema, breadcrumbSchema } from '../lib/weapons';
import { COMMAND_CATEGORIES, ALL_COMMANDS } from '../lib/commands';

const title = 'CS2 Console Commands — Full Searchable Index | CSGOLuck Wiki';
const description = 'An exhaustive CS2 console command directory. Look up 300+ variables and commands organized by topic — movement, firearms, interface, networking, practice mode, server admin, visuals, crosshair, audio, and more. Copy any entry with one click.';

const faqs = [
  { question: 'How do I enable and access the developer console?', answer: 'Head to Settings, select the Game tab, locate the "Enable Developer Console (~)" option, and flip it to "Yes". Once in a match, tap the tilde key (~) — usually found directly above Tab — to bring up the console window where you can enter commands.' },
  { question: 'What separates a console command from a console variable (cvar)?', answer: 'A command triggers an immediate action the moment you press Enter — examples include "quit" and "noclip". A cvar, on the other hand, holds a stored value that adjusts a game setting, such as "sensitivity 2.5" or "cl_showfps 1". Cvars remain in effect across play sessions when you save them with host_writeconfig.' },
  { question: 'Which console commands are allowed in ranked matches?', answer: 'Client-side commands — those prefixed with cl_, hud_, or crosshair — function in every game mode, including competitive. Server-side commands (sv_, mp_ prefixes) are restricted to servers where you hold admin privileges or to offline and private lobbies. Any command gated behind sv_cheats 1 is automatically blocked on Valve matchmaking servers.' },
  { question: 'How can I make my console settings persist after restarting CS2?', answer: 'Set up an autoexec.cfg text file inside your CS2 configuration directory (Steam/steamapps/common/Counter-Strike Global Offensive/game/csgo/cfg/). List each command on its own line, and finish with host_writeconfig at the bottom. CS2 will execute every line in this file automatically each time the game starts up.' },
  { question: 'What happens when you activate sv_cheats 1?', answer: 'Turning on sv_cheats 1 unlocks a set of restricted development commands on that server — things like noclip, invincibility, and grenade trajectory overlays used for practice. It is only available in private or offline lobbies and will suspend achievement tracking for the duration of the session.' },
  { question: 'Is there any risk of a VAC ban from running console commands?', answer: 'None whatsoever. The developer console is an official, built-in feature of Counter-Strike 2. No console command can trigger a VAC ban. If you attempt a cheat-protected command on an official server, it simply will not run — no penalty, no flag.' },
];

const categories = COMMAND_CATEGORIES;
const totalCommands = categories.reduce((sum, cat) => sum + cat.commands.length, 0);
---

<Base title={title} description={description} currentNav="/cs2-tools/">
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema([{name:'Home',url:'/'},{name:'Tools',url:'/cs2-tools/'},{name:'Console Commands',url:'/cs2-commands/'}]))}></script>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema(faqs))}></script>

  <nav class="breadcrumb">
    <a href="/">Home</a> / <a href="/cs2-tools/">Tools</a> / <span>Console Commands</span>
  </nav>

  <section class="cmh-hero">
    <h1>CS2 Console Commands</h1>
    <p class="cmh-hero-desc">An all-in-one index of <strong>{totalCommands}</strong> CS2 console commands and cvars spread across <strong>{categories.length}</strong> categories. Find, filter, and copy any entry in seconds. Generate a complete <a href="/autoexec-generator/" style="color:var(--accent)">autoexec.cfg</a> or set up <a href="/practice-config/" style="color:var(--accent)">practice server configs</a> with our companion tools.</p>
  </section>

  <!-- Search & Filters -->
  <div class="cmh-controls">
    <input type="text" id="cmdSearch" placeholder="Search commands... (e.g. crosshair, fps, grenade)" class="cmh-search" />
    <div class="cmh-filter-row">
      <button class="cmh-filter active" data-filter="all">All Commands</button>
      <button class="cmh-filter" data-filter="safe">Multiplayer Safe</button>
      <button class="cmh-filter" data-filter="cheat">sv_cheats Required</button>
    </div>
    <div class="cmh-cat-row" id="catPills">
      {categories.map(cat => (
        <button class="cmh-cat-pill" data-cat={cat.id}>{cat.icon} {cat.name}</button>
      ))}
    </div>
  </div>

  <!-- Stats bar -->
  <div class="cmh-stats" id="cmdStats">
    Showing <strong id="visibleCount">{totalCommands}</strong> of {totalCommands} commands
  </div>

  <!-- How to Enable Console -->
  <section class="cmh-howto">
    <h2>How to Open the Console</h2>
    <div class="cmh-steps">
      <div class="cmh-step">
        <span class="cmh-step-num">1</span>
        <div>
          <strong>Open Settings</strong>
          <p>Click the gear icon in the top-left corner of the CS2 main menu.</p>
        </div>
      </div>
      <div class="cmh-step">
        <span class="cmh-step-num">2</span>
        <div>
          <strong>Enable Console</strong>
          <p>Go to <em>Game</em> tab, find <em>Enable Developer Console (~)</em>, set to <em>Yes</em>.</p>
        </div>
      </div>
      <div class="cmh-step">
        <span class="cmh-step-num">3</span>
        <div>
          <strong>Press Tilde (~)</strong>
          <p>In-game, press the <code>~</code> key (above Tab) to open the console. Type any command and press Enter.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Command Categories -->
  {categories.map(cat => (
    <section class="cmh-category" data-catid={cat.id}>
      <div class="cmh-cat-header">
        <span class="cmh-cat-icon">{cat.icon}</span>
        <div class="cmh-cat-info">
          <h2 id={cat.id}><a href={'/commands/' + cat.id + '/'}>{cat.name}</a></h2>
          <p>{cat.desc}</p>
        </div>
        <span class="cmh-cat-count">{cat.commands.length}</span>
      </div>
      <div class="cmh-table-wrap">
        <table class="cmh-table">
          <thead>
            <tr>
              <th>Command</th>
              <th>Description</th>
              <th>Default</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            {cat.commands.map(c => (
              <tr class="cmh-row" id={c.cmd.toLowerCase().replace(/[^a-z0-9_]/g, '_')} data-cmd={c.cmd.toLowerCase()} data-desc={c.desc.toLowerCase()} data-cheat={c.cheat ? '1' : '0'}>
                <td class="cmh-cmd-name">
                  <a href={'/command/' + c.cmd.replace(/^\+/, '').replace(/_/g, '-').toLowerCase() + '/'}><code>{c.cmd}</code></a>
                  {c.cheat && <span class="cmh-sv-badge" title="Requires sv_cheats 1">SV</span>}
                </td>
                <td class="cmh-cmd-desc">{c.desc}</td>
                <td class="cmh-cmd-default">{c.def || '—'}</td>
                <td class="cmh-cmd-copy"><button class="cmh-copy-btn" data-copy={c.cmd} title="Copy command">Copy</button></td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>
  ))}

  <!-- No Results -->
  <div id="noResults" class="cmh-no-results" style="display:none">
    <p>No commands found matching your search. Try a different keyword or clear your filters.</p>
  </div>

  <!-- Quick Copy Configs -->
  <section class="cmh-configs">
    <h2>Quick Copy Configs</h2>
    <p class="cmh-configs-desc">Common command combinations ready to paste into your console or autoexec.cfg.</p>
    <div class="cmh-config-list">
      <div class="cmh-config-item">
        <h3>Practice Server Setup</h3>
        <pre><code>sv_cheats 1
sv_infinite_ammo 1
sv_grenade_trajectory 1
sv_grenade_trajectory_time 10
sv_showimpacts 1
mp_warmup_end
mp_freezetime 0
mp_roundtime_defuse 60
mp_buy_anywhere 1
mp_buytime 9999
mp_maxmoney 65535
mp_startmoney 65535
mp_respawn_on_death_ct 1
mp_respawn_on_death_t 1
bot_kick</code></pre>
        <button class="cmh-config-copy">Copy Config</button>
      </div>
      <div class="cmh-config-item">
        <h3>FPS Optimization</h3>
        <pre><code>fps_max 0
fps_max_ui 120
r_drawtracers_firstperson 0
cl_forcepreload 1
cl_animate_player_models 0
engine_low_latency_sleep_after_client_tick true
gameinstructor_enable 0
cl_autohelp 0
cl_showhelp 0</code></pre>
        <button class="cmh-config-copy">Copy Config</button>
      </div>
      <div class="cmh-config-item">
        <h3>Competitive Network</h3>
        <pre><code>rate 786432
cl_interp_ratio 1
cl_interp 0
cl_cmdrate 128
cl_updaterate 128
mm_dedicated_search_maxping 80</code></pre>
        <button class="cmh-config-copy">Copy Config</button>
      </div>
      <div class="cmh-config-item">
        <h3>Clean HUD for Content</h3>
        <pre><code>cl_drawhud 0
cl_draw_only_deathnotices 1
sv_skyname vertigoblue_hdr
fog_override 1
fog_enable 0
r_drawparticles 0</code></pre>
        <button class="cmh-config-copy">Copy Config</button>
      </div>
      <div class="cmh-config-item">
        <h3>Pro Radar Settings</h3>
        <pre><code>cl_radar_scale 0.35
cl_radar_always_centered 0
cl_radar_rotate 1
cl_radar_icon_scale_min 0.5
cl_hud_radar_scale 1.15
cl_radar_square_with_scoreboard 1</code></pre>
        <button class="cmh-config-copy">Copy Config</button>
      </div>
      <div class="cmh-config-item">
        <h3>Audio Optimization</h3>
        <pre><code>volume 0.4
snd_roundstart_volume 0
snd_roundend_volume 0
snd_deathcamera_volume 0
snd_mvp_volume 0
snd_menumusic_volume 0
snd_tensecondwarning_volume 0.1
snd_mute_losefocus 1
voice_scale 0.7</code></pre>
        <button class="cmh-config-copy">Copy Config</button>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="cmh-faq">
    <h2>Frequently Asked Questions</h2>
    {faqs.map(f => (
      <details class="cmh-faq-item">
        <summary>{f.question}</summary>
        <p>{f.answer}</p>
      </details>
    ))}
  </section>

  <!-- Internal Links -->
  <div class="internal-links">
    <strong>Related Resources:</strong>
    <a href="/autoexec-generator/">Autoexec Generator</a>
    <a href="/bind-generator/">Bind Generator</a>
    <a href="/launch-options/">Launch Options</a>
    <a href="/practice-config/">Practice Config</a>
    <a href="/crosshair-generator/">Crosshair Generator</a>
    <a href="/crosshair-codes/">Crosshair Codes</a>
    <a href="/sensitivity-converter/">Sensitivity Converter</a>
    <a href="/damage-calculator/">Damage Calculator</a>
    <a href="/economy-calculator/">Economy Calculator</a>
    <a href="/pro-players/">Pro Player Settings</a>
    <a href="/cs2-guides/beginners-guide/">Beginner's Guide</a>
    <a href="/cs2-guides/fps-optimization-guide/">FPS Optimization Guide</a>
    <a href="/cs2-tools/">All Tools</a>
    <a href="/cs2-guides/config-guide/">Config & Settings Guide</a>
    <a href="/cs2-guides/audio-guide/">Audio Settings Guide</a>
    <a href="/cs2-weapons/">Weapon Database</a>
    <a href="/cs2-maps/">Map Database</a>
  </div>

  <ExploreMore context="tools" />
</Base>

<style>
/* ── Hero ── */
.cmh-hero{background:var(--bg2);border:1px solid var(--border);border-radius:4px;padding:2rem;margin-bottom:1.5rem}
.cmh-hero h1{font-family:'Montserrat',sans-serif;font-size:2rem;font-weight:800;margin:0 0 .5rem;color:var(--text)}
.cmh-hero-desc{color:var(--text2);font-size:.95rem;margin:0;line-height:1.6}

/* ── Controls ── */
.cmh-controls{margin-bottom:1rem}
.cmh-search{width:100%;background:var(--bg2);color:var(--text);border:1px solid var(--border);padding:.65rem .85rem;border-radius:4px;font-size:.95rem;font-family:'Montserrat',sans-serif;margin-bottom:.75rem}
.cmh-search:focus{border-color:var(--accent);outline:none}
.cmh-filter-row{display:flex;gap:.4rem;flex-wrap:wrap;margin-bottom:.5rem}
.cmh-filter{background:var(--bg2);color:var(--text2);border:1px solid var(--border);padding:.35rem .7rem;border-radius:4px;font-size:.82rem;cursor:pointer;transition:border-color .15s,color .15s;font-family:'Montserrat',sans-serif}
.cmh-filter:hover{border-color:var(--accent);color:var(--text)}
.cmh-filter.active{background:var(--accent);color:#000;border-color:var(--accent);font-weight:600}
.cmh-cat-row{display:flex;gap:.35rem;flex-wrap:wrap}
.cmh-cat-pill{background:var(--bg2);color:var(--text2);border:1px solid var(--border);padding:.25rem .55rem;border-radius:4px;font-size:.75rem;cursor:pointer;transition:border-color .15s,color .15s;white-space:nowrap;font-family:'Montserrat',sans-serif}
.cmh-cat-pill:hover{border-color:var(--accent);color:var(--text)}
.cmh-cat-pill.active{background:var(--accent);color:#000;border-color:var(--accent)}

/* ── Stats ── */
.cmh-stats{color:var(--text2);font-size:.85rem;margin-bottom:1.25rem;padding:.4rem 0;border-bottom:1px solid var(--border)}

/* ── How-to ── */
.cmh-howto{background:var(--bg2);border:1px solid var(--border);border-radius:4px;padding:1.5rem;margin-bottom:2rem}
.cmh-howto h2{font-family:'Montserrat',sans-serif;margin:0 0 .85rem;font-size:1.1rem;color:var(--text)}
.cmh-steps{display:flex;gap:1rem;flex-wrap:wrap}
.cmh-step{display:flex;gap:.65rem;flex:1;min-width:200px}
.cmh-step-num{width:28px;height:28px;background:var(--accent);color:#000;border-radius:4px;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:.85rem;flex-shrink:0}
.cmh-step p{margin:.2rem 0 0;font-size:.82rem;color:var(--text2)}
.cmh-step strong{font-size:.9rem;color:var(--text)}

/* ── Category ── */
.cmh-category{margin-bottom:2rem}
.cmh-category.hidden{display:none}
.cmh-cat-header{display:flex;gap:.85rem;align-items:center;margin-bottom:.75rem}
.cmh-cat-icon{font-size:1.5rem;width:38px;height:38px;display:flex;align-items:center;justify-content:center;background:var(--bg2);border:1px solid var(--border);border-radius:4px;flex-shrink:0}
.cmh-cat-info{flex:1}
.cmh-cat-info h2{margin:0;font-size:1.1rem;color:var(--text)}
.cmh-cat-info h2 a{color:var(--text);text-decoration:none}
.cmh-cat-info h2 a:hover{color:var(--accent)}
.cmh-cat-info p{margin:.15rem 0 0;font-size:.82rem;color:var(--text2)}
.cmh-cat-count{background:var(--bg2);border:1px solid var(--border);border-radius:4px;padding:.15rem .45rem;font-size:.75rem;color:var(--text2);flex-shrink:0}

/* ── Table ── */
.cmh-table-wrap{overflow-x:auto;border:1px solid var(--border);border-radius:4px;background:var(--bg2)}
.cmh-table{width:100%;border-collapse:collapse;font-size:.85rem}
.cmh-table thead{background:var(--bg3)}
.cmh-table th{padding:.5rem .7rem;text-align:left;font-weight:600;font-size:.75rem;text-transform:uppercase;letter-spacing:.04em;color:var(--text2);border-bottom:1px solid var(--border)}
.cmh-table td{padding:.45rem .7rem;border-bottom:1px solid var(--border)}
.cmh-table tr:last-child td{border-bottom:none}
.cmh-table tr:hover{background:var(--bg3)}
.cmh-row.hidden{display:none}
.cmh-cmd-name{white-space:nowrap;display:flex;align-items:center;gap:.35rem}
.cmh-cmd-name a{text-decoration:none}
.cmh-cmd-name code{color:var(--accent);font-weight:600;font-size:.85rem}
.cmh-sv-badge{display:inline-flex;align-items:center;justify-content:center;background:rgba(46,204,113,.15);color:var(--accent);font-size:.58rem;font-weight:700;padding:.08rem .25rem;border-radius:4px;letter-spacing:.04em}
.cmh-cmd-desc{color:var(--text2);max-width:400px}
.cmh-cmd-default{color:var(--text2);font-family:monospace;font-size:.78rem;white-space:nowrap}
.cmh-cmd-copy{text-align:center}
.cmh-copy-btn{background:var(--bg3);border:1px solid var(--border);border-radius:4px;color:var(--text2);font-size:.7rem;font-weight:600;padding:.2rem .4rem;cursor:pointer;font-family:'Montserrat',sans-serif;transition:border-color .15s}
.cmh-copy-btn:hover{border-color:var(--accent);color:var(--accent)}
.cmh-copy-btn.copied{background:var(--accent);color:#000;border-color:var(--accent)}

.cmh-no-results{text-align:center;padding:2.5rem;color:var(--text2)}

/* ── Configs ── */
.cmh-configs{margin:2rem 0}
.cmh-configs h2{font-family:'Montserrat',sans-serif;margin:0 0 .35rem;font-size:1.2rem;color:var(--text)}
.cmh-configs-desc{color:var(--text2);margin:0 0 1rem;font-size:.9rem}
.cmh-config-list{display:flex;flex-direction:column;gap:.75rem}
.cmh-config-item{background:var(--bg2);border:1px solid var(--border);border-radius:4px;padding:1.15rem}
.cmh-config-item h3{margin:0 0 .65rem;font-size:.95rem;color:var(--text)}
.cmh-config-item pre{background:var(--bg3);border:1px solid var(--border);border-radius:4px;padding:.65rem;overflow-x:auto;margin:0 0 .65rem;font-size:.75rem;line-height:1.5}
.cmh-config-item code{color:var(--text)}
.cmh-config-copy{width:100%;background:var(--accent);color:#000;border:none;padding:.45rem;border-radius:4px;font-weight:700;font-size:.82rem;cursor:pointer;font-family:'Montserrat',sans-serif;transition:opacity .15s}
.cmh-config-copy:hover{opacity:.85}
.cmh-config-copy.copied{background:#4caf50;color:#fff}

/* ── FAQ ── */
.cmh-faq{margin:2rem 0}
.cmh-faq h2{font-family:'Montserrat',sans-serif;margin:0 0 .75rem;font-size:1.15rem;color:var(--text)}
.cmh-faq-item{background:var(--bg2);border:1px solid var(--border);border-radius:4px;margin-bottom:.35rem;overflow:hidden}
.cmh-faq-item summary{padding:.75rem 2.5rem .75rem 1rem;font-weight:700;font-size:.9rem;color:var(--text);cursor:pointer;list-style:none;position:relative;transition:background .15s}
.cmh-faq-item summary::after{content:'+';position:absolute;right:1.25rem;top:50%;transform:translateY(-50%);font-size:1.2rem;color:var(--accent);font-weight:700}
.cmh-faq-item[open] summary::after{content:'\2212'}
.cmh-faq-item summary:hover{background:var(--bg3)}
.cmh-faq-item summary::-webkit-details-marker{display:none}
.cmh-faq-item p{padding:0 1rem .85rem 1rem;margin:0;color:var(--text2);font-size:.88rem;line-height:1.6}

/* ── Breadcrumb ── */
.breadcrumb{font-size:.82rem;color:var(--text2);margin-bottom:1.25rem;display:flex;gap:.35rem;flex-wrap:wrap}
.breadcrumb a{color:var(--accent);text-decoration:none}
.breadcrumb a:hover{text-decoration:underline}

/* ── Internal Links ── */
.internal-links{display:flex;flex-wrap:wrap;gap:.45rem;align-items:center;margin:2rem 0;font-size:.82rem}
.internal-links strong{color:var(--text);margin-right:.2rem}
.internal-links a{color:var(--accent);text-decoration:none;padding:.2rem .5rem;background:var(--bg2);border:1px solid var(--border);border-radius:4px;transition:border-color .15s}
.internal-links a:hover{border-color:var(--accent)}

/* ── Responsive ── */
@media(max-width:768px){
  .cmh-hero h1{font-size:1.5rem}
  .cmh-table{font-size:.78rem}
  .cmh-cmd-desc{max-width:200px}
  .cmh-steps{flex-direction:column}
  .cmh-cat-header{flex-wrap:wrap}
}
</style>

<script is:inline>
(function(){
  var search = document.getElementById('cmdSearch');
  var rows = document.querySelectorAll('.cmh-row');
  var cats = document.querySelectorAll('.cmh-category');
  var filterBtns = document.querySelectorAll('.cmh-filter');
  var catPills = document.querySelectorAll('.cmh-cat-pill');
  var noRes = document.getElementById('noResults');
  var visibleCount = document.getElementById('visibleCount');
  var currentFilter = 'all';
  var activeCat = null;

  function applyFilters() {
    var q = search.value.toLowerCase().trim();
    var visible = 0;

    rows.forEach(function(row) {
      var matchText = !q || row.dataset.cmd.indexOf(q) > -1 || row.dataset.desc.indexOf(q) > -1;
      var matchFilter = currentFilter === 'all' ||
        (currentFilter === 'cheat' && row.dataset.cheat === '1') ||
        (currentFilter === 'safe' && row.dataset.cheat === '0');
      var matchCat = !activeCat || row.closest('.cmh-category').dataset.catid === activeCat;

      var show = matchText && matchFilter && matchCat;
      row.classList.toggle('hidden', !show);
      if (show) visible++;
    });

    cats.forEach(function(cat) {
      var visCmds = cat.querySelectorAll('.cmh-row:not(.hidden)');
      cat.classList.toggle('hidden', visCmds.length === 0);
      var countEl = cat.querySelector('.cmh-cat-count');
      if (countEl) countEl.textContent = visCmds.length;
    });

    noRes.style.display = visible === 0 ? 'block' : 'none';
    visibleCount.textContent = visible;
  }

  search.addEventListener('input', applyFilters);

  filterBtns.forEach(function(btn) {
    btn.addEventListener('click', function() {
      filterBtns.forEach(function(b) { b.classList.remove('active'); });
      btn.classList.add('active');
      currentFilter = btn.dataset.filter;
      applyFilters();
    });
  });

  catPills.forEach(function(pill) {
    pill.addEventListener('click', function() {
      if (activeCat === pill.dataset.cat) {
        activeCat = null;
        pill.classList.remove('active');
      } else {
        catPills.forEach(function(p) { p.classList.remove('active'); });
        activeCat = pill.dataset.cat;
        pill.classList.add('active');
      }
      applyFilters();
    });
  });

  document.querySelectorAll('.cmh-copy-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var cmd = btn.dataset.copy;
      navigator.clipboard.writeText(cmd).then(function() {
        btn.textContent = 'Copied';
        btn.classList.add('copied');
        setTimeout(function() {
          btn.textContent = 'Copy';
          btn.classList.remove('copied');
        }, 1500);
      });
    });
  });

  document.querySelectorAll('.cmh-config-copy').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var pre = btn.previousElementSibling;
      var code = pre.querySelector('code');
      var text = code ? code.textContent : pre.textContent;
      navigator.clipboard.writeText(text.trim()).then(function() {
        btn.textContent = 'Copied!';
        btn.classList.add('copied');
        setTimeout(function() {
          btn.textContent = 'Copy Config';
          btn.classList.remove('copied');
        }, 1500);
      });
    });
  });

  document.addEventListener('keydown', function(e) {
    if (e.key === '/' && document.activeElement !== search) {
      e.preventDefault();
      search.focus();
    }
  });
})();
</script>
</Base>
