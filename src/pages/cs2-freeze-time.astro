    .cft-section-header{background:rgba(46,204,113,.05);margin:0 -1.25rem 1.25rem;padding:.75rem 1.25rem;border-radius:4px}
    .cft-section-header h2{margin:0;padding:0;font-size:1.5rem;font-weight:700;color:var(--text);border:none;letter-spacing:-.01em}
    section{margin-bottom:2.5rem}
    p{line-height:1.7;color:var(--text2);margin-bottom:1rem}
    .cft-list{list-style:none;padding:0;margin:.75rem 0 1.5rem}
    .cft-list li{padding:.4rem 0 .4rem 1.6rem;position:relative;color:var(--text2);line-height:1.65}
