---
import Base from '../layouts/Base.astro';
import AuthorBox from '../components/AuthorBox.astro';
import { faqSchema, breadcrumbSchema } from '../lib/weapons';

const title = 'CS2 General FAQ: Common Questions Answered | CSGOLuck Wiki';
const description = 'The most common CS2 questions — round counts, match length, console commands, removing bots, and freeze time explained.';

const faqs = [
  {
    question: 'How many rounds are in a CS2 match?',
    answer: 'Competitive and Premier matches use the MR12 format, meaning each half is 12 rounds long for a maximum of 24 rounds in regulation. The first team to 13 round wins takes the match. If the score ties at 12-12, overtime rounds are played in sets of six (three on each side) until a winner is decided. Casual and deathmatch modes use different, shorter round structures.',
  },
  {
    question: 'How long does a CS2 game last?',
    answer: 'A typical competitive CS2 match lasts between 30 and 50 minutes. Shorter matches occur when one team dominates early, while closely contested games with overtime can stretch past an hour. Each round has a 1:55 timer (1:40 in competitive), plus freeze time between rounds. Casual modes are faster, usually finishing in 15-20 minutes with fewer rounds per game.',
  },
  {
    question: 'How to remove and kick bots in CS2?',
    answer: 'In a private server with cheats enabled (sv_cheats 1), use bot_kick to remove all bots instantly. To kick a specific bot, use bot_kick followed by the bot name. To prevent bots from joining in the first place, set bot_quota 0 before starting the match. In official matchmaking, you cannot remove bots — they automatically fill in for disconnected players. Check our <a href="/cs2-commands/">commands reference</a> for more bot-related commands.',
  },
  {
    question: 'How to use the console in CS2?',
    answer: 'First, enable the developer console in Settings under the Game tab — set "Enable Developer Console" to Yes. Then press the tilde key (~) during gameplay to open it. Type commands directly and press Enter to execute them. The console is essential for adjusting settings, running practice configs, and fine-tuning your setup. Our <a href="/launch-options/">launch options guide</a> and <a href="/practice-config/">practice config</a> generator both rely on console access.',
  },
  {
    question: 'How to freeze time in CS2?',
    answer: 'Freeze time is the period at the start of each round where players cannot move and use the buy menu. To adjust it on a private server, use mp_freezetime followed by the number of seconds you want. Set mp_freezetime 0 to eliminate it entirely, which is useful during practice sessions. In official matchmaking, freeze time is locked at a fixed duration and cannot be modified by players.',
  },
];
---

<Base title={title} description={description}>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema([{name:'Home',url:'/'},{name:'CS2 General FAQ',url:'/cs2-general-faq'}]))}></script>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema(faqs))}></script>

  <nav class="gef-breadcrumb">
    <a href="/">Home</a> / <span>CS2 General FAQ</span>
  </nav>

  <section class="gef-hero">
    <h1>CS2 General FAQ: Common Questions Answered</h1>
    <p class="gef-hero-desc">This CS2 FAQ covers the most common questions new and returning players ask about Counter-Strike 2 — from round counts and match duration to console usage, bot management, and freeze time settings. If you are looking for a quick answer to a basic CS2 question, you will likely find it here.</p>
  </section>

  <div class="gef-faq-list">
    {faqs.map(faq => (
      <details class="gef-faq-item">
        <summary class="gef-faq-question">{faq.question}</summary>
        <div class="gef-faq-answer" set:html={faq.answer}></div>
      </details>
    ))}
  </div>

  <section class="gef-related">
    <h2>Related Articles</h2>
    <div class="gef-related-grid">
      <a href="/cs2-console-commands/" class="gef-related-card"><span class="gef-related-name">CS2 Console Commands</span><span class="gef-related-arrow">&rarr;</span></a>
      <a href="/how-long-cs2-game/" class="gef-related-card"><span class="gef-related-name">How Long Does a CS2 Game Last?</span><span class="gef-related-arrow">&rarr;</span></a>
      <a href="/remove-bots-cs2/" class="gef-related-card"><span class="gef-related-name">How to Remove Bots in CS2</span><span class="gef-related-arrow">&rarr;</span></a>
      <a href="/cs2-commands/" class="gef-related-card"><span class="gef-related-name">Full Commands Reference</span><span class="gef-related-arrow">&rarr;</span></a>
      <a href="/launch-options/" class="gef-related-card"><span class="gef-related-name">Launch Options Guide</span><span class="gef-related-arrow">&rarr;</span></a>
      <a href="/practice-config/" class="gef-related-card"><span class="gef-related-name">Practice Config Generator</span><span class="gef-related-arrow">&rarr;</span></a>
    </div>
  </section>

  <section class="gef-explore">
    <h2>Explore More</h2>
    <div class="gef-explore-links">
      <a href="/cs2-gameplay-practice-faq/">CS2 Gameplay &amp; Practice FAQ</a>
      <a href="/cs2-settings-config-faq/">CS2 Settings &amp; Config FAQ</a>
      <a href="/cs2-game-history-faq/">CS2 &amp; CS:GO History FAQ</a>
    </div>
  </section>

  <div class="gef-outbound">
    <strong>Official Resources:</strong>
    <a href="https://developer.valvesoftware.com/" target="_blank" rel="noopener noreferrer">Valve Developer Wiki</a>
  </div>

  <AuthorBox updated="2026-03-04" />
</Base>

<style>
/* ── Breadcrumb ── */
.gef-breadcrumb{font-size:.82rem;color:var(--text2);margin-bottom:1.25rem;display:flex;gap:.35rem;flex-wrap:wrap}
.gef-breadcrumb a{color:var(--accent);text-decoration:none}
.gef-breadcrumb a:hover{text-decoration:underline}

/* ── Hero ── */
.gef-hero{background:var(--bg2);border:1px solid var(--border);border-radius:4px;padding:2rem;margin-bottom:1.5rem}
.gef-hero h1{font-family:'Montserrat',sans-serif;font-size:2rem;font-weight:800;margin:0 0 .75rem;color:var(--text)}
.gef-hero-desc{color:var(--text2);font-size:.95rem;line-height:1.7;margin:0}

/* ── FAQ List ── */
.gef-faq-list{display:flex;flex-direction:column;gap:.5rem;margin-bottom:2.5rem}
.gef-faq-item{background:var(--bg2);border:1px solid var(--border);border-radius:4px;overflow:hidden}
.gef-faq-question{display:block;padding:1rem 1.25rem;font-size:.95rem;font-weight:600;color:var(--text);cursor:pointer;list-style:none;position:relative;padding-right:2.5rem;transition:background .2s}
.gef-faq-question::-webkit-details-marker{display:none}
.gef-faq-question::after{content:'+';position:absolute;right:1.25rem;top:50%;transform:translateY(-50%);font-size:1.2rem;color:var(--accent);font-weight:700}
.gef-faq-item[open] .gef-faq-question::after{content:'\2212'}
.gef-faq-item[open] .gef-faq-question{border-bottom:1px solid var(--border);background:rgba(46,204,113,.03)}
.gef-faq-question:hover{background:rgba(46,204,113,.03)}
.gef-faq-answer{padding:1rem 1.25rem;margin:0;font-size:.9rem;color:var(--text2);line-height:1.7}
.gef-faq-answer a{color:var(--accent);text-decoration:none}
.gef-faq-answer a:hover{text-decoration:underline}

/* ── Related Articles ── */
.gef-related{margin-bottom:2rem}
.gef-related h2{font-family:'Montserrat',sans-serif;font-size:1.2rem;font-weight:700;color:var(--text);margin:0 0 .75rem;padding-bottom:.5rem;border-bottom:2px solid var(--accent)}
.gef-related-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:.6rem}
.gef-related-card{display:flex;align-items:center;justify-content:space-between;padding:.75rem 1rem;background:var(--bg2);border:1px solid var(--border);border-radius:4px;text-decoration:none;border-left:2px solid transparent;transition:border-left-color .2s,color .2s}
.gef-related-card:hover{border-left-color:var(--accent)}
.gef-related-name{font-size:.88rem;color:var(--text2);font-weight:500;transition:color .2s}
.gef-related-card:hover .gef-related-name{color:var(--text)}
.gef-related-arrow{font-size:1rem;color:var(--accent);opacity:0;transition:opacity .2s}
.gef-related-card:hover .gef-related-arrow{opacity:1}

/* ── Explore More ── */
.gef-explore{margin-bottom:2rem}
.gef-explore h2{font-family:'Montserrat',sans-serif;font-size:1.2rem;font-weight:700;color:var(--text);margin:0 0 .75rem;padding-bottom:.5rem;border-bottom:2px solid var(--accent)}
.gef-explore-links{display:flex;flex-wrap:wrap;gap:.45rem}
.gef-explore-links a{color:var(--accent);text-decoration:none;padding:.4rem .75rem;background:var(--bg2);border:1px solid var(--border);border-radius:4px;font-size:.85rem;font-weight:600;transition:border-color .15s,color .15s}
.gef-explore-links a:hover{border-color:var(--accent);color:var(--text)}

/* ── Outbound Links ── */
.gef-outbound{display:flex;flex-wrap:wrap;gap:.45rem;align-items:center;margin:1.5rem 0 2rem;font-size:.82rem}
.gef-outbound strong{color:var(--text);margin-right:.2rem}
.gef-outbound a{color:var(--accent);text-decoration:none;padding:.2rem .5rem;background:var(--bg2);border:1px solid var(--border);border-radius:4px;transition:border-color .15s}
.gef-outbound a:hover{border-color:var(--accent)}

/* ── Responsive ── */
@media(max-width:768px){
  .gef-hero h1{font-size:1.5rem}
  .gef-related-grid{grid-template-columns:1fr}
}
</style>
