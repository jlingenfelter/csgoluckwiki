---
import Base from '../../layouts/Base.astro';
import AuthorBox from '../../components/AuthorBox.astro';
import { faqSchema, breadcrumbSchema } from '../../lib/weapons';

const title = 'CS2 Float Value Guide — Wear Ratings Explained | CSGOLuck Wiki';
const description = 'Decode the float system behind CS2 skin wear. Discover how float numbers map to condition tiers, shape market value, and influence the price tags collectors are willing to pay.';

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Guides', url: '/cs2-guides' },
  { name: 'Float Value Guide', url: '/cs2-guides/float-guide' },
];

const faqs = [
  { question: 'What is a float value in CS2?', answer: 'A float value is a decimal number between 0.00 and 1.00 assigned to every CS2 skin. It determines the visual wear and condition of the skin. Lower float means better condition (less scratches and wear).' },
  { question: 'What are the CS2 wear conditions?', answer: 'There are five wear tiers: Factory New (0.00-0.07), Minimal Wear (0.07-0.15), Field-Tested (0.15-0.38), Well-Worn (0.38-0.45), Battle-Scarred (0.45-1.00). Each skin has minimum and maximum float caps that may restrict available conditions.' },
  { question: 'Can a skin exist in all float ranges?', answer: 'No. Each skin has hardcoded minimum and maximum float values. For example, the AK-47 Asiimov has a minimum float of 0.05 and maximum of 0.70, meaning it cannot exist in Factory New (which requires below 0.07) though some rare ones get close.' },
  { question: 'Does float value affect gameplay?', answer: 'No. Float value is purely cosmetic — it only changes how the skin looks (scratches, fading, paint wear). There is zero gameplay difference between a Factory New and Battle-Scarred version of the same skin.' },
  { question: 'How do I check a skin float value?', answer: 'Inspect the skin in your inventory and look at the wear rating. For exact float numbers, use third-party tools like CSFloat, Steam Inventory Helper browser extension, or marketplace listings which display exact float values.' },
];

const articleSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "description": description,
  "author": { "@type": "Person", "name": "Josh Lingenfelter", "url": "https://www.linkedin.com/in/josh-lingenfelter-8157274b/", "jobTitle": "Director", "worksFor": { "@type": "Organization", "name": "CSGOLuck" } },
  "publisher": { "@type": "Organization", "name": "CSGOLuck Wiki", "url": "https://wiki.csgoluck.com" },
  "mainEntityOfPage": `https://wiki.csgoluck.com/cs2-guides/float-guide/`,
  "inLanguage": "en-US"
});

const wearTiers = [
  { name: 'Factory New', range: '0.00 – 0.07', abbr: 'FN', color: '#4caf50', desc: 'Near-perfect condition with minimal visible scratches. The most desirable and expensive condition for most skins.' },
  { name: 'Minimal Wear', range: '0.07 – 0.15', abbr: 'MW', color: '#8bc34a', desc: 'Slight cosmetic wear with minor scratches barely visible during gameplay. Often the best value tier.' },
  { name: 'Field-Tested', range: '0.15 – 0.38', abbr: 'FT', color: '#d4956e', desc: 'Moderate wear with visible scratches and marks. The most common condition and typically the cheapest useful tier.' },
  { name: 'Well-Worn', range: '0.38 – 0.45', abbr: 'WW', color: '#ff9800', desc: 'Significant wear with noticeable scratches and fading. Less common than FT due to narrow float range.' },
  { name: 'Battle-Scarred', range: '0.45 – 1.00', abbr: 'BS', color: '#ef5350', desc: 'Heavy wear with major scratches, chips, and paint fading. Some collectors seek high-float BS skins for their unique look.' },
];

const sections = [
  { id: 'tiers', label: 'Wear Condition Tiers' },
  { id: 'determined', label: 'How Floats Work' },
  { id: 'pricing', label: 'Float & Pricing' },
  { id: 'tradeup', label: 'Trade-Up Contracts' },
  { id: 'faq', label: 'FAQ' },
  { id: 'resources', label: 'Resources' },
];
---

<Base title={title} description={description} currentNav="/cs2-guides/">
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema(breadcrumbs))}></script>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema(faqs))}></script>
  <script type="application/ld+json" set:html={articleSchema}></script>

  <div class="fg-wrap">
    <nav class="fg-breadcrumb">
      <a href="/">Home</a>
      <span class="fg-sep">/</span>
      <a href="/cs2-guides">Guides</a>
      <span class="fg-sep">/</span>
      <span>Float Value Guide</span>
    </nav>

    <header class="fg-header">
      <h1>CS2 Float Value Guide</h1>
      <p class="fg-subtitle">Decode the decimal that decides how scratched -- or pristine -- your skin really is</p>
    </header>

    <nav class="fg-toc-mobile" aria-label="Table of contents">
      {sections.map((s) => (
        <a href={`#${s.id}`} class="fg-toc-mobile-link">{s.label}</a>
      ))}
    </nav>

    <div class="fg-layout">
      <aside class="fg-sidebar">
        <nav class="fg-toc" aria-label="Table of contents">
          <span class="fg-toc-title">Contents</span>
          {sections.map((s) => (
            <a href={`#${s.id}`} class="fg-toc-link">{s.label}</a>
          ))}
        </nav>
      </aside>

      <article class="fg-content">
        <p class="fg-intro">
          Every CS2 skin carries a float value -- a decimal between 0 and 1 that controls how worn or clean it appears in-game. If you <a href="/cs2-guides/trading-guide/">trade</a>, <a href="/cs2-guides/skins-investing-guide/">invest</a>, or simply want the best-looking loadout, grasping how floats work is essential -- a gap of just 0.05 in float can swing the price of a high-tier item by hundreds of dollars.
        </p>

        <section id="tiers">
          <div class="fg-section-header"><h2>Wear Condition Tiers</h2></div>
          <table class="fg-table">
            <thead><tr><th>Condition</th><th>Float Range</th><th>Description</th></tr></thead>
            <tbody>
              {wearTiers.map(t => (
                <tr>
                  <td><span style={`color:${t.color};font-weight:700`}>{t.name} ({t.abbr})</span></td>
                  <td>{t.range}</td>
                  <td>{t.desc}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </section>

        <section id="determined">
          <div class="fg-section-header"><h2>How Float Values Are Determined</h2></div>
          <p>When a skin drops from a <a href="/cs2-cases/">case opening</a>, random drop, or trade-up contract, the game engine assigns a random float value within the skin's defined range. Each skin in CS2 has a hardcoded minimum and maximum float -- for example, the M4A1-S Hyper Beast has a min float of 0.00 and max of 1.00 (all conditions possible), while the AWP Asiimov has a min of 0.18 and max of 0.90 (only Field-Tested through Battle-Scarred).</p>
          <p>This means some skins physically cannot exist in Factory New condition. The skin's float caps are set by the developers and cannot be changed. When you see a skin listed as "Factory New," its float is guaranteed to be between 0.00 and 0.07 -- but it may not be available in FN if the minimum float is above 0.07.</p>
        </section>

        <section id="pricing">
          <div class="fg-section-header"><h2>Float Value and Pricing</h2></div>
          <p>Within the same wear tier, lower floats almost always command higher prices. Use the <a href="/float-checker/">float checker</a> to verify the exact value of any skin before buying. A Factory New AWP Dragon Lore at 0.01 float might sell for double the price of one at 0.06. This premium becomes even more extreme at the boundaries -- the jump from 0.0699 (barely FN) to 0.0701 (just MW) can represent a 30-50% price drop because the condition label changes.</p>
          <p>The reverse is also true at the high end. Some collectors specifically seek "max float" Battle-Scarred skins (0.99+) for their unique heavily-worn aesthetic. These can sometimes be worth more than lower-float BS versions due to scarcity and collector demand. Patterns matter too -- check the <a href="/cs2-guides/case-hardened-guide/">Case Hardened pattern guide</a> for a prime example of how visuals influence value beyond float alone.</p>
        </section>

        <section id="tradeup">
          <div class="fg-section-header"><h2>Float in Trade-Up Contracts</h2></div>
          <p>The output float from a trade-up contract is calculated using the average float of your 10 input skins. The formula is: <code>Output Float = Average Input Float x (Max Float - Min Float) + Min Float</code>. By carefully selecting low-float inputs, you can guarantee the output lands in a specific wear condition, which is critical for targeting Factory New results from profitable trade-ups. Use the <a href="/tradeup-calculator/">trade-up calculator</a> to model outcomes before committing your skins. Browse all available input skins in the <a href="/cs2-skins/">skin database</a>.</p>
        </section>

        <section id="faq">
          <div class="fg-section-header"><h2>Frequently Asked Questions</h2></div>
          <div class="fg-faq-list">
            {faqs.map(f => (
              <details class="fg-faq-item">
                <summary class="fg-faq-question">{f.question}</summary>
                <p class="fg-faq-answer">{f.answer}</p>
              </details>
            ))}
          </div>
        </section>

        <section id="resources">
          <div class="fg-section-header"><h2>Related Resources</h2></div>
          <div class="fg-resources-grid">
            <a href="/float-checker/" class="fg-resource-card"><span class="fg-resource-name">Float Checker</span><span class="fg-resource-arrow">&rarr;</span></a>
            <a href="/tradeup-calculator/" class="fg-resource-card"><span class="fg-resource-name">Trade-Up Calculator</span><span class="fg-resource-arrow">&rarr;</span></a>
            <a href="/cs2-skins/" class="fg-resource-card"><span class="fg-resource-name">Skin Database</span><span class="fg-resource-arrow">&rarr;</span></a>
            <a href="/skin-compare/" class="fg-resource-card"><span class="fg-resource-name">Compare Skins</span><span class="fg-resource-arrow">&rarr;</span></a>
            <a href="/price-tracker/" class="fg-resource-card"><span class="fg-resource-name">Price Tracker</span><span class="fg-resource-arrow">&rarr;</span></a>
            <a href="/market-trends/" class="fg-resource-card"><span class="fg-resource-name">Market Trends</span><span class="fg-resource-arrow">&rarr;</span></a>
            <a href="/case-odds-calculator/" class="fg-resource-card"><span class="fg-resource-name">Case Odds Calculator</span><span class="fg-resource-arrow">&rarr;</span></a>
            <a href="/case-simulator/" class="fg-resource-card"><span class="fg-resource-name">Case Simulator</span><span class="fg-resource-arrow">&rarr;</span></a>
            <a href="/cs2-cases/" class="fg-resource-card"><span class="fg-resource-name">Cases & Collections</span><span class="fg-resource-arrow">&rarr;</span></a>
            <a href="/inventory-lookup/" class="fg-resource-card"><span class="fg-resource-name">Inventory Lookup</span><span class="fg-resource-arrow">&rarr;</span></a>
            <a href="/cs2-guides/trading-guide/" class="fg-resource-card"><span class="fg-resource-name">Trading Guide</span><span class="fg-resource-arrow">&rarr;</span></a>
            <a href="/cs2-guides/skins-investing-guide/" class="fg-resource-card"><span class="fg-resource-name">Skins Investing Guide</span><span class="fg-resource-arrow">&rarr;</span></a>
          </div>
        </section>
      </article>
    </div>
  </div>

  <style>
    .fg-wrap{max-width:1100px;margin:0 auto;padding:0 1.5rem 2rem}
    .fg-breadcrumb{display:flex;align-items:center;gap:.5rem;padding:1.25rem 0;font-size:.85rem;color:var(--text2)}
    .fg-breadcrumb a{color:var(--accent);text-decoration:none}
    .fg-breadcrumb a:hover{color:var(--accent2)}
    .fg-sep{color:var(--border)}
    .fg-header{padding:1.5rem 0 1.25rem;border-bottom:2px solid var(--accent);margin-bottom:1.5rem}
    .fg-header h1{margin:0 0 .35rem;font-size:2.2rem;font-weight:800;color:var(--text);letter-spacing:-.02em;line-height:1.2}
    .fg-subtitle{margin:0;font-size:1.05rem;color:var(--text2);font-weight:400}
    .fg-toc-mobile{display:none}
    .fg-layout{display:grid;grid-template-columns:220px 1fr;gap:2.5rem;align-items:start}
    .fg-sidebar{position:sticky;top:80px}
    .fg-toc{display:flex;flex-direction:column;gap:0;border-left:2px solid var(--border);padding-left:0}
    .fg-toc-title{font-size:.7rem;font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:var(--accent);padding:0 0 .6rem 1rem}
    .fg-toc-link{display:block;padding:.4rem 1rem;font-size:.82rem;color:var(--text2);text-decoration:none;border-left:2px solid transparent;margin-left:-2px;transition:color .2s,border-color .2s}
    .fg-toc-link:hover{color:var(--text);border-left-color:var(--accent)}
    .fg-content{min-width:0}
    .fg-intro{font-size:1rem;line-height:1.8;color:var(--text2);margin-bottom:2rem}
    .fg-section-header{background:rgba(46,204,113,.05);margin:0 -1.25rem 1.25rem;padding:.75rem 1.25rem;border-radius:4px}
    .fg-section-header h2{margin:0;padding:0;font-size:1.5rem;font-weight:700;color:var(--text);border:none;letter-spacing:-.01em}
    section{margin-bottom:2.5rem}
    h3{font-size:1.15rem;font-weight:600;margin:1.5rem 0 .6rem;color:var(--text)}
    p{line-height:1.7;color:var(--text2);margin-bottom:1rem}
    .fg-table{width:100%;border-collapse:collapse;margin:1rem 0;font-size:.85rem}
    .fg-table th,.fg-table td{padding:.6rem .8rem;border:1px solid var(--border);text-align:left}
    .fg-table th{background:var(--bg3);color:var(--text);font-weight:600;font-size:.8rem}
    .fg-table td{color:var(--text2)}
    code{background:var(--bg3);padding:.1rem .35rem;border-radius:3px;font-size:.85em;color:var(--accent);font-family:'Courier New',Courier,monospace}
    .fg-faq-list{display:flex;flex-direction:column;gap:.5rem}
    .fg-faq-item{background:var(--bg2);border:1px solid var(--border);border-radius:4px;overflow:hidden}
    .fg-faq-question{display:block;padding:1rem 1.25rem;font-size:.95rem;font-weight:600;color:var(--text);cursor:pointer;list-style:none;position:relative;padding-right:2.5rem;transition:background .2s}
    .fg-faq-question::-webkit-details-marker{display:none}
    .fg-faq-question::after{content:'+';position:absolute;right:1.25rem;top:50%;transform:translateY(-50%);font-size:1.2rem;color:var(--accent);font-weight:700}
    .fg-faq-item[open] .fg-faq-question::after{content:'\2212'}
    .fg-faq-item[open] .fg-faq-question{border-bottom:1px solid var(--border);background:rgba(46,204,113,.03)}
    .fg-faq-question:hover{background:rgba(46,204,113,.03)}
    .fg-faq-answer{padding:1rem 1.25rem;margin:0;font-size:.9rem;color:var(--text2);line-height:1.7}
    .fg-resources-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:.6rem;margin:.5rem 0 1.5rem}
    .fg-resource-card{display:flex;align-items:center;justify-content:space-between;padding:.75rem 1rem;background:var(--bg2);border:1px solid var(--border);border-radius:4px;text-decoration:none;border-left:2px solid transparent;transition:border-left-color .2s,color .2s}
    .fg-resource-card:hover{border-left-color:var(--accent)}
    .fg-resource-name{font-size:.88rem;color:var(--text2);font-weight:500;transition:color .2s}
    .fg-resource-card:hover .fg-resource-name{color:var(--text)}
    .fg-resource-arrow{font-size:1rem;color:var(--accent);opacity:0;transition:opacity .2s}
    .fg-resource-card:hover .fg-resource-arrow{opacity:1}
    @media(max-width:860px){
      .fg-layout{grid-template-columns:1fr;gap:0}
      .fg-sidebar{display:none}
      .fg-toc-mobile{display:flex;gap:.25rem;overflow-x:auto;padding:.75rem 0;margin-bottom:1rem;-webkit-overflow-scrolling:touch;scrollbar-width:none}
      .fg-toc-mobile::-webkit-scrollbar{display:none}
      .fg-toc-mobile-link{flex-shrink:0;padding:.35rem .75rem;font-size:.78rem;font-weight:600;color:var(--text2);background:var(--bg2);border:1px solid var(--border);border-radius:4px;text-decoration:none;white-space:nowrap;transition:color .2s,border-color .2s}
      .fg-toc-mobile-link:hover{color:var(--accent);border-color:var(--accent)}
      .fg-header h1{font-size:1.7rem}
      .fg-section-header{margin:0 -1rem 1rem;padding:.6rem 1rem}
      .fg-resources-grid{grid-template-columns:repeat(2,1fr)}
      .fg-table{font-size:.78rem}
      .fg-table th,.fg-table td{padding:.4rem .5rem}
    }
    @media(max-width:600px){
      .fg-wrap{padding:0 1rem 1.5rem}
      .fg-resources-grid{grid-template-columns:1fr}
      .fg-header h1{font-size:1.5rem}
    }
  </style>
  <AuthorBox updated="2026-03-02" />
</Base>
