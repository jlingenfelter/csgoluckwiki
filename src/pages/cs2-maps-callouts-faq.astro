---
import Base from '../layouts/Base.astro';
import AuthorBox from '../components/AuthorBox.astro';
import { faqSchema, breadcrumbSchema } from '../lib/weapons';

const title = 'CS2 Maps FAQ: Map Pool & Workshop Maps | CSGOLuck Wiki';
const description = 'Is Cache coming to CS2? How many maps are there? Learn about the active duty pool, workshop maps, and rounds per map.';

const faqs = [
  {
    question: 'When is Cache coming to CS2?',
    answer: 'There is no confirmed release date for Cache in CS2. The map was removed from the active duty pool before the CS2 transition, and Valve has not announced plans to reintroduce it. The FMPONE-designed map would need a full Source 2 rebuild to meet CS2 standards. Community members continue to request its return, but for now it remains unavailable in official matchmaking.',
  },
  {
    question: 'Why is Cache not in CS2?',
    answer: 'Cache was not included in the CS2 launch because Valve chose to focus on porting their highest-priority maps to the Source 2 engine first. Cache is community-made (by FMPONE), which adds complexity to the porting process. The map would require significant rework to take advantage of Source 2 lighting, volumetric smokes, and updated geometry. Valve has not provided a timeline for its potential return.',
  },
  {
    question: 'How many maps are in CS2?',
    answer: 'The CS2 active duty map pool — the maps available in Competitive and Premier matchmaking — typically contains seven maps. Valve rotates maps in and out periodically, adding new ones and retiring others. Beyond the active duty pool, additional maps are available in casual modes and the Steam Workshop. Check our <a href="/cs2-maps/">maps page</a> for the current active duty lineup and detailed callout guides.',
  },
  {
    question: 'How to play workshop maps in CS2?',
    answer: 'Open Steam, go to the CS2 Workshop page, and subscribe to the map you want. In CS2, go to Play and select Practice or Workshop Maps from the game mode options. Your subscribed maps will appear in the list. Workshop maps include aim trainers, surf maps, movement courses, grenade practice tools, and community-made competitive layouts. Browse our curated <a href="/workshop-maps/">workshop maps collection</a> for recommended picks.',
  },
  {
    question: 'How many rounds per map in CS2?',
    answer: 'In competitive and Premier modes, each map uses the MR12 format — 12 rounds per half, for a maximum of 24 rounds in regulation. The first team to win 13 rounds wins the map. If the score reaches 12-12, overtime consists of additional six-round sets (three rounds per side) until one team pulls ahead. Casual modes use shorter formats. Use our <a href="/practice-config/">practice config</a> to customize round settings in private matches.',
  },
];

const cards = [
  { href: '/cache-cs2/', title: 'Is Cache Coming to CS2?', excerpt: 'Current status, why it was removed, and what we know about a return.' },
  { href: '/cs2-map-pool/', title: 'How Many Maps Are in CS2?', excerpt: 'Active duty pool, rotation history, and current competitive maps.' },
  { href: '/cs2-workshop-maps/', title: 'How to Play Workshop Maps', excerpt: 'Subscribe, install, and launch community-created maps.' },
  { href: '/cs2-rounds-per-match/', title: 'How Many Rounds Per Map?', excerpt: 'MR12 regulation format, overtime rules, and casual mode differences.' },
];
---

<Base title={title} description={description}>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema([{name:'Home',url:'/'},{name:'CS2 Maps & Callouts FAQ',url:'/cs2-maps-callouts-faq'}]))}></script>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema(faqs))}></script>

  <nav class="mcf-breadcrumb">
    <a href="/">Home</a> / <span>CS2 Maps &amp; Callouts FAQ</span>
  </nav>

  <section class="mcf-hero">
    <h1>CS2 Maps FAQ: Map Pool &amp; Workshop Maps</h1>
    <p class="mcf-hero-desc">Understanding CS2 maps and callouts is key to competitive success. From the active duty map pool to workshop creations and the ongoing Cache debate, this FAQ covers the most common map-related questions. Explore our full <a href="/cs2-maps/">map database</a> for callout guides and detailed breakdowns of every playable map.</p>
  </section>

  <p class="mcf-intro">Click any question below for a detailed answer.</p>

  <div class="mcf-faq-grid">
    {cards.map(card => (
      <a href={card.href} class="mcf-faq-card">
        <div class="mcf-faq-card-content">
          <span class="mcf-faq-card-q">{card.title}</span>
          <p class="mcf-faq-card-excerpt">{card.excerpt}</p>
        </div>
        <span class="mcf-faq-card-arrow">&rarr;</span>
      </a>
    ))}
  </div>

  <section class="mcf-explore">
    <h2>Explore More</h2>
    <div class="mcf-explore-links">
      <a href="/cs2-gameplay-practice-faq/">CS2 Gameplay &amp; Practice FAQ</a>
      <a href="/cs2-general-faq/">CS2 General FAQ</a>
    </div>
  </section>

  <div class="mcf-outbound">
    <strong>Official Resources:</strong>
    <a href="https://www.counter-strike.net/" target="_blank" rel="noopener noreferrer">Counter-Strike.net</a>
  </div>

  <AuthorBox updated="2026-03-04" />
</Base>

<style>
/* ── Breadcrumb ── */
.mcf-breadcrumb{font-size:.82rem;color:var(--text2);margin-bottom:1.25rem;display:flex;gap:.35rem;flex-wrap:wrap}
.mcf-breadcrumb a{color:var(--accent);text-decoration:none}
.mcf-breadcrumb a:hover{text-decoration:underline}

/* ── Hero ── */
.mcf-hero{background:var(--bg2);border:1px solid var(--border);border-radius:4px;padding:2rem;margin-bottom:1.5rem}
.mcf-hero h1{font-family:'Montserrat',sans-serif;font-size:2rem;font-weight:800;margin:0 0 .75rem;color:var(--text)}
.mcf-hero-desc{color:var(--text2);font-size:.95rem;line-height:1.7;margin:0}
.mcf-hero-desc a{color:var(--accent);text-decoration:none}
.mcf-hero-desc a:hover{text-decoration:underline}

/* ── Intro ── */
.mcf-intro{font-size:.9rem;color:var(--text2);margin:0 0 1.25rem;line-height:1.6}

/* ── FAQ Card Grid ── */
.mcf-faq-grid{display:grid;grid-template-columns:1fr;gap:.75rem;margin-bottom:2.5rem}
.mcf-faq-card{display:flex;align-items:center;justify-content:space-between;padding:1.25rem;background:var(--bg2);border:1px solid var(--border);border-radius:4px;text-decoration:none;border-left:3px solid transparent;transition:border-left-color .2s,background .15s}
.mcf-faq-card:hover{border-left-color:var(--accent);background:rgba(46,204,113,.03)}
.mcf-faq-card-content{flex:1}
.mcf-faq-card-q{font-size:.95rem;font-weight:600;color:var(--text);margin:0 0 .25rem;display:block}
.mcf-faq-card-excerpt{font-size:.82rem;color:var(--text2);margin:0;line-height:1.5}
.mcf-faq-card-arrow{font-size:1.1rem;color:var(--accent);margin-left:1rem;opacity:0;transition:opacity .2s}
.mcf-faq-card:hover .mcf-faq-card-arrow{opacity:1}

/* ── Explore More ── */
.mcf-explore{margin-bottom:2rem}
.mcf-explore h2{font-family:'Montserrat',sans-serif;font-size:1.2rem;font-weight:700;color:var(--text);margin:0 0 .75rem;padding-bottom:.5rem;border-bottom:2px solid var(--accent)}
.mcf-explore-links{display:flex;flex-wrap:wrap;gap:.45rem}
.mcf-explore-links a{color:var(--accent);text-decoration:none;padding:.4rem .75rem;background:var(--bg2);border:1px solid var(--border);border-radius:4px;font-size:.85rem;font-weight:600;transition:border-color .15s,color .15s}
.mcf-explore-links a:hover{border-color:var(--accent);color:var(--text)}

/* ── Outbound Links ── */
.mcf-outbound{display:flex;flex-wrap:wrap;gap:.45rem;align-items:center;margin:1.5rem 0 2rem;font-size:.82rem}
.mcf-outbound strong{color:var(--text);margin-right:.2rem}
.mcf-outbound a{color:var(--accent);text-decoration:none;padding:.2rem .5rem;background:var(--bg2);border:1px solid var(--border);border-radius:4px;transition:border-color .15s}
.mcf-outbound a:hover{border-color:var(--accent)}

/* ── Responsive ── */
@media(max-width:768px){
  .mcf-hero h1{font-size:1.5rem}
}
</style>
