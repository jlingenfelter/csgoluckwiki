---
import Base from '../layouts/Base.astro';
import ExploreMore from '../components/ExploreMore.astro';
import { MAPS } from '../lib/maps';
import { faqSchema } from '../lib/weapons';

const activeMaps = MAPS.filter(m => m.pool === 'active');
const title = 'CS2 Maps — Callout Names, Utility Lineups & Tactical Breakdowns | CSGOLuck Wiki';
const description = 'An in-depth reference for every Counter-Strike 2 competitive map. Standardized callout labels, smoke and flash lineup spots, side-specific strategies, and practical advice for all active duty maps.';

const faqs = [
  { question: 'Which maps currently make up the CS2 active duty rotation?', answer: `The active duty pool presently includes: ${activeMaps.map(m => m.name).join(', ')}. These are the battlegrounds featured in ranked matchmaking queues and on the professional tournament circuit.` },
  { question: 'What does "callout" mean in Counter-Strike 2?', answer: 'A callout is a universally recognised label for a specific spot on a map. Players rely on callouts to quickly relay enemy locations, coordinate pushes, and direct utility throws during a round. Knowing your callouts is essential for clear team communication.' },
  { question: 'How do grenade lineups work in CS2?', answer: 'A lineup is a repeatable stance-and-aim combination that lets you throw utility — smokes, flashes, molotovs, or HE grenades — so it consistently lands on a precise target location. Building a personal library of reliable lineups for your main maps is one of the fastest ways to level up your competitive game.' },
  { question: 'Which competitive map favours the CT side the most?', answer: 'Nuke and Inferno historically tilt towards the CT side more than any other maps — Nuke because defenders can rotate between sites in seconds, and Inferno because of its narrow choke points that are easy to lock down. Ancient is another map that tends to give CTs a structural advantage.' },
  { question: 'What map should a new CS2 player learn first?', answer: 'Dust II and Mirage are the go-to starting points. Both follow a clean three-lane design that is intuitive to navigate, and their callout names are simple enough to pick up after just a few matches.' },
];

const poolLabels: Record<string, { label: string; color: string }> = {
  active: { label: 'Active', color: 'var(--accent)' },
  reserve: { label: 'Reserve', color: 'var(--text2)' },
  wingman: { label: 'Wingman', color: '#4fc3f7' },
};

const itemListSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "CS2 Active Duty Maps",
  "description": "The full active duty map pool in Counter-Strike 2, complete with standardized callout names, utility lineups, and side-specific tactics.",
  "numberOfItems": activeMaps.length,
  "itemListElement": activeMaps.map((m, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "name": m.name,
    "description": m.description,
    "url": `https://wiki.csgoluck.com/cs2-maps/${m.slug}/`
  }))
});
---

<Base title={title} description={description} currentNav="/cs2-maps/">
<Fragment slot="head">
<script type="application/ld+json" set:html={JSON.stringify(faqSchema(faqs))} />
<script type="application/ld+json" set:html={itemListSchema} />
</Fragment>

<nav class="breadcrumb"><a href="/">Home</a> <span>/</span> <span>Maps</span></nav>

<!-- Left-aligned hero with stats inline -->
<div class="mh-hero">
  <div class="mh-hero-text">
    <h1 class="mh-title">CS2 Map Database</h1>
    <p class="mh-subtitle">Named positions, side-specific game plans, <a href="/cs2-guides/grenade-guide/" style="color:var(--accent)">grenade lineup spots</a>, and tactical primers for each ranked map in CS2. See how <a href="/pro-players/" style="color:var(--accent)">pro players</a> approach these battlegrounds.</p>
  </div>
  <div class="mh-hero-stats">
    <div class="mh-stat">
      <span class="mh-stat-val">{activeMaps.length}</span>
      <span class="mh-stat-label">Active Maps</span>
    </div>
    <div class="mh-stat">
      <span class="mh-stat-val">{MAPS.reduce((t, m) => t + m.callouts.length, 0)}+</span>
      <span class="mh-stat-label">Callouts</span>
    </div>
    <div class="mh-stat">
      <span class="mh-stat-val">7</span>
      <span class="mh-stat-label">Lineup Guides</span>
    </div>
  </div>
</div>

<!-- Filter bar with pool tabs and sort -->
<div class="mh-toolbar">
  <div class="mh-tabs">
    <button class="mh-tab mh-tab-active" data-filter="all">All Maps</button>
    <button class="mh-tab" data-filter="active">Active Duty</button>
    <button class="mh-tab" data-filter="reserve">Reserve</button>
  </div>
  <div class="mh-sort">
    <label class="mh-sort-label">Sort:</label>
    <select class="mh-sort-select" id="mh-sort">
      <option value="name">Name A-Z</option>
      <option value="callouts">Most Callouts</option>
    </select>
  </div>
</div>

<!-- Map rows — horizontal row layout instead of card grid -->
<div class="mh-list">
{activeMaps.map(m => {
  const pool = poolLabels[m.pool] || poolLabels.active;
  const topCallouts = m.callouts.slice(0, 4);
  return (
    <article class="mh-row" id={m.slug} data-pool={m.pool} data-callouts={m.callouts.length}>
      <div class="mh-row-main">
        <div class="mh-row-left">
          <h2 class="mh-map-name">{m.name}</h2>
          <div class="mh-badges">
            <span class="mh-pool-badge" style={`color:${pool.color};border-color:${pool.color}`}>{pool.label}</span>
            <span class="mh-mode-badge">{m.mode === 'defusal' ? 'Defusal' : 'Hostage'}</span>
            {m.tags.slice(0, 3).map(t => (
              <span class="mh-tag-badge">{t}</span>
            ))}
          </div>
          <p class="mh-desc">{m.description}</p>
        </div>
        <div class="mh-row-right">
          <a href={`/cs2-maps/${m.slug}/`} class="mh-action mh-action-primary">Callouts</a>
          <a href={`/lineups/${m.slug}/`} class="mh-action">Lineups</a>
          <a href={`/map/${m.slug}/`} class="mh-action">Full Guide</a>
        </div>
      </div>

      <!-- Expandable details -->
      <div class="mh-row-details">
        <div class="mh-detail-col">
          <h3 class="mh-detail-heading">Key Callouts</h3>
          <div class="mh-callout-strip">
            {topCallouts.map(c => (
              <span class={`mh-callout mh-callout-${c.side}`}>
                <span class="mh-callout-name">{c.name}</span>
                <span class={`mh-callout-side mh-callout-side-${c.side}`}>{c.side.toUpperCase()}</span>
              </span>
            ))}
            <a href={`/cs2-maps/${m.slug}/`} class="mh-callout-link">+{m.callouts.length - 4} more</a>
          </div>
        </div>
        <div class="mh-detail-col">
          <h3 class="mh-detail-heading"><span class="mh-ct-indicator">CT</span> Defence Tips</h3>
          <ul class="mh-tip-list">
            {m.ctTips.slice(0, 2).map(tip => (
              <li>{tip}</li>
            ))}
          </ul>
        </div>
        <div class="mh-detail-col">
          <h3 class="mh-detail-heading"><span class="mh-t-indicator">T</span> Attack Tips</h3>
          <ul class="mh-tip-list">
            {m.tTips.slice(0, 2).map(tip => (
              <li>{tip}</li>
            ))}
          </ul>
        </div>
      </div>

      {m.meta && <p class="mh-meta">{m.meta}</p>}
    </article>
  );
})}
</div>

<!-- Related -->
<div class="mh-related">
  <strong>Related:</strong>
  <a href="/workshop-maps/">Workshop Maps</a>,
  <a href="/practice-config/">Practice Config</a>,
  <a href="/crosshair-generator/">Crosshair Generator</a>,
  <a href="/cs2-guides/advanced-mechanics-guide/">Advanced Mechanics</a>,
  <a href="/bind-generator/">Bind Generator</a>,
  <a href="/sensitivity-converter/">Sensitivity Converter</a>,
  <a href="/pro-players/">Pro Configs</a>,
  <a href="/cs2-guides/grenade-guide/">Grenade & Utility Guide</a>,
  <a href="/cs2-guides/movement-guide/">Movement Guide</a>,
  <a href="/cs2-weapons/">Weapon Database</a>,
  <a href="/cs2-commands/">Console Commands</a>,
  <a href="/cs2-tools/">All Tools</a>
</div>

<!-- FAQ -->
<section class="mh-faq">
  <h2 class="mh-faq-title">Common Questions</h2>
  <dl class="faq">
    {faqs.map(f => (
      <>
        <dt>{f.question}</dt>
        <dd>{f.answer}</dd>
      </>
    ))}
  </dl>
</section>

<ExploreMore context="maps" />
</Base>

<script>
  // Filter tabs
  document.querySelectorAll('.mh-tab').forEach(tab => {
    tab.addEventListener('click', () => {
      document.querySelectorAll('.mh-tab').forEach(t => t.classList.remove('mh-tab-active'));
      tab.classList.add('mh-tab-active');
      const filter = tab.getAttribute('data-filter');
      document.querySelectorAll('.mh-row').forEach(row => {
        if (filter === 'all' || row.getAttribute('data-pool') === filter) {
          (row as HTMLElement).style.display = '';
        } else {
          (row as HTMLElement).style.display = 'none';
        }
      });
    });
  });

  // Sort
  const sortSelect = document.getElementById('mh-sort') as HTMLSelectElement;
  if (sortSelect) {
    sortSelect.addEventListener('change', () => {
      const list = document.querySelector('.mh-list');
      if (!list) return;
      const rows = Array.from(list.querySelectorAll('.mh-row'));
      rows.sort((a, b) => {
        if (sortSelect.value === 'callouts') {
          return parseInt(b.getAttribute('data-callouts') || '0') - parseInt(a.getAttribute('data-callouts') || '0');
        }
        return (a.querySelector('.mh-map-name')?.textContent || '').localeCompare(b.querySelector('.mh-map-name')?.textContent || '');
      });
      rows.forEach(r => list.appendChild(r));
    });
  }
</script>

<style>
/* Hero — left-aligned two-column with stats on right */
.mh-hero{display:flex;align-items:center;justify-content:space-between;gap:2rem;margin-bottom:1.5rem;padding:1.5rem;background:var(--bg2);border:1px solid var(--border);border-left:3px solid var(--accent);border-radius:4px}
.mh-hero-text{flex:1;min-width:0}
.mh-title{margin:0 0 .4rem;font-size:1.5rem;color:var(--text)}
.mh-subtitle{margin:0;color:var(--text2);font-size:.85rem;line-height:1.6;max-width:540px}
.mh-hero-stats{display:flex;gap:1.5rem;flex-shrink:0}
.mh-stat{text-align:center;padding:0 .75rem}
.mh-stat-val{display:block;font-size:1.4rem;font-weight:800;color:var(--accent)}
.mh-stat-label{font-size:.7rem;color:var(--text2);text-transform:uppercase;letter-spacing:.03em}

/* Toolbar — filter tabs + sort */
.mh-toolbar{display:flex;align-items:center;justify-content:space-between;gap:1rem;margin-bottom:1.25rem;padding:.6rem .8rem;background:var(--bg2);border:1px solid var(--border);border-radius:4px}
.mh-tabs{display:flex;gap:.25rem}
.mh-tab{background:none;border:1px solid transparent;color:var(--text2);font-size:.78rem;font-weight:600;padding:.3rem .65rem;border-radius:4px;cursor:pointer;font-family:inherit;transition:color .15s,border-color .15s}
.mh-tab:hover{color:var(--text)}
.mh-tab-active{color:var(--accent);border-color:var(--accent);background:rgba(46,204,113,.06)}
.mh-sort{display:flex;align-items:center;gap:.4rem}
.mh-sort-label{font-size:.75rem;color:var(--text2)}
.mh-sort-select{background:var(--bg3);color:var(--text);border:1px solid var(--border);border-radius:4px;padding:.25rem .5rem;font-size:.78rem;font-family:inherit;cursor:pointer}

/* Map list — horizontal rows */
.mh-list{display:flex;flex-direction:column;gap:.75rem;margin-bottom:2rem}

.mh-row{background:var(--bg2);border:1px solid var(--border);border-radius:4px;padding:1rem 1.25rem;scroll-margin-top:80px;transition:border-color .15s}
.mh-row:hover{border-left:3px solid var(--accent)}

.mh-row-main{display:flex;align-items:flex-start;justify-content:space-between;gap:1.25rem;margin-bottom:.75rem}
.mh-row-left{flex:1;min-width:0}
.mh-map-name{margin:0 0 .35rem;font-size:1.15rem}
.mh-badges{display:flex;align-items:center;gap:.35rem;flex-wrap:wrap;margin-bottom:.5rem}
.mh-pool-badge{font-size:.65rem;font-weight:700;text-transform:uppercase;letter-spacing:.04em;padding:.1rem .35rem;border:1px solid;border-radius:4px}
.mh-mode-badge{font-size:.7rem;color:var(--text2)}
.mh-tag-badge{font-size:.65rem;color:var(--text2);background:var(--bg3);padding:.08rem .3rem;border-radius:4px}
.mh-desc{color:var(--text2);font-size:.84rem;line-height:1.6;margin:0}

.mh-row-right{display:flex;gap:.35rem;flex-shrink:0;flex-wrap:wrap}
.mh-action{padding:.3rem .6rem;background:var(--bg3);border:1px solid var(--border);border-radius:4px;font-size:.78rem;font-weight:600;color:var(--text2);text-decoration:none;transition:border-color .15s,color .15s}
.mh-action:hover{border-left:2px solid var(--accent);color:var(--accent)}
.mh-action-primary{background:var(--accent);color:#000;border-color:var(--accent)}
.mh-action-primary:hover{opacity:.9;border-left:2px solid #000}

/* Row details — three-column grid for callouts + tips */
.mh-row-details{display:grid;grid-template-columns:1fr 1fr 1fr;gap:1rem;padding-top:.75rem;border-top:1px solid var(--border)}
.mh-detail-col{}
.mh-detail-heading{font-size:.78rem;font-weight:700;color:var(--text);margin:0 0 .4rem;display:flex;align-items:center;gap:.3rem}
.mh-ct-indicator{background:#4a8db7;color:#fff;font-size:.58rem;font-weight:800;padding:.08rem .25rem;border-radius:3px}
.mh-t-indicator{background:#c44;color:#fff;font-size:.58rem;font-weight:800;padding:.08rem .25rem;border-radius:3px}

/* Callout strip — horizontal inline tags */
.mh-callout-strip{display:flex;flex-wrap:wrap;gap:.3rem;align-items:center}
.mh-callout{display:inline-flex;align-items:center;gap:.3rem;padding:.2rem .5rem;background:var(--bg3);border-radius:4px;border-left:2px solid var(--border)}
.mh-callout-ct{border-left-color:#4a8db7}
.mh-callout-t{border-left-color:#c44}
.mh-callout-mid{border-left-color:var(--text2)}
.mh-callout-name{font-size:.75rem;font-weight:600;color:var(--text)}
.mh-callout-side{font-size:.55rem;font-weight:700;letter-spacing:.03em}
.mh-callout-side-ct{color:#4a8db7}
.mh-callout-side-t{color:#c44}
.mh-callout-side-mid{color:var(--text2)}
.mh-callout-link{font-size:.72rem;color:var(--accent);font-weight:600;text-decoration:none}
.mh-callout-link:hover{text-decoration:underline}

/* Tip lists */
.mh-tip-list{list-style:none;padding:0;margin:0}
.mh-tip-list li{padding:.25rem 0 .25rem .75rem;position:relative;font-size:.78rem;color:var(--text2);border-bottom:1px solid var(--border)}
.mh-tip-list li:last-child{border-bottom:none}
.mh-tip-list li::before{content:'>';position:absolute;left:0;color:var(--accent);font-weight:700;font-size:.75rem}

.mh-meta{font-size:.78rem;color:var(--text2);font-style:italic;background:var(--bg3);padding:.5rem .7rem;border-radius:4px;border-left:3px solid var(--accent);margin:.75rem 0 0}

/* Related */
.mh-related{margin:2rem 0;font-size:.85rem;color:var(--text2)}
.mh-related a{color:var(--accent);text-decoration:none}
.mh-related a:hover{text-decoration:underline}

/* FAQ */
.mh-faq{margin:2rem 0}
.mh-faq-title{margin:0 0 1rem;font-size:1.1rem}

/* Responsive */
@media(max-width:900px){
  .mh-hero{flex-direction:column;align-items:flex-start;gap:1rem}
  .mh-hero-stats{gap:1rem}
  .mh-row-details{grid-template-columns:1fr}
}
@media(max-width:640px){
  .mh-row-main{flex-direction:column;gap:.75rem}
  .mh-row-right{width:100%}
  .mh-toolbar{flex-direction:column;align-items:flex-start;gap:.5rem}
  .mh-hero-stats{flex-wrap:wrap}
}
</style>
