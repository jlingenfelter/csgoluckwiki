---
import Base from '../layouts/Base.astro';
import AuthorBox from '../components/AuthorBox.astro';
import { faqSchema, breadcrumbSchema } from '../lib/weapons';

const title = 'CS2 Ranks & Competitive Modes FAQ | CSGOLuck Wiki';
const description = 'How CS2 ranking works — Premier, Wingman, FACEIT, and competitive modes fully explained. Start climbing the ranks today.';

const faqs = [
  {
    question: 'How to unlock Premier mode in CS2?',
    answer: 'To access Premier mode, you need to win ten Competitive matches first. This requirement ensures new players have a baseline understanding of CS2 mechanics before entering the ranked Premier queue. Once unlocked, Premier uses a map-veto system and assigns you a visible numerical rating. Players with Prime Status gain additional benefits like exclusive drops and improved matchmaking quality.',
  },
  {
    question: 'What is Wingman in CS2?',
    answer: 'Wingman is a 2v2 competitive mode played on smaller, single-bombsite versions of standard maps. Matches are best-of-16 rounds with shorter round timers, making them faster-paced than full 5v5 games. Wingman has its own separate skill group ranking that does not affect your Competitive or Premier rating. It is a great way to warm up or practice with a friend.',
  },
  {
    question: 'What is FACEIT CS2?',
    answer: 'FACEIT is a third-party competitive platform that runs its own matchmaking system and servers outside of Valve\'s official infrastructure. It uses 128-tick servers, offers its own Elo-based ranking system with ten skill levels, and provides a more structured anti-cheat environment. Many aspiring professionals and serious players prefer FACEIT for its higher-quality matches and tournament pathways.',
  },
  {
    question: 'How to play FACEIT CS2?',
    answer: 'Create a free account at faceit.com and link your Steam profile. Download and install the FACEIT Anti-Cheat client, which is required for ranked play. Once set up, you can queue for matches directly through the FACEIT platform. Free queues are available immediately, while premium subscriptions unlock additional features like priority matchmaking and league access.',
  },
  {
    question: 'How does CS2 ranking work?',
    answer: 'CS2 uses two parallel ranking systems. Competitive mode assigns one of 18 skill groups (Silver I through Global Elite) on a per-map basis. Premier mode uses a visible numerical rating that adjusts after each match based on the result and individual performance. Both systems use behind-the-scenes MMR calculations, but Premier provides more transparent progression feedback.',
  },
  {
    question: 'What is Premier in CS2?',
    answer: 'Premier is the flagship ranked mode in CS2 where two teams ban maps in alternating turns until one remains. Your performance is tracked by a numerical CS Rating visible on your profile and leaderboard. Wins and losses adjust this number in real time, with larger swings for upsets and closer adjustments for expected outcomes. Premier is considered the primary competitive experience in CS2.',
  },
];

const cards = [
  { url: '/unlock-premier-cs2/', question: 'How to Unlock Premier Mode', excerpt: 'Win 10 competitive matches to access Premier ranked play.' },
  { url: '/cs2-wingman-mode/', question: 'What Is Wingman in CS2?', excerpt: '2v2 ranked mode on smaller maps with separate ranking.' },
  { url: '/faceit-cs2-guide/', question: 'What Is FACEIT & How to Play', excerpt: 'Third-party competitive platform with 128-tick servers.' },
  { url: '/cs2-ranks-explained/', question: 'How Does CS2 Ranking Work?', excerpt: 'Skill groups, Premier rating, and MMR explained.' },
  { url: '/cs2-premier-mode/', question: 'What Is Premier Mode in CS2?', excerpt: 'Map veto, CS Rating, and the flagship ranked experience.' },
];
---

<Base title={title} description={description}>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema([{name:'Home',url:'/'},{name:'CS2 Ranks & Competitive FAQ',url:'/cs2-ranks-competitive-faq'}]))}></script>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema(faqs))}></script>

  <nav class="rcf-breadcrumb">
    <a href="/">Home</a> / <span>CS2 Ranks &amp; Competitive FAQ</span>
  </nav>

  <section class="rcf-hero">
    <h1>CS2 Ranks &amp; Competitive Modes FAQ</h1>
    <p class="rcf-hero-desc">Understanding CS2 ranks and competitive modes is essential for climbing the ladder, whether you are grinding Premier rating, pushing Competitive skill groups, or considering a move to FACEIT. This page breaks down every ranking-related question so you can focus on improving instead of guessing how the system works.</p>
  </section>

  <p class="rcf-intro">Click any question below for a detailed answer.</p>

  <div class="rcf-faq-grid">
    {cards.map(card => (
      <a href={card.url} class="rcf-faq-card">
        <div class="rcf-faq-card-content">
          <span class="rcf-faq-card-q">{card.question}</span>
          <p class="rcf-faq-card-excerpt">{card.excerpt}</p>
        </div>
        <span class="rcf-faq-card-arrow">&rarr;</span>
      </a>
    ))}
  </div>

  <section class="rcf-explore">
    <h2>Explore More</h2>
    <div class="rcf-explore-links">
      <a href="/cs2-gameplay-practice-faq/">CS2 Gameplay &amp; Practice FAQ</a>
      <a href="/cs2-esports-pro-scene-faq/">CS2 Esports &amp; Pro Scene FAQ</a>
    </div>
  </section>

  <div class="rcf-outbound">
    <strong>Official Resources:</strong>
    <a href="https://www.counter-strike.net/" target="_blank" rel="noopener noreferrer">Counter-Strike.net</a>
    <a href="https://www.faceit.com/" target="_blank" rel="noopener noreferrer">FACEIT</a>
  </div>

  <AuthorBox updated="2026-03-04" />
</Base>

<style>
/* ── Breadcrumb ── */
.rcf-breadcrumb{font-size:.82rem;color:var(--text2);margin-bottom:1.25rem;display:flex;gap:.35rem;flex-wrap:wrap}
.rcf-breadcrumb a{color:var(--accent);text-decoration:none}
.rcf-breadcrumb a:hover{text-decoration:underline}

/* ── Hero ── */
.rcf-hero{background:var(--bg2);border:1px solid var(--border);border-radius:4px;padding:2rem;margin-bottom:1.5rem}
.rcf-hero h1{font-family:'Montserrat',sans-serif;font-size:2rem;font-weight:800;margin:0 0 .75rem;color:var(--text)}
.rcf-hero-desc{color:var(--text2);font-size:.95rem;line-height:1.7;margin:0}

/* ── Intro ── */
.rcf-intro{font-size:.9rem;color:var(--text2);margin:0 0 1rem;line-height:1.6}

/* ── FAQ Card Grid ── */
.rcf-faq-grid{display:grid;grid-template-columns:1fr;gap:.75rem;margin-bottom:2.5rem}
.rcf-faq-card{display:flex;align-items:center;justify-content:space-between;padding:1.25rem;background:var(--bg2);border:1px solid var(--border);border-radius:4px;text-decoration:none;border-left:3px solid transparent;transition:border-left-color .2s,background .15s}
.rcf-faq-card:hover{border-left-color:var(--accent);background:rgba(46,204,113,.03)}
.rcf-faq-card-content{flex:1}
.rcf-faq-card-q{font-size:.95rem;font-weight:600;color:var(--text);margin:0 0 .25rem;display:block}
.rcf-faq-card-excerpt{font-size:.82rem;color:var(--text2);margin:0;line-height:1.5}
.rcf-faq-card-arrow{font-size:1.1rem;color:var(--accent);margin-left:1rem;opacity:0;transition:opacity .2s}
.rcf-faq-card:hover .rcf-faq-card-arrow{opacity:1}

/* ── Explore More ── */
.rcf-explore{margin-bottom:2rem}
.rcf-explore h2{font-family:'Montserrat',sans-serif;font-size:1.2rem;font-weight:700;color:var(--text);margin:0 0 .75rem;padding-bottom:.5rem;border-bottom:2px solid var(--accent)}
.rcf-explore-links{display:flex;flex-wrap:wrap;gap:.45rem}
.rcf-explore-links a{color:var(--accent);text-decoration:none;padding:.4rem .75rem;background:var(--bg2);border:1px solid var(--border);border-radius:4px;font-size:.85rem;font-weight:600;transition:border-color .15s,color .15s}
.rcf-explore-links a:hover{border-color:var(--accent);color:var(--text)}

/* ── Outbound Links ── */
.rcf-outbound{display:flex;flex-wrap:wrap;gap:.45rem;align-items:center;margin:1.5rem 0 2rem;font-size:.82rem}
.rcf-outbound strong{color:var(--text);margin-right:.2rem}
.rcf-outbound a{color:var(--accent);text-decoration:none;padding:.2rem .5rem;background:var(--bg2);border:1px solid var(--border);border-radius:4px;transition:border-color .15s}
.rcf-outbound a:hover{border-color:var(--accent)}

/* ── Responsive ── */
@media(max-width:768px){
  .rcf-hero h1{font-size:1.5rem}
}
</style>
