---
import Base from '../layouts/Base.astro';
import AuthorBox from '../components/AuthorBox.astro';
import { faqSchema, breadcrumbSchema } from '../lib/weapons';

const title = 'CS2 Settings & Config FAQ | CSGOLuck Wiki';
const description = 'How to show FPS, change FOV, adjust crosshair settings, and configure your CS2 setup. Quick answers to common config questions.';

const faqs = [
  {
    question: 'How to show FPS in CS2?',
    answer: 'Open the developer console (press tilde ~) and type cl_showfps 1 to display a basic FPS counter in the top-left corner. For more detailed network and performance data, use net_graph 1 instead. You can also enable the Steam overlay FPS counter through Steam Settings under In-Game.',
  },
  {
    question: 'How to change FOV in CS2?',
    answer: 'CS2 does not allow you to change the gameplay field of view beyond the default 90 degrees — this is locked by Valve to maintain competitive fairness. However, you can adjust the viewmodel FOV, which changes how your weapon appears on screen, using the viewmodel_fov command in the console. Values between 54 and 68 are accepted. A higher value pulls the weapon model further from the screen center.',
  },
  {
    question: 'How to change viewmodel in CS2?',
    answer: 'Use console commands to adjust your weapon viewmodel. The key commands are viewmodel_fov (54-68), viewmodel_offset_x (-2 to 2.5), viewmodel_offset_y (-2 to 2), and viewmodel_offset_z (-2 to 2). These control how far away, how left or right, and how high or low your weapon sits on screen. Save your preferred settings in an autoexec.cfg file so they load automatically.',
  },
  {
    question: 'How to copy and import a crosshair in CS2?',
    answer: 'CS2 uses shareable crosshair codes. To export yours, open Settings, go to the Crosshair tab, and click Share or Copy Code. To import someone else\'s crosshair, paste their code in the same menu using the Import option. You can also apply crosshair codes through the console with the apply_crosshair_code command.',
  },
  {
    question: 'How to change crosshair in CS2?',
    answer: 'Go to Settings and select the Crosshair tab for a visual editor that lets you adjust style, size, thickness, gap, color, outline, and dot visibility. For more granular control, use console commands like cl_crosshairsize, cl_crosshairgap, cl_crosshaircolor, and cl_crosshairstyle.',
  },
];

const cards = [
  { url: '/show-fps-cs2/', question: 'How to Show FPS in CS2', excerpt: 'Console commands and Steam overlay options for FPS display.' },
  { url: '/change-fov-cs2/', question: 'How to Change FOV in CS2', excerpt: 'Viewmodel FOV adjustment and why gameplay FOV is locked.' },
  { url: '/cs2-viewmodel-settings/', question: 'How to Change Viewmodel in CS2', excerpt: 'Console commands for weapon position, offset, and bob.' },
  { url: '/cs2-crosshair-guide/', question: 'CS2 Crosshair Guide', excerpt: 'Import, export, and customize crosshairs with codes and console.' },
];
---

<Base title={title} description={description}>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema([{name:'Home',url:'/'},{name:'CS2 Settings & Config FAQ',url:'/cs2-settings-config-faq'}]))}></script>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema(faqs))}></script>

  <nav class="scf-breadcrumb">
    <a href="/">Home</a> / <span>CS2 Settings &amp; Config FAQ</span>
  </nav>

  <section class="scf-hero">
    <h1>CS2 Settings &amp; Config FAQ</h1>
    <p class="scf-hero-desc">Fine-tuning your CS2 settings and config is one of the fastest ways to play more comfortably and consistently. From displaying your FPS counter to importing pro crosshairs and adjusting your viewmodel, these are the most commonly asked configuration questions — with clear, actionable answers.</p>
  </section>

  <p class="scf-intro">Click any question below for a detailed answer.</p>

  <div class="scf-faq-grid">
    {cards.map(card => (
      <a href={card.url} class="scf-faq-card">
        <div class="scf-faq-card-content">
          <span class="scf-faq-card-q">{card.question}</span>
          <p class="scf-faq-card-excerpt">{card.excerpt}</p>
        </div>
        <span class="scf-faq-card-arrow">&rarr;</span>
      </a>
    ))}
  </div>

  <section class="scf-explore">
    <h2>Explore More</h2>
    <div class="scf-explore-links">
      <a href="/cs2-gameplay-practice-faq/">CS2 Gameplay &amp; Practice FAQ</a>
      <a href="/cs2-download-platform-faq/">CS2 Download &amp; Platform FAQ</a>
    </div>
  </section>

  <div class="scf-outbound">
    <strong>Official Resources:</strong>
    <a href="https://developer.valvesoftware.com/" target="_blank" rel="noopener noreferrer">Valve Developer Wiki</a>
  </div>

  <AuthorBox updated="2026-03-04" />
</Base>

<style>
/* ── Breadcrumb ── */
.scf-breadcrumb{font-size:.82rem;color:var(--text2);margin-bottom:1.25rem;display:flex;gap:.35rem;flex-wrap:wrap}
.scf-breadcrumb a{color:var(--accent);text-decoration:none}
.scf-breadcrumb a:hover{text-decoration:underline}

/* ── Hero ── */
.scf-hero{background:var(--bg2);border:1px solid var(--border);border-radius:4px;padding:2rem;margin-bottom:1.5rem}
.scf-hero h1{font-family:'Montserrat',sans-serif;font-size:2rem;font-weight:800;margin:0 0 .75rem;color:var(--text)}
.scf-hero-desc{color:var(--text2);font-size:.95rem;line-height:1.7;margin:0}

/* ── Intro ── */
.scf-intro{font-size:.9rem;color:var(--text2);margin:0 0 1rem;line-height:1.6}

/* ── FAQ Card Grid ── */
.scf-faq-grid{display:grid;grid-template-columns:1fr;gap:.75rem;margin-bottom:2.5rem}
.scf-faq-card{display:flex;align-items:center;justify-content:space-between;padding:1.25rem;background:var(--bg2);border:1px solid var(--border);border-radius:4px;text-decoration:none;border-left:3px solid transparent;transition:border-left-color .2s,background .15s}
.scf-faq-card:hover{border-left-color:var(--accent);background:rgba(46,204,113,.03)}
.scf-faq-card-content{flex:1}
.scf-faq-card-q{font-size:.95rem;font-weight:600;color:var(--text);margin:0 0 .25rem;display:block}
.scf-faq-card-excerpt{font-size:.82rem;color:var(--text2);margin:0;line-height:1.5}
.scf-faq-card-arrow{font-size:1.1rem;color:var(--accent);margin-left:1rem;opacity:0;transition:opacity .2s}
.scf-faq-card:hover .scf-faq-card-arrow{opacity:1}

/* ── Explore More ── */
.scf-explore{margin-bottom:2rem}
.scf-explore h2{font-family:'Montserrat',sans-serif;font-size:1.2rem;font-weight:700;color:var(--text);margin:0 0 .75rem;padding-bottom:.5rem;border-bottom:2px solid var(--accent)}
.scf-explore-links{display:flex;flex-wrap:wrap;gap:.45rem}
.scf-explore-links a{color:var(--accent);text-decoration:none;padding:.4rem .75rem;background:var(--bg2);border:1px solid var(--border);border-radius:4px;font-size:.85rem;font-weight:600;transition:border-color .15s,color .15s}
.scf-explore-links a:hover{border-color:var(--accent);color:var(--text)}

/* ── Outbound Links ── */
.scf-outbound{display:flex;flex-wrap:wrap;gap:.45rem;align-items:center;margin:1.5rem 0 2rem;font-size:.82rem}
.scf-outbound strong{color:var(--text);margin-right:.2rem}
.scf-outbound a{color:var(--accent);text-decoration:none;padding:.2rem .5rem;background:var(--bg2);border:1px solid var(--border);border-radius:4px;transition:border-color .15s}
.scf-outbound a:hover{border-color:var(--accent)}

/* ── Responsive ── */
@media(max-width:768px){
  .scf-hero h1{font-size:1.5rem}
}
</style>
