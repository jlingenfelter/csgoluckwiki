---
import Base from '../../layouts/Base.astro';
import ExploreMore from '../../components/ExploreMore.astro';
import { SKINS, RARITY_COLORS, RARITY_BG, MARKETPLACES, getSkinsByWeapon, getSkinBySlug, getLowestPrice, getHighestPrice, getPhaseVariants, getParentSkin } from '../../lib/skins';
import { getWeaponBySlug, faqSchema, breadcrumbSchema } from '../../lib/weapons';
import { skinDetailImage, skinRelatedImage } from '../../lib/imageOptimize';
import { getPlayersUsingSkin } from '../../lib/pro-players';
import { getCasesForSkin } from '../../lib/cases';
import { getCollectionImage } from '../../lib/collection-images';
import skindeckRaw from '../../lib/skindeck-data.json';

export async function getStaticPaths() {
  return SKINS.map(skin => ({
    params: { slug: skin.slug },
    props: { skin },
  }));
}

const { skin } = Astro.props;
const rarityColor = skin.rarityColor || RARITY_COLORS[skin.rarity] || '#fff';
const rarityBg = RARITY_BG[skin.rarity] || 'rgba(255,255,255,0.05)';
const lowPrice = getLowestPrice(skin);
const highPrice = getHighestPrice(skin);
const weapon = getWeaponBySlug(skin.weaponSlug);

// Related skins from the same weapon
const relatedSkins = getSkinsByWeapon(skin.weaponSlug)
  .filter(s => s.slug !== skin.slug && !s.phase) // exclude phase variants from "related"
  .slice(0, 8);

// Phase data
const phaseVariants = getPhaseVariants(skin);
const parentSkin = getParentSkin(skin);
const isPhaseVariant = !!skin.phase;
const isDopplerParent = phaseVariants.length > 0;
// For phase variant pages, get all siblings from parent
const siblingVariants = parentSkin ? getPhaseVariants(parentSkin) : [];

// Category label
const categoryLabels: Record<string, string> = {
  rifle: 'Rifle', pistol: 'Pistol', smg: 'SMG', heavy: 'Heavy',
  knife: 'Knife', glove: 'Glove', other: 'Weapon',
};
const catLabel = categoryLabels[skin.category] || skin.category;

// Pro players using this skin
const playersUsingSkin = getPlayersUsingSkin(skin.slug);

// Marketplace display info — expanded with all known providers
const defaultMarketplaces: Record<string, { name: string; color: string; icon: string; domain: string; trustpilot?: number | null }> = {
  // Tier 1: Major marketplaces
  'buff163':        { name: 'Buff163',        color: '#d4956e', icon: 'BUFF', domain: 'buff.163.com', trustpilot: null },
  'buff163_buy':    { name: 'Buff163 Buy',    color: '#d4956e', icon: 'BUFF', domain: 'buff.163.com', trustpilot: null },
  'steam':          { name: 'Steam Market',   color: '#66c0f4', icon: 'STM', domain: 'store.steampowered.com', trustpilot: null },
  'skinport':       { name: 'Skinport',       color: '#00a3ff', icon: 'SP', domain: 'skinport.com', trustpilot: 4.9 },
  'csmoney':        { name: 'CS.Money',       color: '#ffca28', icon: 'CSM', domain: 'cs.money', trustpilot: 4.6 },
  'csmoneym':       { name: 'CS.Money Bot',   color: '#ffca28', icon: 'CSM', domain: 'cs.money', trustpilot: 4.6 },
  'dmarket':        { name: 'DMarket',        color: '#6c5ce7', icon: 'DM', domain: 'dmarket.com', trustpilot: 4.0 },
  'bitskins':       { name: 'BitSkins',       color: '#ff6b35', icon: 'BS', domain: 'bitskins.com', trustpilot: 3.8 },
  'csfloat':        { name: 'CSFloat',         color: '#1a73e8', icon: 'CSF', domain: 'csfloat.com', trustpilot: 4.8 },
  'waxpeer':        { name: 'Waxpeer',         color: '#ff9800', icon: 'WP', domain: 'waxpeer.com', trustpilot: 4.0 },
  'lisskins':       { name: 'LIS-SKINS',      color: '#ff5722', icon: 'LIS', domain: 'lis-skins.com', trustpilot: 4.8 },
  'skinbaron':      { name: 'SkinBaron',       color: '#e53935', icon: 'SBN', domain: 'skinbaron.de', trustpilot: 4.4 },
  // Tier 2: Popular marketplaces
  'csgoempire':     { name: 'CSGOEmpire',     color: '#f0b90b', icon: 'EMP', domain: 'csgoempire.com', trustpilot: 3.5 },
  'csgoroll':       { name: 'CSGORoll',        color: '#e74c3c', icon: 'ROLL', domain: 'csgoroll.com', trustpilot: 3.4 },
  'clashgg':        { name: 'Clash.GG',        color: '#f39c12', icon: 'CLG', domain: 'clash.gg', trustpilot: 3.7 },
  'skinsmonkey':    { name: 'SkinsMonkey',     color: '#27ae60', icon: 'SM', domain: 'skinsmonkey.com', trustpilot: 4.5 },
  'youpin':         { name: 'Youpin (UU)',     color: '#e91e63', icon: 'YP', domain: 'youpin898.com', trustpilot: null },
  'uuskins':        { name: 'UUSkins',         color: '#9b59b6', icon: 'UU', domain: 'uuskins.com', trustpilot: 4.1 },
  'whitemarket':    { name: 'White.Market',    color: '#bdc3c7', icon: 'WM', domain: 'white.market', trustpilot: 4.0 },
  'ecosteam':       { name: 'Ecosteam',        color: '#2ecc71', icon: 'ECO', domain: 'ecosteam.com', trustpilot: 3.7 },
  'shadowpay':      { name: 'ShadowPay',      color: '#9c27b0', icon: 'SHP', domain: 'shadowpay.com', trustpilot: 3.7 },
  'skinswap':       { name: 'SkinSwap',        color: '#8bc34a', icon: 'SW', domain: 'skinswap.com', trustpilot: 3.9 },
  'gamerpay':       { name: 'GamerPay',        color: '#00c853', icon: 'GP', domain: 'gamerpay.gg', trustpilot: 4.2 },
  'mannco':         { name: 'Mannco.store',    color: '#795548', icon: 'MC', domain: 'mannco.store', trustpilot: null },
  'rain':           { name: 'Rain.GG',         color: '#3498db', icon: 'RN', domain: 'rain.gg', trustpilot: null },
  'pirateswap':     { name: 'PirateSwap',      color: '#e74c3c', icon: 'PS', domain: 'pirateswap.gg', trustpilot: null },
  'skins':          { name: 'Skins.com',       color: '#8e44ad', icon: 'SKN', domain: 'skins.com', trustpilot: 4.5 },
  'buffmarket':     { name: 'BuffMarket',      color: '#f5a623', icon: 'BM', domain: 'buffmarket.com', trustpilot: null },
  // Tier 3: Smaller/niche marketplaces
  'c5game':         { name: 'C5Game',          color: '#ff6f00', icon: 'C5', domain: 'c5game.com', trustpilot: null },
  'lootfarm':       { name: 'Loot.Farm',       color: '#ff7043', icon: 'LF', domain: 'loot.farm', trustpilot: 3.8 },
  'skinflow':       { name: 'SkinFlow',        color: '#1abc9c', icon: 'SF', domain: 'skinflow.gg', trustpilot: null },
  'haloskins':      { name: 'HaloSkins',       color: '#ab47bc', icon: 'HS', domain: 'haloskins.com', trustpilot: null },
  'rapidskins':     { name: 'RapidSkins',      color: '#e67e22', icon: 'RS', domain: 'rapidskins.com', trustpilot: null },
  'tradeit':        { name: 'Tradeit.gg',      color: '#4caf50', icon: 'TI', domain: 'tradeit.gg', trustpilot: 4.8 },
  'skinbid':        { name: 'SkinBid',         color: '#2196f3', icon: 'SB', domain: 'skinbid.com', trustpilot: null },
  'marketcsgo':     { name: 'Market.CSGO',     color: '#607d8b', icon: 'MCS', domain: 'market.csgo.com', trustpilot: null },
  'itrade':         { name: 'iTrade',          color: '#00bcd4', icon: 'IT', domain: 'itrade.gg', trustpilot: null },
  'cstrade':        { name: 'CSTrade',         color: '#009688', icon: 'CST', domain: 'cs.trade', trustpilot: null },
  'avanmarket':     { name: 'AvanMarket',      color: '#673ab7', icon: 'AV', domain: 'avanmarket.com', trustpilot: null },
  'dupefi':         { name: 'Dupe.fi',         color: '#34495e', icon: 'DF', domain: 'dupe.fi', trustpilot: null },
  'krakatoa':       { name: 'Krakatoa',        color: '#d35400', icon: 'KRK', domain: 'krakatoa.gg', trustpilot: null },
  'csgo500':        { name: 'CSGO500',         color: '#e74c3c', icon: '500', domain: 'csgo500.com', trustpilot: null },
  'skinrave':       { name: 'SkinRave',        color: '#e91e63', icon: 'SR', domain: 'skinrave.gg', trustpilot: null },
  '49skins':        { name: '49Skins',         color: '#3f51b5', icon: '49', domain: '49skins.com', trustpilot: null },
  'snipeskins':     { name: 'SnipeSkins',      color: '#ff5722', icon: 'SNP', domain: 'snipeskins.com', trustpilot: null },
  'skinplace':      { name: 'SkinPlace',       color: '#009688', icon: 'SPL', domain: 'skinplace.com', trustpilot: null },
  'exeskins':       { name: 'ExeSkins',        color: '#607d8b', icon: 'EXE', domain: 'exeskins.com', trustpilot: null },
  'swap_gg':        { name: 'Swap.gg',         color: '#7c4dff', icon: 'SG', domain: 'swap.gg', trustpilot: 3.5 },
  'csdeals':        { name: 'CS.Deals',        color: '#26a69a', icon: 'CSD', domain: 'cs.deals', trustpilot: 3.4 },
  'lootbear':       { name: 'LootBear',        color: '#ffd54f', icon: 'LB', domain: 'lootbear.com', trustpilot: 3.7 },
  // Tier 4: From providerKeys API
  'csgoexo':        { name: 'CSGOExo',         color: '#ff7043', icon: 'EXO', domain: 'csgoexo.com', trustpilot: null },
  'gamdom':         { name: 'Gamdom',           color: '#2ecc71', icon: 'GAM', domain: 'gamdom.com', trustpilot: null },
  'skinwallet':     { name: 'SkinWallet',      color: '#3498db', icon: 'SWL', domain: 'skinwallet.com', trustpilot: null },
  'skintrade':      { name: 'SkinTrade',       color: '#e67e22', icon: 'STR', domain: 'skintrade.com', trustpilot: null },
  'skinthunder':    { name: 'SkinThunder',     color: '#f39c12', icon: 'STH', domain: 'skinthunder.com', trustpilot: null },
  'skinout':        { name: 'SkinOut',          color: '#1abc9c', icon: 'SO', domain: 'skinout.gg', trustpilot: null },
  'nerf':           { name: 'Nerf.app',         color: '#e74c3c', icon: 'NRF', domain: 'nerf.app', trustpilot: null },
  'ggskin':         { name: 'GGSkin',           color: '#9b59b6', icon: 'GGS', domain: 'ggskin.com', trustpilot: null },
  'cs2go':          { name: 'CS2GO',            color: '#3f51b5', icon: 'C2G', domain: 'cs2go.com', trustpilot: null },
  'bitskinsp2p':    { name: 'BitSkins P2P',    color: '#ff6b35', icon: 'BSP', domain: 'bitskins.com', trustpilot: 3.8 },
  'swapmarket':     { name: 'SwapMarket',      color: '#795548', icon: 'SWM', domain: 'swapmarket.com', trustpilot: null },
  'vmarket':        { name: 'V.Market',         color: '#607d8b', icon: 'VM', domain: 'vmarket.com', trustpilot: null },
  'itemherald':     { name: 'ItemHerald',      color: '#00bcd4', icon: 'IH', domain: 'itemherald.com', trustpilot: null },
  'skinswap_cn':    { name: 'SkinSwap CN',     color: '#8bc34a', icon: 'SWC', domain: 'skinswap.cn', trustpilot: null },
  'gameboost':      { name: 'GameBoost',        color: '#4caf50', icon: 'GB', domain: 'gameboost.com', trustpilot: null },
  'gsoltrade':      { name: 'GSOL.Trade',       color: '#ff9800', icon: 'GSL', domain: 'gsol.trade', trustpilot: null },
};
// Merge: defaultMarketplaces has richer data (domain, trustpilot), so it takes priority
// MARKETPLACES from skins-data.json fills in any keys not already covered
const mpInfo: Record<string, any> = { ...MARKETPLACES };
for (const [key, val] of Object.entries(defaultMarketplaces)) {
  mpInfo[key] = { ...(mpInfo[key] || {}), ...val };
}

function getMarketplace(key: string) {
  return mpInfo[key] || { name: key, color: '#888', icon: key.substring(0, 3).toUpperCase(), domain: '', trustpilot: null };
}

// ── Deep-link URL builders per marketplace ────────────────────────────────
// IMPORTANT: Most marketplaces break when the pipe "|" is in the search query.
// We use "Weapon Name" (no pipe) with "+" for spaces, which works across sites.
const searchTerm = `${skin.weapon} ${skin.name}`.replace(/\s+/g, '+');

// Waxpeer uses a slug format: "ak-47-redline"
const waxpeerSlug = `${skin.weapon}-${skin.name}`.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');

// Build deep-link search URLs for each marketplace
function getMarketplaceUrl(key: string): string {
  switch (key) {
    // ── VERIFIED WORKING ─────────────────────────────────────────────────

    // Steam Community Market — ?q= with appid filter
    case 'steam':
      return `https://steamcommunity.com/market/search?appid=730&q=${searchTerm}`;

    // Skinport — /market?search= (NOT /market/cs2)
    case 'skinport':
      return `https://skinport.com/market?search=${searchTerm}`;

    // CS.Money — /market/buy/?search=
    case 'csmoney':
    case 'csmoneym':
      return `https://cs.money/market/buy/?search=${searchTerm}`;

    // DMarket — ?title= parameter
    case 'dmarket':
      return `https://dmarket.com/ingame-items/item-list/csgo-skins?title=${searchTerm}`;

    // Tradeit.gg — /csgo/store?search=
    case 'tradeit':
      return `https://tradeit.gg/csgo/store?search=${searchTerm}`;

    // ShadowPay — /csgo-items?search=
    case 'shadowpay':
      return `https://shadowpay.com/csgo-items?search=${searchTerm}`;

    // SkinBaron — /en/csgo?str= (NOT ?search=)
    case 'skinbaron':
      return `https://skinbaron.de/en/csgo?str=${searchTerm}`;

    // Waxpeer — slug-based URL like /ak-47-redline/item
    case 'waxpeer':
      return `https://waxpeer.com/${waxpeerSlug}/item`;

    // ── LIKELY WORKING (search param, unverified) ────────────────────────

    // Buff163 — market search (Chinese marketplace, hard to verify)
    case 'buff163':
    case 'buff163_buy':
      return `https://buff.163.com/market/csgo#tab=selling&page_num=1&search=${searchTerm}`;

    // SkinSwap — market search
    case 'skinswap':
      return `https://skinswap.com/market/cs2?search=${searchTerm}`;

    // Youpin/UU — keyword search
    case 'youpin':
      return `https://youpin898.com/search?keyword=${searchTerm}`;

    // LIS-SKINS — market search
    case 'lisskins':
      return `https://lis-skins.com/market/?search=${searchTerm}`;

    // SkinBid — acquired by Skinport, link to Skinport instead
    case 'skinbid':
      return `https://skinport.com/market?search=${searchTerm}`;

    // Loot.Farm — hash-based (uses pipe format in fragment)
    case 'lootfarm':
      return `https://loot.farm/`;

    // Swap.gg — search
    case 'swap_gg':
      return `https://swap.gg/csgo?search=${searchTerm}`;

    // Mannco.store — search
    case 'mannco':
      return `https://mannco.store/search?q=${searchTerm}`;

    // CS.Deals — market search
    case 'csdeals':
      return `https://cs.deals/market/csgo/?search=${searchTerm}`;

    // C5Game — Chinese marketplace
    case 'c5game':
      return `https://www.c5game.com/csgo?keyword=${searchTerm}`;

    // IGXE — Chinese marketplace
    case 'igxe':
      return `https://www.igxe.cn/csgo?keyword=${searchTerm}`;

    // HaloSkins
    case 'haloskins':
      return `https://haloskins.com/market?search=${searchTerm}`;

    // LootBear
    case 'lootbear':
      return `https://lootbear.com/en/counter-strike-2?search=${searchTerm}`;

    // ── NO URL SEARCH SUPPORT (link to general market page) ──────────────

    // CSFloat — client-side only, no URL param filtering
    case 'csfloat':
      return `https://csfloat.com/`;

    // BitSkins — client-side only, search param doesn't filter
    case 'bitskins':
      return `https://bitskins.com/market/cs2`;

    // GamerPay — 404s on search URLs
    case 'gamerpay':
      return `https://gamerpay.gg/`;

    // CSGOEmpire — market search
    case 'csgoempire':
      return `https://csgoempire.com/withdraw?search=${searchTerm}`;

    // CSGORoll — market search
    case 'csgoroll':
      return `https://csgoroll.com/withdraw?search=${searchTerm}`;

    // Clash.GG — market
    case 'clashgg':
      return `https://clash.gg/withdraw?search=${searchTerm}`;

    // SkinsMonkey — market
    case 'skinsmonkey':
      return `https://skinsmonkey.com/`;

    // UUSkins
    case 'uuskins':
      return `https://uuskins.com/`;

    // White.Market — market search
    case 'whitemarket':
      return `https://white.market/search?query=${searchTerm}`;

    // Ecosteam
    case 'ecosteam':
      return `https://ecosteam.de/market?search=${searchTerm}`;

    // Rain.GG
    case 'rain':
      return `https://rain.gg/market?search=${searchTerm}`;

    // PirateSwap
    case 'pirateswap':
      return `https://pirateswap.gg/`;

    // Skins.com
    case 'skins':
      return `https://skins.com/`;

    // SkinFlow
    case 'skinflow':
      return `https://skinflow.gg/`;

    // RapidSkins
    case 'rapidskins':
      return `https://rapidskins.com/`;

    // Dupe.fi
    case 'dupefi':
      return `https://dupe.fi/`;

    // Default: link nowhere
    default:
      return '#';
  }
}



// ── Blocked providers (empty — show all marketplaces) ──
const BLOCKED_PROVIDERS = new Set<string>();

// Compute lowest price per provider across the default wear
const defaultWearIndex = 0;
const defaultWear = skin.prices[defaultWearIndex] || null;

// Get all unique providers across all wears
const allProviders = new Set<string>();
for (const p of skin.prices) {
  if (p.providers) {
    for (const pk of Object.keys(p.providers)) {
      if (!BLOCKED_PROVIDERS.has(pk)) allProviders.add(pk);
    }
  }
}

// Top 3 cheapest providers for the header cards
function getTopProviders(wearData: typeof defaultWear) {
  if (!wearData?.providers) return [];
  return Object.entries(wearData.providers)
    .filter(([k, v]) => v > 0 && !BLOCKED_PROVIDERS.has(k))
    .sort((a, b) => a[1] - b[1])
    .slice(0, 3);
}

// ── CSGOLuck Market Prices (via SkinDeck) ─────────────────────────────────
const skindeckItems: Record<string, { price: number; marketPrice: number | null; count: number }> = (skindeckRaw as any).items || {};

const csgoluckPrices = skin.prices.map(p => {
  const hashName = `${skin.weapon} | ${skin.name} (${p.wear})`;
  const item = skindeckItems[hashName];
  return {
    wear: p.wear,
    price: item?.price ?? null as number | null,
    count: item?.count ?? 0,
  };
});

const csgoluckStPrices = (skin.statTrakPrices || []).map(p => {
  const hashName = `StatTrak\u2122 ${skin.weapon} | ${skin.name} (${p.wear})`;
  const item = skindeckItems[hashName];
  return {
    wear: p.wear,
    price: item?.price ?? null as number | null,
    count: item?.count ?? 0,
  };
});

const hasCsgoluckPrice = csgoluckPrices.some(p => p.price !== null);

// ── SEO Title & Description ────────────────────────────────────────────────
const title = `${skin.weapon} | ${skin.name} — Price, Float, Details | CSGOLuck Wiki`;
const description = `${skin.weapon} | ${skin.name} skin prices from ${allProviders.size}+ marketplaces. Compare Buff163, CS.Money, Skinport and more. ${skin.rarity} ${catLabel} with float range ${skin.minFloat.toFixed(2)}–${skin.maxFloat.toFixed(2)}.`;

// ── Wear condition descriptions (for SEO content) ─────────────────────────
const wearDescriptions: Record<string, string> = {
  'Factory New': 'near-perfect condition with minimal scratches, float value between 0.00 and 0.07',
  'Minimal Wear': 'slight cosmetic wear with minor scratches, float value between 0.07 and 0.15',
  'Field-Tested': 'moderate wear with visible scratches and marks, float value between 0.15 and 0.38',
  'Well-Worn': 'significant wear with noticeable scratches and fading, float value between 0.38 and 0.45',
  'Battle-Scarred': 'heavy wear with major scratches, chips and fading, float value between 0.45 and 1.00',
};

// ── Price comparison table data ───────────────────────────────────────────
const priceTable: { wear: string; prices: [string, number][] }[] = skin.prices.map(p => ({
  wear: p.wear,
  prices: p.providers
    ? Object.entries(p.providers).filter(([k, v]) => v > 0 && !BLOCKED_PROVIDERS.has(k)).sort((a, b) => a[1] - b[1])
    : [],
}));

// StatTrak price comparison table data
const stPriceTable: { wear: string; prices: [string, number][] }[] = (skin.statTrakPrices || []).map(p => ({
  wear: p.wear,
  prices: p.providers
    ? Object.entries(p.providers).filter(([k, v]) => v > 0 && !BLOCKED_PROVIDERS.has(k)).sort((a, b) => a[1] - b[1])
    : [],
}));

// Cheapest provider per wear
const cheapestPerWear = skin.prices.map(p => {
  if (!p.providers) return { wear: p.wear, provider: '', price: p.price };
  const sorted = Object.entries(p.providers).filter(([k, v]) => v > 0 && !BLOCKED_PROVIDERS.has(k)).sort((a, b) => a[1] - b[1]);
  return sorted.length > 0
    ? { wear: p.wear, provider: sorted[0][0], price: sorted[0][1] }
    : { wear: p.wear, provider: '', price: p.price };
});

// ── Rarity tier descriptions ──────────────────────────────────────────────
const rarityDescriptions: Record<string, string> = {
  'Consumer': 'the most common grade, often found in collections and cases',
  'Industrial': 'a common grade, slightly rarer than Consumer',
  'Mil-Spec': 'a mid-tier grade, the baseline for most case drops',
  'Restricted': 'a mid-high tier grade with a distinctive purple color',
  'Classified': 'a high-tier grade, identifiable by its pink color',
  'Covert': 'one of the rarest grades, known for its red color',
  'Contraband': 'the rarest grade in CS2, reserved for exclusive items',
  'Extraordinary': 'a special grade reserved for rare gloves and unique items',
};

// ── Product Schema (schema.org) ───────────────────────────────────────────
const productSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Product",
  "name": `${skin.weapon} | ${skin.name}`,
  "description": `${skin.weapon} | ${skin.name} is a ${skin.rarity} grade ${catLabel.toLowerCase()} skin in Counter-Strike 2${skin.collection ? ` from the ${skin.collection}` : ''}. Available in ${skin.prices.length} wear condition${skin.prices.length !== 1 ? 's' : ''} with float range ${skin.minFloat.toFixed(2)} to ${skin.maxFloat.toFixed(2)}.`,
  "image": skin.image || undefined,
  "brand": { "@type": "Brand", "name": "Counter-Strike 2" },
  "category": `CS2 ${catLabel} Skins`,
  "sku": skin.slug,
  ...(lowPrice > 0 ? {
    "offers": {
      "@type": "AggregateOffer",
      "priceCurrency": "USD",
      "lowPrice": lowPrice.toFixed(2),
      "highPrice": highPrice.toFixed(2),
      "offerCount": allProviders.size,
      "availability": "https://schema.org/InStock",
    },
  } : {}),
  "additionalProperty": [
    { "@type": "PropertyValue", "name": "Rarity", "value": skin.rarity },
    { "@type": "PropertyValue", "name": "Float Range", "value": `${skin.minFloat.toFixed(2)} - ${skin.maxFloat.toFixed(2)}` },
    { "@type": "PropertyValue", "name": "StatTrak", "value": skin.statTrak ? "Available" : "Not Available" },
    ...(skin.collection ? [{ "@type": "PropertyValue", "name": "Collection", "value": skin.collection }] : []),
  ],
});

// ── FAQs (expanded for SEO) ───────────────────────────────────────────────
const faqs = [
  {
    q: `How much is ${skin.weapon} | ${skin.name}?`,
    a: skin.prices.length > 0
      ? `The ${skin.weapon} | ${skin.name} ranges from $${lowPrice.toFixed(2)} to $${highPrice.toFixed(2)} depending on wear condition. ${skin.prices.map(p => `${p.wear} starts at $${p.price.toFixed(2)}`).join(', ')}.`
      : `The ${skin.weapon} | ${skin.name} is a ${skin.rarity} ${catLabel} skin. Check current marketplace listings for up-to-date pricing.`,
  },
  {
    q: `What rarity is ${skin.weapon} | ${skin.name}?`,
    a: `${skin.weapon} | ${skin.name} is a ${skin.rarity} grade skin${skin.collection ? ` from the ${skin.collection}` : ''}. ${skin.rarity} is ${rarityDescriptions[skin.rarity] || `a ${skin.rarity} tier`} in CS2.`,
  },
  {
    q: `Where is the cheapest place to buy ${skin.weapon} | ${skin.name}?`,
    a: cheapestPerWear.length > 0 && cheapestPerWear[0].provider
      ? `The cheapest listing for ${skin.weapon} | ${skin.name} (${cheapestPerWear[0].wear}) is currently $${cheapestPerWear[0].price.toFixed(2)} on ${getMarketplace(cheapestPerWear[0].provider).name}. Compare prices across all ${allProviders.size} marketplaces above.`
      : `Compare prices across ${allProviders.size}+ marketplaces above to find the best deal. Prices update regularly from Buff163, CS.Money, Skinport, and other trusted platforms.`,
  },
  {
    q: `What float range does ${skin.weapon} | ${skin.name} have?`,
    a: `${skin.weapon} | ${skin.name} has a float range of ${skin.minFloat.toFixed(2)} to ${skin.maxFloat.toFixed(2)}. This means it${skin.minFloat === 0 ? ' can drop in Factory New condition' : ` has a minimum float of ${skin.minFloat.toFixed(2)}`}${skin.maxFloat < 1 ? ` and cannot exceed ${skin.maxFloat.toFixed(2)} float value` : ''}.`,
  },
  {
    q: `Is ${skin.weapon} | ${skin.name} available in StatTrak?`,
    a: skin.statTrak
      ? `Yes, ${skin.weapon} | ${skin.name} is available in StatTrak versions which track kill counts. StatTrak variants typically cost more than regular versions.`
      : `No, ${skin.weapon} | ${skin.name} is not available in StatTrak. Only skins obtainable from weapon cases can have StatTrak versions.`,
  },
  ...(skin.collection ? [{
    q: `What collection is ${skin.weapon} | ${skin.name} from?`,
    a: `${skin.weapon} | ${skin.name} is from the ${skin.collection}. Other skins from this collection can be found on the collection page.`,
  }] : []),
  ...(playersUsingSkin.length > 0 ? [{
    q: `Which pro players use ${skin.weapon} | ${skin.name}?`,
    a: `${playersUsingSkin.map(p => p.name).join(', ')} ${playersUsingSkin.length === 1 ? 'uses' : 'use'} the ${skin.weapon} | ${skin.name} in their CS2 loadout.`,
  }] : []),
];

const crumbs = [
  { name: 'Home', url: 'https://wiki.csgoluck.com/' },
  { name: 'Skins', url: 'https://wiki.csgoluck.com/cs2-skins/' },
  { name: `${skin.weapon} Skins`, url: `https://wiki.csgoluck.com/cs2-weapon/${skin.weaponSlug}/` },
  ...(isPhaseVariant && parentSkin ? [{ name: parentSkin.name, url: `https://wiki.csgoluck.com/cs2-skin/${parentSkin.slug}/` }] : []),
  { name: isPhaseVariant ? skin.phase! : skin.name, url: `https://wiki.csgoluck.com/cs2-skin/${skin.slug}/` },
];

// ── Related skins from same collection ────────────────────────────────────
const collectionSkins = skin.collection
  ? SKINS.filter(s => s.collection === skin.collection && s.slug !== skin.slug).slice(0, 6)
  : [];

// ── Related skins by similar price ────────────────────────────────────────
const priceSimilar = SKINS
  .filter(s => s.slug !== skin.slug && s.category === skin.category)
  .map(s => ({ skin: s, diff: Math.abs(getHighestPrice(s) - highPrice) }))
  .sort((a, b) => a.diff - b.diff)
  .slice(0, 4)
  .map(s => s.skin);

// ── Containers (which cases contain this skin) ───────────────────────────
const skinCases = getCasesForSkin(skin.weapon, skin.name);

// ── Collection emblem image (official CS2 collection logos) ──────────────
const collectionImage = skin.collection ? getCollectionImage(skin.collection) : null;

// ── Rich content data ────────────────────────────────────────────────────
const totalSkinCount = SKINS.filter(s => s.category === skin.category).length;
const rarityDropChances: Record<string, string> = {
  'Consumer': '~79.92%', 'Industrial': '~79.92%', 'Mil-Spec': '~79.92%',
  'Restricted': '~15.98%', 'Classified': '~3.2%', 'Covert': '~0.64%',
  'Contraband': '~0.26%', 'Extraordinary': '~0.26%',
};
const dropChance = rarityDropChances[skin.rarity] || 'unknown';
const wearCount = skin.prices.length;
const hasAllWears = skin.minFloat === 0 && skin.maxFloat >= 1;
const availableWears = skin.prices.map(p => p.wear);

// Popularity tier based on rank
const popTier = (skin.rank ?? 999) <= 50 ? 'extremely popular' : (skin.rank ?? 999) <= 200 ? 'very popular' : (skin.rank ?? 999) <= 500 ? 'popular' : (skin.rank ?? 999) <= 1000 ? 'moderately popular' : 'niche';
const popPercent = totalSkinCount > 0 ? Math.max(1, Math.round(100 - ((skin.rank ?? totalSkinCount) / totalSkinCount * 100))) : 0;

// Availability description
const listingDesc = (skin.listingCount ?? 0) > 10000 ? 'widely available with high supply' : (skin.listingCount ?? 0) > 1000 ? 'readily available across multiple markets' : (skin.listingCount ?? 0) > 100 ? 'available but with limited supply' : (skin.listingCount ?? 0) > 0 ? 'scarce with very few listings' : 'check individual marketplaces for availability';
---
<Base title={title} description={description} currentNav="/cs2-skins/" ogImage={skin.image || undefined}>
<script type="application/ld+json" set:html={JSON.stringify(faqSchema(faqs))} />
<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema(crumbs))} />
<script type="application/ld+json" set:html={productSchema} />

<!-- Breadcrumb Navigation -->
<nav class="wi-crumbs">
  <a href="/">Home</a> <span class="wi-crumbs-sep">/</span> <a href="/cs2-skins/">Skins</a> <span class="wi-crumbs-sep">/</span> <a href={`/cs2-weapon/${skin.weaponSlug}/`}>{skin.weapon}</a>{isPhaseVariant && parentSkin ? <> <span class="wi-crumbs-sep">/</span> <a href={`/cs2-skin/${parentSkin.slug}/`}>{parentSkin.name}</a></> : null} <span class="wi-crumbs-sep">/</span> <span class="wi-crumbs-current">{isPhaseVariant ? skin.phase : skin.name}</span>
</nav>

<!-- Title Strip -->
<div class="wi-head">
  <h1 class="wi-title">{skin.weapon} | {skin.name} <span class="wi-wear-tag" id="active-wear-label">{defaultWear ? defaultWear.wear : ''}</span></h1>
  <div class="wi-title-accent" style={`background:${rarityColor}`}></div>
</div>

<!-- ═══ TWO-COLUMN GRID ═══ -->
<div class="wi-two-col">

  <!-- LEFT COLUMN -->
  <div class="wi-col-left">

    <!-- Image box with rarity badge -->
    <div class="wi-preview" style={`border-bottom-color:${rarityColor}`}>
      {skin.image ? (
        <img src={skinDetailImage(skin.image)} alt={`${skin.weapon} | ${skin.name}`} class="wi-preview-img" width="800" height="600" loading="eager" />
      ) : (
        <div class="wi-preview-ph" style={`color:${rarityColor}`}>{skin.weapon.substring(0, 3)}</div>
      )}
      <span class="wi-grade-tag" style={`background:${rarityColor}`}>{skin.rarity}</span>
    </div>

    <!-- Specs table -->
    <div class="wi-specs">
      <table class="wi-specs-table">
        <tbody>
          <tr class="wi-spec-row"><td class="wi-spec-key">Class</td><td class="wi-spec-val">{skin.category === 'knife' || skin.category === 'glove' ? 'Special' : 'Skin'}</td></tr>
          <tr class="wi-spec-row"><td class="wi-spec-key">Weapon Type</td><td class="wi-spec-val">{catLabel}</td></tr>
          <tr class="wi-spec-row"><td class="wi-spec-key">Weapon</td><td class="wi-spec-val"><a href={`/cs2-weapon/${skin.weaponSlug}/`}>{skin.weapon}</a></td></tr>
          <tr class="wi-spec-row"><td class="wi-spec-key">Skin Name</td><td class="wi-spec-val">{skin.name}</td></tr>
          {skin.collection && <tr class="wi-spec-row"><td class="wi-spec-key">Set</td><td class="wi-spec-val">{skin.collection}</td></tr>}
          <tr class="wi-spec-row"><td class="wi-spec-key">Grade</td><td class="wi-spec-val" style={`color:${rarityColor}`}>{skin.rarity}</td></tr>
          <tr class="wi-spec-row"><td class="wi-spec-key">Float</td><td class="wi-spec-val">{skin.minFloat.toFixed(2)} -- {skin.maxFloat.toFixed(2)}</td></tr>
          <tr class="wi-spec-row"><td class="wi-spec-key">StatTrak&#8482;</td><td class="wi-spec-val">{skin.statTrak ? 'Available' : 'Unavailable'}</td></tr>
          <tr class="wi-spec-row"><td class="wi-spec-key">Souvenir</td><td class="wi-spec-val">{skin.souvenir ? 'Available' : 'Unavailable'}</td></tr>
        </tbody>
      </table>
    </div>

    <!-- Grade indicator bar -->
    <div class="wi-panel wi-grade-strip">
      <div class="wi-grade-info">
        <span class="wi-grade-label" style={`color:${rarityColor}`}>{skin.rarity}</span>
        <span class="wi-grade-type">{skin.statTrak ? 'StatTrak' : skin.souvenir ? 'Souvenir' : 'Normal'}</span>
      </div>
      <div class="wi-grade-bar">
        <div class="wi-grade-bar-fill" style={`background:${rarityColor};width:${skin.rarity === 'Consumer' ? '15%' : skin.rarity === 'Industrial' ? '28%' : skin.rarity === 'Mil-Spec' ? '42%' : skin.rarity === 'Restricted' ? '56%' : skin.rarity === 'Classified' ? '70%' : skin.rarity === 'Covert' ? '85%' : '100%'}`}></div>
      </div>
    </div>

    <!-- Containers / Cases -->
    {skinCases.length > 0 && (
      <div class="wi-source">
        <h2>Found In</h2>
        <div class="wi-source-list">
          {skinCases.map(c => (
            <a href={`/cs2-cases/${c.id}/`} class="wi-source-item">
              <div class="wi-source-thumb">
                <img src={c.image} alt={c.name} loading="lazy" width="120" height="90" />
              </div>
              <span class="wi-source-name">{c.name}</span>
            </a>
          ))}
        </div>
      </div>
    )}

    <!-- Collection -->
    {skin.collection && (
      <div class="wi-source">
        <h2>Collection</h2>
        <div class="wi-source-list">
          <a href={`/cs2-collections/${skin.collection.toLowerCase().replace(/[^a-z0-9]+/g, '-')}/`} class="wi-source-item">
            <div class="wi-source-thumb">
              {collectionImage ? (
                <img src={collectionImage} alt={skin.collection} loading="lazy" width="120" height="90" style="object-fit: contain;" />
              ) : (
                <span class="wi-source-icon" style={`color:${rarityColor}`}>{skin.collection.replace(/^The /, '').substring(0, 2)}</span>
              )}
            </div>
            <span class="wi-source-name">{skin.collection}</span>
          </a>
        </div>
      </div>
    )}

  </div><!-- /wi-col-left -->

  <!-- RIGHT COLUMN -->
  <div class="wi-col-right">

    <!-- Wear condition tabs (pill buttons) -->
    <div class="wi-conditions">
      <div class="wi-conditions-label">Condition</div>
      {skin.prices.length > 0 ? (
        <div class="wi-cond-pills" id="variant-list">
          {skin.prices.map((p, i) => {
            const filteredProviders = p.providers ? Object.entries(p.providers).filter(([k, v]) => v > 0 && !BLOCKED_PROVIDERS.has(k)) : [];
            const cheapest = filteredProviders.length > 0 ? Math.min(...filteredProviders.map(([, v]) => v)) : p.price;
            return (
              <button
                class={`wi-cond-tab ${i === 0 ? 'active' : ''}`}
                data-wear-index={i}
                data-wear={p.wear}
              >
                <span class="wi-cond-name">{p.wear}</span>
                <span class="wi-cond-price">${cheapest > 0 ? cheapest.toFixed(2) : p.price.toFixed(2)}</span>
              </button>
            );
          })}
        </div>
      ) : (
        <p class="wi-nodata">No pricing data at this time</p>
      )}
    </div>

    <!-- Marketplace Prices -->
    {skin.prices.length > 0 ? (
      <div class="wi-market" id="marketplace-list">
        <div class="wi-market-head">
          <span class="wi-market-title">Market Prices</span>
          <span class="wi-market-wear" id="mp-wear-indicator">{defaultWear?.wear || ''}</span>
        </div>
        {skin.prices.map((wearData, wearIdx) => {
          const cl = csgoluckPrices[wearIdx];
          const steamPrice = wearData.providers?.steam;
          const savingsPct = (cl?.price !== null && steamPrice && steamPrice > 0 && cl.price < steamPrice)
            ? Math.round(((steamPrice - cl.price) / steamPrice) * 100)
            : null;
          const steamMp = getMarketplace('steam');
          return (
            <div class={`wi-market-group ${wearIdx === 0 ? '' : 'hidden'}`} data-mp-row={wearIdx}>
              {/* CSGOLuck — always first */}
              <div class="wi-market-row wi-csgoluck-row">
                <div class="wi-market-left">
                  <span class="wi-market-icon wi-csgoluck-icon">
                    <img src="/images/csgoluck-logo.png" alt="CSGOLuck" loading="lazy" />
                  </span>
                  <div class="wi-csgoluck-info">
                    <span class="wi-market-name">CSGOLuck</span>
                    {cl?.price !== null ? (
                      <span class="wi-csgoluck-count">{cl.count} listing{cl.count !== 1 ? 's' : ''}</span>
                    ) : (
                      <span class="wi-csgoluck-count">No listings</span>
                    )}
                  </div>
                </div>
                <div class="wi-market-right">
                  {cl?.price !== null ? (
                    <>
                      {savingsPct !== null && savingsPct > 0 && (
                        <span class="wi-savings-badge">-{savingsPct}%</span>
                      )}
                      <span class="wi-market-amount wi-csgoluck-price">${cl.price.toFixed(2)}</span>
                      <a href="/go/" rel="nofollow" class="wi-csgoluck-buy">Buy</a>
                    </>
                  ) : (
                    <a href="/go/" rel="nofollow" class="wi-csgoluck-buy">Browse</a>
                  )}
                </div>
              </div>
              {/* Steam Market — reference price */}
              {steamPrice && steamPrice > 0 && (
                <div class="wi-market-row wi-steam-ref">
                  <div class="wi-market-left">
                    <span class="wi-market-icon" style={`background:${steamMp.color}`}>
                      <img src={`https://www.google.com/s2/favicons?domain=${steamMp.domain}&sz=64`} alt="Steam" loading="lazy" />
                    </span>
                    <span class="wi-market-name">Steam Market</span>
                  </div>
                  <div class="wi-market-right">
                    <span class="wi-market-amount wi-steam-price">${steamPrice.toFixed(2)}</span>
                  </div>
                </div>
              )}
              {!cl?.price && (!steamPrice || steamPrice <= 0) && (
                <p class="wi-nodata">No pricing data for this condition</p>
              )}
            </div>
          );
        })}
      </div>
    ) : (
      <div class="wi-panel">
        <p class="wi-nodata">No pricing data at this time.</p>
      </div>
    )}

    <!-- Pro Players Using This Skin -->
    {playersUsingSkin.length > 0 && (
      <div class="wi-panel wi-pros">
        <div class="wi-pros-head">
          <h2>Professional Players</h2>
          <span class="wi-pros-count">{playersUsingSkin.length}</span>
        </div>
        <div class="wi-pros-list">
          {playersUsingSkin.slice(0, 12).map(p => (
            <a href={`/pro-players/${p.slug}/`} class="wi-pro-item">
              <div class="wi-pro-avatar">
                {p.image ? (
                  <img src={p.image} alt={p.name} width="80" height="80" loading="lazy" />
                ) : (
                  <span class="wi-pro-ph">{p.flag || p.name.charAt(0)}</span>
                )}
              </div>
              <span class="wi-pro-name">{p.name}</span>
              <span class="wi-pro-team">{p.team}</span>
            </a>
          ))}
        </div>
        {playersUsingSkin.length > 12 && (
          <div class="wi-pros-overflow">
            <a href="/pro-players/" class="wi-pros-more">View all {playersUsingSkin.length} players</a>
          </div>
        )}
      </div>
    )}

  </div><!-- /wi-col-right -->

</div><!-- /wi-two-col -->

<!-- ═══ FULL-WIDTH SECTIONS BELOW GRID ═══ -->

<!-- Info Blocks -->
<div class="wi-info-grid">
  <div class="wi-info-block">
    <h3>Popularity</h3>
    <p>
      {popPercent > 0 ? `Ranked in the top ${100 - popPercent}% of all skins, the ` : `The `}{skin.weapon} | {skin.name} is considered {popTier}{(skin.volume30d ?? 0) > 0 ? `, recording ${(skin.volume30d!).toLocaleString()} transactions over the past 30 days` : ', based on current market activity'}.
      {(skin.liquidity ?? 0) >= 80 ? ' Sellers can expect fast turnaround due to high demand.' : (skin.liquidity ?? 0) >= 40 ? ' This item trades at a steady pace on most platforms.' : ''}
    </p>
  </div>
  <div class="wi-info-block">
    <h3>Grade Details</h3>
    <p>
      Among {totalSkinCount} {catLabel} skins in the game, the {skin.weapon} | {skin.name} holds a {skin.rarity} classification -- {rarityDescriptions[skin.rarity] || ''}{skin.rarity !== 'Consumer' && skin.rarity !== 'Industrial' ? `. The estimated unbox rate for this tier is ${dropChance}` : ''}.
    </p>
  </div>
  <div class="wi-info-block">
    <h3>Market Value</h3>
    <p>
      Priced between ${lowPrice.toFixed(2)} and ${highPrice.toFixed(2)}, the {skin.weapon} | {skin.name} falls into the {lowPrice < 5 ? 'budget-friendly' : lowPrice < 50 ? 'affordable' : lowPrice < 200 ? 'mid-tier' : lowPrice < 1000 ? 'high-end' : 'elite'} bracket. Currently {listingDesc}{(skin.listingCount ?? 0) > 0 ? ` across ${(skin.listingCount!).toLocaleString()}+ active listings` : ''}.
    </p>
  </div>
  <div class="wi-info-block">
    <h3>Exterior Conditions</h3>
    <p>
      Float values span from {skin.minFloat.toFixed(2)} to {skin.maxFloat.toFixed(2)}, meaning this skin ships in {hasAllWears ? 'every possible exterior' : `${wearCount} exterior${wearCount !== 1 ? 's' : ''}: ${availableWears.join(', ')}`}.
      {skin.statTrak ? ' A StatTrak variant exists for each condition.' : ''}
      {skin.souvenir ? ' Souvenir editions can also be obtained from tournament drops.' : ''}
    </p>
  </div>
</div>

<!-- Float Visualizer -->
<div class="wi-float-viz">
  <h2>Float Range</h2>
  <div class="wi-float-display">
    <div class="wi-float-bounds">
      <span>{skin.minFloat.toFixed(2)}</span>
      <span>{skin.maxFloat.toFixed(2)}</span>
    </div>
    <div class="wi-float-track">
      <div class="wi-float-fill" style={`left:${skin.minFloat * 100}%;width:${(skin.maxFloat - skin.minFloat) * 100}%;background:${rarityColor}`}></div>
    </div>
    <div class="wi-float-markers">
      <span>0.00 FN</span><span>0.07</span><span>0.15 MW</span><span>0.38 FT</span><span>0.45 WW</span><span>1.00 BS</span>
    </div>
  </div>
  <p class="wi-float-note">
    {skin.weapon} | {skin.name} accepts float values from <strong>{skin.minFloat.toFixed(2)} to {skin.maxFloat.toFixed(2)}</strong>.
    {skin.minFloat === 0 && skin.maxFloat >= 1 ? ' Every wear tier from Factory New through Battle-Scarred is attainable.' :
     skin.minFloat === 0 && skin.maxFloat < 0.45 ? ` This skin is restricted from dropping in ${skin.maxFloat < 0.38 ? 'Field-Tested, Well-Worn, or Battle-Scarred' : skin.maxFloat < 0.45 ? 'Well-Worn or Battle-Scarred' : 'Battle-Scarred'} condition.` :
     skin.minFloat > 0.07 ? ` Factory New is not available for this skin.` : ''}
  </p>
</div>

<!-- Price History Chart -->
<div class="wi-chart-section">
  <div class="wi-chart-head">
    <h2>Historical Pricing</h2>
    <div class="wi-chart-controls">
      <select id="ph-source" class="wi-chart-select">
        <option value="buff163">Buff163</option>
        <option value="steam" selected>Steam</option>
        <option value="skinport">Skinport</option>
        <option value="csmoney">CS.Money</option>
        <option value="csfloat">CSFloat</option>
      </select>
      <select id="ph-wear" class="wi-chart-select">
        {skin.prices.map((p, i) => (
          <option value={p.wear} selected={i === 0}>{p.wear}</option>
        ))}
      </select>
    </div>
  </div>
  <div class="wi-chart-wrap">
    <canvas id="price-history-chart" height="280"></canvas>
    <div id="ph-loading" class="wi-chart-loading">Fetching price data...</div>
    <div id="ph-error" class="wi-chart-error" style="display:none"><span id="ph-error-msg">Historical pricing is unavailable for this item.</span></div>
  </div>
</div>

<!-- Price Comparison Table -->
{priceTable.length > 0 && priceTable.some(p => p.prices.length > 0) && (
  <div class="wi-price-table">
    <h2>{skin.weapon} | {skin.name} -- Pricing by Condition</h2>
    <p class="wi-section-note">Cross-marketplace price data for each wear tier. All values in USD.</p>
    <div class="wi-table-scroll">
      <table class="wi-data-table">
        <thead>
          <tr>
            <th>Condition</th>
            <th>Lowest</th>
            <th>Source</th>
            <th>Average</th>
            <th>Providers</th>
          </tr>
        </thead>
        <tbody>
          {priceTable.map(row => {
            const cheapestEntry = row.prices.length > 0 ? row.prices[0] : null;
            const avg = row.prices.length > 0 ? row.prices.reduce((s, [, v]) => s + v, 0) / row.prices.length : 0;
            return (
              <tr>
                <td><strong>{row.wear}</strong></td>
                <td class="wi-cell-price">{cheapestEntry ? `$${cheapestEntry[1].toFixed(2)}` : '--'}</td>
                <td>{cheapestEntry ? getMarketplace(cheapestEntry[0]).name : '--'}</td>
                <td class="wi-cell-price">{avg > 0 ? `$${avg.toFixed(2)}` : '--'}</td>
                <td>{row.prices.length}</td>
              </tr>
            );
          })}
        </tbody>
      </table>
    </div>
  </div>
)}

<!-- StatTrak Price Comparison Table -->
{skin.statTrak && stPriceTable.length > 0 && stPriceTable.some(p => p.prices.length > 0) && (
  <div class="wi-price-table wi-st-section">
    <h2><span class="wi-st-label">StatTrak&#8482;</span> {skin.weapon} | {skin.name} Pricing</h2>
    <p class="wi-section-note">StatTrak editions record confirmed eliminations and command higher prices than standard versions.</p>
    <div class="wi-table-scroll">
      <table class="wi-data-table wi-st-table">
        <thead>
          <tr>
            <th>Condition</th>
            <th>Lowest</th>
            <th>Source</th>
            <th>Average</th>
            <th>Premium</th>
          </tr>
        </thead>
        <tbody>
          {stPriceTable.map(row => {
            const cheapestEntry = row.prices.length > 0 ? row.prices[0] : null;
            const avg = row.prices.length > 0 ? row.prices.reduce((s, [, v]) => s + v, 0) / row.prices.length : 0;
            const normalRow = priceTable.find(r => r.wear === row.wear);
            const normalCheapest = normalRow?.prices?.[0]?.[1] || 0;
            const premium = cheapestEntry && normalCheapest > 0
              ? Math.round(((cheapestEntry[1] - normalCheapest) / normalCheapest) * 100)
              : null;
            return (
              <tr>
                <td><strong>{row.wear}</strong></td>
                <td class="wi-cell-price wi-st-val">{cheapestEntry ? `$${cheapestEntry[1].toFixed(2)}` : '--'}</td>
