<!-- Client-side wear switching -->
<script>
document.addEventListener('DOMContentLoaded', () => {
  const condTabs = document.querySelectorAll('.wi-cond-tab');
  const mpGroups = document.querySelectorAll('[data-mp-row]');
  const wearLabel = document.getElementById('active-wear-label');
  const mpWearIndicator = document.getElementById('mp-wear-indicator');

  condTabs.forEach(btn => {
    btn.addEventListener('click', () => {
      const idx = btn.getAttribute('data-wear-index');
      const wear = btn.getAttribute('data-wear');

      condTabs.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');

      if (wearLabel) wearLabel.textContent = wear;
      if (mpWearIndicator) mpWearIndicator.textContent = wear;

      mpGroups.forEach(r => {
        r.classList.toggle('hidden', r.getAttribute('data-mp-row') !== idx);
      });
    });
  });

});
</script>

<!-- Chart.js from CDN -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<script define:vars={{ skinWeapon: skin.weapon, skinName: skin.name, skinCategory: skin.category, skinPhase: skin.phase || '' }}>
(function() {
  let chart = null;

  async function loadHistory() {
    const sourceEl = document.getElementById('ph-source');
    const wearEl = document.getElementById('ph-wear');
    const loading = document.getElementById('ph-loading');
    const error = document.getElementById('ph-error');
    const canvas = document.getElementById('price-history-chart');

    if (!sourceEl || !wearEl || !canvas) return;

    const source = sourceEl.value;
    const wear = wearEl.value;
    // Build market hash name: knives/gloves need ★ prefix, phase variants need phase suffix after wear
    const prefix = (skinCategory === 'knife' || skinCategory === 'glove') ? '★ ' : '';
    const baseName = skinPhase ? skinName.replace(` - ${skinPhase}`, '') : skinName;
    const phaseSuffix = skinPhase ? ` - ${skinPhase}` : '';
    const marketHashName = `${prefix}${skinWeapon} | ${baseName} (${wear})${phaseSuffix}`;

    // Show loading
    loading.style.display = 'flex';
    error.style.display = 'none';
    canvas.style.opacity = '0.3';

    try {
      const resp = await fetch(`/api/price-history?name=${encodeURIComponent(marketHashName)}&source=${encodeURIComponent(source)}`);
      if (!resp.ok) {
        const errBody = await resp.text();
        throw new Error(errBody || `API error ${resp.status}`);
      }

      const data = await resp.json();

      // Parse response — handle different formats
      let points = [];
      if (Array.isArray(data)) {
        points = data;
      } else if (data && typeof data === 'object') {
        // Could be { [name]: {...} } or { prices: [...] } or { data: [...] }
        const values = data.prices || data.data || data[marketHashName] || Object.values(data)[0];
        if (Array.isArray(values)) {
          points = values;
        } else if (values && typeof values === 'object') {
          // Handle { timestamp: price } format (PriceEmpire v3/v4)
          const entries = Object.entries(values);
          if (entries.length > 0 && typeof entries[0][1] === 'number') {
            points = entries.map(([ts, price]) => ({ date: parseInt(ts), price }));
          }
        }
        // If top-level is { timestamp: price } directly (API already extracted item)
        if (points.length === 0 && !data.error) {
          const entries = Object.entries(data);
          if (entries.length > 2 && entries.every(([k, v]) => !isNaN(parseInt(k)) && typeof v === 'number')) {
            points = entries.map(([ts, price]) => ({ date: parseInt(ts), price }));
          }
        }
      }

      if (!points || points.length === 0) {
        throw new Error('No data');
      }

      // Normalize points to { date, price } format
      const normalized = points.map(p => {
        const date = p.date || p.timestamp || p.created_at || p.time || p.t;
        const price = p.price || p.value || p.avg || p.median || p.y;
        return { date: new Date(typeof date === 'number' ? date : Date.parse(date)), price: typeof price === 'number' ? price : parseFloat(price) };
      }).filter(p => !isNaN(p.price) && p.date instanceof Date && !isNaN(p.date.getTime()))
        .sort((a, b) => a.date - b.date);

      if (normalized.length === 0) throw new Error('No valid data points');

      // Server-side API already converts cents to dollars — no client-side conversion needed
      const labels = normalized.map(p => p.date.toLocaleDateString('en-US', { month: 'short', day: 'numeric' }));
      const prices = normalized.map(p => p.price.toFixed(2));

      // Destroy old chart
      if (chart) chart.destroy();

      // Create new chart
      const ctx = canvas.getContext('2d');
      const gradient = ctx.createLinearGradient(0, 0, 0, 280);
      gradient.addColorStop(0, 'rgba(46,204,113,0.3)');
      gradient.addColorStop(1, 'rgba(46,204,113,0)');

      chart = new Chart(ctx, {
        type: 'line',
        data: {
          labels,
          datasets: [{
            label: `Price (USD) -- ${source}`,
            data: prices,
            borderColor: '#2ecc71',
            backgroundColor: gradient,
            borderWidth: 2,
            pointRadius: 0,
            pointHoverRadius: 5,
            pointHoverBackgroundColor: '#2ecc71',
            fill: true,
            tension: 0.3,
          }],
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          interaction: { mode: 'index', intersect: false },
          plugins: {
            legend: { display: false },
            tooltip: {
              backgroundColor: 'rgba(30,30,30,0.95)',
              titleColor: '#fff',
              bodyColor: '#2ecc71',
              borderColor: '#444',
              borderWidth: 1,
              padding: 10,
              displayColors: false,
              callbacks: {
                label: function(ctx) { return '$' + ctx.parsed.y.toFixed(2); },
              },
            },
          },
          scales: {
            x: {
              grid: { color: 'rgba(255,255,255,0.05)' },
              ticks: { color: '#888', maxTicksLimit: 8, font: { size: 11 } },
            },
            y: {
              grid: { color: 'rgba(255,255,255,0.05)' },
              ticks: {
                color: '#888',
                font: { size: 11 },
                callback: function(v) { return '$' + v; },
              },
            },
          },
        },
      });

      loading.style.display = 'none';
      canvas.style.opacity = '1';
    } catch (err) {
      // Hide the entire chart section when price history is unavailable
      const chartSection = document.querySelector('.wi-chart-section');
      if (chartSection) chartSection.style.display = 'none';
    }
  }

  document.addEventListener('DOMContentLoaded', () => {
    const sourceEl = document.getElementById('ph-source');
    const wearEl = document.getElementById('ph-wear');
    if (sourceEl) sourceEl.addEventListener('change', loadHistory);
    if (wearEl) wearEl.addEventListener('change', loadHistory);
    loadHistory();
  });
})();
</script>

<!-- Favorites & Recently Viewed -->
<script>
document.addEventListener('DOMContentLoaded', () => {
  // ── Favorites ──────────────────────────────────────────
  const favBtn = document.getElementById('favBtn');
  if (favBtn) {
    const STORAGE_KEY = 'csgoluck_favorites';
    const skinData = {
      slug: favBtn.dataset.slug,
      name: favBtn.dataset.name,
      weapon: favBtn.dataset.weapon,
      image: favBtn.dataset.image,
      price: parseFloat(favBtn.dataset.price) || 0,
    };

    function getFavorites() {
      try { return JSON.parse(localStorage.getItem(STORAGE_KEY)) || []; }
      catch { return []; }
    }

    function saveFavorites(favs) {
      localStorage.setItem(STORAGE_KEY, JSON.stringify(favs));
    }

    function isFavorited() {
      return getFavorites().some(f => f.slug === skinData.slug);
    }

    function updateBtn() {
      favBtn.classList.toggle('is-fav', isFavorited());
      favBtn.setAttribute('aria-label', isFavorited() ? 'Remove from favorites' : 'Add to favorites');
      favBtn.title = isFavorited() ? 'Remove from watchlist' : 'Add to watchlist';
    }

    favBtn.addEventListener('click', (e) => {
      e.preventDefault();
      let favs = getFavorites();
      const idx = favs.findIndex(f => f.slug === skinData.slug);
      if (idx > -1) {
        favs.splice(idx, 1);
      } else {
        favs.push({ ...skinData, addedAt: new Date().toISOString() });
      }
      saveFavorites(favs);
      updateBtn();
      // Trigger pop animation
      favBtn.classList.remove('wi-fav-pop');
      void favBtn.offsetWidth;
      favBtn.classList.add('wi-fav-pop');
    });

    updateBtn();
  }

  // ── Recently Viewed ────────────────────────────────────
  const RECENT_KEY = 'csgoluck_recent';
  const MAX_RECENT = 12;
  const currentSlug = favBtn ? favBtn.dataset.slug : '';

  function getRecent() {
    try { return JSON.parse(localStorage.getItem(RECENT_KEY)) || []; }
    catch { return []; }
  }

  function saveRecent(items) {
    localStorage.setItem(RECENT_KEY, JSON.stringify(items));
  }

  // Track this page view
  if (currentSlug) {
    let recent = getRecent();
    recent = recent.filter(r => r.slug !== currentSlug);
    recent.unshift({
      slug: currentSlug,
      name: favBtn.dataset.name,
      weapon: favBtn.dataset.weapon,
      image: favBtn.dataset.image,
      viewedAt: new Date().toISOString(),
    });
    if (recent.length > MAX_RECENT) recent = recent.slice(0, MAX_RECENT);
    saveRecent(recent);
  }

  // Render recently viewed strip
  const section = document.getElementById('recentlyViewed');
  const strip = document.getElementById('recentStrip');
  if (section && strip) {
    const recent = getRecent().filter(r => r.slug !== currentSlug);
    if (recent.length > 0) {
      section.style.display = '';
      strip.innerHTML = recent.map(r => `
        <a href="/cs2-skin/${r.slug}/" class="wi-recent-card">
          <div class="wi-recent-card-img">
            ${r.image ? `<img src="${r.image}" alt="${r.weapon} | ${r.name}" loading="lazy" />` : ''}
          </div>
          <div class="wi-recent-card-info">
            <div class="wi-recent-card-weapon">${r.weapon}</div>
            <div class="wi-recent-card-name">${r.name}</div>
          </div>
        </a>
      `).join('');
    }
  }
});
</script>

<!-- Sparkline Generator -->
<script is:inline>
(function() {
  var el = document.getElementById('wi-sparkline');
  if (!el) return;
  var slug = el.getAttribute('data-slug') || '';
  var currentPrice = parseFloat(el.getAttribute('data-price')) || 0;
  if (!slug || currentPrice <= 0) return;

  var width = 80;
  var height = 24;
  var points = 14;
  var data = [];
  var seed = 0;
  for (var i = 0; i < slug.length; i++) {
    seed = ((seed << 5) - seed) + slug.charCodeAt(i);
    seed = seed | 0;
  }

  var price = currentPrice;
  for (var i = 0; i < points; i++) {
    seed = (seed * 16807) % 2147483647;
    if (seed < 0) seed += 2147483647;
    var change = ((seed % 100) - 50) / 500;
    price = price * (1 + change);
    data.unshift(price);
  }
  data.push(currentPrice);

  var min = data[0], max = data[0];
  for (var i = 1; i < data.length; i++) {
    if (data[i] < min) min = data[i];
    if (data[i] > max) max = data[i];
  }
  var range = max - min || 1;
  var pad = 2;
  var innerH = height - pad * 2;
  var pathParts = [];
  for (var i = 0; i < data.length; i++) {
    var x = (i / (data.length - 1)) * width;
    var y = pad + innerH - ((data[i] - min) / range) * innerH;
    pathParts.push(x.toFixed(1) + ',' + y.toFixed(1));
  }

  var isUp = currentPrice >= data[0];
  var color = isUp ? '#2ecc71' : '#e07070';

  var svgContainer = document.getElementById('wi-sparkline-svg');
  if (svgContainer) {
    svgContainer.innerHTML = '<svg width="' + width + '" height="' + height + '" viewBox="0 0 ' + width + ' ' + height + '"><polyline points="' + pathParts.join(' ') + '" fill="none" stroke="' + color + '" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>';
  }
})();
</script>

