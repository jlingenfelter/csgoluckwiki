/* ── Price Sparkline ───────────────────────────────────── */
.wi-sparkline-wrap{display:flex;align-items:center;justify-content:space-between;gap:.6rem;background:var(--bg2);border:1px solid var(--border);border-radius:4px;padding:.55rem .8rem;margin-bottom:0}
.wi-sparkline-label{display:flex;flex-direction:column;gap:.1rem;flex-shrink:0}
.wi-sparkline-title{font-size:.75rem;font-weight:700;text-transform:uppercase;letter-spacing:.05em;color:var(--text2)}
.wi-sparkline-hint{font-size:.62rem;color:var(--text2);opacity:.65}
.wi-sparkline-chart{flex:1;display:flex;align-items:center;justify-content:flex-end}
.wi-sparkline-chart svg{display:block}

/* ── CTA ────────────────────────────────────────────────── */
.wi-cta{border:1px solid rgba(46,204,113,.25);border-radius:4px;background:var(--bg2)}
.wi-cta-body{display:flex;align-items:center;justify-content:space-between;padding:1rem 1.2rem;gap:1rem}
.wi-cta-copy{flex:1}
.wi-cta-copy strong{display:block;color:var(--text);font-size:.92rem;margin-bottom:.1rem}
.wi-cta-copy span{color:var(--text2);font-size:.82rem}
.wi-cta-action{display:inline-block;padding:.5rem 1.2rem;background:#2ecc71;color:#fff;border-radius:4px;font-weight:700;font-size:.85rem;text-decoration:none;white-space:nowrap;transition:background .15s}
.wi-cta-action:hover{background:#27ae60;color:#fff}

/* ── CSGOLuck Row (pinned top) ────────────────────────── */
.wi-csgoluck-row{background:rgba(46,204,113,.06);border-left:3px solid #2ecc71;border-bottom:1px solid var(--border)}
.wi-csgoluck-row > .wi-market-row{padding:.65rem 1rem;border-bottom:none}
.wi-csgoluck-icon{background:#1a1c24 !important;padding:2px}
.wi-csgoluck-icon img{width:100%;height:100%;object-fit:contain}
.wi-csgoluck-info{display:flex;flex-direction:column}
.wi-csgoluck-count{font-size:.65rem;color:var(--text2)}
.wi-csgoluck-price{font-size:1rem;font-weight:900;color:#2ecc71}
.wi-csgoluck-buy{display:inline-block;padding:.35rem .85rem;background:#2ecc71;color:#fff;border-radius:4px;font-size:.75rem;font-weight:700;text-decoration:none;white-space:nowrap;transition:background .15s}
.wi-csgoluck-buy:hover{background:#27ae60;color:#fff}
.wi-csgoluck-bonus-line{display:flex;align-items:center;justify-content:center;gap:.4rem;padding:.35rem 1rem;background:rgba(46,204,113,.03);border-top:1px solid rgba(46,204,113,.1);text-decoration:none;transition:background .15s}
.wi-csgoluck-bonus-line:hover{background:rgba(46,204,113,.08)}
.wi-csgoluck-bonus-line span{font-size:.7rem;font-weight:700;color:#2ecc71}

/* ── Marketplace buy links ─────────────────────────────── */
.wi-market-buy-link{display:inline-block;padding:.3rem .7rem;background:var(--bg3);border:1px solid var(--border);color:var(--text);border-radius:4px;font-size:.7rem;font-weight:700;text-decoration:none;white-space:nowrap;transition:all .15s}
.wi-market-buy-link:hover{border-color:#ff9800;color:#ff9800}

/* ── Savings badge ─────────────────────────────────────── */
.wi-savings-badge{display:inline-block;padding:.15rem .45rem;background:#2ecc71;color:#fff;font-size:.7rem;font-weight:800;border-radius:3px;white-space:nowrap;letter-spacing:.02em}

/* ── Steam reference row ───────────────────────────────── */
.wi-steam-ref{background:rgba(255,255,255,.02);border-bottom:1px solid rgba(255,255,255,.04)}
.wi-steam-price{color:var(--text2) !important;font-weight:600 !important;font-size:.85rem !important}

.wi-nodata{color:var(--text2);font-size:.85rem;padding:1rem;text-align:center;margin:0}

/* ── Pro Players ────────────────────────────────────────── */
.wi-pros{margin-bottom:0}
.wi-pros-head{display:flex;align-items:center;justify-content:space-between;margin-bottom:.6rem}
.wi-pros-head h2{margin:0;font-size:.95rem}
.wi-pros-count{font-size:.72rem;background:var(--bg3);color:var(--text2);padding:.15rem .45rem;border-radius:4px;font-weight:600}
.wi-pros-list{display:grid;grid-template-columns:repeat(auto-fill,minmax(90px,1fr));gap:.5rem}
.wi-pro-item{display:flex;flex-direction:column;align-items:center;gap:.25rem;padding:.5rem .3rem;border-radius:4px;border:1px solid var(--border);background:var(--bg3);text-decoration:none;color:inherit;transition:border-color .15s}
.wi-pro-item:hover{border-left:3px solid #2ecc71}
.wi-pro-avatar{width:56px;height:56px;border-radius:50%;overflow:hidden;display:flex;align-items:center;justify-content:center;background:var(--bg2)}
.wi-pro-avatar img{width:100%;height:100%;object-fit:cover}
.wi-pro-ph{font-size:1rem;color:var(--text2)}
.wi-pro-name{font-size:.72rem;font-weight:700;color:var(--text);text-align:center;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:100%}
.wi-pro-team{font-size:.65rem;color:var(--text2);text-align:center;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:100%}
.wi-pros-overflow{padding:.4rem;text-align:center}
.wi-pros-more{font-size:.78rem;color:var(--text2);text-decoration:none;font-weight:600}
.wi-pros-more:hover{color:#2ecc71}

/* ── Phases ─────────────────────────────────────────────── */
.wi-phases{border:1px solid var(--border);border-radius:4px;overflow:hidden;margin-bottom:1rem;background:var(--bg2)}
.wi-phases-head{display:flex;align-items:center;justify-content:space-between;padding:.6rem 1rem;border-bottom:1px solid var(--border)}
.wi-phases-head h2{margin:0;font-size:.95rem}
.wi-phases-num{font-size:.72rem;background:var(--bg3);color:var(--text2);padding:.15rem .45rem;border-radius:4px;font-weight:600}
.wi-phases-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(100px,1fr));gap:.4rem;padding:.6rem}
.wi-phase-item{display:flex;flex-direction:column;align-items:center;gap:.25rem;padding:.4rem .3rem;border-radius:4px;background:var(--bg3);border:1px solid var(--border);text-decoration:none;color:inherit;transition:border-color .15s}
.wi-phase-item:hover{border-left:3px solid #2ecc71}
.wi-phase-thumb{width:100%;aspect-ratio:4/3;display:flex;align-items:center;justify-content:center;overflow:hidden}
.wi-phase-thumb img{max-width:90%;max-height:100%;object-fit:contain}
.wi-phase-ph{font-size:.65rem;color:var(--text2);opacity:.5;font-weight:700}
.wi-phase-name{font-size:.72rem;font-weight:700;color:var(--text);text-align:center}
.wi-phase-price{font-size:.68rem;color:#2ecc71;font-weight:600}

.wi-phases-nav{display:flex;flex-wrap:wrap;gap:.3rem;padding:.6rem}
.wi-phase-link{padding:.35rem .6rem;border-radius:4px;font-size:.75rem;font-weight:600;text-decoration:none;color:var(--text2);background:var(--bg3);border:1px solid var(--border);transition:border-color .15s;white-space:nowrap}
.wi-phase-link:hover{color:var(--text);border-color:#2ecc71}
.wi-phase-link.active{color:#2ecc71;border-color:#2ecc71;border-left:3px solid #2ecc71}

/* ── Source (containers/collection in left column) ──────── */
.wi-source{border:1px solid var(--border);border-radius:4px;padding:1rem;margin-bottom:0;background:var(--bg2)}
.wi-source h2{margin:0 0 .8rem;font-size:.95rem}
.wi-source-list{display:flex;flex-wrap:wrap;gap:.8rem}
.wi-source-item{display:flex;flex-direction:column;align-items:center;gap:.4rem;text-decoration:none;color:var(--text);transition:border-color .15s}
.wi-source-item:hover .wi-source-thumb{border-color:#2ecc71}
.wi-source-thumb{width:90px;height:68px;display:flex;align-items:center;justify-content:center;border-radius:4px;overflow:hidden;background:var(--bg3);border:1px solid var(--border);transition:border-color .15s}
.wi-source-thumb img{max-width:85%;max-height:85%;object-fit:contain}
.wi-source-icon{font-size:1.5rem;font-weight:900;opacity:.5}
.wi-source-name{font-size:.75rem;text-align:center;color:var(--text2);max-width:110px;line-height:1.2}

/* ── Info Blocks (2-column grid on desktop) ─────────────── */
.wi-info-grid{display:grid;grid-template-columns:1fr 1fr;gap:0;margin:0 0 1.5rem;border:1px solid var(--border);border-radius:4px;overflow:hidden}
.wi-info-block{padding:1rem 1.2rem;border-left:3px solid #2ecc71;border-bottom:1px solid var(--border);background:var(--bg2)}
.wi-info-block:nth-child(odd){border-right:1px solid var(--border)}
.wi-info-block:nth-last-child(-n+2){border-bottom:none}
.wi-info-block h3{margin:0 0 .4rem;font-size:.9rem;color:var(--text);font-weight:700}
.wi-info-block p{margin:0;font-size:.84rem;color:var(--text2);line-height:1.65}
@media(max-width:860px){
  .wi-info-grid{grid-template-columns:1fr}
  .wi-info-block:nth-child(odd){border-right:none}
  .wi-info-block:nth-last-child(-n+2){border-bottom:1px solid var(--border)}
  .wi-info-block:last-child{border-bottom:none}
}

/* ── Float Visualizer ───────────────────────────────────── */
.wi-float-viz{border:1px solid var(--border);border-radius:4px;padding:1rem 1.2rem;margin-bottom:1.5rem;background:var(--bg2)}
.wi-float-viz h2{margin:0 0 .6rem;font-size:.95rem}
.wi-float-display{padding:.4rem 0}
.wi-float-bounds{display:flex;justify-content:space-between;font-size:.78rem;color:var(--text2);margin-bottom:.3rem}
.wi-float-track{height:6px;background:var(--bg3);border-radius:2px;position:relative;overflow:hidden}
.wi-float-fill{position:absolute;top:0;height:100%;border-radius:2px;opacity:.75}
.wi-float-markers{display:flex;justify-content:space-between;font-size:.68rem;color:var(--text2);margin-top:.35rem;font-weight:600}
.wi-float-note{font-size:.82rem;color:var(--text2);margin-top:.6rem;line-height:1.55}
.wi-float-note strong{color:var(--text)}

/* ── Chart Section ──────────────────────────────────────── */
.wi-chart-section{border:1px solid var(--border);border-radius:4px;padding:1rem 1.2rem;margin-bottom:1.5rem;background:var(--bg2)}
.wi-chart-head{display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:.6rem;margin-bottom:.8rem}
.wi-chart-head h2{margin:0;font-size:.95rem}
.wi-chart-controls{display:flex;gap:.4rem}
.wi-chart-select{background:var(--bg3);color:var(--text);border:1px solid var(--border);border-radius:4px;padding:.35rem .6rem;font-size:.78rem;cursor:pointer;outline:none}
.wi-chart-select:hover{border-color:#2ecc71}
.wi-chart-wrap{position:relative;min-height:280px}
.wi-chart-loading{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;color:var(--text2);font-size:.85rem;z-index:2}
.wi-chart-error{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;color:var(--text2);font-size:.82rem;z-index:2}

/* ── Price Table ────────────────────────────────────────── */
.wi-price-table{margin:1.5rem 0;border:1px solid var(--border);border-radius:4px;padding:1.2rem;background:var(--bg2);overflow:hidden}
.wi-price-table h2{margin:0 0 .25rem;font-size:1rem}
.wi-section-note{font-size:.82rem;color:var(--text2);margin-bottom:1rem}
.wi-table-scroll{overflow-x:auto;-webkit-overflow-scrolling:touch;border-radius:4px;border:1px solid var(--border)}
.wi-data-table{width:100%;border-collapse:collapse;font-size:.84rem}
.wi-data-table th{background:var(--bg3);color:var(--text);font-weight:700;font-size:.75rem;text-transform:uppercase;letter-spacing:.04em;padding:.65rem .9rem;text-align:left;border-bottom:2px solid #2ecc71;white-space:nowrap}
.wi-data-table td{padding:.6rem .9rem;border-bottom:1px solid var(--border);color:var(--text2)}
.wi-data-table tbody tr{transition:background .12s}
.wi-data-table tbody tr:hover td{background:rgba(255,255,255,.02)}
.wi-data-table tbody tr:last-child td{border-bottom:none}
.wi-cell-price{font-weight:800;color:#2ecc71;font-size:.9rem}

/* ── StatTrak ───────────────────────────────────────────── */
.wi-st-section{border-color:#cf6a32}
.wi-st-label{display:inline-block;background:linear-gradient(135deg,#cf6a32,#e8a245);color:#fff;font-size:.68rem;font-weight:700;padding:.12rem .45rem;border-radius:4px;text-transform:uppercase;letter-spacing:.04em;vertical-align:middle;margin-right:.25rem}
.wi-st-table .wi-st-val{color:#e8a245}
.wi-premium-val{color:#f59e0b;font-weight:600;font-size:.84rem}

/* ── About Section ──────────────────────────────────────── */
.wi-about{border-left:3px solid #2ecc71;padding:1rem 1.2rem;margin:1.5rem 0;background:none}
.wi-about h2{margin:0 0 .6rem;font-size:1rem}
.wi-about p{font-size:.86rem;color:var(--text2);line-height:1.7;margin-bottom:.7rem}
.wi-about p:last-child{margin-bottom:0}
.wi-about strong{color:var(--text)}
.wi-about a{color:#2ecc71}

/* ── Related Skins ──────────────────────────────────────── */
.wi-related{margin:1.5rem 0}
.wi-related h2{margin:0 0 .5rem;font-size:1rem}
.wi-rel-strip{display:flex;gap:.6rem;overflow-x:auto;padding-bottom:.5rem;-webkit-overflow-scrolling:touch;scrollbar-width:thin}
.wi-rel-strip::-webkit-scrollbar{height:4px}
.wi-rel-strip::-webkit-scrollbar-thumb{background:var(--border);border-radius:2px}
.wi-rel-card{flex:0 0 140px;border-radius:4px;overflow:hidden;text-decoration:none;color:inherit;border:1px solid var(--border);background:var(--bg2);position:relative;transition:border-color .15s}
.wi-rel-card:hover{border-left:3px solid var(--rc,#2ecc71)}
.wi-rel-thumb{display:flex;align-items:center;justify-content:center;height:85px;padding:.3rem}
.wi-rel-thumb img{max-width:90%;max-height:70px;object-fit:contain}
.wi-rel-overlay{padding:.4rem .5rem .5rem;border-top:1px solid var(--border)}
.wi-rel-weapon{display:block;font-size:.65rem;color:var(--text2);letter-spacing:.02em}
.wi-rel-name{display:block;font-weight:700;font-size:.78rem;color:var(--text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.wi-rel-price{display:block;font-size:.78rem;font-weight:700;color:#2ecc71;margin-top:.15rem}

/* ── Utility ────────────────────────────────────────────── */
.hidden{display:none!important}

@media(max-width:600px){
  .wi-market-row{flex-wrap:wrap;gap:.4rem;padding:.6rem .8rem}
  .wi-market-right{margin-left:auto}
  .wi-market-amount{font-size:.95rem}
  .wi-market-link{padding:.35rem .7rem;font-size:.72rem}
  .wi-preview{min-height:140px}
  .wi-rel-card{flex:0 0 120px}
  .wi-cta-body{flex-direction:column;text-align:center}
  .wi-cta-action{width:100%;text-align:center}
  .wi-stats-grid{grid-template-columns:repeat(2,1fr)}
  .wi-wear-grid{grid-template-columns:repeat(3,1fr)}
  .wi-stat-card{padding:.6rem .5rem}
}

/* ── Flavor Text ───────────────────────────────────────── */
.wi-flavor{background:var(--bg2);border:1px solid var(--border);border-left:3px solid var(--accent);border-radius:4px;padding:.6rem .9rem;margin-bottom:.75rem;font-size:.82rem;color:var(--text2);line-height:1.5}
.wi-flavor em{font-style:italic}

/* ── Marketplace enhancements ──────────────────────────── */
.wi-mp-info{display:flex;flex-direction:column;gap:1px}
.wi-mp-rating{font-size:.65rem;color:#f5a623;letter-spacing:.02em}
.wi-mp-disabled{opacity:.3;pointer-events:none}

/* ── Price Statistics ──────────────────────────────────── */
.wi-stats{margin-bottom:2rem}
.wi-stats h2{margin:0 0 .75rem;font-size:1.05rem;font-weight:700;border-bottom:2px solid var(--border);padding-bottom:.4rem}
.wi-stats-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:.5rem}
.wi-stat-card{background:var(--bg2);border:1px solid var(--border);border-radius:4px;padding:.75rem;text-align:center;display:flex;flex-direction:column;gap:.2rem}
.wi-stat-value{font-size:1.1rem;font-weight:800;color:var(--text);font-family:'Montserrat',sans-serif}
.wi-stat-label{font-size:.68rem;color:var(--text2);text-transform:uppercase;letter-spacing:.04em;font-weight:600}

/* ── Wear Availability Grid ────────────────────────────── */
.wi-wear-grid-section{margin-bottom:2rem}
.wi-wear-grid-section h2{margin:0 0 .75rem;font-size:1.05rem;font-weight:700;border-bottom:2px solid var(--border);padding-bottom:.4rem}
.wi-wear-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:.5rem}
.wi-wear-card{background:var(--bg2);border:1px solid var(--border);border-radius:4px;padding:.75rem .5rem;text-align:center;display:flex;flex-direction:column;gap:.25rem;transition:border-color .15s}
.wi-wear-card:not(.wi-wear-impossible):hover{border-color:var(--accent)}
.wi-wear-name{font-size:.78rem;font-weight:700;color:var(--text)}
.wi-wear-float{font-size:.65rem;color:var(--text2)}
.wi-wear-price{font-size:.95rem;font-weight:800;color:#2ecc71;font-family:'Montserrat',sans-serif}
.wi-wear-nodata{color:var(--text2);font-size:.75rem;font-weight:400}
.wi-wear-st{font-size:.7rem;color:#f39c12;font-weight:600}
.wi-wear-impossible{opacity:.35;border-style:dashed}
.wi-wear-impossible-label{font-size:.72rem;color:var(--text2);font-style:italic;margin-top:.15rem}

/* ── About description ─────────────────────────────────── */
.wi-about-desc{color:var(--text2);font-style:italic;border-left:3px solid var(--border);padding-left:.75rem;margin:.5rem 0}

/* ── Similar Skins ─────────────────────────────────────── */
.wi-similar{margin:1.5rem 0}
.wi-similar h2{margin:0 0 .75rem;font-size:1.05rem;font-weight:700;border-bottom:2px solid var(--border);padding-bottom:.4rem}
.wi-similar-strip{display:grid;grid-template-columns:repeat(6,1fr);gap:.6rem}
.wi-similar-card{border-radius:8px;overflow:hidden;text-decoration:none;color:inherit;border:1px solid var(--border);background:var(--bg2);transition:border-color .15s,transform .15s}
.wi-similar-card:hover{border-color:#2ecc71;transform:translateY(-2px)}
.wi-similar-thumb{display:flex;align-items:center;justify-content:center;height:90px;padding:.4rem}
.wi-similar-thumb img{max-width:90%;max-height:75px;object-fit:contain}
.wi-similar-info{padding:.45rem .55rem .55rem;border-top:1px solid var(--border);display:flex;flex-direction:column;gap:.15rem}
.wi-similar-weapon{font-size:.65rem;color:var(--text2);letter-spacing:.02em}
.wi-similar-name{font-weight:700;font-size:.78rem;color:var(--text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.wi-similar-price{font-size:.8rem;font-weight:700;color:#2ecc71}
.wi-similar-rarity{display:inline-block;font-size:.6rem;font-weight:700;color:#fff;padding:.1rem .35rem;border-radius:3px;margin-top:.15rem;width:fit-content;letter-spacing:.02em}
@media(max-width:900px){.wi-similar-strip{grid-template-columns:repeat(3,1fr)}}
@media(max-width:600px){.wi-similar-strip{display:flex;overflow-x:auto;-webkit-overflow-scrolling:touch;scrollbar-width:thin;padding-bottom:.5rem}.wi-similar-card{flex:0 0 130px}}

/* ── Favorite Button ──────────────────────────────────── */
.wi-fav-btn{background:none;border:none;cursor:pointer;padding:0;margin-left:.5rem;color:var(--text2);vertical-align:middle;position:relative;top:-1px;transition:transform .2s ease}
.wi-fav-btn:hover{transform:scale(1.15)}
.wi-fav-btn:active{transform:scale(.9)}
.wi-fav-icon{width:22px;height:22px;display:none}
.wi-fav-btn .wi-fav-outline{display:inline-block}
.wi-fav-btn .wi-fav-filled{display:none}
.wi-fav-btn.is-fav{color:#e74c3c}
.wi-fav-btn.is-fav .wi-fav-outline{display:none}
.wi-fav-btn.is-fav .wi-fav-filled{display:inline-block}
.wi-fav-btn.wi-fav-pop{animation:favPop .35s ease}
@keyframes favPop{0%{transform:scale(1)}30%{transform:scale(1.35)}60%{transform:scale(.9)}100%{transform:scale(1)}}

/* ── Recently Viewed Strip ────────────────────────────── */
.wi-recent{margin-bottom:2rem}
.wi-recent h2{margin:0 0 .75rem;font-size:1.05rem;font-weight:700;border-bottom:2px solid var(--border);padding-bottom:.4rem}
.wi-recent-strip{display:flex;gap:.65rem;overflow-x:auto;padding-bottom:.5rem;scrollbar-width:thin;scrollbar-color:var(--border) transparent}
.wi-recent-strip::-webkit-scrollbar{height:6px}
.wi-recent-strip::-webkit-scrollbar-track{background:transparent}
.wi-recent-strip::-webkit-scrollbar-thumb{background:var(--border);border-radius:3px}
.wi-recent-card{flex:0 0 140px;background:var(--bg2);border:1px solid var(--border);border-radius:4px;overflow:hidden;text-decoration:none;color:inherit;transition:border-color .15s,background .15s}
.wi-recent-card:hover{border-color:var(--accent);background:var(--bg3)}
.wi-recent-card-img{width:100%;height:85px;background:var(--bg3);display:flex;align-items:center;justify-content:center;overflow:hidden}
.wi-recent-card-img img{width:100%;height:100%;object-fit:contain;padding:4px}
.wi-recent-card-info{padding:.45rem .55rem}
.wi-recent-card-weapon{font-size:.65rem;color:var(--text2);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.wi-recent-card-name{font-size:.75rem;font-weight:700;color:var(--text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}

/* ── Float Range Chart ─────────────────────────────────── */
.wi-float-chart{background:var(--bg2);border:1px solid var(--border);border-radius:4px;padding:1rem;margin-bottom:0}
.wi-float-chart h2{margin:0 0 .75rem;font-size:.95rem;font-weight:700}
.wi-float-bar-wrap{position:relative;max-width:100%}
.wi-float-bar{display:flex;height:28px;border-radius:4px;overflow:hidden;border:1px solid var(--border);position:relative}
.wi-float-seg{position:relative;height:100%;transition:opacity .2s}
.wi-float-fn{background:rgba(76,175,80,0.2)}
.wi-float-mw{background:rgba(33,150,243,0.2)}
.wi-float-ft{background:rgba(255,235,59,0.15)}
.wi-float-ww{background:rgba(255,152,0,0.2)}
.wi-float-bs{background:rgba(244,67,54,0.18)}
.wi-float-seg-inner{border-radius:2px}
.wi-float-markers{position:relative;height:18px;margin-top:2px}
.wi-float-marker{position:absolute;top:0;transform:translateX(-50%)}
.wi-float-marker-line{display:block;width:2px;height:8px;background:var(--accent);margin:0 auto;border-radius:1px}
.wi-float-marker-val{display:block;font-size:.65rem;font-weight:700;color:var(--accent);text-align:center;white-space:nowrap;margin-top:1px}
.wi-float-labels{display:flex;margin-top:.2rem}
.wi-float-label{text-align:center;font-size:.68rem;font-weight:700;color:var(--text2);padding:0 2px}
.wi-float-scale{display:flex;justify-content:space-between;font-size:.6rem;color:var(--text2);margin-top:.15rem;opacity:.7}
.wi-float-desc{font-size:.8rem;color:var(--text2);margin:.6rem 0 0;line-height:1.5}
.wi-float-desc strong{color:var(--text);font-weight:700}
@media(max-width:600px){.wi-float-bar{height:22px}.wi-float-label{font-size:.6rem}.wi-float-scale{font-size:.55rem}}
</style>
</Base>
