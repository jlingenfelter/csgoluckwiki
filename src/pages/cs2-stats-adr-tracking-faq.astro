---
import Base from '../layouts/Base.astro';
import AuthorBox from '../components/AuthorBox.astro';
import { faqSchema, breadcrumbSchema } from '../lib/weapons';

const title = 'CS2 Stats FAQ: ADR, StatTrak & Tracking | CSGOLuck Wiki';
const description = 'What ADR means, what counts as a good ADR, how to check your CS2 stats, StatTrak explained, and current player counts.';

const faqs = [
  {
    question: 'What is ADR in CS2?',
    answer: 'ADR stands for Average Damage per Round and measures how much damage you deal to opponents on a per-round basis across a match. It is one of the most widely used performance metrics in competitive CS2 because it captures consistent combat contribution regardless of whether you secure the final kill. ADR is displayed on the match scoreboard and in third-party stat trackers.',
  },
  {
    question: 'What does ADR mean and what is a good ADR in CS2?',
    answer: 'ADR means Average Damage per Round — the total damage you deal divided by the number of rounds played. A solid benchmark for most competitive players is 80 ADR or higher. Professional players routinely average 80-100+ ADR. If your ADR sits below 60, you are likely not taking enough fights or missing too many shots. Tracking ADR over time is a reliable way to measure improvement.',
  },
  {
    question: 'How to check CS2 stats?',
    answer: 'In-game, you can view basic lifetime stats from the main menu under the Stats section. For more detailed data, open your match history from the Personal Game Data tab in settings to download demo files and review per-match performance. Third-party platforms like Leetify, SCOPE.gg, and CS2Tracker offer deep stat breakdowns including ADR trends, utility usage, and aim analysis.',
  },
  {
    question: 'What is StatTrak in CS2?',
    answer: 'StatTrak is a special item attribute that adds a digital kill counter to a weapon skin. The counter on the weapon tracks how many enemies you have eliminated with that specific gun and displays the number on the weapon model itself. StatTrak variants of skins typically sell for a premium over their non-StatTrak counterparts. The counter can be reset using a StatTrak Swap Tool.',
  },
  {
    question: 'How many people play CS2?',
    answer: 'Counter-Strike 2 consistently ranks among the most-played games on Steam, regularly exceeding one million concurrent players during peak hours. You can check real-time and historical player counts on <a href="https://steamcharts.com/" target="_blank" rel="noopener noreferrer">SteamCharts</a> or the official <a href="https://store.steampowered.com/stats/" target="_blank" rel="noopener noreferrer">Steam Stats page</a>. The player base has remained strong since the transition from CS:GO, with numbers spiking around Major tournaments and seasonal updates.',
  },
];

const cards = [
  { href: '/what-is-adr-cs2/', title: 'What Is ADR in CS2?', excerpt: 'Average Damage per Round explained with benchmarks and improvement tips.' },
  { href: '/check-cs2-stats/', title: 'How to Check CS2 Stats', excerpt: 'In-game stats, match history, and third-party tracking platforms.' },
  { href: '/what-is-stattrak-cs2/', title: 'What Is StatTrak in CS2?', excerpt: 'Kill counter weapon attribute, pricing premium, and swap tools.' },
  { href: '/cs2-player-count/', title: 'How Many People Play CS2?', excerpt: 'Live concurrent player counts and historical trends.' },
];
---

<Base title={title} description={description}>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema([{name:'Home',url:'/'},{name:'CS2 Stats, ADR & Tracking FAQ',url:'/cs2-stats-adr-tracking-faq'}]))}></script>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema(faqs))}></script>

  <nav class="saf-breadcrumb">
    <a href="/">Home</a> / <span>CS2 Stats, ADR &amp; Tracking FAQ</span>
  </nav>

  <section class="saf-hero">
    <h1>CS2 Stats FAQ: ADR, StatTrak &amp; Tracking</h1>
    <p class="saf-hero-desc">Tracking your CS2 stats, understanding ADR, and knowing what StatTrak does are fundamental to measuring your progress as a player. Whether you want to know what a good ADR looks like, how to pull up your match stats, or how many people are playing CS2 right now, this FAQ covers the key stat-related questions.</p>
  </section>

  <p class="saf-intro">Click any question below for a detailed answer.</p>

  <div class="saf-faq-grid">
    {cards.map(card => (
      <a href={card.href} class="saf-faq-card">
        <div class="saf-faq-card-content">
          <span class="saf-faq-card-q">{card.title}</span>
          <p class="saf-faq-card-excerpt">{card.excerpt}</p>
        </div>
        <span class="saf-faq-card-arrow">&rarr;</span>
      </a>
    ))}
  </div>

  <section class="saf-explore">
    <h2>Explore More</h2>
    <div class="saf-explore-links">
      <a href="/cs2-esports-pro-scene-faq/">CS2 Esports &amp; Pro Scene FAQ</a>
      <a href="/cs2-ranks-competitive-faq/">CS2 Ranks &amp; Competitive FAQ</a>
    </div>
  </section>

  <div class="saf-outbound">
    <strong>Official Resources:</strong>
    <a href="https://steamcharts.com/" target="_blank" rel="noopener noreferrer">SteamCharts</a>
    <a href="https://store.steampowered.com/stats/" target="_blank" rel="noopener noreferrer">Steam Stats</a>
  </div>

  <AuthorBox updated="2026-03-04" />
</Base>

<style>
/* ── Breadcrumb ── */
.saf-breadcrumb{font-size:.82rem;color:var(--text2);margin-bottom:1.25rem;display:flex;gap:.35rem;flex-wrap:wrap}
.saf-breadcrumb a{color:var(--accent);text-decoration:none}
.saf-breadcrumb a:hover{text-decoration:underline}

/* ── Hero ── */
.saf-hero{background:var(--bg2);border:1px solid var(--border);border-radius:4px;padding:2rem;margin-bottom:1.5rem}
.saf-hero h1{font-family:'Montserrat',sans-serif;font-size:2rem;font-weight:800;margin:0 0 .75rem;color:var(--text)}
.saf-hero-desc{color:var(--text2);font-size:.95rem;line-height:1.7;margin:0}

/* ── Intro ── */
.saf-intro{font-size:.9rem;color:var(--text2);margin:0 0 1.25rem;line-height:1.6}

/* ── FAQ Card Grid ── */
.saf-faq-grid{display:grid;grid-template-columns:1fr;gap:.75rem;margin-bottom:2.5rem}
.saf-faq-card{display:flex;align-items:center;justify-content:space-between;padding:1.25rem;background:var(--bg2);border:1px solid var(--border);border-radius:4px;text-decoration:none;border-left:3px solid transparent;transition:border-left-color .2s,background .15s}
.saf-faq-card:hover{border-left-color:var(--accent);background:rgba(46,204,113,.03)}
.saf-faq-card-content{flex:1}
.saf-faq-card-q{font-size:.95rem;font-weight:600;color:var(--text);margin:0 0 .25rem;display:block}
.saf-faq-card-excerpt{font-size:.82rem;color:var(--text2);margin:0;line-height:1.5}
.saf-faq-card-arrow{font-size:1.1rem;color:var(--accent);margin-left:1rem;opacity:0;transition:opacity .2s}
.saf-faq-card:hover .saf-faq-card-arrow{opacity:1}

/* ── Explore More ── */
.saf-explore{margin-bottom:2rem}
.saf-explore h2{font-family:'Montserrat',sans-serif;font-size:1.2rem;font-weight:700;color:var(--text);margin:0 0 .75rem;padding-bottom:.5rem;border-bottom:2px solid var(--accent)}
.saf-explore-links{display:flex;flex-wrap:wrap;gap:.45rem}
.saf-explore-links a{color:var(--accent);text-decoration:none;padding:.4rem .75rem;background:var(--bg2);border:1px solid var(--border);border-radius:4px;font-size:.85rem;font-weight:600;transition:border-color .15s,color .15s}
.saf-explore-links a:hover{border-color:var(--accent);color:var(--text)}

/* ── Outbound Links ── */
.saf-outbound{display:flex;flex-wrap:wrap;gap:.45rem;align-items:center;margin:1.5rem 0 2rem;font-size:.82rem}
.saf-outbound strong{color:var(--text);margin-right:.2rem}
.saf-outbound a{color:var(--accent);text-decoration:none;padding:.2rem .5rem;background:var(--bg2);border:1px solid var(--border);border-radius:4px;transition:border-color .15s}
.saf-outbound a:hover{border-color:var(--accent)}

/* ── Responsive ── */
@media(max-width:768px){
  .saf-hero h1{font-size:1.5rem}
}
</style>
