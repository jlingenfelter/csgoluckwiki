---
import Base from '../../layouts/Base.astro';
import { WEAPONS, WEAPON_CATEGORIES, getWeaponsByCategory, faqSchema, breadcrumbSchema } from '../../lib/weapons';
import { getSkinsByWeapon, RARITY_COLORS, getLowestPrice } from '../../lib/skins';

export async function getStaticPaths() {
  return WEAPON_CATEGORIES.map(cat => ({
    params: { category: cat.slug },
    props: { category: cat },
  }));
}

const { category } = Astro.props;
const weapons = getWeaponsByCategory(category.slug);

const seoContent: Record<string, { intro: string; meta: string; buyingGuide: string; faqs: { question: string; answer: string }[] }> = {
  rifle: {
    meta: 'Complete guide to all CS2 rifles — AK-47, M4A4, M4A1-S, AWP, and more. Compare damage, fire rate, recoil, and prices for every rifle in Counter-Strike 2.',
    intro: 'Rifles are the backbone of competitive CS2. From the one-tap AK-47 to the devastating AWP, rifle selection defines round outcomes more than any other weapon class. Understanding each rifle\'s strengths, weaknesses, and optimal use cases is fundamental to climbing the ranks.',
    buyingGuide: 'On T-side, the AK-47 ($2,700) is the default full-buy rifle — its ability to one-shot headshot through helmets makes it the most lethal rifle in the game. The Galil AR ($1,800) serves as the force-buy alternative when funds are tight. On CT-side, choose between the M4A4\'s 30-round magazine for spray-heavy positions or the M4A1-S\'s silenced precision for long-range holds. The AWP ($4,750) is a luxury purchase that pays massive dividends in the right hands, but its $100 kill reward means missed shots are costly.',
    faqs: [
      { question: 'What is the best rifle in CS2?', answer: 'The AK-47 is widely considered the best rifle due to its one-shot headshot capability against armored opponents. However, the AWP is the most impactful weapon in skilled hands. For CT-side, the M4A1-S is currently favored in professional play for its accuracy and silenced shots.' },
      { question: 'AK-47 or M4A4 — which does more damage?', answer: 'The AK-47 deals 36 base damage with 77.5% armor penetration, while the M4A4 deals 33 damage with 70% armor penetration. Critically, the AK-47 can one-shot headshot through helmets (36 × 4 = 144 damage), while the M4A4 cannot (33 × 4 = 132, leaving enemies alive at ~8 HP).' },
      { question: 'When should I buy the AWP vs a rifle?', answer: 'Buy the AWP when your team economy can sustain the $4,750 cost, when you have a dedicated AWP player, and when the map favors long-range engagements. Never sacrifice your team\'s utility budget for an AWP, and always have a rifle backup plan.' },
      { question: 'Is the SG 553 worth buying?', answer: 'The SG 553 costs $3,000 (only $300 more than AK-47) and offers a scope, better armor penetration (100%), and one-shot headshot capability. Its scoped accuracy makes it excellent for long-range duels, though many players prefer the AK-47\'s spray pattern.' },
    ]
  },
  smg: {
    meta: 'All CS2 SMGs compared — MAC-10, MP9, UMP-45, P90, and more. Stats, damage values, kill rewards, and when to buy each SMG in competitive play.',
    intro: 'SMGs fill a crucial economic niche in CS2. With $600 kill rewards (double that of rifles), they accelerate your team\'s economy while providing viable firepower against unarmored or lightly-armored opponents. The right SMG purchase after a pistol round win can snowball your entire half.',
    buyingGuide: 'After winning the pistol round, SMGs are the go-to anti-eco weapon. The MAC-10 ($1,050) and MP9 ($1,250) are the cheapest options for T and CT respectively, offering excellent close-range damage and movement speed. The UMP-45 ($1,200) is the most versatile SMG — its damage holds up at medium range and it remains viable even against armored opponents in later rounds. The P90 ($2,350) is a more expensive option with 50 rounds and high fire rate, popular among players who prefer spray-and-pray tactics.',
    faqs: [
      { question: 'Which SMG should I buy after winning pistol round?', answer: 'MAC-10 ($1,050) for T-side or MP9 ($1,250) for CT-side are the most popular choices. They are cheap, have high kill rewards ($600), and are lethal against unarmored opponents. The UMP-45 ($1,200) is another solid choice if you expect the enemy to force-buy armor.' },
      { question: 'Why do SMGs give more kill reward than rifles?', answer: 'SMGs give $600 per kill (vs $300 for rifles) as a balance mechanism. Since SMGs are weaker overall, the higher kill reward incentivizes buying them during anti-eco rounds, rewarding aggressive play and helping teams build economy.' },
      { question: 'Is the P90 a good weapon in CS2?', answer: 'The P90 is effective in lower ranks and casual play due to its 50-round magazine and manageable recoil. However, at higher levels, its low damage against armor and predictable spray make it inferior to rifles. It costs $2,350 — for $350 more you could get an AK-47.' },
      { question: 'What is the best SMG for long range?', answer: 'The UMP-45 has the best damage falloff of any SMG, maintaining reasonable damage at medium-to-long range. The MP7 is also decent at range. However, no SMG truly competes with rifles at long distance.' },
    ]
  },
  pistol: {
    meta: 'Every CS2 pistol compared — Glock, USP-S, Desert Eagle, P250, and more. Damage stats, accuracy, eco round strategies, and pistol round tips.',
    intro: 'Pistols determine the first two rounds of every half and play a critical role in eco rounds throughout the game. Mastering pistol mechanics — particularly the Desert Eagle\'s one-shot headshot and the starting pistol dynamics — can swing entire matches. A strong pistol round win gives your team a 3-round economic advantage.',
    buyingGuide: 'The Glock-18 (T-side starting pistol) has a 20-round magazine and burst-fire mode but struggles against armor. The USP-S (CT-side default) has better first-shot accuracy and silenced shots but only 12 rounds. For eco rounds, the P250 ($300) offers one-shot headshot capability at close range against helmets. The Desert Eagle ($700) is the premier eco weapon — its one-shot headshot at any range makes it a round-winner. The CZ75-Auto ($500) provides automatic fire in a pistol slot.',
    faqs: [
      { question: 'Which starting pistol is better — Glock or USP-S?', answer: 'The USP-S has better first-shot accuracy and deals more damage per bullet, making it superior in 1v1 pistol duels. The Glock-18 has 20 rounds and burst-fire, making it better for rushing and close-range spam. Most pros slightly favor USP-S/P2000 for CT-side.' },
      { question: 'Is the Desert Eagle worth $700 on eco rounds?', answer: 'Absolutely — the Deagle is one of the most impactful eco purchases. Its one-shot headshot at any range means you can eliminate a fully-equipped rifler with a single click. The risk is that it requires precise aim and only holds 7 rounds.' },
      { question: 'P250 vs CZ75-Auto — which is better for eco?', answer: 'The P250 ($300) offers controlled tapping with one-shot headshot potential at close range. The CZ75-Auto ($500) is automatic but has 12 rounds total and a long draw time. P250 is safer and cheaper; CZ75 is higher risk/reward for close ambushes.' },
      { question: 'Should I buy a pistol on pistol round?', answer: 'It depends. CT-side, many players keep the USP-S and buy Kevlar ($650) instead. T-side, buying a P250 or Tec-9 can help against armored CTs. The most common pistol-round buy is Kevlar + no pistol upgrade for CTs, or Kevlar + Tec-9/P250 for Ts.' },
    ]
  },
  heavy: {
    meta: 'CS2 heavy weapons guide — all shotguns (Nova, MAG-7, XM1014, Sawed-Off) and machine guns (M249, Negev). Stats, buy scenarios, and positioning tips.',
    intro: 'Heavy weapons occupy a specialist niche in CS2. Shotguns deliver devastating close-range damage with generous kill rewards ($900), making them powerful anti-eco choices in tight spaces. Machine guns offer suppressive fire with massive magazines. While rarely seen in professional play, heavy weapons can be devastatingly effective when used in the right positions.',
    buyingGuide: 'The MAG-7 ($1,300, CT-only) is the premier competitive shotgun — its pump-action one-shot capability at close range makes it lethal for holding tight corners on CT-side. The Nova ($1,050) is the budget option with a $900 kill reward, great for boosting economy. The Negev ($1,700) is a suppression tool that becomes perfectly accurate after its initial spray, useful for denying rushes through choke points.',
    faqs: [
      { question: 'When should I buy a shotgun in CS2?', answer: 'Shotguns shine on anti-eco rounds in close-quarter positions (like holding B tunnels on Dust 2 or banana on Inferno). They are also viable force-buy options when you need the $900 kill reward to rebuild economy. Never buy shotguns when expecting long-range engagements.' },
      { question: 'Is the Negev viable in competitive CS2?', answer: 'The Negev is situationally powerful. At $1,700, it provides a 150-round magazine that becomes laser-accurate after the initial spray-up period. It excels at denying narrow choke points and can suppress rushes single-handedly. However, its slow movement and loud audio make rotation difficult.' },
      { question: 'What is the best shotgun in CS2?', answer: 'The MAG-7 is the best competitive shotgun for CT-side due to its reliable one-shot kill potential and reasonable fire rate. The XM1014 (auto-shotgun) offers the fastest follow-up shots. The Sawed-Off has the tightest spread but is T-side only with very limited range.' },
      { question: 'Why do shotguns give $900 kill reward?', answer: 'The high kill reward ($900 vs $300 for rifles) compensates for shotguns\' severe range limitations. Valve designed this to incentivize aggressive close-quarter play during anti-eco rounds and to help teams recover economy through risky positioning.' },
    ]
  },
  grenade: {
    meta: 'Complete CS2 grenade guide — HE grenades, smoke grenades, flashbangs, molotovs, and incendiary grenades. Usage tips, lineups, and competitive strategies.',
    intro: 'Grenades are the tactical layer that separates CS2 from other shooters. Proper utility usage wins rounds without firing a single bullet. A well-placed smoke blocks sightlines for 18 seconds, a flashbang blinds entire pushes, and molotovs deny positions and force rotations. Teams that master grenade usage gain a massive strategic advantage.',
    buyingGuide: 'Smoke grenades ($300) are the single most important utility purchase — they block vision for 18 seconds and are essential for executing onto bombsites. Flashbangs ($200, buy two) enable aggressive peeks and site takes. Molotovs ($400 T-side) and Incendiary Grenades ($600 CT-side) deny positions and flush out enemies. HE Grenades ($300) deal area damage — stack them with teammates for devastating combined damage.',
    faqs: [
      { question: 'How long does a CS2 smoke grenade last?', answer: 'Smoke grenades last approximately 18 seconds in CS2. They create a spherical smoke cloud that blocks vision. Smokes are the single most important piece of utility — learn at least 3-5 smoke lineups per map you play competitively.' },
      { question: 'How much damage does an HE grenade do?', answer: 'An HE grenade deals up to 98 damage against unarmored opponents and up to 57 damage against armored players at point-blank range. Damage falls off with distance. Stacking HE grenades with teammates can kill or severely weaken grouped enemies.' },
      { question: 'What is the best grenade buy for T-side?', answer: 'Standard T-side utility: 1 smoke ($300), 2 flashbangs ($400), 1 molotov ($400). Total: $1,100. This gives you site-execute utility. Adjust based on your role — entry fraggers may prefer 2 flashes and a molotov, while support players carry smokes and HEs.' },
      { question: 'How do molotovs work in CS2?', answer: 'Molotovs (T-side, $400) and Incendiary Grenades (CT-side, $600) create a fire zone lasting about 7 seconds. They deal 40 damage per second to anyone standing in the fire. They can be extinguished by smoke grenades. Use them to deny positions, delay pushes, or flush enemies from cover.' },
    ]
  },
};

const content = seoContent[category.slug] || seoContent.rifle;
const title = `CS2 ${category.name} — All ${category.name} Stats, Damage & Skins | CSGOLuck Wiki`;
const description = content.meta;

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Weapons', url: '/cs2-weapons' },
  { name: category.name, url: `/cs2-weapons/${category.slug}` },
];
---

<Base title={title} description={description} currentNav="/cs2-weapons/">
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema(breadcrumbs))}></script>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema(content.faqs))}></script>

  <nav class="breadcrumb">
    <a href="/">Home</a> <span>/</span> <a href="/cs2-weapons/">Weapons</a> <span>/</span> <span>{category.name}</span>
  </nav>

  <!-- Hero: left-aligned with category name and weapon count -->
  <section class="wc-hero">
    <h1 class="wc-hero-title">CS2 {category.name}</h1>
    <p class="wc-hero-desc">{content.intro}</p>
    <div class="wc-hero-pills">
      <span class="wc-pill"><strong>{weapons.length}</strong> weapons</span>
      <span class="wc-pill"><strong>{weapons.filter(w => w.team === 'ct').length}</strong> CT</span>
      <span class="wc-pill"><strong>{weapons.filter(w => w.team === 't').length}</strong> T</span>
      <span class="wc-pill"><strong>{weapons.filter(w => w.team === 'both').length}</strong> Both</span>
    </div>
  </section>

  <!-- Category nav tabs -->
  <nav class="wc-tabs">
    {WEAPON_CATEGORIES.map(c => (
      <a href={`/cs2-weapons/${c.slug}/`} class:list={['wc-tab', { 'wc-tab-active': c.slug === category.slug }]}>
        {c.name}
      </a>
    ))}
  </nav>

  <!-- Quick comparison table at top -->
  {weapons.length > 1 && !weapons[0]?.cosmetic && (
    <section class="wc-compare">
      <h2 class="wc-section-title">Quick Comparison</h2>
      <div class="wc-compare-table">
        <div class="wc-compare-head">
          <span class="wc-ch">Weapon</span>
          <span class="wc-ch">Price</span>
          <span class="wc-ch">Damage</span>
          <span class="wc-ch">RPM</span>
          <span class="wc-ch">Armor Pen</span>
          <span class="wc-ch">Move Speed</span>
        </div>
        {weapons.map((w, i) => (
          <div class:list={['wc-compare-row', { 'wc-compare-alt': i % 2 === 1 }]}>
            <span class="wc-cv wc-cv-name">{w.name}</span>
            <span class="wc-cv wc-cv-price">${w.price}</span>
            <span class="wc-cv">{w.damage}</span>
            <span class="wc-cv">{w.rpm}</span>
            <span class="wc-cv">{w.armorPen}%</span>
            <span class="wc-cv">{w.moveSpeed}</span>
          </div>
        ))}
      </div>
    </section>
  )}

  <!-- Weapon list: collapsible details groups by subcategory, then table rows -->
  <section class="wc-weapons">
    <h2 class="wc-section-title">All {category.name}</h2>
    {(() => {
      const subcats = [...new Set(weapons.map(w => w.subcategory || 'General'))];
      const hasMultipleSubs = subcats.length > 1;

      if (hasMultipleSubs) {
        return subcats.map(sub => {
          const subWeapons = weapons.filter(w => (w.subcategory || 'General') === sub);
          return (
            <details class="wc-group" open>
              <summary class="wc-group-summary">
                <span class="wc-group-name">{sub}</span>
                <span class="wc-group-count">{subWeapons.length}</span>
              </summary>
              <div class="wc-group-body">
                {subWeapons.map((w, i) => {
                  const skins = getSkinsByWeapon(w.slug);
                  const skinCount = skins.length;
                  return (
                    <a href={`/cs2-weapons/${w.slug}/`} class:list={['wc-row', { 'wc-row-alt': i % 2 === 1 }]}>
                      <span class="wc-rd wc-rd-name">{w.name}</span>
                      <span class="wc-rd wc-rd-side">
                        <span class={`wc-side wc-side-${w.team}`}>{w.team === 'ct' ? 'CT' : w.team === 't' ? 'T' : 'Both'}</span>
                      </span>
                      <span class="wc-rd wc-rd-price">${w.price}</span>
                      <span class="wc-rd wc-rd-dmg">{w.damage} dmg</span>
                      <span class="wc-rd wc-rd-rpm">{w.rpm} rpm</span>
                      <span class="wc-rd wc-rd-pen">{w.armorPen}%</span>
                      <span class="wc-rd wc-rd-mag">{w.magSize}/{w.reserveAmmo}</span>
                      <span class="wc-rd wc-rd-skins">{skinCount > 0 ? `${skinCount} skins` : ''}</span>
                    </a>
                  );
                })}
              </div>
            </details>
          );
        });
      } else {
        return (
          <div class="wc-flat-list">
            {weapons.map((w, i) => {
              const skins = getSkinsByWeapon(w.slug);
              const skinCount = skins.length;
              return (
                <a href={`/cs2-weapons/${w.slug}/`} class:list={['wc-row', { 'wc-row-alt': i % 2 === 1 }]}>
                  <span class="wc-rd wc-rd-name">{w.name}</span>
                  <span class="wc-rd wc-rd-side">
                    <span class={`wc-side wc-side-${w.team}`}>{w.team === 'ct' ? 'CT' : w.team === 't' ? 'T' : 'Both'}</span>
                  </span>
                  <span class="wc-rd wc-rd-price">${w.price}</span>
                  <span class="wc-rd wc-rd-dmg">{w.damage} dmg</span>
                  <span class="wc-rd wc-rd-rpm">{w.rpm} rpm</span>
                  <span class="wc-rd wc-rd-pen">{w.armorPen}%</span>
                  <span class="wc-rd wc-rd-mag">{w.magSize}/{w.reserveAmmo}</span>
                  <span class="wc-rd wc-rd-skins">{skinCount > 0 ? `${skinCount} skins` : ''}</span>
                </a>
              );
            })}
          </div>
        );
      }
    })()}
  </section>

  <!-- Purchase Notes -->
  <section class="wc-notes">
    <h2 class="wc-section-title">Purchase Notes</h2>
    <p class="wc-notes-text">{content.buyingGuide}</p>
  </section>

  <!-- FAQ: collapsible -->
  <section class="wc-faq">
    <h2 class="wc-section-title">Frequently Asked Questions</h2>
    {content.faqs.map(f => (
      <details class="wc-faq-item">
        <summary class="wc-faq-q">{f.question}</summary>
        <p class="wc-faq-a">{f.answer}</p>
      </details>
    ))}
  </section>

  <!-- Internal links -->
  <nav class="wc-links">
    <strong class="wc-links-label">Related:</strong>
    <div class="wc-links-list">
      {WEAPON_CATEGORIES.map(c => (
        <a href={`/cs2-weapons/${c.slug}/`} class="wc-link-pill">{c.name}</a>
      ))}
      <a href="/weapon-compare/" class="wc-link-pill">Compare Weapons</a>
      <a href="/damage-calculator/" class="wc-link-pill">Damage Calculator</a>
      <a href="/recoil-patterns/" class="wc-link-pill">Recoil Patterns</a>
      <a href="/economy-calculator/" class="wc-link-pill">Economy Calculator</a>
      <a href="/cs2-skins/" class="wc-link-pill">Skin Database</a>
      <a href="/pro-players/" class="wc-link-pill">Pro Configs</a>
      <a href="/cs2-tools/" class="wc-link-pill">All Tools</a>
    </div>
  </nav>
</Base>

<style>
  /* === Weapon Category Page (wc-) === */

  /* Section title */
  .wc-section-title {
    margin: 0 0 .75rem;
    font-size: 1.05rem;
    font-weight: 700;
    padding-bottom: .4rem;
    border-bottom: 2px solid var(--border);
  }

  /* Hero */
  .wc-hero {
    margin-bottom: 1.75rem;
  }
  .wc-hero-title {
    margin: 0 0 .5rem;
    font-size: 2rem;
    font-weight: 800;
    line-height: 1.1;
  }
  .wc-hero-desc {
    margin: 0 0 .75rem;
    color: var(--text2);
    font-size: .88rem;
    line-height: 1.6;
    max-width: 600px;
  }
  .wc-hero-pills {
    display: flex;
    gap: .4rem;
    flex-wrap: wrap;
  }
  .wc-pill {
    display: inline-flex;
    align-items: center;
    gap: .25rem;
    padding: .25rem .6rem;
    background: rgba(46,204,113,.08);
    border: 1px solid rgba(46,204,113,.2);
    border-radius: 4px;
    font-size: .75rem;
    color: var(--text2);
  }
  .wc-pill strong {
    color: var(--accent);
    font-weight: 700;
  }

  /* Category nav tabs */
  .wc-tabs {
    display: flex;
    gap: 0;
    border-bottom: 2px solid var(--border);
    margin-bottom: 2rem;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }
  .wc-tab {
    padding: .55rem 1rem;
    font-size: .8rem;
    font-weight: 700;
    color: var(--text2);
    text-decoration: none;
    border-bottom: 2px solid transparent;
    margin-bottom: -2px;
    white-space: nowrap;
    transition: color .15s, border-color .15s;
  }
  .wc-tab:hover {
    color: var(--accent);
    border-bottom-color: var(--accent);
  }
  .wc-tab-active {
    color: var(--accent);
    border-bottom-color: var(--accent);
    background: rgba(46,204,113,.05);
  }

  /* Quick comparison table */
  .wc-compare {
    margin-bottom: 2rem;
  }
  .wc-compare-table {
    border: 1px solid var(--border);
    border-radius: 4px;
    overflow: hidden;
    overflow-x: auto;
  }
  .wc-compare-head {
    display: grid;
    grid-template-columns: 1fr 80px 75px 70px 85px 85px;
    gap: .4rem;
    padding: .45rem .75rem;
    background: var(--accent);
    color: #000;
    font-size: .68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .04em;
    min-width: 550px;
  }
  .wc-compare-row {
    display: grid;
    grid-template-columns: 1fr 80px 75px 70px 85px 85px;
    gap: .4rem;
    padding: .4rem .75rem;
    border-bottom: 1px solid var(--border);
    align-items: center;
    min-width: 550px;
  }
  .wc-compare-row:last-child { border-bottom: none; }
  .wc-compare-alt { background: var(--bg2); }
  .wc-cv {
    font-size: .8rem;
    color: var(--text2);
  }
  .wc-cv-name {
    font-weight: 600;
    color: var(--text);
  }
  .wc-cv-price {
    font-weight: 700;
    color: var(--accent);
  }

  /* Weapon list and collapsible groups */
  .wc-weapons {
    margin-bottom: 2rem;
  }
  .wc-group {
    margin-bottom: .5rem;
    border: 1px solid var(--border);
    border-radius: 4px;
    overflow: hidden;
  }
  .wc-group-summary {
    display: flex;
    align-items: center;
    gap: .5rem;
    padding: .65rem 1rem;
    background: var(--bg3);
    cursor: pointer;
    list-style: none;
    border-left: 3px solid transparent;
    transition: border-left-color .15s;
  }
  .wc-group-summary::-webkit-details-marker { display: none; }
  .wc-group-summary::before {
    content: '\25B6';
    font-size: .6rem;
    color: var(--accent);
    transition: transform .15s;
  }
  .wc-group[open] > .wc-group-summary::before {
    transform: rotate(90deg);
  }
  .wc-group-summary:hover {
    border-left-color: var(--accent);
  }
  .wc-group-name {
    font-size: .9rem;
    font-weight: 700;
    color: var(--text);
  }
  .wc-group-count {
    font-size: .68rem;
    font-weight: 700;
    color: var(--accent);
    background: rgba(46,204,113,.1);
    padding: .1rem .4rem;
    border-radius: 4px;
  }
  .wc-group-body {
    border-top: 1px solid var(--border);
  }
  .wc-flat-list {
    border: 1px solid var(--border);
    border-radius: 4px;
    overflow: hidden;
  }

  /* Weapon rows */
  .wc-row {
    display: grid;
    grid-template-columns: 1fr 60px 75px 70px 70px 60px 75px 70px;
    gap: .4rem;
    padding: .55rem 1rem;
    text-decoration: none;
    color: inherit;
    align-items: center;
    border-bottom: 1px solid var(--border);
    border-left: 3px solid transparent;
    transition: border-left-color .15s, background-color .15s;
  }
  .wc-row:last-child { border-bottom: none; }
  .wc-row:hover {
    border-left-color: var(--accent);
    background: var(--bg3);
  }
  .wc-row-alt {
    background: var(--bg2);
  }
  .wc-rd {
    font-size: .8rem;
    color: var(--text2);
  }
  .wc-rd-name {
    font-weight: 600;
    color: var(--text);
    font-size: .88rem;
  }
  .wc-rd-price {
    font-weight: 700;
    color: var(--accent);
  }
  .wc-rd-skins {
    font-size: .72rem;
    opacity: .7;
  }
  .wc-side {
    font-size: .6rem;
    font-weight: 700;
    padding: .08rem .3rem;
    border-radius: 3px;
    text-transform: uppercase;
  }
  .wc-side-ct { background: #4a8db7; color: #fff; }
  .wc-side-t { background: #c44; color: #fff; }
  .wc-side-both { background: var(--accent); color: #000; }

  /* Purchase notes */
  .wc-notes {
    margin-bottom: 2rem;
