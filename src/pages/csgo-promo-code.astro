---
import Base from '../layouts/Base.astro';
import ExploreMore from '../components/ExploreMore.astro';
import { faqSchema, breadcrumbSchema } from '../lib/weapons';

const title = 'CSGOLuck Promo Code: WIKIPEDIA — Free Bonus | CSGOLuck Wiki';
const description = 'Use CSGOLuck promo code WIKIPEDIA for a 100% deposit bonus up to 100 coins plus 5 free cases. Verified & working March 2026.';

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'CSGOLuck Promo Code' },
];

const faqs = [
  {
    question: 'What is the CSGOLuck promo code for 2026?',
    answer: 'The active CSGOLuck promo code for 2026 is WIKIPEDIA. Enter it when you register or in the promo code section of your account to receive a 100% deposit bonus up to 100 coins plus 5 free cases.',
  },
  {
    question: 'How do I redeem the WIKIPEDIA promo code?',
    answer: 'Visit CSGOLuck.com, create an account or log in, navigate to the promo code section, and enter WIKIPEDIA. Your bonus will be applied automatically to your next deposit.',
  },
  {
    question: 'Does the WIKIPEDIA code expire?',
    answer: 'The WIKIPEDIA promo code is active and verified as of March 2026. Promo codes can change or expire at any time, so we recommend using it as soon as possible to lock in the bonus.',
  },
  {
    question: 'Can I use the promo code if I already have an account?',
    answer: 'The WIKIPEDIA promo code is primarily designed for new players creating an account. If you already have a CSGOLuck account, check the promotions section — some codes can be applied to existing accounts depending on the current offer terms.',
  },
  {
    question: 'What do I get with the WIKIPEDIA code?',
    answer: 'You receive two bonuses: a 100% match on your first deposit (up to 100 coins) and 5 free cases to open immediately. This gives new players extra value to explore everything CSGOLuck has to offer.',
  },
  {
    question: 'Is CSGOLuck legitimate?',
    answer: 'CSGOLuck is an established CS2 case opening and gaming platform. As with any platform involving real-money transactions, always play responsibly and within your means. Read the terms of service and understand the odds before participating.',
  },
];

const sections = [
  { id: 'current-code', label: 'Current Code' },
  { id: 'how-to-use', label: 'How to Use' },
  { id: 'what-you-get', label: 'What You Get' },
  { id: 'about-csgoluck', label: 'About CSGOLuck' },
  { id: 'tips', label: 'Tips & Advice' },
  { id: 'faq', label: 'FAQ' },
  { id: 'related', label: 'Related Pages' },
];

const breadcrumbSchema_ = breadcrumbSchema(breadcrumbs);
const faqSchema_ = faqSchema(faqs);

const articleSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "description": description,
  "author": { "@type": "Person", "name": "Josh Lingenfelter", "url": "https://www.linkedin.com/in/josh-lingenfelter-8157274b/", "jobTitle": "Director", "worksFor": { "@type": "Organization", "name": "CSGOLuck" } },
  "publisher": { "@type": "Organization", "name": "CSGOLuck Wiki", "url": "https://wiki.csgoluck.com" },
  "mainEntityOfPage": "https://wiki.csgoluck.com/csgo-promo-code/",
  "datePublished": "2026-03-05",
  "dateModified": "2026-03-05",
  "inLanguage": "en-US"
});
---

<Base title={title} description={description}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema_)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema_)} />
    <script type="application/ld+json" set:html={articleSchema} />
  </Fragment>

  <div class="cpc-wrap">
    <nav class="cpc-breadcrumb">
      <a href="/">Home</a>
      <span class="cpc-sep">/</span>
      <span>CSGOLuck Promo Code</span>
    </nav>

    <header class="cpc-header">
      <h1>CSGOLuck Promo Code</h1>
      <p class="cpc-subtitle">Verified working code for March 2026 — claim your free bonus today</p>
    </header>

    <!-- Promo Code Hero Box -->
    <div class="cpc-promo-box">
      <div class="cpc-promo-badge">Active & Verified — March 2026</div>
      <div class="cpc-promo-code-row">
        <span class="cpc-promo-label">Promo Code:</span>
        <div class="cpc-reveal-wrap" id="revealWrap">
          <span class="cpc-promo-code cpc-code-hidden" id="promoCode">WIKIPEDIA</span>
          <button class="cpc-reveal-btn" id="revealBtn">Click to Reveal Code</button>
        </div>
        <button class="cpc-copy-btn cpc-copy-hidden" id="copyBtn" title="Copy code">Copy</button>
      </div>
      <div class="cpc-promo-reward">
        <div class="cpc-reward-item">
          <span class="cpc-reward-val">100%</span>
          <span class="cpc-reward-lbl">Deposit Bonus</span>
        </div>
        <div class="cpc-reward-divider"></div>
        <div class="cpc-reward-item">
          <span class="cpc-reward-val">100</span>
          <span class="cpc-reward-lbl">Max Coins</span>
        </div>
        <div class="cpc-reward-divider"></div>
        <div class="cpc-reward-item">
          <span class="cpc-reward-val">5</span>
          <span class="cpc-reward-lbl">Free Cases</span>
        </div>
      </div>
      <a href="https://csgoluck.com/r/WIKIPEDIA" class="cpc-claim-btn" target="_blank" rel="noopener nofollow">Claim Bonus at CSGOLuck &rarr;</a>
    </div>

    <nav class="cpc-toc-mobile" aria-label="Table of contents">
      {sections.map((s) => (
        <a href={`#${s.id}`} class="cpc-toc-mobile-link">{s.label}</a>
      ))}
    </nav>

    <div class="cpc-layout">
      <aside class="cpc-sidebar">
        <nav class="cpc-toc" aria-label="Table of contents">
          <span class="cpc-toc-title">Contents</span>
          {sections.map((s) => (
            <a href={`#${s.id}`} class="cpc-toc-link">{s.label}</a>
          ))}
        </nav>
      </aside>

      <article class="cpc-content">
        <p class="cpc-intro">
          Looking for a working CSGOLuck promo code in 2026? You are in the right place. The code <strong>WIKIPEDIA</strong> is currently active and gives new players a generous welcome bonus when signing up at CSGOLuck. This page covers everything you need to know — what you get, how to redeem it, and tips for getting the most from your bonus.
        </p>

        <section id="current-code">
          <div class="cpc-section-header"><h2>Current CSGOLuck Promo Code</h2></div>
          <p>The current and verified CSGOLuck promo code is <strong>WIKIPEDIA</strong>. This code has been tested and confirmed working as of March 2026. When you enter this code during registration or in the promotions section of your CSGOLuck account, you will receive a welcome bonus applied to your first deposit.</p>
          <p>Unlike many promo codes floating around online that are outdated or fake, the WIKIPEDIA code is an official referral code directly linked to the CSGOLuck Wiki. It provides the same maximum bonus that CSGOLuck offers to new users, ensuring you do not miss out on any available rewards.</p>
          <p>Promo codes on case opening and gaming sites change periodically, so we keep this page updated whenever changes occur. If you are reading this in 2026, the WIKIPEDIA code is your best option for claiming the full welcome bonus at CSGOLuck.</p>
        </section>

        <section id="how-to-use">
          <div class="cpc-section-header"><h2>How to Use the WIKIPEDIA Promo Code</h2></div>
          <p>Redeeming the CSGOLuck promo code is straightforward. Follow these steps to claim your bonus:</p>
          <ol class="cpc-steps">
            <li><strong>Visit CSGOLuck:</strong> Head to <a href="https://csgoluck.com/r/WIKIPEDIA" target="_blank" rel="noopener nofollow">CSGOLuck.com</a> using our referral link, which automatically associates the WIKIPEDIA code with your registration.</li>
            <li><strong>Create your account:</strong> Sign up using your preferred method. CSGOLuck supports Steam login for quick and secure account creation.</li>
            <li><strong>Enter the promo code:</strong> If the code was not applied automatically through the referral link, navigate to the promotions or promo code section of your account and enter <strong>WIKIPEDIA</strong> manually.</li>
            <li><strong>Make your first deposit:</strong> Add funds to your account. The 100% deposit match will be applied automatically, doubling your balance up to 100 coins.</li>
            <li><strong>Open your free cases:</strong> Your 5 free cases will be available immediately. Open them from the case opening section of the site.</li>
          </ol>
          <p>The entire process takes less than two minutes. If you use our direct referral link above, the code is pre-applied so you may not need to enter it manually at all.</p>
        </section>

        <section id="what-you-get">
          <div class="cpc-section-header"><h2>What You Get with the WIKIPEDIA Code</h2></div>
          <p>The WIKIPEDIA promo code unlocks two separate bonuses that stack together, giving new players a strong starting position on the platform:</p>
          <ul class="cpc-list">
            <li><strong>100% Deposit Bonus (up to 100 coins):</strong> Your first deposit is matched pound for pound. If you deposit 50 coins, you receive an additional 50 coins for free, giving you 100 coins to play with. The maximum match is capped at 100 bonus coins.</li>
            <li><strong>5 Free Cases:</strong> On top of the deposit bonus, you receive 5 cases to open at no additional cost. These cases contain a range of CS2 skins and items, giving you a chance at valuable drops without spending any of your own balance.</li>
          </ul>
          <p>Combined, these bonuses effectively double your initial budget and give you free shots at pulling skins from cases. For new players exploring what CSGOLuck has to offer, this is one of the best ways to start with extra value.</p>
          <p>The deposit bonus is typically released in stages as you play on the platform, which is standard for most gaming site bonuses. Check the specific terms on CSGOLuck for the current release schedule and any wagering requirements that apply to bonus funds.</p>
        </section>

        <section id="about-csgoluck">
          <div class="cpc-section-header"><h2>About CSGOLuck</h2></div>
          <p>CSGOLuck is a CS2 case opening platform where players can open cases containing Counter-Strike 2 skins. The platform features a variety of cases at different price points, from budget-friendly options to premium cases with high-value drops. Beyond case opening, CSGOLuck offers additional game modes and features that give players multiple ways to engage with the platform.</p>
          <p>The site accepts deposits through several payment methods and supports CS2 skin deposits and withdrawals, making it convenient for players who are already active in the skin trading ecosystem. CSGOLuck uses a provably fair system that allows users to independently verify the fairness of each case opening result.</p>
          <p>As with any platform that involves real-money gaming, it is important to approach CSGOLuck responsibly. Set a budget before you start, treat case opening as entertainment rather than an income source, and never spend more than you can afford to lose. The odds in case opening are always structured to favour the platform over time — bonuses like the WIKIPEDIA code simply give you more starting value to enjoy the experience.</p>
        </section>

        <section id="tips">
          <div class="cpc-section-header"><h2>Tips for Getting the Most from Your Bonus</h2></div>
          <p>Once you have redeemed the WIKIPEDIA promo code and claimed your bonus, here are some practical tips to maximize the value you get:</p>
          <ul class="cpc-list">
            <li><strong>Start with your free cases:</strong> Open the 5 free cases before depositing. This lets you get a feel for the platform and potentially win skins without risking any of your own money.</li>
            <li><strong>Choose your deposit wisely:</strong> Since the bonus matches up to 100 coins, depositing the full 100 coins gives you the maximum 200 coin starting balance. If that is outside your budget, deposit whatever you are comfortable with — the percentage match applies regardless.</li>
            <li><strong>Explore different case tiers:</strong> Do not immediately spend everything on the most expensive cases. Try a mix of price points to understand the odds and find what you enjoy most.</li>
            <li><strong>Read the bonus terms:</strong> Understand any wagering requirements or restrictions on the bonus funds. Knowing the rules upfront prevents surprises when you want to withdraw winnings.</li>
            <li><strong>Set a limit and stick to it:</strong> Decide beforehand how much you are willing to spend in total. Once you hit that limit, stop. Bonuses are meant to enhance entertainment, not encourage chasing losses.</li>
          </ul>
        </section>

        <section id="faq">
          <div class="cpc-section-header"><h2>Frequently Asked Questions</h2></div>
          <div class="cpc-faq-list">
            {faqs.map((faq) => (
              <details class="cpc-faq-item">
                <summary class="cpc-faq-question">{faq.question}</summary>
                <p class="cpc-faq-answer">{faq.answer}</p>
              </details>
            ))}
          </div>
        </section>

        <section id="related">
          <div class="cpc-section-header"><h2>Related Pages</h2></div>
          <div class="cpc-resources-grid">
            <a href="/case-simulator/" class="cpc-resource-card"><span class="cpc-resource-name">Case Simulator</span><span class="cpc-resource-arrow">&rarr;</span></a>
            <a href="/cs2-cases/" class="cpc-resource-card"><span class="cpc-resource-name">All CS2 Cases</span><span class="cpc-resource-arrow">&rarr;</span></a>
            <a href="/cs2-skins/" class="cpc-resource-card"><span class="cpc-resource-name">CS2 Skins Database</span><span class="cpc-resource-arrow">&rarr;</span></a>
            <a href="/best-cs2-cases-to-open/" class="cpc-resource-card"><span class="cpc-resource-name">Best Cases to Open</span><span class="cpc-resource-arrow">&rarr;</span></a>
            <a href="/free-cs2-skins/" class="cpc-resource-card"><span class="cpc-resource-name">Free CS2 Skins</span><span class="cpc-resource-arrow">&rarr;</span></a>
            <a href="/pro-players/" class="cpc-resource-card"><span class="cpc-resource-name">Pro Player Settings</span><span class="cpc-resource-arrow">&rarr;</span></a>
          </div>
        </section>
      </article>
    </div>
  </div>

  <ExploreMore context="general" />
</Base>

<style>
.cpc-wrap{max-width:1100px;margin:0 auto;padding:0 1.5rem 2rem}
.cpc-breadcrumb{display:flex;align-items:center;gap:.5rem;padding:1.25rem 0;font-size:.85rem;color:var(--text2)}
.cpc-breadcrumb a{color:var(--accent);text-decoration:none}
.cpc-breadcrumb a:hover{text-decoration:underline}
.cpc-sep{color:var(--border)}
.cpc-header{padding:1.5rem 0 1.25rem;border-bottom:2px solid var(--accent);margin-bottom:1.5rem}
.cpc-header h1{margin:0 0 .35rem;font-size:2.2rem;font-weight:800;color:var(--text);letter-spacing:-.02em;line-height:1.2}
.cpc-subtitle{margin:0;font-size:1.05rem;color:var(--text2);font-weight:400}

/* Promo Code Hero Box */
.cpc-promo-box{background:linear-gradient(135deg,rgba(46,204,113,.08),rgba(39,174,96,.04));border:2px solid var(--accent);border-radius:8px;padding:2rem;text-align:center;margin-bottom:2rem;position:relative;overflow:hidden}
.cpc-promo-box::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at top center,rgba(46,204,113,.1) 0%,transparent 60%);pointer-events:none}
.cpc-promo-badge{display:inline-block;font-size:.72rem;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:#fff;background:var(--accent);padding:.3rem .8rem;border-radius:4px;margin-bottom:1.25rem}
.cpc-promo-code-row{display:flex;align-items:center;justify-content:center;gap:.75rem;margin-bottom:1.5rem;flex-wrap:wrap}
.cpc-promo-label{font-size:.9rem;font-weight:600;color:var(--text2)}
.cpc-reveal-wrap{position:relative;display:inline-block}
.cpc-promo-code{font-size:2rem;font-weight:900;color:var(--accent);letter-spacing:.08em;font-family:'Montserrat',sans-serif;background:var(--bg);border:2px dashed var(--accent);padding:.5rem 1.5rem;border-radius:6px;user-select:all;transition:filter .4s,opacity .4s}
.cpc-code-hidden{filter:blur(12px);user-select:none;pointer-events:none}
.cpc-reveal-btn{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;background:linear-gradient(135deg,rgba(46,204,113,.9),rgba(39,174,96,.95));color:#fff;font-size:.95rem;font-weight:800;text-transform:uppercase;letter-spacing:.06em;border:2px dashed rgba(255,255,255,.35);border-radius:6px;cursor:pointer;font-family:inherit;transition:all .2s;z-index:2;box-shadow:0 4px 20px rgba(46,204,113,.4)}
.cpc-reveal-btn:hover{transform:scale(1.03);box-shadow:0 6px 25px rgba(46,204,113,.55)}
.cpc-reveal-btn.cpc-revealed{display:none}
.cpc-copy-btn{background:linear-gradient(135deg,#2ecc71,#27ae60);color:#fff;border:none;padding:.5rem 1.25rem;border-radius:4px;font-size:.82rem;font-weight:700;cursor:pointer;font-family:inherit;transition:all .2s;box-shadow:0 4px 15px rgba(46,204,113,.3)}
.cpc-copy-btn:hover{transform:translateY(-2px);box-shadow:0 6px 20px rgba(46,204,113,.4)}
.cpc-copy-hidden{opacity:0;pointer-events:none;transition:opacity .3s}
.cpc-promo-reward{display:flex;align-items:center;justify-content:center;gap:1.5rem;margin-bottom:1.5rem;flex-wrap:wrap}
.cpc-reward-item{text-align:center}
.cpc-reward-val{display:block;font-size:1.8rem;font-weight:800;color:var(--accent);line-height:1.2}
.cpc-reward-lbl{display:block;font-size:.72rem;color:var(--text2);text-transform:uppercase;letter-spacing:.04em;margin-top:.15rem}
.cpc-reward-divider{width:1px;height:40px;background:var(--border)}
.cpc-claim-btn{display:inline-block;background:linear-gradient(135deg,#2ecc71,#27ae60);color:#fff;font-weight:800;font-size:1rem;text-transform:uppercase;letter-spacing:.04em;padding:.85rem 2.5rem;border-radius:6px;text-decoration:none;transition:all .2s;box-shadow:0 4px 20px rgba(46,204,113,.35)}
.cpc-claim-btn:hover{transform:translateY(-3px);box-shadow:0 8px 30px rgba(46,204,113,.5)}

/* TOC Mobile */
.cpc-toc-mobile{display:none;flex-wrap:wrap;gap:.4rem;margin-bottom:1.5rem}
.cpc-toc-mobile-link{font-size:.78rem;padding:.3rem .65rem;background:var(--bg2);border:1px solid var(--border);border-radius:4px;color:var(--text2);text-decoration:none;transition:border-color .2s}
.cpc-toc-mobile-link:hover{border-color:var(--accent);color:var(--text)}

/* Layout */
.cpc-layout{display:grid;grid-template-columns:220px 1fr;gap:2.5rem;align-items:start}
.cpc-sidebar{position:sticky;top:80px}
.cpc-toc{display:flex;flex-direction:column;gap:0;border-left:2px solid var(--border);padding-left:0}
.cpc-toc-title{font-size:.7rem;font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:var(--accent);padding:0 0 .6rem 1rem}
.cpc-toc-link{display:block;padding:.4rem 1rem;font-size:.82rem;color:var(--text2);text-decoration:none;border-left:2px solid transparent;margin-left:-2px;transition:color .2s,border-color .2s}
.cpc-toc-link:hover{color:var(--text);border-left-color:var(--accent)}

/* Content */
.cpc-content{min-width:0}
.cpc-intro{font-size:1rem;line-height:1.8;color:var(--text2);margin-bottom:2rem}
.cpc-section-header{background:rgba(46,204,113,.05);margin:0 -1.25rem 1.25rem;padding:.75rem 1.25rem;border-radius:4px}
.cpc-section-header h2{margin:0;padding:0;font-size:1.5rem;font-weight:700;color:var(--text);border:none;letter-spacing:-.01em}
section{margin-bottom:2.5rem}
p{line-height:1.7;color:var(--text2);margin-bottom:1rem}
p a{color:var(--accent);text-decoration:none}
p a:hover{text-decoration:underline}
strong{color:var(--text)}

/* Steps */
.cpc-steps{list-style:none;padding:0;margin:.75rem 0 1.5rem;counter-reset:steps}
.cpc-steps li{padding:.6rem 0 .6rem 2.4rem;position:relative;color:var(--text2);line-height:1.65;counter-increment:steps}
.cpc-steps li::before{content:counter(steps);position:absolute;left:0;top:.5rem;width:24px;height:24px;background:var(--accent);color:#000;border-radius:50%;font-size:.75rem;font-weight:800;display:flex;align-items:center;justify-content:center}
.cpc-steps li strong{color:var(--text)}

/* Lists */
.cpc-list{list-style:none;padding:0;margin:.75rem 0 1.5rem}
.cpc-list li{padding:.4rem 0 .4rem 1.6rem;position:relative;color:var(--text2);line-height:1.65}
.cpc-list li::before{content:'';position:absolute;left:.25rem;top:.75rem;width:6px;height:6px;background:var(--accent);border-radius:1px}
.cpc-list li strong{color:var(--text)}

/* FAQ */
.cpc-faq-list{display:flex;flex-direction:column;gap:.5rem}
.cpc-faq-item{background:var(--bg2);border:1px solid var(--border);border-radius:4px;overflow:hidden}
.cpc-faq-question{display:block;padding:1rem 1.25rem;font-size:.95rem;font-weight:600;color:var(--text);cursor:pointer;list-style:none;position:relative;padding-right:2.5rem;transition:background .2s}
.cpc-faq-question::-webkit-details-marker{display:none}
.cpc-faq-question::after{content:'+';position:absolute;right:1.25rem;top:50%;transform:translateY(-50%);font-size:1.2rem;color:var(--accent);font-weight:700}
.cpc-faq-item[open] .cpc-faq-question::after{content:'\2212'}
.cpc-faq-item[open] .cpc-faq-question{background:rgba(46,204,113,.04)}
.cpc-faq-answer{padding:0 1.25rem 1rem;line-height:1.65;color:var(--text2)}

/* Resources */
.cpc-resources-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:.75rem}
.cpc-resource-card{display:flex;align-items:center;justify-content:space-between;padding:.85rem 1rem;background:var(--bg2);border:1px solid var(--border);border-radius:4px;text-decoration:none;transition:border-left .15s}
.cpc-resource-card:hover{border-left:3px solid var(--accent)}
.cpc-resource-name{font-size:.88rem;font-weight:600;color:var(--text)}
.cpc-resource-arrow{color:var(--text2);font-size:1rem}

/* Responsive */
@media(max-width:900px){
  .cpc-layout{grid-template-columns:1fr}
  .cpc-sidebar{display:none}
  .cpc-toc-mobile{display:flex}
  .cpc-resources-grid{grid-template-columns:repeat(2,1fr)}
}
@media(max-width:600px){
  .cpc-header h1{font-size:1.6rem}
  .cpc-promo-code{font-size:1.4rem;padding:.4rem 1rem}
  .cpc-reveal-btn{font-size:.78rem}
  .cpc-promo-box{padding:1.25rem}
  .cpc-reward-val{font-size:1.4rem}
  .cpc-claim-btn{font-size:.88rem;padding:.7rem 1.8rem}
  .cpc-resources-grid{grid-template-columns:1fr}
  .cpc-section-header{margin:0 -.75rem 1rem;padding:.6rem .75rem}
  .cpc-section-header h2{font-size:1.25rem}
}
</style>

<script is:inline>
(function(){
  var revealBtn = document.getElementById('revealBtn');
  var copyBtn = document.getElementById('copyBtn');
  var code = document.getElementById('promoCode');
  if (!revealBtn || !copyBtn || !code) return;

  /* Reveal the code on click */
  revealBtn.addEventListener('click', function() {
    code.classList.remove('cpc-code-hidden');
    revealBtn.classList.add('cpc-revealed');
    copyBtn.classList.remove('cpc-copy-hidden');
    copyBtn.style.opacity = '1';
    copyBtn.style.pointerEvents = 'auto';
  });

  /* Copy to clipboard */
  copyBtn.addEventListener('click', function() {
    var text = code.textContent.trim();
    if (navigator.clipboard && navigator.clipboard.writeText) {
      navigator.clipboard.writeText(text).then(function() {
        copyBtn.textContent = 'Copied!';
        setTimeout(function() { copyBtn.textContent = 'Copy'; }, 2000);
      });
    } else {
      var range = document.createRange();
      range.selectNodeContents(code);
      var sel = window.getSelection();
      sel.removeAllRanges();
      sel.addRange(range);
      try {
        document.execCommand('copy');
        copyBtn.textContent = 'Copied!';
        setTimeout(function() { copyBtn.textContent = 'Copy'; }, 2000);
      } catch(e) {}
      sel.removeAllRanges();
    }
  });
})();
</script>
