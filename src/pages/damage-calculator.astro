---
import Base from '../layouts/Base.astro';
import ExploreMore from '../components/ExploreMore.astro';
import { faqSchema, breadcrumbSchema } from '../lib/weapons';

const title = 'CS2 Damage Calculator';
const description = 'Calculate damage output for CS2 weapons with armor penetration. Adjust distance, armor type, and weapon selection.';

const weaponData = [
  { name: 'AK-47', baseDamage: 41, armor: 0.75 },
  { name: 'M4A4', baseDamage: 33, armor: 0.74 },
  { name: 'M4A1-S', baseDamage: 38, armor: 0.8 },
  { name: 'AWP Dragon Lore', baseDamage: 115, armor: 0.85 },
  { name: 'Deagle', baseDamage: 55, armor: 0.75 },
  { name: 'USP-S', baseDamage: 33, armor: 0.75 },
  { name: 'P250', baseDamage: 35, armor: 0.75 },
  { name: 'Glock-18', baseDamage: 20, armor: 0.65 },
  { name: 'Famas', baseDamage: 30, armor: 0.63 },
  { name: 'Galil AR', baseDamage: 33, armor: 0.75 },
];

const faq = [
  {
    question: 'How does armor affect damage in CS2?',
    answer: 'Armor reduces damage by multiplying the incoming damage by the armor penetration factor of the weapon. Different weapons have different penetration values.'
  },
  {
    question: 'What is armor penetration?',
    answer: 'Armor penetration is a multiplier applied to weapon damage when hitting armored targets. For example, 0.75 means the weapon deals 75% of its base damage to armored enemies.'
  },
  {
    question: 'Does distance affect damage?',
    answer: 'Yes, many weapons in CS2 have damage falloff based on distance. Sniper rifles like the AWP maintain full damage at any distance, while rifles and pistols lose damage over range.'
  }
];

const schemaData = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faq.map(item => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer
    }
  }))
};

const toolSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": title,
  "description": description,
  "applicationCategory": "UtilityApplication",
  "operatingSystem": "Web",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
  "author": { "@type": "Organization", "name": "CSGOLuck Wiki", "url": "https://wiki.csgoluck.com" }
});
---

<Base title={title} description={description}>
  <script type="application/ld+json" set:html={toolSchema}></script>
  <script type="application/ld+json" set:html={JSON.stringify(schemaData)} />

  <nav class="breadcrumb"><a href="/">Home</a> <span>/</span> <a href="/cs2-tools/">Tools</a> <span>/</span> <span>Damage Calculator</span></nav>

  <div class="dc-hero">
    <h1 class="dc-title">CS2 Damage Calculator</h1>
    <p class="dc-desc">Calculate <a href="/cs2-weapons/" style="color:var(--accent)">weapon damage</a> with armor penetration, distance falloff, and <a href="/cs2-guides/advanced-mechanics-guide/" style="color:var(--accent)">headshot multipliers</a>.</p>
  </div>

  <div class="dc-panel">
    <div class="dc-inputs">
      <div class="dc-field">
        <label class="dc-label" for="weapon">Weapon</label>
        <select id="weapon" class="dc-select">
          {weaponData.map(w => <option value={w.name}>{w.name}</option>)}
        </select>
      </div>

      <div class="dc-field">
        <label class="dc-label" for="distance">Distance (units): <span id="distanceValue" class="dc-range-val">50</span></label>
        <input type="range" id="distance" min="0" max="100" value="50" class="dc-slider">
      </div>

      <div class="dc-field">
        <label class="dc-label">Target Armor</label>
        <div class="dc-armor-group">
          <button class="dc-armor-btn dc-armor-active" data-armor="none">No Armor</button>
          <button class="dc-armor-btn" data-armor="kevlar">Kevlar</button>
          <button class="dc-armor-btn" data-armor="helmet">Kevlar + Helmet</button>
        </div>
      </div>
    </div>

    <div class="dc-results">
      <div class="dc-result-row">
        <div class="dc-result-item">
          <span class="dc-result-label">Base Damage</span>
          <span class="dc-result-value" id="baseDamage">41</span>
        </div>
        <div class="dc-result-item">
          <span class="dc-result-label">Armor Reduction</span>
          <span class="dc-result-value" id="armorReduction">0%</span>
        </div>
      </div>
      <div class="dc-result-row">
        <div class="dc-result-item dc-result-highlight">
          <span class="dc-result-label">Final Damage</span>
          <span class="dc-result-value" id="finalDamage">41</span>
        </div>
        <div class="dc-result-item">
          <span class="dc-result-label">Headshot Damage</span>
          <span class="dc-result-value" id="headshotDamage">123</span>
        </div>
      </div>
    </div>
  </div>

  <div class="dc-two-col">
    <div class="dc-info-block">
      <h2 class="dc-section-title">How It Works</h2>
      <ul class="dc-info-list">
        <li><strong>Base Damage:</strong> The standard damage value for the selected weapon</li>
        <li><strong>Armor Reduction:</strong> Percentage of damage mitigated by armor</li>
        <li><strong>Distance Falloff:</strong> Some weapons lose damage over distance</li>
        <li><strong>Headshot Multiplier:</strong> Headshots deal 3x damage (2.3x with helmet)</li>
      </ul>
    </div>

    <div class="dc-info-block">
      <h2 class="dc-section-title">Related Tools</h2>
      <div class="dc-link-list">
        <a href="/economy-calculator/" class="dc-link">Economy Calculator</a>
        <a href="/weapon-compare/" class="dc-link">Weapon Compare</a>
        <a href="/recoil-patterns/" class="dc-link">Recoil Patterns</a>
        <a href="/spray-trainer/" class="dc-link">Spray Trainer</a>
        <a href="/sensitivity-converter/" class="dc-link">Sensitivity Converter</a>
        <a href="/cs2-weapons/" class="dc-link">Weapon Database</a>
        <a href="/pro-players/" class="dc-link">Pro Player Settings</a>
        <a href="/cs2-tools/" class="dc-link">All Tools</a>
        <a href="/cs2-guides/advanced-mechanics-guide/" class="dc-link">Advanced Mechanics Guide</a>
        <a href="/cs2-maps/" class="dc-link">Map Database</a>
        <a href="/cs2-guides/beginners-guide/" class="dc-link">Beginner's Guide</a>
        <a href="/loadout-builder/" class="dc-link">Loadout Builder</a>
        <a href="/cs2-guides/economy-guide/" class="dc-link">Economy Guide</a>
      </div>
    </div>
  </div>

  <section class="dc-faq">
    <h2 class="dc-section-title">Frequently Asked Questions</h2>
    {faq.map(item => (
      <details class="dc-faq-item">
        <summary class="dc-faq-q">{item.question}</summary>
        <p class="dc-faq-a">{item.answer}</p>
      </details>
    ))}
  </section>

  <ExploreMore context="tools" />
</Base>

<style>
  .dc-hero{padding:1.5rem 0;margin-bottom:1.5rem}
  .dc-title{font-size:2rem;font-weight:800;margin:0 0 .5rem;color:var(--text)}
  .dc-desc{color:var(--text2);font-size:.95rem;margin:0;max-width:600px;line-height:1.6}

  .dc-panel{background:var(--bg2);border:1px solid var(--border);border-radius:4px;padding:1.5rem;margin-bottom:2rem}
  .dc-inputs{display:flex;flex-direction:column;gap:1.25rem;margin-bottom:1.5rem}
  .dc-field{display:flex;flex-direction:column;gap:.4rem}
  .dc-label{font-weight:600;color:var(--text2);font-size:.85rem;text-transform:uppercase;letter-spacing:.04em}
  .dc-range-val{color:var(--accent);font-weight:700}

  .dc-select,.dc-slider{padding:.6rem;background:var(--bg3);border:1px solid var(--border);border-radius:4px;color:var(--text);font-size:.95rem;font-family:inherit}
  .dc-select:focus,.dc-slider:focus{outline:none;border-color:var(--accent)}

  .dc-armor-group{display:flex;gap:.4rem;flex-wrap:wrap}
  .dc-armor-btn{padding:.55rem 1rem;background:var(--bg3);border:1px solid var(--border);border-radius:4px;color:var(--text2);cursor:pointer;font-weight:500;font-size:.85rem;font-family:inherit;transition:all .15s}
  .dc-armor-btn:hover{border-color:var(--accent);color:var(--text)}
  .dc-armor-active{background:var(--accent);border-color:var(--accent);color:#000}

  .dc-results{display:flex;flex-direction:column;gap:.75rem}
  .dc-result-row{display:grid;grid-template-columns:1fr 1fr;gap:.75rem}
  .dc-result-item{background:var(--bg);border:1px solid var(--border);border-radius:4px;padding:1.25rem;text-align:center}
  .dc-result-highlight{border-left:3px solid var(--accent);background:rgba(46,204,113,.06)}
  .dc-result-label{display:block;font-size:.78rem;font-weight:600;color:var(--text2);text-transform:uppercase;letter-spacing:.04em;margin-bottom:.5rem}
  .dc-result-value{display:block;font-size:2rem;font-weight:800;color:var(--accent)}

  .dc-two-col{display:grid;grid-template-columns:1fr 1fr;gap:1.5rem;margin-bottom:2rem}
  .dc-info-block{background:var(--bg2);border:1px solid var(--border);border-radius:4px;padding:1.5rem}
  .dc-section-title{font-size:1.1rem;font-weight:700;color:var(--text);margin:0 0 1rem}
  .dc-info-list{list-style:none;padding:0;margin:0}
  .dc-info-list li{padding:.6rem 0;border-bottom:1px solid var(--border);color:var(--text2);font-size:.88rem;line-height:1.5}
  .dc-info-list li:last-child{border-bottom:none}
  .dc-info-list strong{color:var(--text)}

  .dc-link-list{display:flex;flex-direction:column;gap:.4rem}
  .dc-link{display:block;padding:.5rem .75rem;background:var(--bg3);border:1px solid var(--border);border-left:3px solid transparent;border-radius:4px;color:var(--accent);text-decoration:none;font-size:.85rem;transition:border-left-color .15s}
  .dc-link:hover{border-left-color:var(--accent)}

  .dc-faq{margin-bottom:2rem}
  .dc-faq-item{background:var(--bg2);border:1px solid var(--border);border-radius:4px;margin-bottom:.5rem;overflow:hidden}
  .dc-faq-q{padding:.8rem 1rem;cursor:pointer;font-weight:600;font-size:.9rem;color:var(--text);list-style:none;display:flex;align-items:center;justify-content:space-between}
  .dc-faq-q::-webkit-details-marker{display:none}
  .dc-faq-q::after{content:'+';font-size:1.1rem;color:var(--accent);font-weight:700}
  .dc-faq-item[open] .dc-faq-q::after{content:'-'}
  .dc-faq-item[open]{border-left:3px solid var(--accent)}
  .dc-faq-a{padding:0 1rem .8rem;margin:0;font-size:.88rem;color:var(--text2);line-height:1.6}

  @media(max-width:768px){
    .dc-two-col{grid-template-columns:1fr}
    .dc-result-row{grid-template-columns:1fr}
  }
</style>

<script>
  const weaponData = [
    { name: 'AK-47', baseDamage: 41, armor: 0.75, headMultiplier: 2.02 },
    { name: 'M4A4', baseDamage: 33, armor: 0.74, headMultiplier: 2.08 },
    { name: 'M4A1-S', baseDamage: 38, armor: 0.8, headMultiplier: 2.05 },
    { name: 'AWP Dragon Lore', baseDamage: 115, armor: 0.85, headMultiplier: 1.0 },
    { name: 'Deagle', baseDamage: 55, armor: 0.75, headMultiplier: 2.1 },
    { name: 'USP-S', baseDamage: 33, armor: 0.75, headMultiplier: 2.06 },
    { name: 'P250', baseDamage: 35, armor: 0.75, headMultiplier: 2.07 },
    { name: 'Glock-18', baseDamage: 20, armor: 0.65, headMultiplier: 2.13 },
    { name: 'Famas', baseDamage: 30, armor: 0.63, headMultiplier: 2.09 },
    { name: 'Galil AR', baseDamage: 33, armor: 0.75, headMultiplier: 2.09 },
  ];

  const weaponSelect = document.getElementById('weapon');
  const distanceSlider = document.getElementById('distance');
  const distanceValue = document.getElementById('distanceValue');
  const armorButtons = document.querySelectorAll('.dc-armor-btn');
  const baseDamageEl = document.getElementById('baseDamage');
  const armorReductionEl = document.getElementById('armorReduction');
  const finalDamageEl = document.getElementById('finalDamage');
  const headshotDamageEl = document.getElementById('headshotDamage');

  let selectedArmor = 'none';

  function getArmorReduction(armor, armorType) {
    if (armorType === 'none') return 1;
    if (armorType === 'kevlar') return armor;
    if (armorType === 'helmet') return armor * 0.5;
    return 1;
  }

  function calculateDamage() {
    const weapon = weaponData.find(w => w.name === weaponSelect.value);
    const distance = parseInt(distanceSlider.value);
    const armorMultiplier = getArmorReduction(weapon.armor, selectedArmor);
    const distanceFalloff = Math.max(0.5, 1 - distance / 500);

    const base = Math.round(weapon.baseDamage * distanceFalloff);
    const armored = Math.round(base * armorMultiplier);
    const reduction = Math.round((1 - armorMultiplier) * 100);
    const headshot = Math.round(armored * weapon.headMultiplier);

    baseDamageEl.textContent = base;
    armorReductionEl.textContent = reduction + '%';
    finalDamageEl.textContent = armored;
    headshotDamageEl.textContent = headshot;
  }

  distanceSlider.addEventListener('input', (e) => {
    distanceValue.textContent = e.target.value;
    calculateDamage();
  });

  weaponSelect.addEventListener('change', calculateDamage);

  armorButtons.forEach(btn => {
    btn.addEventListener('click', (e) => {
      armorButtons.forEach(b => b.classList.remove('dc-armor-active'));
      e.target.classList.add('dc-armor-active');
      selectedArmor = e.target.dataset.armor;
      calculateDamage();
    });
  });

  calculateDamage();
</script>
