/* ── Breadcrumb (site standard) ───────────────────────────────────────────── */
.breadcrumb{font-size:.85rem;color:var(--text2);margin-bottom:1.5rem;display:flex;gap:.4rem;flex-wrap:wrap}
.breadcrumb a{color:var(--accent);text-decoration:none}
