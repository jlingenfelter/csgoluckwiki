.gr-role-pct{font-size:.78rem;color:var(--text2);font-weight:600}

/* ── Related Gear ─────────────────────────────────────────────────────────── */
.gr-related-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:1rem}
.gr-related-card{background:var(--bg2);border:1px solid var(--border);border-radius:8px;padding:1rem;text-decoration:none;transition:border-color .2s,transform .2s}
