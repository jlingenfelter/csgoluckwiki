.gr-specs-list{margin:0;padding:0}
.gr-specs-list dt{font-size:.78rem;color:var(--text2);text-transform:uppercase;letter-spacing:.03em;font-weight:600;margin-top:.65rem;padding-top:.65rem;border-top:1px solid var(--border)}
.gr-specs-list dt:first-child{margin-top:0;padding-top:0;border-top:none}
.gr-specs-list dd{font-size:.9rem;color:var(--text);font-weight:600;margin:.15rem 0 0;padding:0}
.gr-specs-btn{display:block;width:100%;text-align:center;margin-top:1.25rem;padding:.6rem 1rem;font-size:.88rem;box-sizing:border-box}

/* ── Responsive ───────────────────────────────────────────────────────────── */
@media(max-width:768px){
  .gr-hero-top{flex-direction:column;align-items:flex-start}
  .gr-hero-info h1{font-size:1.5rem}
  .gr-hero-stats{grid-template-columns:repeat(2,1fr)}
  .gr-analysis-grid{grid-template-columns:1fr}
  .gr-player-grid{grid-template-columns:1fr}
  .pp-stats{grid-template-columns:repeat(2,1fr)}
  .pp-gear{grid-template-columns:1fr}
  .gr-related-grid{grid-template-columns:1fr 1fr}
  .gr-role-grid{grid-template-columns:1fr 1fr}
  .gr-teams-grid{grid-template-columns:repeat(2,1fr)}
}
@media(max-width:480px){
  .gr-related-grid{grid-template-columns:1fr}
  .gr-teams-grid{grid-template-columns:1fr}
  .gr-role-grid{grid-template-columns:1fr}
  .gr-hero-stats{grid-template-columns:1fr}
}
</style>

<script is:inline>
(function(){
  // ── Copy buttons (crosshair codes on cards) ──
  document.querySelectorAll('.pp-copy').forEach(function(btn){
    btn.addEventListener('click', function(){
      navigator.clipboard.writeText(btn.dataset.code).then(function(){
        btn.textContent = 'Copied!';
        btn.classList.add('copied');
        setTimeout(function(){ btn.textContent = 'Copy'; btn.classList.remove('copied'); }, 1500);
      });
    });
  });

  // ── Copy buttons (table crosshair codes) ──
  document.querySelectorAll('.gr-copy-sm').forEach(function(btn){
    btn.addEventListener('click', function(){
      navigator.clipboard.writeText(btn.dataset.code).then(function(){
        btn.textContent = 'Copied!';
        btn.classList.add('copied');
        setTimeout(function(){ btn.textContent = 'Copy'; btn.classList.remove('copied'); }, 1500);
      });
    });
  });

  // ── Load More pagination ──
  var loadMoreBtn = document.getElementById('loadMoreBtn');
  var loadMoreWrap = document.getElementById('loadMoreWrap');
  var loadMoreCount = document.getElementById('loadMoreCount');
  var BATCH = 24;

  function updateLoadMore() {
    if (!loadMoreWrap) return;
    var paginated = document.querySelectorAll('#grPlayerGrid .pp-card.pp-paginated:not(.pp-revealed)');
    if (paginated.length === 0) {
      loadMoreWrap.style.display = 'none';
    } else {
      loadMoreWrap.style.display = 'block';
      if (loadMoreCount) loadMoreCount.textContent = '(' + paginated.length + ' remaining)';
    }
  }

  if (loadMoreBtn) {
    loadMoreBtn.addEventListener('click', function(){
      var hidden = document.querySelectorAll('#grPlayerGrid .pp-card.pp-paginated:not(.pp-revealed)');
      var count = 0;
      hidden.forEach(function(c){
        if (count < BATCH) {
          c.classList.add('pp-revealed');
          c.style.display = '';
          count++;
        }
      });
      updateLoadMore();
    });
  }

  updateLoadMore();

  // ── Teams toggle ──
  var teamsToggle = document.getElementById('grTeamsToggle');
  if (teamsToggle) {
    teamsToggle.addEventListener('click', function(){
      document.querySelectorAll('.gr-team-hidden').forEach(function(c){
        c.classList.add('gr-team-shown');
      });
      teamsToggle.style.display = 'none';
    });
  }
})();
</script>
