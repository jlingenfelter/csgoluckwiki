.gr-xcode{font-size:.72rem;color:var(--text2);max-width:120px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;display:inline-block;vertical-align:middle}
.gr-copy-sm{background:var(--accent);color:#000;border:none;padding:.2rem .45rem;border-radius:3px;font-size:.68rem;font-weight:700;cursor:pointer;font-family:inherit;white-space:nowrap}
