/* ── Role Breakdown ───────────────────────────────────────────────────────── */
.gr-role-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:1rem}
.gr-role-item{background:var(--bg2);border:1px solid var(--border);border-radius:8px;padding:1rem;display:flex;flex-direction:column;gap:.5rem}
