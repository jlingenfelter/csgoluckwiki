---
import Base from '../../layouts/Base.astro';
import ExploreMore from '../../components/ExploreMore.astro';
import { getAllGear, getAverageEdpi, amazonSearchUrl, getGearImageUrl, type GearItem, type GearType } from '../../lib/pro-players';
import { getGearDescription } from '../../data/gear-descriptions';
import { breadcrumbSchema, faqSchema } from '../../lib/weapons';

const allGear = getAllGear();

export function getStaticPaths() {
  return getAllGear().map(g => ({
    params: { slug: g.slug },
    props: { gear: g },
  }));
}

const { gear } = Astro.props as { gear: GearItem };
const avgEdpi = getAverageEdpi();

// Type icon map
const typeIcons: Record<GearType, string> = {
  mouse: '\u{1F5B1}\uFE0F',
  keyboard: '\u2328\uFE0F',
  headset: '\u{1F3A7}',
  monitor: '\u{1F5A5}\uFE0F',
  mousepad: '\u{1F3AF}',
};
const typeLabels: Record<GearType, string> = {
  mouse: 'Mouse',
  keyboard: 'Keyboard',
  headset: 'Headset',
  monitor: 'Monitor',
  mousepad: 'Mousepad',
};

const icon = typeIcons[gear.type];
const label = typeLabels[gear.type];
const players = gear.players;
const gearImage = getGearImageUrl(gear.name);
const gearDesc = getGearDescription(gear.name, gear.type);

// ── Computed averages ────────────────────────────────────────────────────────
const avgDpi = players.length > 0 ? Math.round(players.reduce((s, p) => s + p.dpi, 0) / players.length) : 0;
const avgSens = players.length > 0 ? +(players.reduce((s, p) => s + p.sens, 0) / players.length).toFixed(2) : 0;
const avgPlayerEdpi = players.length > 0 ? Math.round(players.reduce((s, p) => s + p.edpi, 0) / players.length) : 0;
const avgRefreshRate = players.length > 0 ? Math.round(players.reduce((s, p) => s + p.refreshRate, 0) / players.length) : 0;

// ── Teams using this gear ────────────────────────────────────────────────────
const NON_TEAMS = ['free agent', 'retired', 'inactive', 'no team', 'none', 'benched', 'n/a', ''];
const teamData: Record<string, { count: number; slug: string }> = {};
players.forEach(p => {
  if (NON_TEAMS.includes(p.team.toLowerCase().trim())) return;
  if (!teamData[p.team]) {
    teamData[p.team] = {
      count: 0,
      slug: p.team.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, ''),
    };
  }
  teamData[p.team].count++;
});
const topTeams = Object.entries(teamData).sort((a, b) => b[1].count - a[1].count);
const maxTeamCount = topTeams[0]?.[1].count ?? 1;

// ── Related gear — same type, sorted by popularity, exclude current ─────────
const relatedGear = allGear
  .filter(g => g.type === gear.type && g.slug !== gear.slug)
  .slice(0, 8);

// ── Role breakdown ───────────────────────────────────────────────────────────
const roleCounts: Record<string, number> = {};
players.forEach(p => { roleCounts[p.role] = (roleCounts[p.role] || 0) + 1; });
const roleBreakdown = Object.entries(roleCounts).sort((a, b) => b[1] - a[1]);

// ── SEO ──────────────────────────────────────────────────────────────────────
const title = `${gear.name} CS2 Settings \u2014 ${gear.players.length} Pro Players | CSDB.gg`;
const description = `${gear.players.length} CS2 pro players use the ${gear.name}. See their sensitivity, crosshair, resolution, and full settings. Compare configs and find optimal settings for this ${gear.type}.`;

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Pro Players', url: '/pro-players/' },
  { name: 'Gear', url: '/gear/' },
  { name: gear.name, url: `/gear/${gear.slug}/` },
];

// ── FAQ ──────────────────────────────────────────────────────────────────────
const sensDesc = avgPlayerEdpi < 600 ? 'low' : avgPlayerEdpi < 900 ? 'medium' : 'high';
const faqs = [
  {
    question: `How many CS2 pros use the ${gear.name}?`,
    answer: `${gear.players.length} professional CS2 players in our database currently use the ${gear.name}. This makes it ${gear.players.length >= 10 ? 'one of the more popular' : 'a notable'} ${label.toLowerCase()} choices among the competitive scene.`,
  },
  {
    question: `What settings do ${gear.name} users prefer?`,
    answer: gear.type === 'mouse'
      ? `Players using the ${gear.name} average ${avgDpi} DPI, ${avgSens} in-game sensitivity, and ${avgPlayerEdpi} eDPI. This puts them in the ${sensDesc} sensitivity range${avgPlayerEdpi < avgEdpi ? ', slightly below' : avgPlayerEdpi > avgEdpi ? ', slightly above' : ', right at'} the overall pro average of ${avgEdpi} eDPI.`
      : gear.type === 'monitor'
      ? `Pro players using the ${gear.name} average ${avgRefreshRate}Hz refresh rate with an average eDPI of ${avgPlayerEdpi}. The high refresh rate provides smoother visuals and reduced input lag for competitive play.`
      : `Pro players using the ${gear.name} average ${avgPlayerEdpi} eDPI (${sensDesc} sensitivity). Their settings vary by role and playstyle \u2014 check the comparison table below for full details.`,
  },
  {
    question: `Is the ${gear.name} good for competitive CS2?`,
    answer: `With ${gear.players.length} professional player${gear.players.length !== 1 ? 's' : ''} using it, the ${gear.name} is a proven choice at the highest level of CS2.${topTeams.length > 0 ? ` Teams like ${topTeams.slice(0, 3).map(t => t[0]).join(', ')} have players using this ${label.toLowerCase()}.` : ''} However, personal comfort and preference are the most important factors when choosing gear.`,
  },
];
---

<Base {title} {description} currentNav="/pro-players/">
<Fragment slot="head">
<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema(breadcrumbs))} />
<script type="application/ld+json" set:html={JSON.stringify(faqSchema(faqs))} />
</Fragment>

<nav class="breadcrumb"><a href="/">Home</a> <span>/</span> <a href="/pro-players/">Pro Players</a> <span>/</span> <span>Gear</span> <span>/</span> <span>{gear.name}</span></nav>

<!-- Hero -->
<section class="gr-hero">
  <div class="gr-hero-top">
    <div class="gr-hero-info">
      {gearImage ? (
        <img class="gr-product-img" src={gearImage} alt={gear.name} width="96" height="96" loading="eager" onerror="this.style.display='none'" />
      ) : (
        <span class="gr-type-icon">{icon}</span>
      )}
      <div>
        <span class="gr-type-label">{label}</span>
        <h1>{gear.name}</h1>
        <p class="gr-player-count">{players.length} pro player{players.length !== 1 ? 's' : ''} use this {label.toLowerCase()}</p>
      </div>
    </div>
    <a href={amazonSearchUrl(gear.name)} target="_blank" rel="nofollow noopener" class="amazon-btn">Check Price on Amazon</a>
  </div>
  <div class="gr-hero-stats">
    {gear.type === 'mouse' && (
      <>
        <div class="gr-hs"><span class="gr-hv">{avgDpi}</span><span class="gr-hl">Avg DPI</span></div>
        <div class="gr-hs"><span class="gr-hv">{avgSens}</span><span class="gr-hl">Avg Sens</span></div>
        <div class="gr-hs"><span class="gr-hv">{avgPlayerEdpi}</span><span class="gr-hl">Avg eDPI</span></div>
      </>
    )}
    {gear.type === 'monitor' && (
      <>
        <div class="gr-hs"><span class="gr-hv">{avgRefreshRate}Hz</span><span class="gr-hl">Avg Refresh Rate</span></div>
        <div class="gr-hs"><span class="gr-hv">{avgPlayerEdpi}</span><span class="gr-hl">Avg eDPI</span></div>
      </>
    )}
    {gear.type !== 'mouse' && gear.type !== 'monitor' && (
      <div class="gr-hs"><span class="gr-hv">{avgPlayerEdpi}</span><span class="gr-hl">Avg eDPI</span></div>
    )}
    <div class="gr-hs"><span class="gr-hv">{players.length}</span><span class="gr-hl">Pro Players</span></div>
    {topTeams.length > 0 && (
      <div class="gr-hs"><span class="gr-hv">{topTeams.length}</span><span class="gr-hl">Teams</span></div>
    )}
  </div>
</section>

<!-- Product Analysis -->
{gearDesc.overview && (
<section class="gr-section gr-analysis">
  <h2>About the {gear.name}</h2>
  <div class="gr-analysis-grid">
    <div class="gr-analysis-main">
      <p class="gr-analysis-overview">{gearDesc.overview}</p>
      <div class="gr-review">
        <h3>Why Pros Use It in CS2</h3>
        <p>{gearDesc.prosForCS2}</p>
      </div>
    </div>
    {gearDesc.specs && gearDesc.specs.length > 0 && (
      <div class="gr-specs-card">
        <h3>Key Specifications</h3>
        <dl class="gr-specs-list">
          {gearDesc.specs.map(s => (
            <>
              <dt>{s.label}</dt>
              <dd>{s.value}</dd>
            </>
          ))}
        </dl>
        <a href={amazonSearchUrl(gear.name)} target="_blank" rel="nofollow noopener" class="amazon-btn gr-specs-btn">Check Price on Amazon</a>
      </div>
    )}
  </div>
</section>
)}

<!-- Teams Using This Gear -->
{topTeams.length > 0 && (
<section class="gr-section">
  <h2>Teams Using the {gear.name}</h2>
  <p class="gr-section-desc">{topTeams.length} team{topTeams.length !== 1 ? 's' : ''} have players using this {label.toLowerCase()}.</p>
  <div class="gr-teams-grid" id="grTeamsGrid">
    {topTeams.map(([team, data], i) => (
      <a href={`/team/${data.slug}/`} class={`gr-team-card${i >= 12 ? ' gr-team-hidden' : ''}`}>
        <div class="gr-team-top">
          <span class="gr-team-name">{team}</span>
          <span class="gr-team-badge">{data.count}</span>
        </div>
        <div class="gr-team-bar">
          <div class="gr-team-bar-fill" style={`width:${Math.round((data.count / maxTeamCount) * 100)}%`}></div>
        </div>
        <span class="gr-team-count">{data.count} player{data.count !== 1 ? 's' : ''}</span>
      </a>
    ))}
  </div>
  {topTeams.length > 12 && (
    <button class="gr-teams-toggle" id="grTeamsToggle">Show all {topTeams.length} teams</button>
  )}
</section>
)}

<!-- Player Cards Grid -->
<section class="gr-section">
  <h2>All Players Using the {gear.name}</h2>
  <div class="gr-player-grid" id="grPlayerGrid">
    {players.map((p, i) => (
      <a href={`/player/${p.slug}/`} class={`pp-card${i >= 24 ? ' pp-paginated' : ''}`} data-role={p.role} data-name={p.name.toLowerCase()} data-team={p.team.toLowerCase()} data-idx={i}>
        <div class="pp-card-top">
          {p.image && <img class="pp-avatar" src={p.image} alt={p.name} width="56" height="56" loading="lazy" onerror="this.style.display='none'" />}
          <div class="pp-card-info">
            <h3 class="pp-name">{p.flag} {p.name}</h3>
            <div class="pp-team-role">
              <span class="pp-team">{p.team}</span>
              <span class="pp-role" data-r={p.role.toLowerCase().replace(/\s/g,'-')}>{p.role}</span>
            </div>
            {p.realName && <div class="pp-realname">{p.realName}</div>}
          </div>
        </div>

        <div class="pp-stats">
          <div class="pp-s"><span class="pp-sv">{p.dpi}</span><span class="pp-sl">DPI</span></div>
          <div class="pp-s"><span class="pp-sv">{p.sens}</span><span class="pp-sl">Sens</span></div>
          <div class="pp-s pp-edpi"><span class="pp-sv">{p.edpi}</span><span class="pp-sl">eDPI</span></div>
          <div class="pp-s"><span class="pp-sv">{p.res}</span><span class="pp-sl">{p.aspect} {p.stretch}</span></div>
        </div>

        {p.crosshairCode && (
          <div class="pp-xhair" onclick="event.preventDefault();">
            <code>{p.crosshairCode}</code>
            <button class="pp-copy" data-code={p.crosshairCode}>Copy</button>
          </div>
        )}

        <div class="pp-gear">
          <div class="pp-gi"><span class="pp-gk">Mouse</span><span class="pp-gv">{p.mouse}</span></div>
          <div class="pp-gi"><span class="pp-gk">Monitor</span><span class="pp-gv">{p.monitor}</span></div>
          <div class="pp-gi"><span class="pp-gk">Keyboard</span><span class="pp-gv">{p.keyboard}</span></div>
          <div class="pp-gi"><span class="pp-gk">Headset</span><span class="pp-gv">{p.headset}</span></div>
          <div class="pp-gi"><span class="pp-gk">Mousepad</span><span class="pp-gv">{p.mousepad}</span></div>
        </div>

        <div class="pp-edpi-bar">
          <div class="pp-ebar-fill" style={`width:${Math.min(100, Math.round(((p.edpi - 400) / (1700 - 400)) * 100))}%`}></div>
          <span class="pp-ebar-label">{p.edpi} eDPI \u2014 {p.edpi < 600 ? 'Low' : p.edpi < 900 ? 'Medium' : 'High'} sens</span>
        </div>

        <div class="pp-view-more">View Full Profile \u2192</div>
      </a>
    ))}
  </div>
  {players.length > 24 && (
    <div class="pp-loadmore-wrap" id="loadMoreWrap">
      <button class="pp-loadmore-btn" id="loadMoreBtn">Load More Players <span id="loadMoreCount"></span></button>
    </div>
  )}
</section>

<!-- Settings Comparison Table -->
<section class="gr-section">
  <h2>Settings Comparison Table</h2>
  <div class="gr-table-wrap">
    <table class="gr-table">
      <thead>
        <tr>
          <th>Player</th><th>Team</th><th>Role</th><th>DPI</th><th>Sens</th><th>eDPI</th><th>Resolution</th><th>Aspect</th><th>Display</th><th>Refresh</th><th>Crosshair Code</th>
        </tr>
      </thead>
      <tbody>
        {players.map(p => (
          <tr>
            <td><a href={`/player/${p.slug}/`} class="gr-tlink"><strong>{p.flag} {p.name}</strong></a></td>
            <td>{p.team}</td>
            <td><span class="pp-role pp-role-sm" data-r={p.role.toLowerCase().replace(/\s/g,'-')}>{p.role}</span></td>
            <td>{p.dpi}</td>
            <td>{p.sens}</td>
            <td><strong>{p.edpi}</strong></td>
            <td>{p.res}</td>
            <td>{p.aspect}</td>
            <td>{p.stretch}</td>
            <td>{p.refreshRate}Hz</td>
            <td>
              {p.crosshairCode ? (
                <span class="gr-xcode-wrap">
                  <code class="gr-xcode">{p.crosshairCode}</code>
                  <button class="gr-copy-sm" data-code={p.crosshairCode}>Copy</button>
                </span>
              ) : (
                <span class="gr-na">N/A</span>
              )}
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</section>

<!-- Role Breakdown -->
{roleBreakdown.length > 1 && (
<section class="gr-section">
  <h2>Role Breakdown</h2>
  <p class="gr-section-desc">Distribution of player roles among {gear.name} users.</p>
  <div class="gr-role-grid">
    {roleBreakdown.map(([role, count]) => (
      <div class="gr-role-item">
        <span class="pp-role" data-r={role.toLowerCase().replace(/\s/g,'-')}>{role}</span>
        <span class="gr-role-count">{count} player{count !== 1 ? 's' : ''}</span>
        <div class="gr-role-bar">
          <div class="gr-role-fill" style={`width:${Math.round((count / players.length) * 100)}%`}></div>
        </div>
        <span class="gr-role-pct">{Math.round((count / players.length) * 100)}%</span>
      </div>
    ))}
  </div>
</section>
)}

<!-- Related Gear -->
{relatedGear.length > 0 && (
<section class="gr-section">
  <h2>Other Popular {label === 'Mousepad' ? 'Mousepads' : label + 's'}</h2>
  <div class="gr-related-grid">
    {relatedGear.map(g => (
      <a href={`/gear/${g.slug}/`} class="gr-related-card">
        <div class="gr-rc-top">
          <span class="gr-rc-icon">{typeIcons[g.type]}</span>
          <div>
            <div class="gr-rc-name">{g.name}</div>
            <div class="gr-rc-count">{g.players.length} player{g.players.length !== 1 ? 's' : ''}</div>
          </div>
        </div>
      </a>
    ))}
  </div>
</section>
)}

<!-- FAQ -->
<section class="gr-section">
  <h2>Frequently Asked Questions</h2>
  <dl class="faq">
    {faqs.map(f => (
      <>
        <dt>{f.question}</dt>
        <dd>{f.answer}</dd>
      </>
    ))}
  </dl>
</section>

<!-- Internal Links -->
<div class="internal-links">
  <strong>Related:</strong>
  <a href="/pro-players/">All Pro Settings</a>
  <a href="/crosshair-codes/">Crosshair Codes</a>
  <a href="/crosshair-generator/">Crosshair Generator</a>
  <a href="/sensitivity-converter/">Sensitivity Converter</a>
  <a href="/edpi-calculator/">eDPI Calculator</a>
  <a href="/cm360-calculator/">cm/360 Calculator</a>
  <a href="/resolution-calculator/">Resolution Calculator</a>
  <a href="/weapons/">Weapon Database</a>
  <a href="/tools/">All Tools</a>
</div>

<ExploreMore context="general" />

</Base>

<style>
/* ── Hero ──────────────────────────────────────────────────────────────────── */
.gr-hero{background:linear-gradient(135deg,var(--bg2),var(--bg3));border:1px solid var(--border);border-radius:12px;padding:2rem;margin-bottom:2rem}
.gr-hero-top{display:flex;gap:1.5rem;align-items:center;justify-content:space-between;flex-wrap:wrap;margin-bottom:1.5rem}
.gr-hero-info{display:flex;gap:1.25rem;align-items:center}
.gr-type-icon{font-size:3rem;line-height:1}
.gr-product-img{width:96px;height:96px;object-fit:contain;border-radius:8px;background:var(--bg1);flex-shrink:0}
.gr-type-label{font-size:.75rem;text-transform:uppercase;font-weight:700;color:var(--accent);letter-spacing:.05em}
.gr-hero-info h1{font-size:2rem;margin:0;line-height:1.2}
.gr-player-count{color:var(--text2);font-size:1rem;margin:.25rem 0 0}
.gr-hero-stats{display:grid;grid-template-columns:repeat(auto-fit,minmax(120px,1fr));gap:.75rem}
.gr-hs{background:var(--bg);border:1px solid var(--border);border-radius:8px;padding:.75rem 1rem;text-align:center}
.gr-hv{display:block;font-size:1.3rem;font-weight:800;color:var(--accent)}
.gr-hl{display:block;font-size:.7rem;color:var(--text2);margin-top:.15rem;text-transform:uppercase}

/* ── Amazon Button ────────────────────────────────────────────────────────── */
.amazon-btn{display:inline-flex;align-items:center;gap:.5rem;background:#ff9900;color:#000;text-decoration:none;padding:.65rem 1.5rem;border-radius:8px;font-weight:700;font-size:.95rem;white-space:nowrap;transition:opacity .2s,transform .2s}
.amazon-btn:hover{opacity:.9;transform:translateY(-1px)}

/* ── Sections ─────────────────────────────────────────────────────────────── */
.gr-section{margin-bottom:2.5rem}
.gr-section h2{font-size:1.3rem;margin:0 0 1rem;color:var(--text);font-weight:700}
.gr-section-desc{color:var(--text2);font-size:.9rem;margin:0 0 1rem}

/* ── Teams Grid ───────────────────────────────────────────────────────────── */
.gr-teams-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:.75rem}
.gr-team-card{display:block;text-decoration:none;background:var(--bg2);border:1px solid var(--border);border-radius:8px;padding:.85rem 1rem;transition:border-color .2s,transform .2s}
.gr-team-card:hover{border-color:var(--accent);transform:translateY(-1px)}
.gr-team-hidden{display:none}
.gr-team-card.gr-team-shown{display:block}
.gr-team-top{display:flex;align-items:center;justify-content:space-between;gap:.5rem;margin-bottom:.5rem}
.gr-team-name{font-weight:700;color:var(--text);font-size:.9rem;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.gr-team-badge{background:var(--accent);color:#000;font-size:.72rem;font-weight:700;padding:.15rem .45rem;border-radius:4px;flex-shrink:0}
.gr-team-bar{height:4px;background:var(--bg3);border-radius:2px;overflow:hidden;margin-bottom:.35rem}
.gr-team-bar-fill{height:100%;background:var(--accent);border-radius:2px;opacity:.6}
.gr-team-count{color:var(--text2);font-size:.75rem}
.gr-teams-toggle{display:block;margin:1rem auto 0;background:var(--bg2);border:1px solid var(--border);color:var(--accent);padding:.5rem 1.5rem;border-radius:6px;font-size:.85rem;font-weight:600;cursor:pointer;font-family:inherit;transition:border-color .2s}
.gr-teams-toggle:hover{border-color:var(--accent)}

/* ── Player Cards (reuse from pro-players listing) ────────────────────────── */
.gr-player-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(380px,1fr));gap:1.25rem;margin-bottom:1rem}
.pp-card{display:block;text-decoration:none;color:inherit;background:var(--bg2);border:1px solid var(--border);border-radius:10px;padding:1.25rem;transition:border-color .2s,transform .2s,box-shadow .2s}
.pp-card:hover{border-color:var(--accent);transform:translateY(-2px);box-shadow:0 4px 16px rgba(212,149,110,.1)}
.pp-card.hidden{display:none}
.pp-card-top{display:flex;align-items:flex-start;margin-bottom:1rem;gap:.75rem}
.pp-avatar{width:56px;height:56px;border-radius:50%;object-fit:cover;border:2px solid var(--border);flex-shrink:0;background:var(--bg3)}
.pp-card-info{flex:1;min-width:0}
.pp-name{margin:0;font-size:1.3rem;font-weight:800}
.pp-team-role{display:flex;gap:.5rem;align-items:center;margin-top:.3rem}
.pp-team{color:var(--accent);font-size:.85rem;font-weight:600}
.pp-realname{color:var(--text2);font-size:.78rem;margin-top:.2rem}
.pp-view-more{text-align:center;color:var(--accent);font-size:.82rem;font-weight:700;margin-top:.75rem;padding-top:.5rem;border-top:1px solid var(--border)}

.pp-stats{display:grid;grid-template-columns:repeat(4,1fr);gap:.5rem;margin-bottom:1rem}
.pp-s{background:var(--bg);border:1px solid var(--border);border-radius:6px;padding:.5rem;text-align:center}
.pp-s.pp-edpi{border-color:var(--accent)}
.pp-sv{display:block;font-size:1.1rem;font-weight:700;color:var(--text)}
.pp-edpi .pp-sv{color:var(--accent)}
.pp-sl{display:block;font-size:.65rem;color:var(--text2);text-transform:uppercase;margin-top:.15rem}

.pp-xhair{display:flex;gap:.5rem;background:var(--bg);border:1px solid var(--border);border-radius:6px;padding:.4rem;margin-bottom:1rem;align-items:center}
.pp-xhair code{flex:1;font-size:.75rem;color:var(--text2);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;padding:0 .4rem}
.pp-copy{background:var(--accent);color:#000;border:none;padding:.3rem .6rem;border-radius:4px;font-size:.75rem;font-weight:700;cursor:pointer;white-space:nowrap;font-family:inherit}
