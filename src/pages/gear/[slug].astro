/* ── Product Analysis ─────────────────────────────────────────────────────── */
.gr-analysis-grid{display:grid;grid-template-columns:1fr 320px;gap:1.5rem;align-items:start}
.gr-analysis-overview{color:var(--text2);font-size:.95rem;line-height:1.7;margin:0 0 1.25rem}
