/* ── Internal Links (site standard) ───────────────────────────────────────── */
.internal-links{display:flex;flex-wrap:wrap;gap:.5rem;align-items:center;margin:2rem 0;font-size:.85rem}
.internal-links strong{color:var(--text);margin-right:.25rem}
