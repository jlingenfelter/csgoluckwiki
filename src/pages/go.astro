---
<!DOCTYPE html>
<html lang="en" style="background:#0d0e12">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>{title}</title>
<meta name="robots" content="noindex, nofollow" />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700;800;900&display=swap" rel="stylesheet" />
<style is:global>
  :root{--bg:#0d0e12;--bg2:#13141a;--bg3:#1a1c24;--text:#fff;--text2:#909090;--accent:#2ecc71;--border:#242630;
    --consumer:#b0c3d9;--industrial:#5e98d9;--milspec:#4b69ff;--restricted:#8847ff;--classified:#d32ce6;--covert:#eb4b4b;--gold:#ffd700}
  *{margin:0;padding:0;box-sizing:border-box}
  body{background:var(--bg);color:var(--text);font-family:'Montserrat',sans-serif;min-height:100vh;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;padding:1.5rem;overflow:hidden}

  .go-logo-wrap{margin-bottom:1.25rem;opacity:0;animation:fadeIn .3s ease .1s forwards}
  .go-logo{height:28px;width:auto}
  @keyframes fadeIn{to{opacity:1}}

  /* Title above reel */
  .co-title{font-size:1.15rem;font-weight:800;color:var(--gold);text-transform:uppercase;letter-spacing:.04em;margin-bottom:.75rem;opacity:0;animation:fadeIn .3s ease .15s forwards;text-shadow:0 0 20px rgba(255,215,0,.3)}

  /* Case opening */
  .co-wrap{width:100%;max-width:600px;position:relative;margin-bottom:2rem;opacity:0;animation:fadeIn .3s ease .2s forwards}

  /* Open button overlay */
  .co-open-overlay{position:absolute;inset:0;z-index:10;display:flex;align-items:center;justify-content:center;background:rgba(0,0,0,.55);border-radius:5px;cursor:pointer;transition:background .2s}
  .co-open-overlay:hover{background:rgba(0,0,0,.4)}
  .co-open-overlay.hidden{display:none}
  .co-open-btn{background:linear-gradient(135deg,#ffd700,#ffaa00);color:#000;font-family:'Montserrat',sans-serif;font-weight:900;font-size:1.1rem;text-transform:uppercase;letter-spacing:.06em;padding:.65rem 2.5rem;border:none;border-radius:5px;cursor:pointer;box-shadow:0 4px 20px rgba(255,215,0,.4);transition:transform .15s,box-shadow .15s}
  .co-open-btn:hover{transform:scale(1.05);box-shadow:0 6px 30px rgba(255,215,0,.55)}

  /* Pointer */
  .co-pointer{width:0;height:0;border-left:10px solid transparent;border-right:10px solid transparent;border-top:14px solid var(--gold);margin:0 auto 6px;filter:drop-shadow(0 0 6px rgba(255,215,0,.6));z-index:5;position:relative}

  /* Viewport */
  .co-viewport{width:100%;height:80px;overflow:hidden;position:relative;border:2px solid var(--border);border-radius:5px;background:var(--bg2);box-shadow:0 0 20px rgba(0,0,0,.4)}
  .co-viewport::before,.co-viewport::after{content:'';position:absolute;top:0;bottom:0;width:60px;z-index:3;pointer-events:none}
  .co-viewport::before{left:0;background:linear-gradient(to right,var(--bg2),transparent)}
  .co-viewport::after{right:0;background:linear-gradient(to left,var(--bg2),transparent)}

  /* Center line */
  .co-center-line{position:absolute;top:0;bottom:0;left:50%;width:2px;background:var(--gold);z-index:4;transform:translateX(-50%);box-shadow:0 0 10px rgba(255,215,0,.4)}

  /* Strip */
  .co-strip{display:flex;position:absolute;top:0;left:0;height:100%;will-change:transform}

  /* Items — compact */
  .co-item{width:90px;height:80px;flex-shrink:0;display:flex;flex-direction:column;align-items:center;justify-content:center;border-right:1px solid rgba(255,255,255,.05);position:relative;overflow:hidden;gap:2px}
  .co-item::after{content:'';position:absolute;bottom:0;left:0;right:0;height:3px}

  .co-item[data-r="consumer"]{background:linear-gradient(180deg,transparent 50%,rgba(176,195,217,.06))}
  .co-item[data-r="consumer"]::after{background:var(--consumer)}
  .co-item[data-r="industrial"]{background:linear-gradient(180deg,transparent 50%,rgba(94,152,217,.06))}
  .co-item[data-r="industrial"]::after{background:var(--industrial)}
  .co-item[data-r="milspec"]{background:linear-gradient(180deg,transparent 50%,rgba(75,105,255,.06))}
  .co-item[data-r="milspec"]::after{background:var(--milspec)}
  .co-item[data-r="restricted"]{background:linear-gradient(180deg,transparent 50%,rgba(136,71,255,.08))}
  .co-item[data-r="restricted"]::after{background:var(--restricted)}
  .co-item[data-r="classified"]{background:linear-gradient(180deg,transparent 50%,rgba(211,44,230,.08))}
  .co-item[data-r="classified"]::after{background:var(--classified)}
  .co-item[data-r="covert"]{background:linear-gradient(180deg,transparent 50%,rgba(235,75,75,.1))}
  .co-item[data-r="covert"]::after{background:var(--covert)}
  .co-item[data-r="gold"]{background:linear-gradient(180deg,rgba(255,215,0,.04) 0%,rgba(255,215,0,.12) 100%)}
  .co-item[data-r="gold"]::after{background:var(--gold);height:4px;box-shadow:0 0 10px rgba(255,215,0,.6)}

  /* Skin images — small */
  .co-skin-img{width:55px;height:42px;object-fit:contain;filter:drop-shadow(0 1px 3px rgba(0,0,0,.5))}

  /* Gold emblem SVG */
  .co-gold-emblem{width:52px;height:52px}

  /* Label */
  .co-label{font-size:.5rem;text-transform:uppercase;letter-spacing:.02em;opacity:.5;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:85px}
  .co-item[data-r="gold"] .co-label{color:var(--gold);opacity:1;font-weight:800;font-size:.55rem}
  .co-item[data-r="covert"] .co-label{color:var(--covert);opacity:.85}
  .co-item[data-r="classified"] .co-label{color:var(--classified);opacity:.85}
  .co-item[data-r="restricted"] .co-label{color:var(--restricted);opacity:.85}

  /* Reveal */
  .co-reveal{opacity:0;transform:translateY(15px) scale(.97);transition:opacity .6s cubic-bezier(.16,1,.3,1),transform .6s cubic-bezier(.16,1,.3,1);max-width:460px;margin:0 auto;pointer-events:none}
  .co-reveal.show{opacity:1;transform:translateY(0) scale(1);pointer-events:auto}

  .co-prize{background:linear-gradient(135deg,#1a1400 0%,#2a2000 50%,#1a1400 100%);border:2px solid var(--gold);border-radius:8px;padding:1.5rem 2rem;position:relative;overflow:hidden}
  .co-prize::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at center,rgba(255,215,0,.1) 0%,transparent 70%);pointer-events:none}

  .co-prize-badge{display:inline-block;background:var(--gold);color:#000;font-weight:800;font-size:.65rem;text-transform:uppercase;letter-spacing:.06em;padding:.25rem .6rem;border-radius:3px;margin-bottom:.6rem}
  .co-prize-title{font-size:1.5rem;font-weight:900;color:var(--gold);margin-bottom:.2rem;text-shadow:0 0 25px rgba(255,215,0,.4)}
  .co-prize-plus{font-size:.9rem;color:var(--gold);font-weight:700;margin-bottom:.6rem}
  .co-prize-sub{font-size:.85rem;font-weight:600;color:var(--text2);margin-bottom:1rem}

  .co-cta{display:inline-block;background:linear-gradient(135deg,#ffd700,#ffaa00);color:#000;font-weight:800;font-size:.95rem;text-transform:uppercase;letter-spacing:.04em;padding:.75rem 2.2rem;border-radius:5px;text-decoration:none;transition:transform .15s,box-shadow .15s;box-shadow:0 4px 20px rgba(255,215,0,.35)}
  .co-cta:hover{transform:translateY(-2px);box-shadow:0 8px 30px rgba(255,215,0,.5)}

  .go-back{display:inline-block;margin-top:.75rem;font-size:.75rem;color:var(--text2);text-decoration:none}
  .go-back:hover{color:var(--accent)}

  @keyframes goldPulse{0%,100%{box-shadow:0 0 15px rgba(255,215,0,.2),inset 0 0 15px rgba(255,215,0,.05)}50%{box-shadow:0 0 35px rgba(255,215,0,.5),inset 0 0 25px rgba(255,215,0,.1)}}
  .co-prize.glow{animation:goldPulse 2s ease-in-out infinite}

  #confettiCanvas{position:fixed;top:0;left:0;width:100%;height:100%;pointer-events:none;z-index:20}

  @media(max-width:480px){
    .co-item{width:70px;height:65px}
    .co-viewport{height:65px}
    .co-skin-img{width:42px;height:32px}
    .co-gold-emblem{width:40px;height:40px}
    .co-label{font-size:.45rem;max-width:65px}
    .co-prize-title{font-size:1.2rem}
    .co-prize{padding:1.25rem 1.5rem}
    .co-cta{font-size:.85rem;padding:.65rem 1.8rem}
  }
</style>
</head>
<body>

<div class="go-logo-wrap">
  <img src="/images/csgoluck-logo.png" alt="CSGOLuck" class="go-logo" />
</div>

<div class="co-title">Open Case for your welcome bonus</div>

<div class="co-wrap">
  <div class="co-pointer"></div>
  <div class="co-viewport">
    <div class="co-center-line"></div>
    <div class="co-strip" id="coStrip"></div>
    <div class="co-open-overlay" id="coOpenOverlay">
      <button class="co-open-btn" id="coOpenBtn">Open</button>
    </div>
  </div>
</div>

<div class="co-reveal" id="coReveal">
  <div class="co-prize" id="coPrize">
    <div class="co-prize-badge">★ Exclusive Offer Unlocked ★</div>
    <div class="co-prize-title">100% Deposit Bonus</div>
    <div class="co-prize-plus">+ 5 Free Cases</div>
    <div class="co-prize-sub">New players only · claim below</div>
    <a href="https://csgoluck.com/r/WIKIPEDIA" class="co-cta" rel="nofollow noopener" id="claimBtn">Claim Now →</a>
  </div>
  <a href="/" class="go-back">&larr; Back to CSGOLuck Wiki</a>
</div>

<canvas id="confettiCanvas"></canvas>

<!-- Gold emblem SVG template (hidden) — CS2-style laurel wreath with ? -->
<template id="goldEmblemTpl">
  <svg class="co-gold-emblem" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
    <defs>
      <radialGradient id="gg" cx="50%" cy="45%" r="50%">
        <stop offset="0%" stop-color="#fff3a0"/>
        <stop offset="40%" stop-color="#ffd700"/>
        <stop offset="100%" stop-color="#b8860b"/>
      </radialGradient>
      <radialGradient id="gc" cx="50%" cy="40%" r="45%">
        <stop offset="0%" stop-color="#ffe066"/>
        <stop offset="100%" stop-color="#c8960c"/>
      </radialGradient>
    </defs>
    <!-- Outer ring -->
    <circle cx="50" cy="50" r="42" fill="none" stroke="url(#gg)" stroke-width="4" opacity=".7"/>
    <!-- Inner filled circle -->
    <circle cx="50" cy="50" r="30" fill="url(#gc)" opacity=".9"/>
    <circle cx="50" cy="50" r="30" fill="none" stroke="#b8860b" stroke-width="1.5"/>
    <!-- Question mark -->
    <text x="50" y="58" text-anchor="middle" font-family="Montserrat,sans-serif" font-size="30" font-weight="900" fill="#1a1400" opacity=".85">?</text>
    <!-- Left laurel -->
    <g fill="#c8960c" opacity=".85">
      <ellipse cx="16" cy="60" rx="5" ry="10" transform="rotate(20 16 60)"/>
      <ellipse cx="12" cy="50" rx="4.5" ry="9" transform="rotate(10 12 50)"/>
      <ellipse cx="11" cy="40" rx="4" ry="8" transform="rotate(-5 11 40)"/>
      <ellipse cx="14" cy="31" rx="3.5" ry="7" transform="rotate(-20 14 31)"/>
      <ellipse cx="20" cy="24" rx="3" ry="6" transform="rotate(-35 20 24)"/>
    </g>
    <!-- Right laurel -->
    <g fill="#c8960c" opacity=".85">
      <ellipse cx="84" cy="60" rx="5" ry="10" transform="rotate(-20 84 60)"/>
      <ellipse cx="88" cy="50" rx="4.5" ry="9" transform="rotate(-10 88 50)"/>
      <ellipse cx="89" cy="40" rx="4" ry="8" transform="rotate(5 89 40)"/>
      <ellipse cx="86" cy="31" rx="3.5" ry="7" transform="rotate(20 86 31)"/>
      <ellipse cx="80" cy="24" rx="3" ry="6" transform="rotate(35 80 24)"/>
    </g>
    <!-- Star at top -->
    <polygon points="50,6 52,12 58,12 53,16 55,22 50,18 45,22 47,16 42,12 48,12" fill="#ffd700"/>
  </svg>
</template>

<script is:inline define:vars={{ skinPool }}>
(function() {
  var ITEM_W = window.innerWidth <= 480 ? 70 : 90;
  var SPIN_MS = 5000;  /* 5 seconds total */

  /*
   * Build a strip of ~30 items: skins repeated 3x so the reel
   * spins past ~2 full cycles before decelerating onto the gold.
   * Gold sits at index 25 with 4 more skins after it.
   */
  var TOTAL_ITEMS = 30;
  var GOLD_INDEX  = 25;

  /* Shuffle skins */
  var skins = skinPool.slice();
  for (var i = skins.length - 1; i > 0; i--) {
    var j = Math.floor(Math.random() * (i + 1));
    var tmp = skins[i]; skins[i] = skins[j]; skins[j] = tmp;
  }

  /* Gold emblem SVG from template */
  var goldSvg = document.getElementById('goldEmblemTpl').innerHTML;

  /* Build strip */
  var strip = document.getElementById('coStrip');
  for (var i = 0; i < TOTAL_ITEMS; i++) {
    var div = document.createElement('div');
    div.className = 'co-item';

    if (i === GOLD_INDEX) {
      div.setAttribute('data-r', 'gold');
      div.innerHTML = goldSvg + '<span class="co-label">★ BONUS ★</span>';
    } else {
      var s = skins[i % skins.length];
      div.setAttribute('data-r', s.rarity);
      div.innerHTML =
        '<img class="co-skin-img" src="' + s.image + '" alt="' + s.weapon + ' ' + s.name + '" loading="eager" />' +
        '<span class="co-label">' + s.name + '</span>';
    }
    strip.appendChild(div);
  }

  /* Animate — calculate target lazily inside rAF so CSS is applied */
  var startTime = null;
  var targetOffset = null;
  var rndOffset = (Math.random() * 16) - 8;

  /* Steep ease — starts very fast, decelerates dramatically at the end */
  function easeOutQuint(t) { return 1 - Math.pow(1 - t, 5); }

  function animate(ts) {
    if (!startTime) {
      startTime = ts;
      var vpWidth = document.querySelector('.co-viewport').offsetWidth;
      targetOffset = (GOLD_INDEX * ITEM_W) + (ITEM_W / 2) - (vpWidth / 2) + rndOffset;
    }
    var progress = Math.min((ts - startTime) / SPIN_MS, 1);
    strip.style.transform = 'translateX(' + (-(targetOffset * easeOutQuint(progress))) + 'px)';
    if (progress < 1) {
      requestAnimationFrame(animate);
    } else {
      setTimeout(showReveal, 350);
    }
  }

  function showReveal() {
    document.getElementById('coReveal').classList.add('show');
    document.getElementById('coPrize').classList.add('glow');
    launchConfetti();
    setTimeout(function() {
      window.location.href = 'https://csgoluck.com/r/WIKIPEDIA';
    }, 5000);
  }

  /* Canvas confetti */
  function launchConfetti() {
    var canvas = document.getElementById('confettiCanvas');
    var ctx = canvas.getContext('2d');
    canvas.width = window.innerWidth;
    canvas.height = window.innerHeight;

    var COLORS = ['#ffd700','#eb4b4b','#2ecc71','#4b69ff','#d32ce6','#ff6b6b','#5e98d9','#ffaa00','#ff4444','#44ff44'];
    var pieces = [];

    function burst(count, originX, spreadX, startY) {
      for (var i = 0; i < count; i++) {
        pieces.push({
          x: originX + (Math.random() - 0.5) * spreadX,
          y: startY - Math.random() * 80,
          w: Math.random() * 10 + 5,
          h: Math.random() * 6 + 3,
          color: COLORS[Math.floor(Math.random() * COLORS.length)],
          vx: (Math.random() - 0.5) * 6,
          vy: Math.random() * 3 + 1.5,
          rot: Math.random() * 360,
          rotV: (Math.random() - 0.5) * 14,
          opacity: 1,
          decay: 0.003 + Math.random() * 0.003,
          shape: Math.random() > 0.35 ? 'rect' : 'circle',
        });
      }
    }

    burst(120, canvas.width / 2, canvas.width, -20);

    var running = true;
    function draw() {
      if (!running) return;
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      var alive = 0;
      for (var i = 0; i < pieces.length; i++) {
        var p = pieces[i];
        if (p.opacity <= 0) continue;
        alive++;
        p.x += p.vx;
        p.y += p.vy;
        p.vy += 0.06;
        p.rot += p.rotV;
        p.opacity -= p.decay;
        if (p.opacity < 0) p.opacity = 0;

        ctx.save();
        ctx.translate(p.x, p.y);
        ctx.rotate(p.rot * Math.PI / 180);
        ctx.globalAlpha = p.opacity;
        ctx.fillStyle = p.color;
        if (p.shape === 'rect') {
          ctx.fillRect(-p.w / 2, -p.h / 2, p.w, p.h);
        } else {
          ctx.beginPath();
          ctx.arc(0, 0, p.w / 2, 0, Math.PI * 2);
          ctx.fill();
        }
        ctx.restore();
      }
      if (alive > 0) {
        requestAnimationFrame(draw);
      } else {
        running = false;
        ctx.clearRect(0, 0, canvas.width, canvas.height);
      }
    }
    requestAnimationFrame(draw);

    /* Second burst */
    setTimeout(function() {
      burst(80, canvas.width / 2, canvas.width * 0.8, -10);
      if (!running) { running = true; requestAnimationFrame(draw); }
    }, 700);
  }

  /* Wait for user click — or redirect after 5s without spinning */
  var redirectTimer = setTimeout(function() {
    window.location.href = 'https://csgoluck.com/r/WIKIPEDIA';
  }, 5000);

  document.getElementById('coOpenBtn').addEventListener('click', function(e) {
    e.stopPropagation();
    clearTimeout(redirectTimer);
    document.getElementById('coOpenOverlay').classList.add('hidden');
    requestAnimationFrame(animate);
  });

  document.getElementById('coOpenOverlay').addEventListener('click', function() {
    clearTimeout(redirectTimer);
    this.classList.add('hidden');
    requestAnimationFrame(animate);
  });
})();
</script>
</body>
</html>