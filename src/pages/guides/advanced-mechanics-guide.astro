  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "description": description,
  "author": { "@type": "Person", "name": "Josh Lingenfelter", "url": "https://www.linkedin.com/in/josh-lingenfelter-8157274b/", "jobTitle": "Director", "worksFor": { "@type": "Organization", "name": "Bettor Media" } },
  "publisher": { "@type": "Organization", "name": "CSDB.gg", "url": "https://csdb.gg" },
  "mainEntityOfPage": `https://csdb.gg/guides/advanced-mechanics-guide/`,
  "inLanguage": "en-US"
});

const faqs = [
  { question: 'What is counter-strafing in CS2?', answer: 'Counter-strafing is tapping the opposite movement key to instantly stop your character momentum. When moving right (D), quickly tap left (A) to reach zero velocity faster than just releasing D. This allows you to shoot accurately sooner after moving.' },
  { question: 'How do I jiggle peek in CS2?', answer: 'Jiggle peeking is quickly strafing in and out of an angle to bait shots or gather information. Press A or D briefly to expose yourself for a fraction of a second, then immediately counter-strafe back to cover. The goal is to peek and return before the enemy can react.' },
  { question: 'What is crosshair placement?', answer: 'Crosshair placement means keeping your crosshair at head level and pre-aimed at common enemy positions. Instead of looking at the ground or center mass, always position your crosshair where an enemy head would appear. This reduces the distance you need to flick when engaging targets.' },
  { question: 'How do spray transfers work?', answer: 'A spray transfer is continuing your spray pattern while moving your aim from one enemy to another. Instead of stopping and re-spraying, you keep tracking the recoil pattern while shifting horizontally to the next target. This requires mastering the full spray pattern of your weapon.' },
  { question: 'What is the difference between wide peeking and shoulder peeking?', answer: 'Wide peeking fully commits to swinging past an angle with your full body exposed — good for surprising enemies or taking duels on favorable terms. Shoulder peeking exposes only your shoulder model to bait out shots, then you fall back without committing to the fight.' },
];
