import Base from '../../layouts/Base.astro';
import AuthorBox from '../../components/AuthorBox.astro';
import { faqSchema, breadcrumbSchema } from '../../lib/weapons';

const title = 'Case Hardened & Blue Gem Pattern Guide';
const description = 'Complete guide to CS2 Case Hardened patterns — blue gems, gold gems, pattern seeds, tier rankings, and pricing for AK-47, knives, and more.';

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Guides', url: '/guides' },
  { name: 'Case Hardened & Blue Gem Guide', url: '/guides/case-hardened-guide' },
];

const faqs = [
  {
    question: 'What is a Blue Gem in CS2?',
