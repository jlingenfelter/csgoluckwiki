    <a href="/practice-config/">Practice Config</a>
    <a href="/tools/">All Tools</a>
    <a href="/pro-players/">Pro Player Settings</a>
    <a href="/guides/crosshair-guide/">Crosshair Guide</a>
    <a href="/guides/beginners-guide/">Beginner's Guide</a>
  </div>

  <h2>Frequently Asked Questions</h2>
  <dl class="faq">
    {faqs.map(f => (
      <Fragment>
        <dt>{f.question}</dt>
        <dd>{f.answer}</dd>
      </Fragment>
    ))}
  </dl>
  <AuthorBox updated="2026-03-02" />
</Base>
