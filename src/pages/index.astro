/* ── Hero ─────────────────────────────────── */
.hp-hero{background:var(--bg);padding:3.5rem 2rem 2.5rem;border-bottom:1px solid var(--border);position:relative;overflow:hidden}
.hp-hero-inner{max-width:900px;margin:0 auto;text-align:left;position:relative;z-index:2}

/* Hero skin showcase */
.hp-hero-skins{position:absolute;top:50%;right:0;transform:translateY(-50%);pointer-events:none;z-index:1;width:500px;height:350px}
.hp-hero-skin{position:absolute;object-fit:contain;filter:drop-shadow(0 4px 24px rgba(0,0,0,.4))}
.hp-hero-skin-center{top:50%;left:50%;transform:translate(-50%,-50%);max-width:320px;max-height:240px;opacity:.18}
.hp-hero-skin-left{top:20%;left:0;max-width:220px;max-height:165px;opacity:.12;transform:rotate(-8deg)}
.hp-hero-skin-right{bottom:15%;right:0;max-width:220px;max-height:165px;opacity:.12;transform:rotate(8deg)}

.hp-title{font-size:2.8rem;font-weight:900;margin:0 0 .75rem;color:#fff;line-height:1.1;letter-spacing:-.02em}
html.light-mode .hp-title{color:#000}
.hp-title em{font-style:normal;color:#2ecc71}
.hp-subtitle{font-size:1.05rem;color:var(--text2);margin:0 0 1.5rem;max-width:640px;line-height:1.65}

.hp-stats-row{display:flex;align-items:center;gap:.5rem;flex-wrap:wrap;margin-bottom:1.75rem}
.hp-stat-pill{display:inline-block;padding:.3rem .75rem;background:rgba(46,204,113,.08);border:1px solid rgba(46,204,113,.4);border-radius:4px;font-size:.82rem;font-weight:700;color:#2ecc71;white-space:nowrap;box-shadow:0 0 8px rgba(46,204,113,.15);transition:all .2s ease}
.hp-stat-pill:hover{box-shadow:0 0 14px rgba(46,204,113,.25);border-color:#2ecc71}
.hp-stat-dot{color:var(--text2);font-size:.8rem;user-select:none}

.hp-search-wrap{max-width:100%;margin:0 0 1.25rem}
.hp-search-form{display:flex;align-items:center;background:var(--bg2);border:1px solid var(--border);border-radius:4px;overflow:hidden;transition:border-color .2s}
