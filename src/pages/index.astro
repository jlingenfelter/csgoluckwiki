<style is:inline>
:root {
  --glow: 0 0 20px rgba(212,149,110,0.15);
  --glow-blue: 0 0 20px rgba(0,170,255,0.15);
  --glow-gold: 0 0 20px rgba(212,149,110,0.15);
}

@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(30px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes glowPulse {
  0%, 100% { box-shadow: var(--glow), 0 0 0 0 rgba(212,149,110,0.3); }
  50% { box-shadow: var(--glow), 0 0 10px 3px rgba(212,149,110,0.05); }
}

@keyframes numGlow {
  0%, 100% { color: var(--accent); }
  50% { color: #00d4ff; text-shadow: 0 0 10px rgba(0,212,255,0.5); }
}

@keyframes gridShimmer {
  0% { background-position: 0 0; }
  100% { background-position: 100px 100px; }
}

@keyframes scanLines {
  0% { transform: translateY(-100%); }
  100% { transform: translateY(100%); }
}

@keyframes floatUp {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-10px); }
}

@media (prefers-reduced-motion: reduce) {
  * {
    animation-duration: 0.01ms !important;
    animation-iteration-count: 1 !important;
    transition-duration: 0.01ms !important;
  }
}

/* Hero Section - Premium Showcase */
.hp-hero {
  position: relative;
  padding: 3rem 1.5rem;
  background: linear-gradient(135deg, #0f1419, #1a2332);
  border-radius: 16px;
  border: 1px solid rgba(212,149,110,0.1);
  margin-bottom: 3rem;
  overflow: hidden;
}

.hp-hero-scanlines {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: repeating-linear-gradient(
    0deg,
    rgba(0,0,0,0.15),
    rgba(0,0,0,0.15) 1px,
    transparent 1px,
    transparent 2px
  );
  pointer-events: none;
  z-index: 1;
}

.hp-hero-gradient {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: radial-gradient(ellipse at 50% -50%, rgba(0,170,255,0.08) 0%, transparent 70%);
  pointer-events: none;
  z-index: 0;
}

.hp-hero-content {
  position: relative;
  z-index: 2;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 2rem;
  align-items: center;
}

.hp-hero-showcase {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 1rem;
  position: relative;
  min-height: 280px;
}

.hp-featured-main {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}

.hp-featured-primary {
  width: 200px;
  height: 280px;
  position: relative;
}

.hp-featured-glow {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 240px;
  height: 240px;
  background: radial-gradient(circle, var(--rarity-color) 0%, transparent 70%);
  opacity: 0.15;
  filter: blur(40px);
  z-index: -1;
}

.hp-featured-image {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, rgba(20, 30, 50, 0.6), rgba(30, 50, 80, 0.4));
  border-radius: 12px;
  border: 2px solid var(--rarity-color);
  position: relative;
  overflow: hidden;
  animation: floatUp 4s ease-in-out infinite;
}

.hp-featured-image img {
  max-width: 90%;
  max-height: 90%;
  object-fit: contain;
}

.hp-featured-placeholder {
  font-size: 3rem;
  font-weight: 900;
  color: var(--rarity-color);
  opacity: 0.3;
}

.hp-featured-badge {
  position: absolute;
  top: 10px;
  right: 10px;
  background: var(--rarity-color);
  color: #000;
  padding: 0.4rem 0.75rem;
  border-radius: 4px;
  font-size: 0.7rem;
  font-weight: 700;
  text-transform: uppercase;
  z-index: 10;
}

.hp-featured-side {
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.hp-featured-secondary {
  width: 140px;
  height: 140px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, rgba(20, 30, 50, 0.8), rgba(30, 50, 80, 0.6));
  border-radius: 12px;
  border: 2px solid var(--rarity-color);
