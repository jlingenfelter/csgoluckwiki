  <a href="/matches/" class="hp-nav-item"><svg viewBox="0 0 24 24"><path d="M6 9H4.5a2.5 2.5 0 010-5C7 4 7 7 7 7m12-3a2.5 2.5 0 00-2.5 2.5V9m-9 0h9V4a3 3 0 00-6 0v5m0 0H7l1 12h8l1-12h-3z" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg><span>Esports</span></a>
</nav>

