---
import Base from '../layouts/Base.astro';
import { SKINS, getLowestPrice, getHighestPrice, RARITY_COLORS, RARITY_BG, SKINS_TOTAL, getCollections } from '../lib/skins';
import { WEAPONS } from '../lib/weapons';
import { faqSchema } from '../lib/weapons';
import { skinHeroImage, skinHeroSideImage, homeSkinCardImage, categoryCardImage } from '../lib/imageOptimize';
import { getAllGear, getGearImageUrl, getPlayerBySlug } from '../lib/pro-players';

const topSkins = SKINS
  .filter(s => !s.phase)
  .map(skin => ({ ...skin, maxPrice: getHighestPrice(skin) }))
  .sort((a, b) => b.maxPrice - a.maxPrice)
  .slice(0, 10);

const skinCount = SKINS_TOTAL || SKINS.length;
const weaponCount = WEAPONS.length;
const collectionCount = getCollections().length;

// Count pro players
const playerFiles = import.meta.glob('../data/players/*.json', { eager: true });
const playerCount = Object.keys(playerFiles).length;

// Top gear items (one per type, most popular, with images)
const topGear = getAllGear()
  .filter(g => getGearImageUrl(g.name))
  .reduce((acc, g) => {
    if (!acc.find(x => x.type === g.type)) acc.push(g);
    return acc;
  }, [] as ReturnType<typeof getAllGear>)
  .slice(0, 5);

const faqs = [
  { question: 'What is CSDB.gg?', answer: 'CSDB.gg is a comprehensive Counter-Strike 2 resource hub covering skin prices from 14+ marketplaces, weapon stats, 860+ pro player settings, 30+ interactive tools, map callouts, and in-depth guides — everything a CS2 player needs in one place.' },
  { question: 'How are skin prices updated?', answer: 'Prices are aggregated from 14+ marketplaces including Buff163, CSFloat, BitSkins, DMarket, and more via PriceEmpire. Data is refreshed regularly to ensure accuracy across all wear conditions and Doppler phases.' },
  { question: 'Are the tools free to use?', answer: 'Yes, every tool on CSDB.gg is completely free — damage calculator, sensitivity converter, bind generator, crosshair codes, case simulator, inventory lookup, and more.' },
  { question: 'Is CSDB.gg affiliated with Valve?', answer: 'No. CSDB.gg is an independent community resource. All game content and trademarks belong to Valve Corporation.' },
  { question: 'How do I find pro player settings?', answer: `Visit our Pro Players page to browse ${playerCount}+ professional player configs with crosshair codes, sensitivity, resolution, gear loadouts, and weapon skin preferences.` },
  { question: 'Can I compare weapon stats?', answer: 'Yes! Our weapon pages show detailed combat stats, and the Weapon Compare tool lets you compare any two weapons side by side.' },
  { question: 'What Doppler phases are tracked?', answer: 'Every Doppler and Gamma Doppler knife has individual pages for each phase — Phase 1 through 4, Ruby, Sapphire, Black Pearl, and Emerald — with phase-specific pricing and images.' },
  { question: 'Can I look up my Steam inventory?', answer: 'Yes! Our Inventory Lookup tool lets you search any public Steam inventory to see all CS2 skins with current market values and float values.' },
];
---

<Base title="CSDB.gg — CS2 Database, Skin Prices, Pro Settings & Tools" description={`The ultimate CS2 resource: ${skinCount.toLocaleString()} skins with live prices from 14+ marketplaces, ${weaponCount} weapon stats, ${playerCount}+ pro player settings & gear, 30+ free tools, map callouts, and guides.`} currentNav="/">
<Fragment slot="head">
<script type="application/ld+json" set:html={JSON.stringify(faqSchema(faqs))} />
</Fragment>

<!-- Hero with Featured Skin Showcase -->
<section class="hp-hero">
  <div class="hp-hero-content">
    <div class="hp-hero-showcase">
      <div class="hp-featured-main">
        {topSkins[0] && (
          <div class="hp-featured-skin hp-featured-primary" style={`--rarity-color: ${RARITY_COLORS[topSkins[0].rarity] || '#d4956e'}`}>
            <div class="hp-featured-glow"></div>
            <div class="hp-featured-image">
              {topSkins[0].image ? (
                <img src={skinHeroImage(topSkins[0].image)} alt={`${topSkins[0].weapon} | ${topSkins[0].name}`} width="600" height="450" loading="lazy" />
              ) : (
                <div class="hp-featured-placeholder">{topSkins[0].name.substring(0, 2)}</div>
              )}
            </div>
            <div class="hp-featured-badge">{topSkins[0].rarity}</div>
          </div>
        )}
      </div>
      <div class="hp-featured-side">
        {topSkins[1] && (
          <a href={`/skin/${topSkins[1].slug}/`} class="hp-featured-skin hp-featured-secondary" style={`--rarity-color: ${RARITY_COLORS[topSkins[1].rarity] || '#d4956e'}`}>
            <div class="hp-featured-image-sm">
              {topSkins[1].image ? (
                <img src={skinHeroSideImage(topSkins[1].image)} alt={`${topSkins[1].weapon} | ${topSkins[1].name}`} width="400" height="300" loading="lazy" />
              ) : (
                <div class="hp-featured-placeholder-sm">{topSkins[1].name.substring(0, 2)}</div>
              )}
            </div>
          </a>
        )}
        {topSkins[2] && (
          <a href={`/skin/${topSkins[2].slug}/`} class="hp-featured-skin hp-featured-secondary" style={`--rarity-color: ${RARITY_COLORS[topSkins[2].rarity] || '#d4956e'}`}>
            <div class="hp-featured-image-sm">
              {topSkins[2].image ? (
                <img src={skinHeroSideImage(topSkins[2].image)} alt={`${topSkins[2].weapon} | ${topSkins[2].name}`} width="400" height="300" loading="lazy" />
              ) : (
                <div class="hp-featured-placeholder-sm">{topSkins[2].name.substring(0, 2)}</div>
              )}
            </div>
          </a>
        )}
      </div>
    </div>

    <div class="hp-hero-text">
      <h1>Your Complete CS2 Resource Hub</h1>
      <p class="hp-sub">Skin prices, weapon stats, pro settings, interactive tools, map callouts, and guides — everything you need for Counter-Strike 2.</p>
      <div class="hp-search-hero">
        <form action="/search/" method="get" class="hp-search-form">
          <svg class="hp-search-icon" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><circle cx="11" cy="11" r="7" fill="none" stroke="currentColor" stroke-width="2"/><line x1="16.5" y1="16.5" x2="21" y2="21" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
          <input type="search" name="q" placeholder="Search skins, weapons, tools..." class="hp-search-input" autocomplete="off" />
          <button type="submit" class="hp-search-btn">Search</button>
        </form>
        <div class="hp-search-tags">
          <a href="/search/?q=Dragon+Lore">Dragon Lore</a>
          <a href="/search/?q=AK-47">AK-47</a>
          <a href="/search/?q=AWP+Fade">AWP Fade</a>
          <a href="/search/?q=Butterfly+Knife">Butterfly Knife</a>
        </div>
      </div>
      <div class="hp-cta">
        <a href="/skins/" class="hp-btn hp-primary">Browse {skinCount.toLocaleString()} Skins</a>
        <a href="/pro-players/" class="hp-btn hp-secondary">{playerCount}+ Pro Players</a>
        <a href="/tools/" class="hp-btn hp-secondary">Free Tools</a>
      </div>
      <div class="hp-stats-row">
        <div class="hp-stat"><span class="hp-sn" style="font-variant-numeric: tabular-nums">{skinCount.toLocaleString()}</span><span class="hp-sl">Skins</span></div>
        <div class="hp-stat"><span class="hp-sn" style="font-variant-numeric: tabular-nums">{weaponCount}</span><span class="hp-sl">Weapons</span></div>
        <div class="hp-stat"><span class="hp-sn">14+</span><span class="hp-sl">Marketplaces</span></div>
        <div class="hp-stat"><span class="hp-sn" style="font-variant-numeric: tabular-nums">{playerCount}+</span><span class="hp-sl">Pro Players</span></div>
        <div class="hp-stat"><span class="hp-sn">30+</span><span class="hp-sl">Free Tools</span></div>
      </div>
    </div>
  </div>

  <div class="hp-hero-scanlines"></div>
  <div class="hp-hero-gradient"></div>
</section>

<!-- Silo 1: Skins & Market -->
<section class="hp-silo">
  <div class="hp-silo-header">
    <span class="hp-header-accent"></span>
    <h2>Skins & Market Data</h2>
    <p>Live prices from 14+ marketplaces across {skinCount.toLocaleString()} skins — including per-phase Doppler pricing, float values, and price tracking.</p>
  </div>
  <div class="hp-skin-grid">
    {topSkins.map(skin => {
      const rc = RARITY_COLORS[skin.rarity] || '#d4956e';
      const rbg = RARITY_BG[skin.rarity] || 'rgba(255,255,255,0.05)';
      return (
        <a href={`/skin/${skin.slug}/`} class="hp-skincard" style={`--rarity-color: ${rc}`}>
          <div class="hp-skincard-rarity">{skin.rarity}</div>
          <div class="hp-skinimg" style={`background:${rbg}`}>
            {skin.image
              ? <img src={homeSkinCardImage(skin.image)} alt={`${skin.weapon} | ${skin.name}`} width="360" height="270" loading="lazy" />
              : <div style={`font-size:1.8rem;font-weight:900;color:${rc};opacity:.25`}>{skin.name.substring(0,2)}</div>
            }
          </div>
          <div class="hp-skininfo">
            <strong>{skin.name}</strong>
            <span class="hp-skinwep">{skin.weapon}</span>
            <span class="hp-skinprice" style="font-variant-numeric: tabular-nums">${getLowestPrice(skin).toLocaleString()} – ${getHighestPrice(skin).toLocaleString()}</span>
          </div>
        </a>
      );
    })}
  </div>
  <div class="hp-silo-links">
    <a href="/skins/" class="hp-link-main">All Skins →</a>
    <a href="/skin-compare/">Compare Skins</a>
    <a href="/price-tracker/">Price Tracker</a>
    <a href="/market-trends/">Market Trends</a>
    <a href="/float-checker/">Float Checker</a>
    <a href="/tradeup-calculator/">Trade-Up Calculator</a>
    <a href="/case-odds-calculator/">Case Odds</a>
    <a href="/case-simulator/">Case Simulator</a>
    <a href="/cases/">Cases & Collections</a>
    <a href="/stickers/">Stickers</a>
    <a href="/agents/">Agents</a>
    <a href="/inventory-lookup/">Inventory Lookup</a>
    <a href="/loadout-builder/">Loadout Builder</a>
    <a href="/trading-sites/">Trading Sites</a>
  </div>
</section>

