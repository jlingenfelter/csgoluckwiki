---
import Base from '../layouts/Base.astro';
import { SKINS, getLowestPrice, getHighestPrice, RARITY_COLORS, RARITY_BG, SKINS_TOTAL, getCollections } from '../lib/skins';
import { WEAPONS } from '../lib/weapons';
import { faqSchema } from '../lib/weapons';
import { skinHeroImage, skinHeroSideImage, homeSkinCardImage, categoryCardImage } from '../lib/imageOptimize';
import { getAllGear, getGearImageUrl, getPlayerBySlug } from '../lib/pro-players';
import { caseDatabase } from '../lib/cases';

const topSkins = SKINS
  .filter(s => !s.phase)
  .map(skin => ({ ...skin, maxPrice: getHighestPrice(skin) }))
  .sort((a, b) => b.maxPrice - a.maxPrice)
  .slice(0, 12);

const skinCount = SKINS_TOTAL || SKINS.length;
const weaponCount = WEAPONS.length;
const collectionCount = getCollections().length;

// Count pro players
const playerFiles = import.meta.glob('../data/players/*.json', { eager: true });
const playerCount = Object.keys(playerFiles).length;

// Hero skins — pick 3 high-value skins with images
const heroSkins = SKINS
  .filter(s => !s.phase && s.image && getHighestPrice(s) > 500)
  .sort((a, b) => getHighestPrice(b) - getHighestPrice(a))
  .slice(0, 3);

// Popular weapons for quick links
const popularWeapons = ['ak-47', 'awp', 'm4a4', 'm4a1-s', 'desert-eagle', 'usp-s'];
const featuredWeapons = WEAPONS.filter(w => popularWeapons.includes(w.slug));

// Case count
const caseCount = Object.keys(caseDatabase).length;

// Popular tool links
const popularTools = [
  { name: 'Sensitivity Converter', slug: 'sensitivity-converter', desc: 'Convert sens between games' },
  { name: 'Crosshair Generator', slug: 'crosshair-generator', desc: 'Build & export crosshairs' },
  { name: 'Damage Calculator', slug: 'damage-calculator', desc: 'Calculate exact damage' },
  { name: 'Case Simulator', slug: 'case-simulator', desc: 'Open cases risk-free' },
  { name: 'Float Checker', slug: 'float-checker', desc: 'Inspect skin wear values' },
  { name: 'Economy Calculator', slug: 'economy-calculator', desc: 'Plan your buy rounds' },
];

const faqs = [
  { question: 'What is CSGOLuck Wiki?', answer: 'CSGOLuck Wiki is the knowledge base powered by CSGOLuck.com, built for the CS2 community. We track skin prices across 14+ marketplaces, document weapon stats, catalog settings from 860+ pro players, and provide 30+ free interactive tools — your one-stop shop for everything Counter-Strike 2.' },
  { question: 'How are skin prices sourced?', answer: 'We pull pricing data from 14+ markets — Buff163, CSFloat, BitSkins, DMarket, and beyond — through the PriceEmpire API. Prices refresh regularly and cover every wear condition, StatTrak variant, and Doppler phase so you always have a clear picture of what skins are worth.' },
  { question: 'Do I need an account to use the tools?', answer: 'Nope. Every tool on CSGOLuck Wiki is 100% free with zero sign-up required. Damage calculators, sensitivity converters, crosshair generators, case simulators — just open the page and start using them.' },
  { question: 'Who runs CSGOLuck Wiki?', answer: 'CSGOLuck Wiki is an independent project brought to you by CSGOLuck.com. We are not affiliated with Valve Corporation — all game content and trademarks belong to their respective owners.' },
  { question: 'Where can I find pro player configs?', answer: `Head over to our Pro Players section to dig through ${playerCount}+ verified professional configs. Each profile includes crosshair codes, sensitivity, resolution, monitor, mouse, keyboard, and full gear breakdowns.` },
  { question: 'Can I compare weapons head-to-head?', answer: 'Absolutely. Our Weapon Compare tool lets you stack any two CS2 weapons side by side — damage output, rate of fire, recoil, armor penetration, and more — so you can make informed buy-round decisions.' },
  { question: 'Do you track individual Doppler phases?', answer: 'Yes. Every Doppler and Gamma Doppler knife gets its own dedicated page per phase — Phase 1 through 4, Ruby, Sapphire, Black Pearl, and Emerald — each with phase-specific market pricing and high-res images.' },
  { question: 'Can I check the value of my Steam inventory?', answer: 'For sure. Our Inventory Lookup tool scans any public Steam profile and totals up current market values for every CS2 skin, including float values and wear details.' },
  { question: 'What is CSGOLuck.com?', answer: 'CSGOLuck.com is our parent platform — visit csgoluck.com to explore everything we offer beyond the wiki, including CS2 gaming experiences and community features.' },
];
---

<Base title="CSGOLuck Wiki — The Ultimate CS2 Database" description={`The CS2 knowledge base by CSGOLuck.com — ${skinCount.toLocaleString()} skins with real-time market prices, ${weaponCount} weapons with full combat data, ${playerCount}+ pro player loadouts, and 30+ free tools to sharpen your game.`} currentNav="/">
<Fragment slot="head">
<script type="application/ld+json" set:html={JSON.stringify(faqSchema(faqs))} />
</Fragment>

<!-- ===== HERO ===== -->
<section class="hp-hero">
  <div class="hp-hero-inner">
    <h1 class="hp-title">CSGOLuck <em>Wiki</em></h1>
    <p class="hp-subtitle">The open CS2 encyclopedia — community-driven guides, live market data, and pro player configs.</p>

    <div class="hp-stats-row">
      <span class="hp-stat-pill">{skinCount.toLocaleString()} Skins</span>
      <span class="hp-stat-dot">&middot;</span>
      <span class="hp-stat-pill">{playerCount}+ Pro Players</span>
      <span class="hp-stat-dot">&middot;</span>
      <span class="hp-stat-pill">8 Active Maps</span>
      <span class="hp-stat-dot">&middot;</span>
      <span class="hp-stat-pill">40+ Tools</span>
    </div>

    <div class="hp-search-wrap">
      <form action="/search/" method="get" class="hp-search-form">
        <svg class="hp-search-icon" viewBox="0 0 24 24"><circle cx="11" cy="11" r="7" fill="none" stroke="currentColor" stroke-width="2"/><line x1="16.5" y1="16.5" x2="21" y2="21" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
        <input type="search" name="q" placeholder="Search the wiki..." class="hp-search-input" autocomplete="off" />
        <button type="submit" class="hp-search-btn">Search</button>
      </form>
    </div>

    <div class="hp-quick-cats">
      <a href="/cs2-skins/" class="hp-cat-pill">Skins</a>
      <a href="/cs2-weapons/" class="hp-cat-pill">Weapons</a>
      <a href="/cs2-maps/" class="hp-cat-pill">Maps</a>
      <a href="/pro-players/" class="hp-cat-pill">Pro Players</a>
      <a href="/cs2-tools/" class="hp-cat-pill">Tools</a>
      <a href="/cs2-guides/" class="hp-cat-pill">Guides</a>
    </div>
  </div>
</section>

<!-- ===== CATEGORY NAV ===== -->
<nav class="hp-nav">
  <a href="/cs2-skins/" class="hp-nav-item"><svg viewBox="0 0 24 24"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg><span>Skins</span></a>
  <a href="/cs2-weapons/" class="hp-nav-item"><svg viewBox="0 0 24 24"><path d="M22 2L11 13M22 2l-7 20-4-9-9-4 20-7z" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg><span>Weapons</span></a>
  <a href="/pro-players/" class="hp-nav-item"><svg viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2" fill="none" stroke="currentColor" stroke-width="1.5"/><circle cx="9" cy="7" r="4" fill="none" stroke="currentColor" stroke-width="1.5"/></svg><span>Pro Players</span></a>
  <a href="/cs2-maps/" class="hp-nav-item"><svg viewBox="0 0 24 24"><polygon points="1 6 1 22 8 18 16 22 23 18 23 2 16 6 8 2 1 6" fill="none" stroke="currentColor" stroke-width="1.5"/></svg><span>Maps</span></a>
  <a href="/cs2-cases/" class="hp-nav-item"><svg viewBox="0 0 24 24"><rect x="2" y="7" width="20" height="14" rx="2" fill="none" stroke="currentColor" stroke-width="1.5"/><path d="M16 7V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v2" fill="none" stroke="currentColor" stroke-width="1.5"/></svg><span>Cases</span></a>
  <a href="/cs2-tools/" class="hp-nav-item"><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="3" fill="none" stroke="currentColor" stroke-width="1.5"/><path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 01-2.83 2.83l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 012.83-2.83l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 014 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 010 4h-.09a1.65 1.65 0 00-1.51 1z" fill="none" stroke="currentColor" stroke-width="1.5"/></svg><span>Tools</span></a>
  <a href="/cs2-guides/" class="hp-nav-item"><svg viewBox="0 0 24 24"><path d="M2 3h6a4 4 0 014 4v14a3 3 0 00-3-3H2z" fill="none" stroke="currentColor" stroke-width="1.5"/><path d="M22 3h-6a4 4 0 00-4 4v14a3 3 0 013-3h7z" fill="none" stroke="currentColor" stroke-width="1.5"/></svg><span>Guides</span></a>
</nav>

<!-- ===== POPULAR SKINS ===== -->
<section class="hp-section">
  <div class="hp-section-head">
    <h2>Popular Skins</h2>
    <a href="/cs2-skins/" class="hp-section-link">View all {skinCount.toLocaleString()} skins &rarr;</a>
  </div>
  <div class="hp-skin-grid">
    {topSkins.map(skin => {
      const rc = RARITY_COLORS[skin.rarity] || '#fff';
      const rbg = RARITY_BG[skin.rarity] || 'rgba(255,255,255,0.05)';
      const low = getLowestPrice(skin);
      const high = getHighestPrice(skin);
      return (
        <a href={`/cs2-skin/${skin.slug}/`} class="hp-skin-card" style={`--rc:${rc}`}>
          <div class="hp-skin-head">
            <span class="hp-skin-weapon">{skin.weapon}</span>
            <strong class="hp-skin-name">{skin.name}</strong>
          </div>
          <span class="hp-skin-rarity" style={`background:${rc}`}>{skin.rarity}</span>
          <div class="hp-skin-img" style={`background:${rbg}`}>
            {skin.image
              ? <img src={homeSkinCardImage(skin.image)} alt={`${skin.weapon} | ${skin.name}`} width="240" height="180" loading="lazy" />
              : <div class="hp-skin-ph" style={`color:${rc}`}>{skin.name.substring(0,2)}</div>
            }
          </div>
          <div class="hp-skin-pricing">
            <span class="hp-skin-price">${low.toFixed(2)}{low !== high ? ` \u2013 $${high.toFixed(2)}` : ''}</span>
          </div>
          <div class="hp-skin-wears">
            {skin.prices.slice(0, 3).map(p => (
              <div class="hp-skin-wear-row">
                <span class="hp-skin-wear-name">{p.wear.replace('Factory New','FN').replace('Minimal Wear','MW').replace('Field-Tested','FT').replace('Well-Worn','WW').replace('Battle-Scarred','BS')}</span>
                <span class="hp-skin-wear-price">${p.price.toFixed(2)}</span>
              </div>
            ))}
            {skin.prices.length > 3 && <div class="hp-skin-wear-more">+{skin.prices.length - 3} more</div>}
          </div>
          <div class="hp-skin-foot">
            <span>{skin.prices.length} wear{skin.prices.length !== 1 ? 's' : ''}</span>
            <span>Float {skin.minFloat.toFixed(2)} &ndash; {skin.maxFloat.toFixed(2)}</span>
          </div>
        </a>
      );
    })}
  </div>
  <div class="hp-skin-cats">
    <strong>Browse by category:</strong>
    <a href="/cs2-skins/rifles/">Rifles</a>
    <a href="/cs2-skins/pistols/">Pistols</a>
    <a href="/cs2-skins/smgs/">SMGs</a>
    <a href="/cs2-skins/heavy/">Heavy</a>
    <a href="/cs2-skins/knives/">Knives</a>
    <a href="/cs2-skins/gloves/">Gloves</a>
  </div>
</section>

<!-- ===== WEAPONS ===== -->
<section class="hp-section">
  <div class="hp-section-head">
    <h2>Weapons</h2>
    <a href="/cs2-weapons/" class="hp-section-link">All {weaponCount} weapons &rarr;</a>
  </div>
  <div class="hp-weapon-grid">
    {featuredWeapons.map(w => (
      <a href={`/cs2-weapon/${w.slug}/`} class="hp-weapon-card">
        <strong>{w.name}</strong>
        <div class="hp-weapon-stats">
          {w.damage && <span>DMG {w.damage}</span>}
          {w.rpm && <span>RPM {w.rpm}</span>}
          {w.price && <span>${w.price}</span>}
        </div>
      </a>
    ))}
  </div>
  <div class="hp-weapon-links">
    <a href="/cs2-weapons/rifle/">Rifles</a>
    <a href="/cs2-weapons/pistol/">Pistols</a>
    <a href="/cs2-weapons/smg/">SMGs</a>
    <a href="/cs2-weapons/heavy/">Heavy</a>
    <a href="/cs2-weapons/knife/">Knives</a>
    <a href="/cs2-weapons/grenade/">Grenades</a>
    <a href="/weapon-compare/">Compare Weapons</a>
    <a href="/damage-calculator/">Damage Calculator</a>
    <a href="/recoil-patterns/">Recoil Patterns</a>
  </div>
</section>

<!-- ===== TOOLS ===== -->
<section class="hp-section">
  <div class="hp-section-head">
    <h2>Free Tools</h2>
    <a href="/cs2-tools/" class="hp-section-link">All 30+ tools &rarr;</a>
  </div>
  <div class="hp-tool-grid">
    {popularTools.map(t => (
      <a href={`/${t.slug}/`} class="hp-tool-card">
        <strong>{t.name}</strong>
        <span>{t.desc}</span>
      </a>
    ))}
  </div>
  <div class="hp-tool-links">
    <strong>More tools:</strong>
    <a href="/edpi-calculator/">eDPI Calculator</a>,
    <a href="/crosshair-codes/">Pro Crosshairs</a>,
    <a href="/price-tracker/">Price Tracker</a>,
    <a href="/tradeup-calculator/">Trade-Up Calculator</a>,
    <a href="/case-odds-calculator/">Case Odds</a>,
    <a href="/inventory-lookup/">Inventory Lookup</a>,
    <a href="/bind-generator/">Bind Generator</a>,
    <a href="/autoexec-generator/">Autoexec Generator</a>,
    <a href="/practice-config/">Practice Config</a>,
    <a href="/loadout-builder/">Loadout Builder</a>
  </div>
</section>

<!-- ===== MORE SECTIONS ===== -->
<div class="hp-grid-2">
  <section class="hp-section">
    <div class="hp-section-head">
      <h2>Pro Players</h2>
      <a href="/pro-players/" class="hp-section-link">{playerCount}+ configs &rarr;</a>
    </div>
    <p class="hp-section-desc">Crosshair codes, sensitivity, resolution, and full gear setups from verified professional CS2 players.</p>
    <div class="hp-quick-links">
      <a href="/pro-players/">Browse All Pros</a>
      <a href="/crosshair-codes/">Pro Crosshairs</a>
      <a href="/sensitivity-converter/">Sens Converter</a>
      <a href="/cs2-rank-distribution/">Rank Distribution</a>
    </div>
  </section>

  <section class="hp-section">
    <div class="hp-section-head">
      <h2>Maps & Strats</h2>
      <a href="/cs2-maps/" class="hp-section-link">All maps &rarr;</a>
    </div>
    <p class="hp-section-desc">Callout names, smoke lineups, flash spots, CT/T strategies and tips for every active duty map in the competitive pool.</p>
    <div class="hp-quick-links">
      <a href="/cs2-maps/">Map Reference</a>
      <a href="/workshop-maps/">Workshop Maps</a>
      <a href="/practice-config/">Practice Config</a>
      <a href="/cs2-guides/grenade-guide/">Grenade Guide</a>
    </div>
  </section>
</div>

<div class="hp-grid-2">
  <section class="hp-section">
    <div class="hp-section-head">
      <h2>Cases & Collections</h2>
      <a href="/cs2-cases/" class="hp-section-link">{caseCount} cases &rarr;</a>
    </div>
    <p class="hp-section-desc">Every CS2 weapon case with drop rates, skin contents, ROI analysis, and unboxing odds.</p>
    <div class="hp-quick-links">
      <a href="/cs2-cases/">Case Archive</a>
      <a href="/case-simulator/">Case Simulator</a>
      <a href="/case-odds-calculator/">Case Odds Calculator</a>
      <a href="/cs2-skins/">Skin Database</a>
    </div>
  </section>

  <section class="hp-section">
    <div class="hp-section-head">
      <h2>Guides & Learning</h2>
      <a href="/cs2-guides/" class="hp-section-link">All guides &rarr;</a>
    </div>
    <p class="hp-section-desc">In-depth guides covering economy management, skin trading, aim training, movement mechanics, and competitive strategy.</p>
    <div class="hp-quick-links">
      <a href="/cs2-guides/beginners-guide/">Beginner's Guide</a>
      <a href="/cs2-guides/trading-guide/">Trading Guide</a>
      <a href="/cs2-guides/economy-guide/">Economy Guide</a>
      <a href="/cs2-guides/movement-guide/">Movement Guide</a>
    </div>
  </section>
</div>

<!-- ===== CTA ===== -->
<section class="hp-cta-banner">
  <div class="hp-cta-inner">
    <div class="hp-cta-text">
      <strong>Ready to play?</strong>
      <span>Check out the full CSGOLuck experience.</span>
    </div>
    <a href="https://csgoluck.com" target="_blank" rel="noopener" class="hp-cta-btn">Visit CSGOLuck.com</a>
  </div>
</section>

<!-- ===== FAQ ===== -->
<section class="hp-faq">
  <h2>Frequently Asked Questions</h2>
  <dl class="hp-faq-list">
    {faqs.map(f => (
      <>
        <dt class="hp-faq-q">{f.question}</dt>
        <dd class="hp-faq-a">{f.answer}</dd>
      </>
    ))}
  </dl>
</section>

<!-- ===== INTERNAL LINKS ===== -->
<div class="internal-links">
  <strong>Explore:</strong>
  <a href="/cs2-skins/">Skins</a>
  <a href="/cs2-weapons/">Weapons</a>
  <a href="/pro-players/">Pro Players</a>
  <a href="/cs2-maps/">Maps</a>
  <a href="/cs2-cases/">Cases</a>
  <a href="/cs2-tools/">Tools</a>
  <a href="/cs2-guides/">Guides</a>
  <a href="/sensitivity-converter/">Sens Converter</a>
  <a href="/crosshair-generator/">Crosshair Generator</a>
  <a href="/damage-calculator/">Damage Calculator</a>
  <a href="/case-simulator/">Case Simulator</a>
  <a href="/float-checker/">Float Checker</a>
  <a href="/price-tracker/">Price Tracker</a>
  <a href="/weapon-compare/">Compare Weapons</a>
  <a href="/skin-compare/">Compare Skins</a>
  <a href="/inventory-lookup/">Inventory Lookup</a>
  <a href="/cs2-rank-distribution/">Ranks</a>
  <a href="/faq/">FAQ</a>
</div>

</Base>

<style is:inline>
/* ── Hero ─────────────────────────────────── */
.hp-hero{background:var(--bg);padding:3.5rem 2rem 2.5rem;border-bottom:1px solid var(--border)}
.hp-hero-inner{max-width:900px;margin:0 auto;text-align:left}

.hp-title{font-size:2.8rem;font-weight:900;margin:0 0 .75rem;color:#fff;line-height:1.1;letter-spacing:-.02em}
.hp-title em{font-style:normal;color:#2ecc71}
.hp-subtitle{font-size:1.05rem;color:var(--text2);margin:0 0 1.5rem;max-width:640px;line-height:1.65}

.hp-stats-row{display:flex;align-items:center;gap:.5rem;flex-wrap:wrap;margin-bottom:1.75rem}
.hp-stat-pill{display:inline-block;padding:.3rem .75rem;background:rgba(46,204,113,.08);border:1px solid rgba(46,204,113,.2);border-radius:4px;font-size:.82rem;font-weight:700;color:#2ecc71;white-space:nowrap}
.hp-stat-dot{color:var(--text2);font-size:.8rem;user-select:none}

.hp-search-wrap{max-width:100%;margin:0 0 1.25rem}
.hp-search-form{display:flex;align-items:center;background:var(--bg2);border:1px solid var(--border);border-radius:4px;overflow:hidden;transition:border-color .2s}
.hp-search-form:focus-within{border-color:#2ecc71}
.hp-search-icon{width:18px;height:18px;color:var(--text2);margin:0 0 0 .85rem;flex-shrink:0}
.hp-search-input{flex:1;background:none;border:none;color:#fff;font-size:.95rem;padding:.75rem .75rem;outline:none;min-width:0;font-family:inherit}
.hp-search-input::placeholder{color:var(--text2);opacity:.6}
.hp-search-btn{background:#2ecc71;color:#000;border:none;padding:.75rem 1.5rem;font-weight:700;font-size:.9rem;cursor:pointer;font-family:inherit;transition:background .2s}
.hp-search-btn:hover{background:#5dde9e}

.hp-quick-cats{display:flex;gap:.5rem;flex-wrap:wrap}
.hp-cat-pill{display:inline-block;padding:.45rem 1rem;background:var(--bg3);border:1px solid var(--border);border-radius:4px;font-size:.85rem;font-weight:600;color:var(--text2);text-decoration:none;transition:border-color .15s,color .15s}
.hp-cat-pill:hover{border-left:3px solid #2ecc71;color:#2ecc71}

/* ── Category Nav ─────────────────────────── */
.hp-nav{display:flex;justify-content:center;gap:.5rem;padding:1rem 0;border-bottom:1px solid var(--border);margin-bottom:2rem;flex-wrap:wrap}
.hp-nav-item{display:flex;flex-direction:column;align-items:center;gap:.25rem;padding:.6rem 1rem;text-decoration:none;color:var(--text2);font-size:.78rem;font-weight:600;transition:color .15s}
.hp-nav-item:hover{color:#2ecc71}
.hp-nav-item svg{width:22px;height:22px}

/* ── Sections ─────────────────────────────── */
.hp-section{margin-bottom:2rem;background:var(--bg2);border:1px solid var(--border);border-radius:4px;padding:1.25rem}
.hp-section-head{display:flex;align-items:center;justify-content:space-between;margin-bottom:1rem}
.hp-section-head h2{margin:0;font-size:1.15rem}
.hp-section-link{font-size:.82rem;color:#2ecc71;font-weight:600;text-decoration:none}
.hp-section-link:hover{text-decoration:underline}
.hp-section-desc{margin:0 0 1rem;font-size:.88rem;color:var(--text2);line-height:1.6}

.hp-grid-2{display:grid;grid-template-columns:1fr 1fr;gap:1rem}

/* ── Skin Grid ────────────────────────────── */
.hp-skin-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:.75rem;margin-bottom:1rem}
.hp-skin-card{display:flex;flex-direction:column;background:var(--bg3);border:1px solid var(--border);border-radius:4px;overflow:hidden;text-decoration:none;color:inherit;transition:border-color .15s}
.hp-skin-card:hover{border-left:3px solid var(--rc,#2ecc71)}
.hp-skin-head{padding:.6rem .7rem .3rem;text-align:center}
.hp-skin-weapon{display:block;font-size:.68rem;color:var(--text2);text-transform:uppercase;letter-spacing:.03em}
.hp-skin-name{display:block;font-size:.92rem;font-weight:800;margin-top:.1rem;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.hp-skin-rarity{display:block;margin:0 .6rem .4rem;padding:.15rem 0;border-radius:4px;font-size:.68rem;font-weight:700;text-transform:uppercase;letter-spacing:.04em;color:#000;text-align:center}
.hp-skin-img{display:flex;align-items:center;justify-content:center;min-height:100px;padding:.5rem;overflow:hidden}
.hp-skin-img img{max-width:90%;max-height:90px;object-fit:contain}
.hp-skin-ph{font-size:1.5rem;font-weight:900;opacity:.2}
.hp-skin-pricing{padding:.4rem .7rem .15rem;text-align:center}
.hp-skin-price{font-size:.95rem;font-weight:700;color:#2ecc71}
.hp-skin-wears{padding:.15rem .6rem .35rem}
.hp-skin-wear-row{display:flex;justify-content:space-between;padding:.15rem 0;font-size:.75rem;border-bottom:1px solid rgba(255,255,255,.04)}
.hp-skin-wear-row:last-child{border-bottom:none}
.hp-skin-wear-name{color:var(--text2)}
.hp-skin-wear-price{font-weight:700;color:#2ecc71}
.hp-skin-wear-more{text-align:center;font-size:.7rem;color:var(--text2);padding:.2rem 0}
.hp-skin-foot{display:flex;justify-content:space-between;padding:.4rem .7rem;background:rgba(255,255,255,.02);border-top:1px solid var(--border);font-size:.7rem;color:var(--text2);margin-top:auto}
.hp-skin-cats{font-size:.82rem;color:var(--text2)}
.hp-skin-cats strong{color:var(--text);margin-right:.3rem}
.hp-skin-cats a{color:#2ecc71;text-decoration:none;margin:0 .2rem}
.hp-skin-cats a:hover{text-decoration:underline}

/* ── Weapon Grid ──────────────────────────── */
.hp-weapon-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:.5rem;margin-bottom:1rem}
.hp-weapon-card{display:flex;flex-direction:column;gap:.25rem;padding:.75rem;background:var(--bg3);border:1px solid var(--border);border-radius:4px;text-decoration:none;color:inherit;transition:border-left .15s}
.hp-weapon-card:hover{border-left:3px solid #2ecc71}
.hp-weapon-card strong{font-size:.9rem;color:var(--text)}
.hp-weapon-stats{display:flex;gap:.75rem;font-size:.75rem;color:var(--text2)}
.hp-weapon-links{font-size:.82rem;color:var(--text2)}
.hp-weapon-links a{color:#2ecc71;text-decoration:none;margin:0 .2rem}
.hp-weapon-links a:hover{text-decoration:underline}

/* ── Tool Grid ────────────────────────────── */
.hp-tool-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:.5rem;margin-bottom:1rem}
.hp-tool-card{display:flex;flex-direction:column;gap:.2rem;padding:.75rem;background:var(--bg3);border:1px solid var(--border);border-radius:4px;text-decoration:none;color:inherit;transition:border-left .15s}
.hp-tool-card:hover{border-left:3px solid #2ecc71}
.hp-tool-card strong{font-size:.88rem;color:var(--text)}
.hp-tool-card span{font-size:.75rem;color:var(--text2)}
.hp-tool-links{font-size:.82rem;color:var(--text2);line-height:1.8}
.hp-tool-links strong{color:var(--text);margin-right:.3rem}
.hp-tool-links a{color:#2ecc71;text-decoration:none}
.hp-tool-links a:hover{text-decoration:underline}

/* ── Quick Links ──────────────────────────── */
.hp-quick-links{display:flex;flex-wrap:wrap;gap:.4rem}
.hp-quick-links a{padding:.4rem .75rem;background:var(--bg3);border:1px solid var(--border);border-radius:4px;font-size:.82rem;font-weight:600;color:var(--text2);text-decoration:none;transition:border-color .15s,color .15s}
.hp-quick-links a:hover{border-color:#2ecc71;color:#2ecc71}

/* ── CTA Banner ───────────────────────────── */
.hp-cta-banner{margin-bottom:2rem;background:linear-gradient(135deg,#1a6b3a 0%,#145a2f 50%,#0f4423 100%);border-radius:4px;padding:2rem}
.hp-cta-inner{display:flex;align-items:center;justify-content:space-between;gap:1.5rem;flex-wrap:wrap}
.hp-cta-text strong{display:block;font-size:1.3rem;font-weight:800;color:#fff;margin-bottom:.15rem}
.hp-cta-text span{font-size:.95rem;color:rgba(255,255,255,.75)}
.hp-cta-btn{display:inline-block;background:#fff;color:#145a2f;font-weight:800;font-size:.95rem;padding:.75rem 2rem;border-radius:4px;text-decoration:none;transition:background .2s;white-space:nowrap}
.hp-cta-btn:hover{background:#5dde9e;color:#000}

/* ── FAQ ──────────────────────────────────── */
.hp-faq{margin-bottom:2rem}
.hp-faq h2{font-size:1.15rem;margin:0 0 1rem}
.hp-faq-list{margin:0}
.hp-faq-q{padding:1rem 2rem 1rem 0;font-weight:700;font-size:.95rem;color:var(--text);cursor:pointer;border-bottom:1px solid var(--border);position:relative;transition:color .2s}
.hp-faq-q::after{content:'+';position:absolute;right:0;top:50%;transform:translateY(-50%);font-size:1.2rem;color:var(--text2);transition:color .2s}
.hp-faq-q.open::after{content:'\2212';color:#2ecc71}
.hp-faq-q.open{color:#2ecc71;border-color:#2ecc71}
.hp-faq-a{max-height:0;overflow:hidden;margin:0;padding:0;font-size:.88rem;color:var(--text2);line-height:1.65;transition:max-height .35s ease,padding .35s ease}
.hp-faq-a.open{max-height:300px;padding:.75rem 0 1rem}

/* ── Responsive ───────────────────────────── */
@media(max-width:1000px){
  .hp-skin-grid{grid-template-columns:repeat(3,1fr)}
}
@media(max-width:768px){
  .hp-title{font-size:2rem}
  .hp-subtitle{font-size:.95rem}
  .hp-stats-row{gap:.35rem}
  .hp-stat-dot{display:none}
  .hp-skin-grid{grid-template-columns:repeat(2,1fr)}
  .hp-weapon-grid,.hp-tool-grid{grid-template-columns:repeat(2,1fr)}
  .hp-grid-2{grid-template-columns:1fr}
  .hp-cta-inner{flex-direction:column;text-align:center}
  .hp-nav{gap:.25rem}
  .hp-nav-item{padding:.5rem .6rem;font-size:.72rem}
  .hp-nav-item svg{width:18px;height:18px}
}
@media(max-width:480px){
  .hp-hero{padding:2rem 1rem 1.5rem}
  .hp-title{font-size:1.6rem}
  .hp-skin-grid{grid-template-columns:1fr}
  .hp-weapon-grid,.hp-tool-grid{grid-template-columns:1fr}
  .hp-quick-cats{gap:.35rem}
  .hp-cat-pill{padding:.35rem .7rem;font-size:.8rem}
}
</style>

<script>
if (typeof window !== 'undefined') {
  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('.hp-faq-q').forEach(dt => {
      dt.addEventListener('click', () => {
        const dd = dt.nextElementSibling;
        const isOpen = dt.classList.contains('open');
        document.querySelectorAll('.hp-faq-q').forEach(d => d.classList.remove('open'));
        document.querySelectorAll('.hp-faq-a').forEach(d => d.classList.remove('open'));
        if (!isOpen && dd) {
          dt.classList.add('open');
          dd.classList.add('open');
        }
      });
    });
  });
}
</script>
