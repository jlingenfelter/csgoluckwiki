<script is:inline>
(function initReel() {
  var dataEl = document.getElementById('hpReelData');
  if (!dataEl) { document.addEventListener('DOMContentLoaded', initReel); return; }
  var skins;
  try { skins = JSON.parse(dataEl.textContent); } catch(e) { return; }
  if (!skins || skins.length === 0) return;

  const strip = document.getElementById('hpReelStrip');
  const spinBtn = document.getElementById('hpSpinBtn');
  const resultDiv = document.getElementById('hpReelResult');
  const resultInner = document.getElementById('hpReelResultInner');
  if (!strip || !spinBtn) return;

  const ITEM_W = window.innerWidth <= 600 ? 80 : 110;
  const STRIP_COUNT = 60;
  let isSpinning = false;
  let hasSpun = false;

  // Build the reel strip with random skins
  function fmtPriceReel(v) { return '$' + v.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 }); }

  function buildReelItem(skin) {
    const item = document.createElement('div');
    item.className = 'hp-reel-item';
    item.style.background = skin.bg;
    item.innerHTML =
      '<img src="' + skin.image + '" alt="' + skin.weapon + ' | ' + skin.name + '" class="hp-reel-item-img" loading="lazy" />' +
      '<span class="hp-reel-item-name">' + skin.weapon + ' | ' + skin.name + '</span>';
    const bar = document.createElement('div');
    bar.className = 'hp-reel-item-bar';
    bar.style.background = skin.color;
    item.appendChild(bar);
    return item;
  }

  function buildGoldItem() {
    var item = document.createElement('div');
    item.className = 'hp-reel-item hp-reel-gold';
    item.innerHTML =
      '<img src="/images/csgoluck-logo.png" alt="CSGOLuck" class="hp-reel-item-img hp-reel-gold-img" />' +
      '<span class="hp-reel-item-name">CSGOLuck</span>';
    var bar = document.createElement('div');
    bar.className = 'hp-reel-item-bar';
    bar.style.background = '#ffd700';
    item.appendChild(bar);
    return item;
  }

  function buildStrip() {
    strip.innerHTML = '';
    for (var i = 0; i < STRIP_COUNT; i++) {
      if (i % 8 === 4) {
        strip.appendChild(buildGoldItem());
      } else {
        var skin = skins[Math.floor(Math.random() * skins.length)];
        strip.appendChild(buildReelItem(skin));
      }
    }
    strip.style.transform = 'translateX(0)';
    strip.classList.remove('spinning');
  }

  buildStrip();

  function popConfetti(container) {
    var colors = ['#ffd700','#ffaa00','#2ecc71','#fff','#e4ae39'];
    for (var i = 0; i < 60; i++) {
      var c = document.createElement('div');
      c.className = 'hp-confetti';
      c.style.left = Math.random() * 100 + '%';
      c.style.background = colors[Math.floor(Math.random() * colors.length)];
      c.style.animationDelay = (Math.random() * 0.5) + 's';
      c.style.animationDuration = (1.5 + Math.random() * 1.5) + 's';
      container.appendChild(c);
    }
    setTimeout(function() {
      container.querySelectorAll('.hp-confetti').forEach(function(el) { el.remove(); });
    }, 3500);
  }

  function spin() {
    if (isSpinning) return;
    isSpinning = true;
    spinBtn.disabled = true;
    spinBtn.textContent = 'Opening...';
    resultDiv.style.display = 'none';

    // 1 in 5 chance of hitting the gold symbol
    var isGoldWin = Math.random() < 0.2;

    // Rebuild strip for fresh randomness
    buildStrip();

    // Pick winning index
    var winIdx = 40 + Math.floor(Math.random() * 10);
    var winSkin = isGoldWin ? null : skins[Math.floor(Math.random() * skins.length)];

    // Replace the winning item
    if (strip.children[winIdx]) {
      if (isGoldWin) {
        strip.replaceChild(buildGoldItem(), strip.children[winIdx]);
      } else {
        strip.replaceChild(buildReelItem(winSkin), strip.children[winIdx]);
      }
    }

    // Calculate offset to center the winning item in viewport
    var viewportW = strip.parentElement.offsetWidth;
    var targetX = (winIdx * ITEM_W) - (viewportW / 2) + (ITEM_W / 2);
    var offset = targetX + (Math.random() * 20 - 10);

    requestAnimationFrame(function() {
      strip.classList.add('spinning');
      strip.style.transform = 'translateX(-' + offset + 'px)';
    });

    setTimeout(function() {
      isSpinning = false;
      hasSpun = true;
      spinBtn.disabled = false;
      spinBtn.innerHTML = '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v2"/></svg> Spin Again';

      if (isGoldWin) {
        // Gold win — confetti + bonus offer
        popConfetti(document.querySelector('.hp-reel-section'));
        resultInner.innerHTML =
          '<div class="hp-reel-gold-win">' +
            '<img src="/images/csgoluck-logo.png" alt="CSGOLuck" class="hp-reel-gold-win-logo" />' +
            '<div class="hp-reel-gold-win-info">' +
              '<div class="hp-reel-gold-win-title">BONUS UNLOCKED!</div>' +
              '<div class="hp-reel-gold-win-desc">100% up to 100 Coins + 5 Free Cases</div>' +
            '</div>' +
          '</div>';
        document.getElementById('hpReelCta').textContent = 'Claim Your Bonus at CSGOLuck \u2192';
      } else {
        // Normal skin win
        var priceHtml = winSkin.price > 0 ? '<span class="hp-reel-result-price">' + fmtPriceReel(winSkin.price) + '</span>' : '';
        resultInner.innerHTML =
          '<img src="' + winSkin.image + '" alt="' + winSkin.weapon + ' | ' + winSkin.name + '" class="hp-reel-result-img" />' +
          '<div class="hp-reel-result-info">' +
            '<div class="hp-reel-result-weapon">' + winSkin.weapon + '</div>' +
            '<div class="hp-reel-result-name">' + winSkin.name + '</div>' +
            '<div class="hp-reel-result-meta">' +
              '<span class="hp-reel-result-rarity" style="background:' + winSkin.color + '">' + winSkin.rarity + '</span>' +
              priceHtml +
            '</div>' +
          '</div>';
        document.getElementById('hpReelCta').textContent = 'Open Real Cases at CSGOLuck \u2192';
      }
      resultDiv.style.display = 'block';
    }, 4200);
  }

  spinBtn.addEventListener('click', spin);
})();
</script>

<script>
if (typeof window !== 'undefined') {
  document.addEventListener('DOMContentLoaded', () => {
    // FAQ accordion
    document.querySelectorAll('.hp-faq-q').forEach(dt => {
      dt.addEventListener('click', () => {
        const dd = dt.nextElementSibling;
        const isOpen = dt.classList.contains('open');
        document.querySelectorAll('.hp-faq-q').forEach(d => d.classList.remove('open'));
        document.querySelectorAll('.hp-faq-a').forEach(d => d.classList.remove('open'));
        if (!isOpen && dd) {
          dt.classList.add('open');
          dd.classList.add('open');
        }
      });
    });

    // Live esports matches
    (async function loadEsportsMatches() {
      const container = document.getElementById('wikiEsportsLive');
      if (!container) return;
      try {
        let res = await fetch('/api/matches?type=running&per_page=3');
        let data = await res.json();
        let matches = data.matches || [];
        let badge = 'live';
        if (matches.length === 0) {
          res = await fetch('/api/matches?type=upcoming&per_page=3');
          data = await res.json();
          matches = data.matches || [];
          badge = 'upcoming';
        }
        if (matches.length === 0) {
          // No matches — show running/upcoming tournaments instead
          try {
            let tRes = await fetch('/api/tournaments?type=running&per_page=3');
            let tData = await tRes.json();
            let tournaments = tData.tournaments || [];
            if (tournaments.length === 0) {
              tRes = await fetch('/api/tournaments?type=upcoming&per_page=3');
              tData = await tRes.json();
              tournaments = tData.tournaments || [];
            }
            if (tournaments.length > 0) {
              container.innerHTML = tournaments.map((t: any) => {
                const league = t.league?.name || '';
                const leagueImg = t.league?.image || '';
                const dates = t.beginAt ? new Date(t.beginAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) : '';
                const tier = t.tier ? t.tier.charAt(0).toUpperCase() + t.tier.slice(1) : '';
                const prize = t.prizepool || '';
                return `<a href="/tournaments/" class="hp-esports-match">
                  <div class="hp-esports-team">
                    ${leagueImg ? `<img src="${leagueImg}" alt="${league}" class="hp-esports-team-logo" />` : ''}
                    <span class="hp-esports-team-name">${t.name || league}</span>
                  </div>
                  <div class="hp-esports-meta" style="flex:1;align-items:flex-end">
                    ${prize ? `<span style="font-size:.75rem;color:#2ecc71;font-weight:700">${prize}</span>` : ''}
                    ${tier ? `<span class="hp-esports-badge hp-esports-badge-upcoming">${tier}</span>` : ''}
                    ${dates ? `<span class="hp-esports-league">${dates}</span>` : ''}
                  </div>
                </a>`;
              }).join('');
              return;
            }
          } catch {}
          container.innerHTML = '<div class="hp-esports-placeholder"><span>No live matches right now — check <a href="/matches/" style="color:#2ecc71">Match Tracker</a></span></div>';
          return;
        }
        container.innerHTML = matches.map((m: any) => {
          const t1 = m.opponents?.[0] || {};
          const t2 = m.opponents?.[1] || {};
          const r1 = m.results?.[0]?.score ?? '-';
          const r2 = m.results?.[1]?.score ?? '-';
          const league = m.league?.name || m.tournament?.name || '';
          const badgeCls = badge === 'live' ? 'hp-esports-badge-live' : 'hp-esports-badge-upcoming';
          const badgeText = badge === 'live' ? 'LIVE' : 'Upcoming';
          return `<a href="/matches/" class="hp-esports-match">
            <div class="hp-esports-match-teams">
              <div class="hp-esports-team">
                ${t1.image ? `<img src="${t1.image}" alt="${t1.name||''}" class="hp-esports-team-logo" />` : ''}
                <span class="hp-esports-team-name">${t1.name || 'TBD'}</span>
              </div>
              <span class="hp-esports-score">${r1} - ${r2}</span>
              <div class="hp-esports-team" style="justify-content:flex-end">
                <span class="hp-esports-team-name" style="text-align:right">${t2.name || 'TBD'}</span>
                ${t2.image ? `<img src="${t2.image}" alt="${t2.name||''}" class="hp-esports-team-logo" />` : ''}
              </div>
            </div>
            <div class="hp-esports-meta">
              <span class="hp-esports-badge ${badgeCls}">${badgeText}</span>
              <span class="hp-esports-league">${league}</span>
            </div>
          </a>`;
        }).join('');
      } catch (e) {
        container.innerHTML = '<div class="hp-esports-placeholder"><span>Could not load matches — <a href="/matches/" style="color:#2ecc71">view all</a></span></div>';
      }
    })();
  });
}
</script>
