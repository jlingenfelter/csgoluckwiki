---
import Base from '../layouts/Base.astro';
import { SKINS, getLowestPrice, getHighestPrice, RARITY_COLORS, RARITY_BG, SKINS_TOTAL, getCollections, fmtPrice } from '../lib/skins';
import { WEAPONS, getWeaponImage } from '../lib/weapons';
import { faqSchema } from '../lib/weapons';
import { skinHeroImage, skinHeroSideImage, homeSkinCardImage, categoryCardImage } from '../lib/imageOptimize';
import { getAllGear, getGearImageUrl, getPlayerBySlug } from '../lib/pro-players';
import { caseDatabase } from '../lib/cases';
import { MAP_LAYOUTS } from '../lib/map-layouts';
import casePricesData from '../lib/case-prices.json';

const topSkins = SKINS
  .filter(s => !s.phase)
  .map(skin => ({ ...skin, maxPrice: getHighestPrice(skin) }))
  .sort((a, b) => b.maxPrice - a.maxPrice)
  .slice(0, 12);

// ── Best Deal of the Day ──────────────────────────────────────────────────────
// Load previous price snapshot for price-drop detection
let previousPrices: Record<string, { price: number; providers?: Record<string, number> }> = {};
try {
  const prevData = await import('../lib/prices-previous.json');
  previousPrices = (prevData as any).default?.prices || (prevData as any).prices || {};
} catch { /* no previous prices yet */ }

interface DealCandidate {
  skin: typeof SKINS[0];
  currentPrice: number;
  previousPrice: number;
  priceDrop: number;
  dropPct: number;
  providerGap: number;
  providerGapPct: number;
  buffPrice: number;
  otherPrice: number;
  otherSource: string;
  dealScore: number;
}

// Find skins >$50 with the best deals
const dealCandidates: DealCandidate[] = [];
const eligibleDealSkins = SKINS.filter(s => !s.phase && s.image && s.prices.length > 0 && getLowestPrice(s) >= 50);

for (const skin of eligibleDealSkins) {
  const currentPrice = getLowestPrice(skin);
  const prev = previousPrices[skin.slug];
  const previousPrice = prev?.price || 0;
  const priceDrop = previousPrice > 0 ? previousPrice - currentPrice : 0;
  const dropPct = previousPrice > 0 && priceDrop > 0 ? (priceDrop / previousPrice) * 100 : 0;

  // Check provider gap (buff163 vs next cheapest non-buff provider)
  let buffPrice = 0;
  let otherPrice = 0;
  let otherSource = '';
  for (const p of skin.prices) {
    if (p.providers) {
      const buff = p.providers.buff163 || p.providers.buff163_buy || 0;
      if (buff > 0 && !buffPrice) buffPrice = buff;
      // Find best non-buff provider
      for (const [src, val] of Object.entries(p.providers)) {
        if (src === 'buff163' || src === 'buff163_buy') continue;
        if (val > buff && (!otherPrice || val > otherPrice)) {
          otherPrice = val;
          otherSource = src;
        }
      }
      if (buffPrice) break;
    }
  }
  const providerGap = otherPrice > 0 && buffPrice > 0 ? otherPrice - buffPrice : 0;
  const providerGapPct = otherPrice > 0 && providerGap > 0 ? (providerGap / otherPrice) * 100 : 0;

  // Combined deal score: weight price drops higher, provider gaps as bonus
  const dealScore = (dropPct * 2) + providerGapPct;

  if (priceDrop > 0 || providerGap > 0) {
    dealCandidates.push({
      skin, currentPrice, previousPrice, priceDrop, dropPct,
      providerGap, providerGapPct, buffPrice, otherPrice, otherSource, dealScore,
    });
  }
}

// Sort by deal score and pick deterministically
dealCandidates.sort((a, b) => b.dealScore - a.dealScore);

// Fallback: if no deals found (no price drops & no provider gaps), pick highest-liquidity skins >$50
let bestDeal: DealCandidate | null = dealCandidates.length > 0 ? dealCandidates[0] : null;
let dealFallback = false;

if (!bestDeal) {
  dealFallback = true;
  const liquidSkins = eligibleDealSkins
    .filter(s => (s.liquidity || 0) > 0 || (s.volume7d || 0) > 0)
    .sort((a, b) => ((b.liquidity || 0) + (b.volume7d || 0)) - ((a.liquidity || 0) + (a.volume7d || 0)));

  // Use deterministic daily pick from top liquid skins
  if (liquidSkins.length > 0) {
    const dayIdx = Math.floor(Date.now() / 86400000) % Math.min(liquidSkins.length, 20);
    const fallbackSkin = liquidSkins[dayIdx];
    bestDeal = {
      skin: fallbackSkin,
      currentPrice: getLowestPrice(fallbackSkin),
      previousPrice: 0, priceDrop: 0, dropPct: 0,
      providerGap: 0, providerGapPct: 0,
      buffPrice: 0, otherPrice: 0, otherSource: '', dealScore: 0,
    };
  }
}

const dealSkin = bestDeal?.skin;
const dealRc = dealSkin ? (RARITY_COLORS[dealSkin.rarity] || '#fff') : '#fff';
const dealBg = dealSkin ? (RARITY_BG[dealSkin.rarity] || 'rgba(255,255,255,0.05)') : 'rgba(255,255,255,0.05)';

const skinCount = SKINS_TOTAL || SKINS.length;
const weaponCount = WEAPONS.length;
const collectionCount = getCollections().length;

// Count pro players
const playerFiles = import.meta.glob('../data/players/*.json', { eager: true });
const playerCount = Object.keys(playerFiles).length;

// Hero skins — pick 3 high-value skins with images
const heroSkins = SKINS
  .filter(s => !s.phase && s.image && getHighestPrice(s) > 500)
  .sort((a, b) => getHighestPrice(b) - getHighestPrice(a))
  .slice(0, 3);

// Popular weapons for quick links
const popularWeapons = ['ak-47', 'awp', 'm4a4', 'm4a1-s', 'desert-eagle', 'usp-s'];
const featuredWeapons = WEAPONS.filter(w => popularWeapons.includes(w.slug));

// Case count
const caseCount = Object.keys(caseDatabase).length;

// Popular tool links
const popularTools = [
  { name: 'Sensitivity Converter', slug: 'sensitivity-converter', desc: 'Convert sens between games', icon: '<path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>' },
  { name: 'Crosshair Generator', slug: 'crosshair-generator', desc: 'Build & export crosshairs', icon: '<circle cx="12" cy="12" r="3" fill="none" stroke="currentColor" stroke-width="2"/><line x1="12" y1="2" x2="12" y2="8" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="12" y1="16" x2="12" y2="22" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="2" y1="12" x2="8" y2="12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="16" y1="12" x2="22" y2="12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>' },
  { name: 'Damage Calculator', slug: 'damage-calculator', desc: 'Calculate exact damage', icon: '<rect x="4" y="2" width="16" height="20" rx="2" fill="none" stroke="currentColor" stroke-width="2"/><line x1="8" y1="6" x2="16" y2="6" stroke="currentColor" stroke-width="2"/><line x1="8" y1="10" x2="16" y2="10" stroke="currentColor" stroke-width="1.5"/><line x1="8" y1="14" x2="12" y2="14" stroke="currentColor" stroke-width="1.5"/><line x1="8" y1="18" x2="14" y2="18" stroke="currentColor" stroke-width="1.5"/>' },
  { name: 'Case Simulator', slug: 'case-simulator', desc: 'Open cases risk-free', icon: '<rect x="2" y="7" width="20" height="14" rx="2" fill="none" stroke="currentColor" stroke-width="2"/><path d="M16 7V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v2" fill="none" stroke="currentColor" stroke-width="2"/><circle cx="12" cy="14" r="2" fill="currentColor"/>' },
  { name: 'Float Checker', slug: 'float-checker', desc: 'Inspect skin wear values', icon: '<path d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>' },
  { name: 'Economy Calculator', slug: 'economy-calculator', desc: 'Plan your buy rounds', icon: '<line x1="12" y1="1" x2="12" y2="23" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>' },
];

// Featured pro players with photos
const featuredPlayerSlugs = ['s1mple', 'zywoo', 'niko', 'ropz', 'm0nesy', 'donk'];
const featuredPlayers = featuredPlayerSlugs
  .map(slug => getPlayerBySlug(slug))
  .filter((p): p is NonNullable<typeof p> => !!p && !!p.image);

// Featured maps for thumbnails
const featuredMapSlugs = ['dust2', 'mirage', 'inferno', 'nuke'];
const featuredMaps = MAP_LAYOUTS.filter(m => featuredMapSlugs.includes(m.slug));

// Featured cases with images
const featuredCaseSlugs = ['kilowatt', 'gallery', 'revolution', 'dreams-nightmares', 'clutch'];
const casePrices = (casePricesData as any).cases || {};
const featuredCases = featuredCaseSlugs
  .map(slug => {
    const caseData = caseDatabase[slug];
    const priceData = casePrices[slug];
    if (!caseData || !priceData?.image) return null;
    return { slug, name: caseData.name, image: priceData.image, price: priceData.price };
  })
  .filter((c): c is NonNullable<typeof c> => !!c);

// ── Mini Case Opening Reel ─────────────────────────────────────────────────────
// Build a pool of skins from the Kilowatt case for the homepage reel
const reelCase = caseDatabase['kilowatt'];
const reelSkins: { weapon: string; name: string; rarity: string; image: string; color: string; bg: string; price: number }[] = [];
if (reelCase) {
  for (const skin of reelCase.skins) {
    const found = SKINS.find(s => s.weapon === skin.weapon && s.name === skin.name && !s.phase);
    if (found?.image) {
      const skinPrice = getLowestPrice(found);
      reelSkins.push({
        weapon: skin.weapon,
        name: skin.name,
        rarity: skin.rarity,
        image: found.image,
        color: RARITY_COLORS[skin.rarity] || RARITY_COLORS[found.rarity] || '#b0c3d9',
        bg: RARITY_BG[skin.rarity] || RARITY_BG[found.rarity] || 'rgba(176,195,217,0.15)',
        price: skinPrice,
      });
    }
  }
}
const reelSkinsJson = JSON.stringify(reelSkins);

const faqs = [
  { question: 'What is CSGOLuck Wiki?', answer: 'CSGOLuck Wiki is the knowledge base powered by CSGOLuck.com, built for the CS2 community. We track skin prices across 14+ marketplaces, document weapon stats, catalog settings from 860+ pro players, and provide 30+ free interactive tools — your one-stop shop for everything Counter-Strike 2.' },
  { question: 'How are skin prices sourced?', answer: 'We pull pricing data from 14+ markets — Buff163, CSFloat, BitSkins, DMarket, and beyond — through the PriceEmpire API. Prices refresh regularly and cover every wear condition, StatTrak variant, and Doppler phase so you always have a clear picture of what skins are worth.' },
  { question: 'Do I need an account to use the tools?', answer: 'Nope. Every tool on CSGOLuck Wiki is 100% free with zero sign-up required. Damage calculators, sensitivity converters, crosshair generators, case simulators — just open the page and start using them.' },
  { question: 'Who runs CSGOLuck Wiki?', answer: 'CSGOLuck Wiki is an independent project brought to you by CSGOLuck.com. We are not affiliated with Valve Corporation — all game content and trademarks belong to their respective owners.' },
  { question: 'Where can I find pro player configs?', answer: `Head over to our Pro Players section to dig through ${playerCount}+ verified professional configs. Each profile includes crosshair codes, sensitivity, resolution, monitor, mouse, keyboard, and full gear breakdowns.` },
  { question: 'Can I compare weapons head-to-head?', answer: 'Absolutely. Our Weapon Compare tool lets you stack any two CS2 weapons side by side — damage output, rate of fire, recoil, armor penetration, and more — so you can make informed buy-round decisions.' },
  { question: 'Do you track individual Doppler phases?', answer: 'Yes. Every Doppler and Gamma Doppler knife gets its own dedicated page per phase — Phase 1 through 4, Ruby, Sapphire, Black Pearl, and Emerald — each with phase-specific market pricing and high-res images.' },
  { question: 'Can I check the value of my Steam inventory?', answer: 'For sure. Our Inventory Lookup tool scans any public Steam profile and totals up current market values for every CS2 skin, including float values and wear details.' },
  { question: 'What is CSGOLuck.com?', answer: 'CSGOLuck.com is our parent platform — visit csgoluck.com to explore everything we offer beyond the wiki, including CS2 gaming experiences and community features.' },
];
---

<Base title="CSGOLuck Wiki — The Ultimate CS2 Database" description={`The CS2 knowledge base by CSGOLuck.com — ${skinCount.toLocaleString()} skins with real-time market prices, ${weaponCount} weapons with full combat data, ${playerCount}+ pro player loadouts, and 30+ free tools to sharpen your game.`} currentNav="/">
<Fragment slot="head">
<script type="application/ld+json" set:html={JSON.stringify(faqSchema(faqs))} />
</Fragment>

<!-- ===== HERO ===== -->
<section class="hp-hero">
  {heroSkins.length >= 3 && (
    <div class="hp-hero-skins" aria-hidden="true">
      <img src={skinHeroSideImage(heroSkins[0].image)} alt="" class="hp-hero-skin hp-hero-skin-left" width="400" height="300" loading="eager" />
      <img src={skinHeroImage(heroSkins[1].image)} alt="" class="hp-hero-skin hp-hero-skin-center" width="600" height="450" loading="eager" />
      <img src={skinHeroSideImage(heroSkins[2].image)} alt="" class="hp-hero-skin hp-hero-skin-right" width="400" height="300" loading="eager" />
    </div>
  )}
  <div class="hp-hero-inner">
    <h1 class="hp-title">CSGOLuck <em>Wiki</em></h1>
    <p class="hp-subtitle">The open CS2 encyclopedia — community-driven guides, live market data, and pro player configs.</p>

    <div class="hp-stats-row">
      <span class="hp-stat-pill">{skinCount.toLocaleString()} Skins</span>
      <span class="hp-stat-dot">&middot;</span>
      <span class="hp-stat-pill">{playerCount}+ Pro Players</span>
      <span class="hp-stat-dot">&middot;</span>
      <span class="hp-stat-pill">8 Active Maps</span>
      <span class="hp-stat-dot">&middot;</span>
      <span class="hp-stat-pill">40+ Tools</span>
      <span class="hp-stat-dot">&middot;</span>
      <span class="hp-stat-pill hp-stat-live"><span class="hp-live-dot"></span>Live Esports</span>
    </div>

    <div class="hp-search-wrap">
      <form action="/search/" method="get" class="hp-search-form">
        <svg class="hp-search-icon" viewBox="0 0 24 24"><circle cx="11" cy="11" r="7" fill="none" stroke="currentColor" stroke-width="2"/><line x1="16.5" y1="16.5" x2="21" y2="21" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
        <input type="search" name="q" placeholder="Search the wiki..." class="hp-search-input" autocomplete="off" />
        <button type="submit" class="hp-search-btn">Search</button>
      </form>
    </div>

    <div class="hp-quick-cats">
      <a href="/cs2-skins/" class="hp-cat-pill">Skins</a>
      <a href="/cs2-weapons/" class="hp-cat-pill">Weapons</a>
