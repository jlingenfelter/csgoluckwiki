.hp-search-btn{background:linear-gradient(135deg,#2ecc71,#27ae60);color:#fff;border:none;padding:.75rem 1.5rem;font-weight:700;font-size:.9rem;cursor:pointer;font-family:inherit;box-shadow:0 4px 15px rgba(46,204,113,.3);transition:all .2s ease}
.hp-search-btn:hover{background:linear-gradient(135deg,#27ae60,#219a52);transform:translateY(-1px);box-shadow:0 6px 20px rgba(46,204,113,.45)}

.hp-quick-cats{display:flex;gap:.5rem;flex-wrap:wrap}
