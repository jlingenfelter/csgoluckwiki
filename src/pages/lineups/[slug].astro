            <svg class="icon" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <circle cx="12" cy="12" r="9" fill="none" stroke="currentColor" stroke-width="1.5"/>
              <path d="M12 5v14M5 12h14M8 8l11.31 11.31M16 8L4.69 19.31" stroke="currentColor" stroke-width="1.5"/>
            </svg>
          )}
          <span class="type-label">
            {lineup.type === 'smoke' && 'Smoke'}
            {lineup.type === 'flash' && 'Flash'}
            {lineup.type === 'molotov' && 'Molotov'}
            {lineup.type === 'he' && 'HE Grenade'}
          </span>
        </div>

        <div class="card-route">
          <div class="route-item">
            <span class="label">From:</span>
            <span class="value">{lineup.from}</span>
          </div>
          <span class="arrow">→</span>
          <div class="route-item">
            <span class="label">To:</span>
            <span class="value">{lineup.to}</span>
          </div>
        </div>

        <p class="description">{lineup.description}</p>

        <div class="use-case">
          <strong>Use Case:</strong> {lineup.useCase}
        </div>

        <!-- Radar Pin Button -->
        {mapLayout && (
          <button class="radar-pin-btn" data-radar-pin title="Pin on trajectory map">
            <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M12 2C7.58 2 4 5.58 4 10c0 5.25 8 13 8 13s8-7.75 8-13c0-4.42-3.58-8-8-8zm0 11c-1.66 0-3-1.34-3-3s1.34-3 3-3 3 1.34 3 3-1.34 3-3 3z" fill="currentColor"/>
            </svg>
          </button>
        )}
      </article>
    ))}
  </section>

  <!-- FAQ Section -->
  <section class="faq">
    <h2>Frequently Asked Questions</h2>
    <div class="faq-list">
      {faqs.map(faq => (
        <details class="faq-item">
          <summary>{faq.question}</summary>
          <p>{faq.answer}</p>
        </details>
      ))}
    </div>
  </section>

  <!-- Schema Markup -->
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbData)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqData)} />

  <!-- Hidden data for JS -->
  <div data-lineups style="display: none;">
    {JSON.stringify(lineups)}
  </div>

  <ExploreMore context="maps" />

  <style>
    .breadcrumbs {
      margin-bottom: 2rem;
      font-size: 0.95rem;
    }

    .breadcrumbs ol {
      display: flex;
      gap: 0.5rem;
      list-style: none;
      padding: 0;
      margin: 0;
    }

    .breadcrumbs li:not(:last-child)::after {
      content: '/';
      margin-left: 0.5rem;
      color: var(--text-secondary);
    }

    .breadcrumbs a {
      color: var(--accent);
      text-decoration: none;
    }

    .breadcrumbs a:hover {
      text-decoration: underline;
    }

    .hero {
      background: linear-gradient(135deg, var(--accent), var(--accent-dark));
      color: white;
      padding: 4rem 2rem;
      border-radius: 12px;
      margin-bottom: 3rem;
      text-align: center;
    }

    .hero h1 {
      font-size: 2.5rem;
      margin: 0;
      font-weight: 700;
    }

    .hero-subtitle {
      font-size: 1.1rem;
      margin: 1rem 0 0 0;
      opacity: 0.95;
    }

    /* Stats Bar */
    .stats-bar {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 1.5rem;
      margin-bottom: 3rem;
    }

    .stat-card {
      background: var(--bg-secondary);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 1.5rem;
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    .stat-value {
      font-size: 2.5rem;
      font-weight: 700;
      color: var(--accent);
    }

    .stat-label {
      font-size: 0.95rem;
      color: var(--text-secondary);
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    .type-breakdown {
      display: flex;
      height: 30px;
      border-radius: 4px;
      overflow: hidden;
      gap: 1px;
      background: var(--border);
    }

    .breakdown-item {
      min-width: 20px;
      transition: all 0.3s ease;
    }

    .breakdown-item:hover {
      filter: brightness(1.2);
    }

    .type-legend {
      display: flex;
      gap: 1rem;
      flex-wrap: wrap;
      font-size: 0.85rem;
    }

    .legend-item {
      display: flex;
      align-items: center;
      gap: 0.4rem;
      color: var(--text-secondary);
    }

    .legend-dot {
      width: 10px;
      height: 10px;
      border-radius: 2px;
      display: inline-block;
    }

    .side-split {
      display: flex;
      height: 30px;
      border-radius: 4px;
      overflow: hidden;
    }

    .side-item {
      display: flex;
      align-items: center;
      justify-content: center;
      color: white;
      font-weight: 600;
      font-size: 0.85rem;
      transition: all 0.3s ease;
    }

    .side-item:hover {
      filter: brightness(1.1);
    }

    .side-item.t-side {
      background: linear-gradient(90deg, #FF6B6B, #FF5252);
    }

    .side-item.ct-side {
      background: linear-gradient(90deg, #4A90E2, #357ABD);
    }

    .side-label {
      text-shadow: 0 1px 2px rgba(0, 0, 0, 0.3);
    }

    .difficulty-bars {
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
    }

    .difficulty-item {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      font-size: 0.85rem;
    }

    .bar-label {
      min-width: 50px;
      color: var(--text-secondary);
      font-weight: 600;
    }

    .bar {
      height: 20px;
      border-radius: 4px;
      min-width: 40px;
      transition: all 0.3s ease;
    }

    .bar:hover {
      filter: brightness(1.1);
    }

    .bar-count {
      min-width: 30px;
      text-align: right;
      color: var(--text-secondary);
      font-weight: 600;
      font-size: 0.8rem;
    }

    /* Learning Tracker */
    .learned-tracker {
      background: var(--bg-secondary);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 1.5rem;
      margin-bottom: 3rem;
    }

    .progress-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 1rem;
    }

    .progress-header h3 {
      margin: 0;
      color: var(--text-primary);
      font-size: 1.1rem;
    }

    [data-progress-text] {
      color: var(--text-secondary);
      font-size: 0.9rem;
      font-weight: 600;
    }

    .progress-container {
      width: 100%;
    }

    .progress-bar-background {
      width: 100%;
      height: 8px;
      background: var(--bg-primary);
      border-radius: 4px;
      overflow: hidden;
    }

    .progress-bar-fill {
      height: 100%;
      background: linear-gradient(90deg, #4CAF50, #8BC34A);
      border-radius: 4px;
      transition: width 0.3s ease;
    }

    /* Radar Section */
    .radar-section {
      background: var(--bg-secondary);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 2rem;
      margin-bottom: 3rem;
    }

    .radar-section h2 {
      margin: 0 0 1.5rem 0;
      font-size: 1.3rem;
      color: var(--text-primary);
    }

    .radar-container {
      width: 100%;
      max-width: 600px;
      margin: 0 auto 2rem;
      border: 1px solid var(--border);
      border-radius: 8px;
      overflow: hidden;
      background: var(--bg-primary);
      aspect-ratio: 1;
    }

    [data-radar-svg] {
      width: 100%;
      height: 100%;
      display: block;
    }

    .radar-legend {
      font-size: 0.9rem;
      color: var(--text-secondary);
      text-align: center;
    }

    .radar-legend p {
      margin: 0 0 1rem 0;
      font-style: italic;
    }

    .legend-items {
      display: flex;
      gap: 1.5rem;
      justify-content: center;
      flex-wrap: wrap;
    }

    .legend-items .legend-item {
      display: flex;
      align-items: center;
      gap: 0.4rem;
    }

    .legend-dot.green {
      background-color: #4CAF50;
    }

    .legend-dot.gray {
      background-color: #888888;
    }

    .legend-dot.yellow {
      background-color: #FFEB3B;
    }

    .legend-dot.orange {
      background-color: #FF9800;
    }

    .legend-dot.red {
      background-color: #F44336;
    }

    /* Filter Section */
    .filters {
      display: flex;
      gap: 2rem;
      margin-bottom: 3rem;
      flex-wrap: wrap;
      background: var(--bg-secondary);
      padding: 2rem;
      border-radius: 12px;
    }

    .filter-group {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }

    .filter-group label {
      font-weight: 600;
      font-size: 0.95rem;
    }

    .filter-group select {
      padding: 0.75rem;
      border: 1px solid var(--border);
      border-radius: 6px;
      background: var(--bg-primary);
      color: var(--text-primary);
      cursor: pointer;
      font-size: 0.95rem;
    }

    /* Lineups Grid */
    .lineups-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
      gap: 2rem;
      margin-bottom: 3rem;
    }

    .lineup-card {
      background: var(--bg-secondary);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 1.5rem;
      transition: all 0.3s ease;
      position: relative;
      border-left: 4px solid transparent;
    }

    .lineup-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 8px 24px rgba(0, 0, 0, 0.15);
      border-color: var(--accent);
    }

    .lineup-card.learned {
      border-left-color: #4CAF50;
      background: linear-gradient(90deg, rgba(76, 175, 80, 0.05), transparent);
    }

    .card-learned-section {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 1rem;
      margin-bottom: 1rem;
    }

    .card-header {
      flex: 1;
    }

    .card-header h3 {
      font-size: 1.3rem;
      margin: 0 0 0.75rem 0;
      color: var(--text-primary);
    }

    .badges {
      display: flex;
      gap: 0.5rem;
      flex-wrap: wrap;
    }

    .badge {
      display: inline-block;
      padding: 0.35rem 0.75rem;
      border-radius: 4px;
      font-size: 0.8rem;
      font-weight: 600;
      text-transform: uppercase;
    }

    .badge-side {
      background: var(--accent-light);
      color: var(--accent);
    }

    .badge-difficulty {
      background: var(--bg-primary);
      color: var(--text-secondary);
    }

    .badge-easy {
      background: rgba(76, 175, 80, 0.2);
      color: #4caf50;
    }

    .badge-medium {
      background: rgba(255, 193, 7, 0.2);
      color: #ffc107;
    }

    .badge-hard {
      background: rgba(244, 67, 54, 0.2);
      color: #f44336;
    }

    /* Learn Checkbox */
    .learn-checkbox-container {
      position: relative;
      display: inline-flex;
      align-items: center;
      cursor: pointer;
    }

    .learn-checkbox {
      appearance: none;
      width: 32px;
      height: 32px;
      border: 2px solid var(--border);
      border-radius: 6px;
      background: var(--bg-primary);
      cursor: pointer;
      transition: all 0.2s ease;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 0;
      margin: 0;
    }

    .learn-checkbox:hover {
      border-color: #4CAF50;
      background: rgba(76, 175, 80, 0.1);
    }

    .learn-checkbox:checked {
      background: #4CAF50;
      border-color: #4CAF50;
    }

    .checkmark {
      position: absolute;
      pointer-events: none;
      font-size: 1.2rem;
      color: white;
      display: none;
      font-weight: bold;
    }

    .learn-checkbox:checked ~ .checkmark {
      display: block;
    }

    /* Grenade Type Icons */
    .card-type {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      margin-bottom: 1rem;
      padding: 1rem;
      background: var(--bg-primary);
      border-radius: 8px;
    }

    .icon {
      width: 28px;
      height: 28px;
      color: var(--text-primary);
      flex-shrink: 0;
    }

    .card-type svg.icon {
      color: #888888;
    }

    .card-type [data-lineup-card*="flash"] svg.icon {
      color: #FFEB3B;
    }

    .card-type [data-lineup-card*="molotov"] svg.icon {
      color: #FF9800;
    }

    .card-type [data-lineup-card*="he"] svg.icon {
      color: #F44336;
    }

    .type-label {
      font-weight: 600;
      color: var(--text-primary);
    }

    /* Route Info */
    .card-route {
      display: flex;
      align-items: center;
      gap: 1rem;
      margin-bottom: 1.5rem;
      font-size: 0.9rem;
    }

    .route-item {
      display: flex;
      flex-direction: column;
      gap: 0.25rem;
    }

    .route-item .label {
      font-size: 0.8rem;
      color: var(--text-secondary);
      font-weight: 600;
    }

    .route-item .value {
      color: var(--text-primary);
      font-weight: 500;
    }

    .arrow {
      color: var(--accent);
      font-weight: bold;
      font-size: 1.2rem;
    }

    /* Description and Use Case */
    .description {
      font-size: 0.9rem;
      color: var(--text-secondary);
      margin: 0 0 1rem 0;
      line-height: 1.5;
    }

    .use-case {
      padding: 0.75rem;
      background: var(--bg-primary);
      border-radius: 6px;
      font-size: 0.85rem;
      border-left: 3px solid var(--accent);
      margin-bottom: 1rem;
    }

    /* Radar Pin Button */
    .radar-pin-btn {
      position: absolute;
      bottom: 1.5rem;
      right: 1.5rem;
      width: 36px;
      height: 36px;
      border: 1px solid var(--border);
      border-radius: 6px;
      background: var(--bg-primary);
      color: var(--text-secondary);
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: all 0.2s ease;
      padding: 0;
    }

    .radar-pin-btn:hover {
      color: var(--accent);
      border-color: var(--accent);
      background: rgba(var(--accent-rgb), 0.1);
    }

    .radar-pin-btn.pinned {
      background: var(--accent);
      color: white;
      border-color: var(--accent);
    }

    .radar-pin-btn svg {
      width: 18px;
      height: 18px;
    }

    /* FAQ Section */
    .faq {
      margin-top: 4rem;
    }

    .faq h2 {
      font-size: 2rem;
      margin-bottom: 2rem;
    }

    .faq-list {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    .faq-item {
      background: var(--bg-secondary);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 1.5rem;
      cursor: pointer;
    }

    .faq-item summary {
      font-weight: 600;
      color: var(--text-primary);
      cursor: pointer;
      user-select: none;
    }

    .faq-item summary:hover {
      color: var(--accent);
    }

    .faq-item p {
      margin: 1rem 0 0 0;
      color: var(--text-secondary);
      line-height: 1.6;
    }

    @media (max-width: 768px) {
      .hero {
        padding: 2rem 1rem;
      }

      .hero h1 {
        font-size: 1.8rem;
      }

      .stats-bar {
        grid-template-columns: 1fr;
      }

      .filters {
        flex-direction: column;
        gap: 1rem;
      }

      .lineups-grid {
        grid-template-columns: 1fr;
        gap: 1.5rem;
      }

      .card-learned-section {
        flex-direction: column;
      }

      .card-route {
        flex-direction: column;
        align-items: flex-start;
      }

      .arrow {
        transform: rotate(90deg);
      }

      .radar-container {
        max-width: 100%;
      }

      .radar-section {
        padding: 1rem;
      }

      .legend-items {
        gap: 0.75rem;
      }
    }
  </style>
</Base>
