<Base title={title} description={description} currentNav="lineups">
  <script define:vars={{ map, lineups: JSON.stringify(lineups), mapLayout: mapLayout ? JSON.stringify(mapLayout) : null }}>
    const STORAGE_KEY = `lineups-learned-${map}`;
    const RADAR_STORAGE_KEY = `radar-pinned-${map}`;

    window.mapLineups = JSON.parse(lineups);
    window.mapLayout = mapLayout ? JSON.parse(mapLayout) : null;
    window.learnedLineups = new Set(JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]'));
    window.pinnedLineup = localStorage.getItem(RADAR_STORAGE_KEY);

    function applyFilters() {
      const activeType = document.querySelector('[data-filter-type].lu-active');
      const activeSide = document.querySelector('[data-filter-side].lu-active');
      const activeDifficulty = document.querySelector('[data-filter-difficulty].lu-active');

      const typeFilter = activeType ? activeType.dataset.filterType : 'all';
      const sideFilter = activeSide ? activeSide.dataset.filterSide : 'all';
      const difficultyFilter = activeDifficulty ? activeDifficulty.dataset.filterDifficulty : 'all';

      const cards = document.querySelectorAll('[data-lineup-card]');
      let visibleCount = 0;

      cards.forEach(card => {
        const type = card.dataset.type;
        const side = card.dataset.side;
        const difficulty = card.dataset.difficulty;

        const typeMatch = typeFilter === 'all' || type === typeFilter;
        const sideMatch = sideFilter === 'all' || side === sideFilter;
        const difficultyMatch = difficultyFilter === 'all' || difficulty === difficultyFilter;

        if (typeMatch && sideMatch && difficultyMatch) {
          card.style.display = '';
          visibleCount++;
        } else {
          card.style.display = 'none';
        }
      });

      document.querySelector('[data-visible-count]').textContent = visibleCount;
    }

    function updateLearnedProgress() {
      const learnedCount = window.learnedLineups.size;
      const total = window.mapLineups.length;
      const progressBar = document.querySelector('[data-progress-bar]');
      const progressText = document.querySelector('[data-progress-text]');

      if (progressBar) {
        const percentage = (learnedCount / total) * 100;
        progressBar.style.width = percentage + '%';
      }

      if (progressText) {
        progressText.textContent = `${learnedCount}/${total} lineups learned`;
      }
    }

    function toggleLineupLearned(cardId) {
      if (window.learnedLineups.has(cardId)) {
        window.learnedLineups.delete(cardId);
      } else {
        window.learnedLineups.add(cardId);
      }

      localStorage.setItem(STORAGE_KEY, JSON.stringify([...window.learnedLineups]));
      updateLearnedUI();
      updateLearnedProgress();
      updateRadarMap();
    }

    function updateLearnedUI() {
      document.querySelectorAll('[data-lineup-card]').forEach((card, idx) => {
        const isLearned = window.learnedLineups.has(idx.toString());
        const checkbox = card.querySelector('[data-learn-checkbox]');
        if (checkbox) {
          checkbox.checked = isLearned;
        }

        if (isLearned) {
          card.classList.add('lu-learned');
        } else {
          card.classList.remove('lu-learned');
        }
      });
    }

    function updateRadarMap() {
      if (!window.mapLayout) return;

      const radarSvg = document.querySelector('[data-radar-svg]');
      if (!radarSvg) return;

      // Clear existing trajectories
      const trajectories = radarSvg.querySelectorAll('[data-trajectory]');
      trajectories.forEach(t => t.remove());

      // Redraw trajectories for all visible cards
      document.querySelectorAll('[data-lineup-card]').forEach((card, idx) => {
        if (card.style.display !== 'none') {
          const lineupData = window.mapLineups[idx];
          drawTrajectory(idx, lineupData, radarSvg, false);
        }
      });

      // Redraw pinned trajectory on top if exists
      if (window.pinnedLineup !== null) {
        const pinnedIdx = parseInt(window.pinnedLineup);
        const pinnedData = window.mapLineups[pinnedIdx];
        drawTrajectory(pinnedIdx, pinnedData, radarSvg, true);
      }
    }

    function drawTrajectory(idx, lineupData, radarSvg, isPinned) {
      const fromPos = fuzzyMatchPosition(lineupData.from);
      const toPos = fuzzyMatchPosition(lineupData.to);

      if (!fromPos || !toPos) return;

      const fromX = fromPos.x * 1024;
      const fromY = fromPos.y * 1024;
      const toX = toPos.x * 1024;
      const toY = toPos.y * 1024;

      const grenadeColors = {
        'smoke': '#888888',
        'flash': '#FFEB3B',
        'molotov': '#FF9800',
        'he': '#F44336'
      };

      const toColor = grenadeColors[lineupData.type] || '#888888';
      const opacity = isPinned ? 1 : 0.5;
      const strokeWidth = isPinned ? 3 : 2;

      // Create dashed curved arrow
      const midX = (fromX + toX) / 2;
      const midY = (fromY + toY) / 2;
      const controlX = midX - (toY - fromY) * 0.1;
      const controlY = midY + (toX - fromX) * 0.1;

      const path = document.createElementNS('http://www.w3.org/2000/svg', 'path');
      path.setAttribute('d', `M ${fromX} ${fromY} Q ${controlX} ${controlY} ${toX} ${toY}`);
      path.setAttribute('stroke', '#888888');
      path.setAttribute('stroke-width', strokeWidth);
      path.setAttribute('fill', 'none');
      path.setAttribute('stroke-dasharray', '5,5');
      path.setAttribute('opacity', opacity);
      path.setAttribute('data-trajectory', idx);
      path.style.pointerEvents = 'none';

      radarSvg.appendChild(path);

      // From dot (green)
      const fromDot = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
      fromDot.setAttribute('cx', fromX);
      fromDot.setAttribute('cy', fromY);
      fromDot.setAttribute('r', isPinned ? 8 : 5);
      fromDot.setAttribute('fill', '#4CAF50');
      fromDot.setAttribute('opacity', opacity);
      fromDot.setAttribute('data-trajectory', idx);
      fromDot.style.pointerEvents = 'none';
      radarSvg.appendChild(fromDot);

      // To dot (grenade type color)
      const toDot = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
      toDot.setAttribute('cx', toX);
      toDot.setAttribute('cy', toY);
      toDot.setAttribute('r', isPinned ? 8 : 5);
      toDot.setAttribute('fill', toColor);
      toDot.setAttribute('opacity', opacity);
      toDot.setAttribute('data-trajectory', idx);
      toDot.style.pointerEvents = 'none';
      radarSvg.appendChild(toDot);
    }

    function fuzzyMatchPosition(query) {
      if (!window.mapLayout || !window.mapLayout.calloutPositions) return null;

      const queryLower = query.toLowerCase();
      const positions = window.mapLayout.calloutPositions;

      // Try exact match first
      for (const [name, pos] of Object.entries(positions)) {
        if (name.toLowerCase() === queryLower) return pos;
      }

      // Try partial match (case-insensitive)
      for (const [name, pos] of Object.entries(positions)) {
        if (name.toLowerCase().includes(queryLower) || queryLower.includes(name.toLowerCase())) {
          return pos;
        }
      }

      // Default fallback to center
      return { x: 0.5, y: 0.5 };
    }

    // Filter pill click handlers
    document.querySelectorAll('[data-filter-type]').forEach(pill => {
      pill.addEventListener('click', () => {
        const wasActive = pill.classList.contains('lu-active');
        document.querySelectorAll('[data-filter-type]').forEach(p => p.classList.remove('lu-active'));
        if (!wasActive) {
          pill.classList.add('lu-active');
        }
        applyFilters();
      });
    });

    document.querySelectorAll('[data-filter-side]').forEach(pill => {
      pill.addEventListener('click', () => {
        const wasActive = pill.classList.contains('lu-active');
        document.querySelectorAll('[data-filter-side]').forEach(p => p.classList.remove('lu-active'));
        if (!wasActive) {
          pill.classList.add('lu-active');
        }
        applyFilters();
      });
    });

    document.querySelectorAll('[data-filter-difficulty]').forEach(pill => {
      pill.addEventListener('click', () => {
        const wasActive = pill.classList.contains('lu-active');
        document.querySelectorAll('[data-filter-difficulty]').forEach(p => p.classList.remove('lu-active'));
        if (!wasActive) {
          pill.classList.add('lu-active');
        }
        applyFilters();
      });
    });

    document.querySelectorAll('[data-learn-checkbox]').forEach((checkbox, idx) => {
      checkbox.addEventListener('change', () => toggleLineupLearned(idx));
    });

    document.querySelectorAll('[data-radar-pin]').forEach((btn, idx) => {
      btn.addEventListener('click', () => {
        if (window.pinnedLineup === idx.toString()) {
          window.pinnedLineup = null;
          localStorage.removeItem(RADAR_STORAGE_KEY);
          btn.classList.remove('lu-pinned');
        } else {
          // Unpin previous
          const prevPin = document.querySelector('[data-radar-pin].lu-pinned');
          if (prevPin) prevPin.classList.remove('lu-pinned');

          window.pinnedLineup = idx.toString();
          localStorage.setItem(RADAR_STORAGE_KEY, idx.toString());
          btn.classList.add('lu-pinned');
        }
        updateRadarMap();
      });
    });

    // Initialize UI
    updateLearnedUI();
    updateLearnedProgress();

    // Setup hover interactions
    document.querySelectorAll('[data-lineup-card]').forEach((card, idx) => {
      card.addEventListener('mouseenter', () => {
        const radarSvg = document.querySelector('[data-radar-svg]');
        if (radarSvg) {
          const trajectories = radarSvg.querySelectorAll(`[data-trajectory="${idx}"]`);
          trajectories.forEach(t => {
            t.style.opacity = '1';
            t.style.filter = 'drop-shadow(0 0 3px rgba(255,255,255,0.5))';
          });
        }
      });

      card.addEventListener('mouseleave', () => {
        const radarSvg = document.querySelector('[data-radar-svg]');
        if (radarSvg) {
          const trajectories = radarSvg.querySelectorAll(`[data-trajectory="${idx}"]`);
          trajectories.forEach(t => {
            const isPinned = window.pinnedLineup === idx.toString();
            t.style.opacity = isPinned ? '1' : '0.5';
            t.style.filter = 'none';
          });
        }
      });
    });
  </script>

