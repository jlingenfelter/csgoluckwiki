    { name: 'A Site Pop Flash from Palace', type: 'flash', side: 't', from: 'Palace', to: 'A Site', position: 'Palace exit', target: 'A Site/Ticket', difficulty: 'medium', description: 'A pop flash that blinds CT players on A site and ticket booth. Stand inside palace near the exit. Aim at the top of the archway above the palace exit. Right-click throw so it pops immediately as it clears the wall, giving CTs no time to turn.', steps: ['Stand inside palace about 2 steps from the exit', 'Face the exit archway and aim at the top edge', 'Right-click throw (underhand) so it pops instantly over the wall', 'Rush out immediately after the flash pops'], useCase: 'Blind A site defenders for a fast palace push' },
