    { name: 'Under Palace Molotov from CT', type: 'molotov', side: 'ct', from: 'CT Spawn', to: 'Palace', position: 'CT Spawn/Stairs', target: 'Under Palace', difficulty: 'easy', description: 'Denies the under-palace position where Ts often hide during an A take. From the stairs near CT spawn, aim toward the dark area under the palace balcony. Left-click throw. The fire covers the under-palace corner.', steps: ['Stand near the stairs between CT spawn and A site', 'Look toward the palace balcony overhang', 'Aim at the ground beneath the balcony', 'Left-click throw to land the molotov under palace'], useCase: 'Deny the under-palace hiding spot during A site defense or retake' },
