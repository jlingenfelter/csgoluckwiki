---
import Base from '../../layouts/Base.astro';
import ExploreMore from '../../components/ExploreMore.astro';
import { breadcrumbSchema, faqSchema } from '../../lib/weapons';
import { MAP_LAYOUTS } from '../../lib/map-layouts';

export async function getStaticPaths() {
  const maps = [
    'mirage',
    'inferno',
    'dust2',
    'anubis',
    'ancient',
    'nuke',
    'overpass',
    'vertigo'
  ];

  return maps.map(map => ({
    params: { slug: map },
    props: { map }
  }));
}

interface Props {
  map: string;
}

const { map } = Astro.props;

