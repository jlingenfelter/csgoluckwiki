---
import Base from '../../layouts/Base.astro';
import ExploreMore from '../../components/ExploreMore.astro';
import { breadcrumbSchema, faqSchema } from '../../lib/weapons';
import { MAP_LAYOUTS } from '../../lib/map-layouts';

export async function getStaticPaths() {
  const maps = [
    'mirage',
    'inferno',
    'dust2',
    'anubis',
    'ancient',
    'nuke',
    'overpass',
    'vertigo'
  ];

  return maps.map(map => ({
    params: { slug: map },
    props: { map }
  }));
}

interface Props {
  map: string;
}

const { map } = Astro.props;

// Get map layout data
const mapLayout = MAP_LAYOUTS.find(m => m.slug === map);

// Lineup data for all maps
const mapLineups: Record<string, any[]> = {
  mirage: [
    { name: 'Window Smoke from T Spawn', type: 'smoke', side: 't', from: 'T Spawn', to: 'Window', position: 'T Spawn', target: 'Window', difficulty: 'easy', description: 'A fundamental smoke that blocks the AWPer on window from seeing T spawn and mid. Stand in the left corner of T spawn near the dumpster. Place your crosshair on the tip of the antenna on the roof above window. Left-click throw. The smoke lands on the window ledge and fully blocks vision.', steps: ['Stand in the left corner of T spawn next to the dumpster', 'Look up and find the antenna tip on the rooftop above window', 'Align your crosshair with the very tip of the antenna', 'Left-click throw (standing, no movement)'], useCase: 'Block the AWPer on window during mid-to-A or mid-to-B splits' },
    { name: 'Connector Smoke from T Spawn', type: 'smoke', side: 't', from: 'T Spawn', to: 'Connector', position: 'T Spawn', target: 'Connector', difficulty: 'medium', description: 'Blocks connector to prevent CTs from rotating through mid during an A execute. Stand on the right side of T spawn near the wooden cart. Aim at the corner where the building meets the sky above connector. Jump-throw. The smoke will arc and land in the connector entrance.', steps: ['Position yourself on the right side of T spawn by the wooden cart', 'Look toward connector and find where the building edge meets the skyline', 'Aim slightly left of that corner point', 'Jump-throw (jump + release at the peak)'], useCase: 'Prevent CT rotations through connector during A site executes' },
