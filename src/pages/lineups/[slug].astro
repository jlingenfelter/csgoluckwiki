    { name: 'Stairs Smoke from T Spawn', type: 'smoke', side: 't', from: 'T Spawn', to: 'Stairs', position: 'T Spawn', target: 'Stairs/CT', difficulty: 'easy', description: 'Blocks the CT stairs angle to safely cross from T spawn toward A ramp or mid. Stand in the center of T spawn. Aim at the top of the building directly ahead above stairs. Left-click throw. Lands on top of stairs and blocks rotation.', steps: ['Stand in the center-left area of T spawn', 'Look straight ahead toward the stairs building', 'Aim at the top edge of the building roofline', 'Left-click throw while standing still'], useCase: 'Block CT rotation through stairs during early round A or B setups' },
