---
import Base from '../layouts/Base.astro';
import ExploreMore from '../components/ExploreMore.astro';
import { MAPS } from '../lib/maps';
import { faqSchema } from '../lib/weapons';

const activeMaps = MAPS.filter(m => m.pool === 'active');
const title = 'CS2 Maps — Callouts, Lineups & Guides | CSDB.gg';
const description = 'Complete guide to all Counter-Strike 2 competitive maps. Callout names, smoke & flash lineups, CT/T strategies, and tips for every active duty map.';

const faqs = [
  { question: 'What maps are in the CS2 active duty pool?', answer: `The current active duty maps are: ${activeMaps.map(m => m.name).join(', ')}. These are the maps played in competitive matchmaking and professional tournaments.` },
  { question: 'What are callouts in CS2?', answer: 'Callouts are standardised names for locations on each map that players use to communicate enemy positions, strategies, and utility placement with teammates.' },
  { question: 'What are lineups in CS2?', answer: 'Lineups are precise positions and aim points for throwing utility (smokes, flashes, molotovs, HE grenades) to land them in specific locations. Learning lineups for each map is key to competitive play.' },
  { question: 'Which CS2 map is the most CT-sided?', answer: 'Nuke and Inferno are traditionally the most CT-sided maps due to fast rotations (Nuke) and tight chokepoints (Inferno). Ancient is also considered CT-sided.' },
  { question: 'Which CS2 map is best for beginners?', answer: 'Dust II and Mirage are the best maps for beginners. They have simple three-lane layouts that are easy to learn, and the callouts are straightforward.' },
];

// Map-specific icons/emojis
const mapEmojis: Record<string, string> = {
  dust2: '🏜️', mirage: '🕌', inferno: '🔥', nuke: '☢️',
  overpass: '🌉', anubis: '🏛️', ancient: '🌿', vertigo: '🏗️',
};

const poolLabels: Record<string, { label: string; color: string }> = {
  active: { label: 'Active Duty', color: 'var(--green)' },
  reserve: { label: 'Reserve', color: 'var(--text2)' },
  wingman: { label: 'Wingman', color: 'var(--blue)' },
};

const itemListSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "CS2 Active Duty Maps",
  "description": "All active duty competitive maps in Counter-Strike 2 with callouts, lineups, and strategies.",
  "numberOfItems": activeMaps.length,
  "itemListElement": activeMaps.map((m, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "name": m.name,
    "description": m.description,
    "url": `https://csdb.gg/maps/${m.slug}/`
  }))
});
---

<Base title={title} description={description} currentNav="/maps/">
<Fragment slot="head">
<script type="application/ld+json" set:html={JSON.stringify(faqSchema(faqs))} />
<script type="application/ld+json" set:html={itemListSchema} />
</Fragment>

<div class="breadcrumb">
  <a href="/">Home</a> → Maps
</div>

<section class="maps-hero">
  <h1>CS2 Maps Hub</h1>
  <p class="maps-hero-sub">Callouts, smoke lineups, flash spots, strategies, and tips for every competitive map in Counter-Strike 2.</p>
  <div class="maps-hero-stats">
    <div class="mhs"><span class="mhv">{activeMaps.length}</span><span class="mhl">Active Maps</span></div>
    <div class="mhs"><span class="mhv">{MAPS.reduce((t, m) => t + m.callouts.length, 0)}+</span><span class="mhl">Callouts</span></div>
    <div class="mhs"><span class="mhv">7</span><span class="mhl">Lineup Guides</span></div>
  </div>
</section>

<!-- Quick Nav -->
<div class="maps-quicknav">
  {activeMaps.map(m => (
    <a href={`#${m.slug}`} class="mqn-chip">
      <span class="mqn-emoji">{mapEmojis[m.slug] || '🗺️'}</span>
      {m.name}
    </a>
  ))}
</div>

<!-- Map Cards -->
{activeMaps.map(m => {
  const pool = poolLabels[m.pool] || poolLabels.active;
  const topCallouts = m.callouts.slice(0, 6);
  return (
    <section class="map-section" id={m.slug}>
      <div class="map-card-full">
        <div class="mcf-header">
          <div class="mcf-title-row">
            <span class="mcf-emoji">{mapEmojis[m.slug] || '🗺️'}</span>
            <div>
              <h2>{m.name}</h2>
              <div class="mcf-tags">
                <span class="mcf-pool" style={`color:${pool.color};border-color:${pool.color}`}>{pool.label}</span>
                <span class="mcf-mode">{m.mode === 'defusal' ? '💣 Defusal' : '🧑‍🦰 Hostage'}</span>
                {m.tags.slice(0, 3).map(t => (
                  <span class="mcf-tag">{t}</span>
                ))}
              </div>
            </div>
          </div>
          <div class="mcf-actions">
            <a href={`/maps/${m.slug}/`} class="mcf-btn mcf-primary">📍 Callouts</a>
            <a href={`/lineups/${m.slug}/`} class="mcf-btn mcf-secondary">🎯 Lineups</a>
            <a href={`/map/${m.slug}/`} class="mcf-btn mcf-tertiary">📖 Full Guide</a>
          </div>
        </div>

        <p class="mcf-desc">{m.description}</p>

        <!-- Callouts Preview -->
        <div class="mcf-callouts">
          <h3>Key Callouts</h3>
          <div class="mcf-callout-grid">
            {topCallouts.map(c => (
              <div class={`mcf-callout mcf-callout-${c.side}`}>
                <span class="mcf-cname">{c.name}</span>
                <span class={`mcf-cside mcf-cside-${c.side}`}>{c.side.toUpperCase()}</span>
              </div>
            ))}
          </div>
          <a href={`/maps/${m.slug}/`} class="mcf-more-link">View all {m.callouts.length} callouts →</a>
        </div>

        <!-- Tips -->
        <div class="mcf-tips-row">
          <div class="mcf-tips-col">
            <h3><span class="mcf-ct-badge">CT</span> CT Tips</h3>
            <ul class="mcf-tiplist">
              {m.ctTips.slice(0, 3).map(tip => (
                <li>{tip}</li>
              ))}
            </ul>
          </div>
          <div class="mcf-tips-col">
            <h3><span class="mcf-t-badge">T</span> T Tips</h3>
            <ul class="mcf-tiplist">
              {m.tTips.slice(0, 3).map(tip => (
                <li>{tip}</li>
              ))}
            </ul>
          </div>
        </div>

        {m.meta && <p class="mcf-meta">{m.meta}</p>}
      </div>
    </section>
  );
})}

<!-- Related Resources -->
<section class="maps-related">
  <h2>Related Resources</h2>
  <div class="maps-related-grid">
    <a href="/workshop-maps/" class="mr-card">
      <span class="mr-icon">🗺️</span>
      <div>
        <strong>Workshop Maps</strong>
        <p>Best aim trainers, surf, and KZ maps</p>
      </div>
    </a>
    <a href="/practice-config/" class="mr-card">
      <span class="mr-icon">🏋️</span>
      <div>
        <strong>Practice Config</strong>
        <p>Set up offline practice servers</p>
      </div>
    </a>
    <a href="/crosshair-generator/" class="mr-card">
      <span class="mr-icon">🎯</span>
      <div>
        <strong>Crosshair Generator</strong>
        <p>Create your perfect crosshair</p>
      </div>
    </a>
    <a href="/guides/advanced-mechanics-guide/" class="mr-card">
      <span class="mr-icon">🧠</span>
      <div>
        <strong>Advanced Mechanics</strong>
        <p>Movement, peeking, and game sense</p>
      </div>
    </a>
    <a href="/bind-generator/" class="mr-card">
      <span class="mr-icon">⌨️</span>
      <div>
        <strong>Bind Generator</strong>
        <p>Custom key binds for utility</p>
      </div>
    </a>
    <a href="/sensitivity-converter/" class="mr-card">
      <span class="mr-icon">🖱️</span>
      <div>
        <strong>Sensitivity Converter</strong>
        <p>Match your sens across games</p>
      </div>
    </a>
    <a href="/pro-players/" class="mr-card">
      <span class="mr-icon">🏆</span>
      <div>
        <strong>Pro Player Settings</strong>
        <p>Configs from 50+ CS2 pros</p>
      </div>
    </a>
  </div>
</section>

<!-- FAQ -->
<section class="maps-faq">
  <h2>Frequently Asked Questions</h2>
  <dl class="faq">
    {faqs.map(f => (
      <>
        <dt>{f.question}</dt>
        <dd>{f.answer}</dd>
      </>
    ))}
  </dl>
</section>

<ExploreMore context="maps" />
</Base>

<style>
/* Hero */
.maps-hero{text-align:center;padding:3rem 1.5rem;background:linear-gradient(135deg,var(--bg2),var(--bg3));border-radius:12px;border:1px solid var(--border);margin-bottom:2rem;position:relative;overflow:hidden}
.maps-hero::before{content:'';position:absolute;inset:0;background:repeating-linear-gradient(0deg,transparent,transparent 50px,rgba(0,170,255,0.02) 50px,rgba(0,170,255,0.02) 100px);pointer-events:none}
.maps-hero h1{font-size:2.5rem;font-weight:900;margin:0 0 .75rem;background:linear-gradient(135deg,var(--accent),#00d4ff);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;position:relative;z-index:1}
.maps-hero-sub{color:var(--text2);font-size:1.05rem;margin:0 0 1.5rem;max-width:650px;margin-left:auto;margin-right:auto;line-height:1.6;position:relative;z-index:1}
.maps-hero-stats{display:flex;justify-content:center;gap:2rem;flex-wrap:wrap;position:relative;z-index:1}
.mhs{text-align:center}
.mhv{display:block;font-size:1.6rem;font-weight:800;color:var(--accent)}
.mhl{font-size:.75rem;color:var(--text2)}

/* Quick Nav */
.maps-quicknav{display:flex;gap:.5rem;flex-wrap:wrap;justify-content:center;margin-bottom:2.5rem;padding:1rem;background:var(--bg2);border-radius:10px;border:1px solid var(--border)}
.mqn-chip{display:flex;align-items:center;gap:.35rem;padding:.45rem .85rem;background:var(--bg3);border:1px solid var(--border);border-radius:6px;color:var(--text);font-size:.85rem;font-weight:600;text-decoration:none;transition:all .2s}
.mqn-chip:hover{border-color:var(--accent);color:var(--accent);transform:translateY(-1px)}
.mqn-emoji{font-size:1rem}

/* Map Section */
.map-section{margin-bottom:2rem;scroll-margin-top:80px}

/* Map Card Full */
.map-card-full{background:var(--bg2);border:1px solid var(--border);border-radius:12px;padding:1.5rem;transition:border-color .2s}
.map-card-full:hover{border-color:rgba(212,149,110,0.3)}

.mcf-header{display:flex;align-items:flex-start;justify-content:space-between;gap:1rem;margin-bottom:1rem;flex-wrap:wrap}
.mcf-title-row{display:flex;align-items:center;gap:.75rem}
.mcf-emoji{font-size:2rem}
.mcf-header h2{margin:0;font-size:1.5rem}
.mcf-tags{display:flex;gap:.4rem;flex-wrap:wrap;margin-top:.3rem}
.mcf-pool{font-size:.72rem;font-weight:700;text-transform:uppercase;letter-spacing:.05em;padding:.15rem .5rem;border:1px solid;border-radius:4px}
.mcf-mode{font-size:.75rem;color:var(--text2)}
.mcf-tag{font-size:.72rem;color:var(--text2);background:var(--bg3);padding:.15rem .45rem;border-radius:4px}

.mcf-actions{display:flex;gap:.5rem;flex-wrap:wrap}
.mcf-btn{padding:.5rem 1rem;border-radius:6px;font-size:.85rem;font-weight:700;text-decoration:none;transition:all .2s;white-space:nowrap}
.mcf-primary{background:var(--accent);color:#000;border:1px solid var(--accent)}
.mcf-primary:hover{opacity:.9;transform:translateY(-2px);box-shadow:0 4px 12px rgba(212,149,110,0.25)}
.mcf-secondary{background:var(--bg3);color:var(--ct);border:1px solid var(--ct)}
.mcf-secondary:hover{background:var(--ct);color:#000;transform:translateY(-2px)}
.mcf-tertiary{background:var(--bg3);color:var(--text);border:1px solid var(--border)}
.mcf-tertiary:hover{border-color:var(--accent);color:var(--accent);transform:translateY(-2px)}

.mcf-desc{color:var(--text2);font-size:.92rem;line-height:1.65;margin-bottom:1.25rem}

/* Callouts Preview */
.mcf-callouts{margin-bottom:1.25rem}
.mcf-callouts h3{font-size:.95rem;margin:0 0 .6rem;color:var(--text)}
.mcf-callout-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:.5rem;margin-bottom:.5rem}
.mcf-callout{display:flex;align-items:center;justify-content:space-between;padding:.5rem .75rem;background:var(--bg3);border-radius:6px;border-left:3px solid var(--border);transition:border-color .2s}
.mcf-callout-ct{border-left-color:var(--ct)}
.mcf-callout-t{border-left-color:var(--t)}
.mcf-callout-mid{border-left-color:var(--text2)}
.mcf-cname{font-size:.85rem;font-weight:600;color:var(--text)}
.mcf-cside{font-size:.65rem;font-weight:700;padding:.1rem .35rem;border-radius:3px;letter-spacing:.04em}
.mcf-cside-ct{background:rgba(93,159,212,0.15);color:var(--ct)}
.mcf-cside-t{background:rgba(230,200,76,0.15);color:var(--t)}
.mcf-cside-mid{background:rgba(149,149,168,0.1);color:var(--text2)}
.mcf-more-link{font-size:.82rem;color:var(--accent);font-weight:600}

/* Tips */
.mcf-tips-row{display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:1rem}
@media(max-width:600px){.mcf-tips-row{grid-template-columns:1fr}}
.mcf-tips-col h3{font-size:.9rem;margin:0 0 .5rem;display:flex;align-items:center;gap:.4rem}
.mcf-ct-badge{background:var(--ct);color:#000;font-size:.65rem;font-weight:800;padding:.15rem .4rem;border-radius:3px}
.mcf-t-badge{background:var(--t);color:#000;font-size:.65rem;font-weight:800;padding:.15rem .4rem;border-radius:3px}
.mcf-tiplist{list-style:none;padding:0;margin:0}
.mcf-tiplist li{padding:.4rem 0 .4rem 1.2rem;position:relative;font-size:.85rem;color:var(--text2);border-bottom:1px solid var(--border)}
.mcf-tiplist li:last-child{border-bottom:none}
.mcf-tiplist li::before{content:'→';position:absolute;left:0;color:var(--accent)}

.mcf-meta{font-size:.82rem;color:var(--text2);font-style:italic;background:var(--bg3);padding:.75rem 1rem;border-radius:6px;border-left:3px solid var(--accent);margin:0}

/* Related Resources */
.maps-related{margin:2.5rem 0}
.maps-related h2{margin-bottom:1rem}
.maps-related-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(250px,1fr));gap:.75rem}
.mr-card{display:flex;gap:.75rem;align-items:center;background:var(--bg2);border:1px solid var(--border);border-radius:8px;padding:1rem;text-decoration:none;color:inherit;transition:all .2s}
.mr-card:hover{border-color:var(--accent);transform:translateY(-2px)}
.mr-icon{font-size:1.3rem;flex-shrink:0}
.mr-card strong{display:block;font-size:.9rem;color:var(--text);margin-bottom:.15rem}
.mr-card p{margin:0;font-size:.8rem;color:var(--text2)}

/* FAQ */
.maps-faq{margin:2rem 0}
.maps-faq h2{margin-bottom:1rem}

@media(max-width:768px){
  .maps-hero h1{font-size:1.8rem}
  .mcf-header{flex-direction:column}
  .mcf-callout-grid{grid-template-columns:1fr 1fr}
}
</style>
