---
import Base from '../layouts/Base.astro';
import ExploreMore from '../components/ExploreMore.astro';
import { SKINS, getLowestPrice, getHighestPrice, RARITY_COLORS, RARITY_BG, getTopByVolume, getTopByLiquidity, getMostTraded, getMostListings, getVolumeLabel, getLiquidityColor, getLiquidityLabel, fmtPrice } from '../lib/skins';
import { faqSchema, breadcrumbSchema } from '../lib/weapons';

const title = 'CS2 Skin Market Trends — Price Movers & Analysis | CSGOLuck Wiki';
const description = 'Analyze CS2 skin market trends. Discover most expensive skins, best value deals, price distribution, and rarity breakdown. Investment tips for CS2 skins.';

// Build-time computed sections

// 1. Most Expensive Skins (top 10 by highest price)
const mostExpensiveSkins = [...SKINS]
  .sort((a, b) => getHighestPrice(b) - getHighestPrice(a))
  .slice(0, 10);

// 2. Best Value Skins (cheapest skins with good rarity: Classified/Covert under $20)
const bestValueSkins = SKINS.filter(s => {
  const rarity = s.rarity;
  const high = getHighestPrice(s);
  return (rarity === 'Classified' || rarity === 'Covert') && high < 20;
})
  .sort((a, b) => getLowestPrice(a) - getLowestPrice(b))
  .slice(0, 10);

// 3. Knife & Glove Market
const knifeGloveSkins = SKINS.filter(s => s.category === 'knife' || s.category === 'glove')
  .sort((a, b) => getHighestPrice(b) - getHighestPrice(a))
  .slice(0, 12);

// 4. Price Distribution
const priceBrackets = [
  { min: 0, max: 5, label: '$0 - $5' },
  { min: 5, max: 20, label: '$5 - $20' },
  { min: 20, max: 100, label: '$20 - $100' },
  { min: 100, max: 500, label: '$100 - $500' },
  { min: 500, max: Infinity, label: '$500+' }
];

const priceDistribution = priceBrackets.map(bracket => {
  const count = SKINS.filter(s => {
    const high = getHighestPrice(s);
    return high >= bracket.min && high < bracket.max;
  }).length;
  return { ...bracket, count };
});

const maxCount = Math.max(...priceDistribution.map(d => d.count));

// 5. Rarity Breakdown
const rarityStats: Record<string, number> = {};
SKINS.forEach(s => {
  rarityStats[s.rarity] = (rarityStats[s.rarity] || 0) + 1;
});

const rarityOrder = ['Consumer', 'Industrial', 'Mil-Spec', 'Restricted', 'Classified', 'Covert', 'Contraband', 'Extraordinary'];
const rarityCounts = rarityOrder
  .filter(r => rarityStats[r])
  .map(r => ({ rarity: r, count: rarityStats[r] }));

// 6. Most Traded Skins (by 7-day trades)
const mostTradedSkins = getMostTraded(12);

// 7. Highest Volume Skins (by 7-day Steam volume)
const highestVolumeSkins = getTopByVolume(12);

// 8. Most Liquid Skins (by liquidity score)
const mostLiquidSkins = getTopByLiquidity(12);

// 9. Most Listed Skins (by current listing count)
const mostListedSkins = getMostListings(12);

// Check if trend data is available
const hasTrendData = mostTradedSkins.length > 0 || highestVolumeSkins.length > 0;

// FAQs
const faqs = [
  {
    question: 'How often do CS2 skin prices change?',
    answer: 'CS2 skin prices update daily based on market supply and demand. Major fluctuations occur when skins are added/removed from cases, during Steam sales, or after significant game updates.'
  },
  {
    question: 'What causes CS2 skin prices to rise?',
    answer: 'Prices rise when a skin is removed from case rotation (supply decreases), community hype increases, pro players use the skin, or during off-season periods. Rare finishes and StatTrak variants command premium prices.'
  },
  {
    question: 'Are CS2 skins good investments?',
    answer: 'Some skins appreciate in value over time, especially rare finishes and discontinued cases. However, the market is volatile. Invest only in skins you understand and can hold long-term. Avoid hype-driven purchases.'
  },
  {
    question: 'Where can I buy CS2 skins at the best price?',
    answer: 'Prices vary across Steam Community Market, third-party marketplaces, and trading sites. Compare prices before buying. Consider fees and withdrawal restrictions. Use reputable sites only.'
  },
  {
    question: 'What is a "price spike"?',
    answer: 'A price spike is a sudden rapid increase in a skin\'s value, often triggered by case discontinuation, content creator hype, or major esports events. Spikes can be temporary or signal sustained value growth.'
  },
  {
    question: 'How do I track skin price history?',
    answer: 'Use our Price Tracker tool to monitor your favorite skins. Chart historical prices, set alerts, and compare across marketplaces. Historical data helps identify trends and investment opportunities.'
  }
];

const crumbs = [
  { name: 'Home', url: '/' },
  { name: 'Skins', url: '/cs2-skins/' },
  { name: 'Market Trends', url: '/market-trends/' }
];
---

<Base title={title} description={description} currentNav="/cs2-skins/">
<script type="application/ld+json" set:html={JSON.stringify(faqSchema(faqs))}></script>
<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema(crumbs))}></script>

<nav class="mt-breadcrumb"><a href="/">Home</a> / <a href="/cs2-skins/">Skins</a> / <span>Market Trends</span></nav>

<section class="mt-hero">
  <h1>CS2 Skin Market Trends</h1>
  <p>Analyze pricing patterns, discover valuable skins, and understand market dynamics. Real-time insights for skin traders and collectors.</p>
</section>

<!-- Most Expensive Skins -->
<section class="mt-section">
  <h2>Most Expensive Skins</h2>
  <p>Top 10 skins by highest price across all wear conditions.</p>
  <div class="mt-list">
    {mostExpensiveSkins.map((skin, idx) => {
      const high = getHighestPrice(skin);
      const low = getLowestPrice(skin);
      const rarityColor = RARITY_COLORS[skin.rarity] || '#fff';
      return (
        <a href={`/cs2-skin/${skin.slug}/`} class="mt-skin-row">
          <span class="mt-rank">#{idx + 1}</span>
          <span class="mt-skin-info">
            <span class="mt-skin-weapon">{skin.weapon}</span>
            <span class="mt-skin-name">{skin.name}</span>
          </span>
          <span class="mt-skin-rarity" style={`color:${rarityColor}`}>{skin.rarity}</span>
          <span class="mt-skin-price">${fmtPrice(high)}</span>
        </a>
      );
    })}
  </div>
</section>

<!-- Best Value Skins -->
<section class="mt-section">
  <h2>Best Value Skins</h2>
  <p>High-rarity skins (Classified/Covert) under $20 — great deals for collectors.</p>
  <div class="mt-list">
    {bestValueSkins.map(skin => {
      const low = getLowestPrice(skin);
      const high = getHighestPrice(skin);
      const rarityColor = RARITY_COLORS[skin.rarity] || '#fff';
      return (
        <a href={`/cs2-skin/${skin.slug}/`} class="mt-skin-row">
          <span class="mt-value-badge">Value</span>
          <span class="mt-skin-info">
            <span class="mt-skin-weapon">{skin.weapon}</span>
            <span class="mt-skin-name">{skin.name}</span>
          </span>
          <span class="mt-skin-rarity" style={`color:${rarityColor}`}>{skin.rarity}</span>
          <span class="mt-skin-price">${fmtPrice(low)} – ${fmtPrice(high)}</span>
        </a>
      );
    })}
  </div>
</section>

<!-- Knife & Glove Market -->
<section class="mt-section">
  <h2>Knife & Glove Market</h2>
  <p>Premium items with the highest market values. Top knives and gloves trending now.</p>
  <div class="mt-list">
    {knifeGloveSkins.map(skin => {
      const high = getHighestPrice(skin);
      const rarityColor = RARITY_COLORS[skin.rarity] || '#fff';
      const isKnife = skin.category === 'knife';
      return (
        <a href={`/cs2-skin/${skin.slug}/`} class="mt-skin-row">
          <span class="mt-premium-badge">{isKnife ? 'Knife' : 'Glove'}</span>
          <span class="mt-skin-info">
            <span class="mt-skin-weapon">{skin.weapon}</span>
            <span class="mt-skin-name">{skin.name}</span>
          </span>
          <span class="mt-skin-rarity" style={`color:${rarityColor}`}>{skin.rarity}</span>
          <span class="mt-skin-price">${fmtPrice(high)}</span>
        </a>
      );
    })}
  </div>
</section>

{hasTrendData && (
<>
<!-- Most Traded Skins -->
{mostTradedSkins.length > 0 && (
<section class="mt-section">
  <h2>Most Traded Skins (7 Days)</h2>
  <p>Skins with the highest number of trades in the past 7 days — the most actively bought and sold items.</p>
  <div class="mt-list">
    {mostTradedSkins.map((skin, idx) => {
      const low = getLowestPrice(skin);
      const rarityColor = RARITY_COLORS[skin.rarity] || '#fff';
      return (
        <a href={`/cs2-skin/${skin.slug}/`} class="mt-mover-row">
          <span class="mt-mover-rank">#{idx + 1}</span>
          <span class="mt-mover-img">
            {skin.image && <img src={skin.image} alt={`${skin.weapon} | ${skin.name}`} loading="lazy" width="60" height="45" />}
          </span>
          <span class="mt-mover-info">
            <span class="mt-skin-weapon">{skin.weapon}</span>
            <span class="mt-skin-name">{skin.name}</span>
            <span class="mt-mover-stats">
              <span class="mt-mover-stat mt-trades">{getVolumeLabel(skin.trades7d || 0)} trades</span>
              {low > 0 && <span class="mt-mover-stat mt-price">from ${fmtPrice(low)}</span>}
            </span>
          </span>
        </a>
      );
    })}
  </div>
</section>
)}

<!-- Highest Volume Skins -->
{highestVolumeSkins.length > 0 && (
<section class="mt-section">
  <h2>Highest Volume Skins (7 Days)</h2>
  <p>Skins with the highest Steam market volume over the past week — strong indicators of market demand.</p>
  <div class="mt-list">
    {highestVolumeSkins.map((skin, idx) => {
      const low = getLowestPrice(skin);
      const rarityColor = RARITY_COLORS[skin.rarity] || '#fff';
      return (
        <a href={`/cs2-skin/${skin.slug}/`} class="mt-mover-row">
          <span class="mt-mover-rank">#{idx + 1}</span>
          <span class="mt-mover-img">
            {skin.image && <img src={skin.image} alt={`${skin.weapon} | ${skin.name}`} loading="lazy" width="60" height="45" />}
          </span>
          <span class="mt-mover-info">
            <span class="mt-skin-weapon">{skin.weapon}</span>
            <span class="mt-skin-name">{skin.name}</span>
            <span class="mt-mover-stats">
              <span class="mt-mover-stat mt-volume">{getVolumeLabel(skin.volume7d || 0)} volume</span>
              {low > 0 && <span class="mt-mover-stat mt-price">from ${fmtPrice(low)}</span>}
            </span>
          </span>
        </a>
      );
    })}
  </div>
</section>
)}

<!-- Most Liquid Skins -->
{mostLiquidSkins.length > 0 && (
<section class="mt-section">
  <h2>Most Liquid Skins</h2>
  <p>Skins with the highest liquidity scores — easy to buy and sell quickly at fair market value.</p>
  <div class="mt-list">
    {mostLiquidSkins.map((skin, idx) => {
      const low = getLowestPrice(skin);
      const liqColor = getLiquidityColor(skin.liquidity || 0);
      const liqLabel = getLiquidityLabel(skin.liquidity || 0);
      return (
        <a href={`/cs2-skin/${skin.slug}/`} class="mt-mover-row">
          <span class="mt-mover-rank">#{idx + 1}</span>
          <span class="mt-mover-img">
            {skin.image && <img src={skin.image} alt={`${skin.weapon} | ${skin.name}`} loading="lazy" width="60" height="45" />}
          </span>
          <span class="mt-mover-info">
            <span class="mt-skin-weapon">{skin.weapon}</span>
            <span class="mt-skin-name">{skin.name}</span>
            <span class="mt-mover-stats">
              <span class="mt-mover-stat" style={`color:${liqColor}`}>{liqLabel} ({skin.liquidity}%)</span>
              {low > 0 && <span class="mt-mover-stat mt-price">from ${fmtPrice(low)}</span>}
            </span>
          </span>
        </a>
      );
    })}
  </div>
</section>
)}

<!-- Most Listed Skins -->
{mostListedSkins.length > 0 && (
<section class="mt-section">
  <h2>Most Listed Skins</h2>
  <p>Skins with the highest number of active marketplace listings — reflects current market supply.</p>
  <div class="mt-list">
    {mostListedSkins.map((skin, idx) => {
      const low = getLowestPrice(skin);
      return (
        <a href={`/cs2-skin/${skin.slug}/`} class="mt-mover-row">
          <span class="mt-mover-rank">#{idx + 1}</span>
          <span class="mt-mover-img">
            {skin.image && <img src={skin.image} alt={`${skin.weapon} | ${skin.name}`} loading="lazy" width="60" height="45" />}
          </span>
          <span class="mt-mover-info">
            <span class="mt-skin-weapon">{skin.weapon}</span>
            <span class="mt-skin-name">{skin.name}</span>
            <span class="mt-mover-stats">
              <span class="mt-mover-stat mt-listings">{getVolumeLabel(skin.listingCount || 0)} listings</span>
              {low > 0 && <span class="mt-mover-stat mt-price">from ${fmtPrice(low)}</span>}
            </span>
          </span>
        </a>
      );
    })}
  </div>
</section>
)}
</>
)}

<!-- Price Distribution -->
<section class="mt-section">
  <h2>Price Distribution</h2>
  <p>How CS2 skins are distributed across price brackets.</p>
  <div class="mt-dist">
    {priceDistribution.map(bracket => {
      const percentage = (bracket.count / SKINS.length) * 100;
      const barWidth = (bracket.count / maxCount) * 100;
      return (
        <div class="mt-dist-row">
          <span class="mt-dist-label">{bracket.label}</span>
          <span class="mt-dist-count">{bracket.count} skins</span>
          <div class="mt-dist-bar-wrap">
            <div class="mt-dist-bar" style={`width:${barWidth}%`}></div>
          </div>
          <span class="mt-dist-pct">{percentage.toFixed(1)}%</span>
        </div>
      );
    })}
  </div>
</section>

<!-- Rarity Breakdown -->
<section class="mt-section">
  <h2>Rarity Breakdown</h2>
  <p>Total skins available per rarity tier.</p>
  <div class="mt-rarity-list">
    {rarityCounts.map(item => {
      const percentage = (item.count / SKINS.length) * 100;
      const color = RARITY_COLORS[item.rarity] || '#fff';
      return (
        <div class="mt-rarity-row" style={`--rarity-color:${color}`}>
          <span class="mt-rarity-name">{item.rarity}</span>
          <span class="mt-rarity-count">{item.count} skins</span>
          <span class="mt-rarity-pct">{percentage.toFixed(1)}%</span>
        </div>
      );
    })}
  </div>
</section>

<!-- Quick Links -->
<section class="mt-quick">
  <h3>Explore More</h3>
  <div class="mt-quick-links">
    <a href="/cs2-skins/" class="mt-quick-link">Browse All Skins</a>
    <a href="/price-tracker/" class="mt-quick-link">Price Tracker</a>
    <a href="/cs2-cases/" class="mt-quick-link">View Cases</a>
    <a href="/inventory-lookup/" class="mt-quick-link">Inventory Lookup</a>
  </div>
</section>

<!-- FAQ -->
<section class="mt-faq">
  <h2>Frequently Asked Questions</h2>
  {faqs.map(f => (
    <details class="mt-faq-item">
      <summary>{f.question}</summary>
      <p>{f.answer}</p>
    </details>
  ))}
</section>

<section class="mt-related">
  <h2>Related Resources</h2>
  <div class="mt-related-list">
    <a href="/cs2-skins/" class="mt-related-row">Skin Database</a>
    <a href="/skin-compare/" class="mt-related-row">Compare Skins</a>
    <a href="/price-tracker/" class="mt-related-row">Price Tracker</a>
    <a href="/float-checker/" class="mt-related-row">Float Checker</a>
    <a href="/tradeup-calculator/" class="mt-related-row">Trade-Up Calculator</a>
    <a href="/case-odds-calculator/" class="mt-related-row">Case Odds Calculator</a>
    <a href="/case-simulator/" class="mt-related-row">Case Simulator</a>
    <a href="/cs2-cases/" class="mt-related-row">Cases & Collections</a>
    <a href="/inventory-lookup/" class="mt-related-row">Inventory Lookup</a>
    <a href="/loadout-builder/" class="mt-related-row">Loadout Builder</a>
    <a href="/cs2-weapons/" class="mt-related-row">Weapon Database</a>
    <a href="/cs2-guides/skins-investing-guide/" class="mt-related-row">Investing Guide</a>
    <a href="/cs2-guides/trading-guide/" class="mt-related-row">Trading Guide</a>
    <a href="/cs2-guides/float-guide/" class="mt-related-row">Float Guide</a>
  </div>
</section>

<ExploreMore context="skins" />

<style is:inline>
/* ── Breadcrumb ── */
.mt-breadcrumb{font-size:.82rem;color:var(--text2);margin-bottom:1.25rem;display:flex;gap:.35rem;flex-wrap:wrap}
.mt-breadcrumb a{color:var(--accent);text-decoration:none}
.mt-breadcrumb a:hover{text-decoration:underline}

/* ── Hero ── */
.mt-hero{background:var(--bg2);border:1px solid var(--border);border-radius:4px;padding:2rem;margin-bottom:1.5rem}
.mt-hero h1{font-family:'Montserrat',sans-serif;font-size:2rem;font-weight:800;margin:0 0 .5rem;color:var(--text)}
.mt-hero p{color:var(--text2);font-size:.95rem;line-height:1.6;margin:0}

/* ── Sections ── */
.mt-section{margin-bottom:2rem}
.mt-section h2{font-family:'Montserrat',sans-serif;font-size:1.15rem;font-weight:700;color:var(--text);margin:0 0 .5rem}
.mt-section>p{color:var(--text2);margin-bottom:1rem;font-size:.95rem}

/* ── Skin Row Lists ── */
.mt-list{display:flex;flex-direction:column;gap:2px}
.mt-skin-row{display:flex;align-items:center;gap:.75rem;text-decoration:none;color:inherit;background:var(--bg2);border:1px solid var(--border);border-left:3px solid transparent;border-radius:4px;padding:.7rem 1rem;transition:border-color .15s,background .15s}
.mt-skin-row:hover{border-left-color:var(--accent);background:var(--bg3)}
.mt-rank{font-weight:800;font-size:.85rem;color:var(--accent);min-width:30px}
.mt-value-badge{font-size:.7rem;font-weight:700;text-transform:uppercase;color:var(--accent);background:rgba(46,204,113,0.15);border:1px solid rgba(46,204,113,0.3);padding:.15rem .5rem;border-radius:4px;white-space:nowrap}
.mt-premium-badge{font-size:.7rem;font-weight:700;text-transform:uppercase;color:var(--text2);background:var(--bg3);border:1px solid var(--border);padding:.15rem .5rem;border-radius:4px;white-space:nowrap}
.mt-skin-info{flex:1;min-width:0;display:flex;flex-direction:column}
.mt-skin-weapon{font-size:.72rem;color:var(--text2);text-transform:uppercase;letter-spacing:.03em}
.mt-skin-name{font-size:.95rem;font-weight:700;color:var(--text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.mt-skin-rarity{font-size:.78rem;font-weight:700;text-transform:uppercase;letter-spacing:.03em;white-space:nowrap}
.mt-skin-price{font-weight:800;color:var(--accent);font-size:.95rem;white-space:nowrap;margin-left:auto}

/* ── Mover Rows ── */
.mt-mover-row{display:flex;align-items:center;gap:.75rem;text-decoration:none;color:inherit;background:var(--bg2);border:1px solid var(--border);border-left:3px solid transparent;border-radius:4px;padding:.7rem 1rem;transition:border-color .15s,background .15s}
.mt-mover-row:hover{border-left-color:var(--accent);background:var(--bg3)}
.mt-mover-rank{font-weight:700;font-size:.78rem;color:var(--text2);min-width:30px}
.mt-mover-img{flex-shrink:0;width:60px;height:45px;display:flex;align-items:center;justify-content:center;background:var(--bg3);border-radius:4px;overflow:hidden}
.mt-mover-img img{max-width:100%;max-height:100%;object-fit:contain}
.mt-mover-info{flex:1;min-width:0;display:flex;flex-direction:column}
.mt-mover-stats{display:flex;gap:.75rem;flex-wrap:wrap;margin-top:.15rem}
.mt-mover-stat{font-size:.78rem;font-weight:600}
.mt-trades{color:#4fc3f7}
.mt-volume{color:#81c784}
.mt-listings{color:#ffb74d}
.mt-price{color:var(--text2);font-weight:400}

/* ── Distribution ── */
.mt-dist{background:var(--bg2);border:1px solid var(--border);border-radius:4px;padding:1.5rem;display:flex;flex-direction:column;gap:1rem}
.mt-dist-row{display:grid;grid-template-columns:90px 80px 1fr 60px;gap:.75rem;align-items:center}
.mt-dist-label{font-weight:700;color:var(--text);font-size:.9rem}
.mt-dist-count{font-size:.75rem;color:var(--text2)}
.mt-dist-bar-wrap{height:24px;background:var(--bg3);border-radius:4px;overflow:hidden}
.mt-dist-bar{height:100%;background:var(--accent);border-radius:4px;transition:width .3s ease}
.mt-dist-pct{font-weight:700;color:var(--accent);font-size:.9rem;text-align:right}

/* ── Rarity List ── */
.mt-rarity-list{display:flex;flex-direction:column;gap:2px}
.mt-rarity-row{display:flex;align-items:center;gap:1rem;background:var(--bg2);border:1px solid var(--border);border-left:3px solid var(--rarity-color);border-radius:4px;padding:.75rem 1rem;transition:background .15s}
.mt-rarity-row:hover{background:var(--bg3)}
.mt-rarity-name{font-weight:700;color:var(--rarity-color);min-width:100px;font-size:.95rem}
.mt-rarity-count{font-size:.85rem;color:var(--text2);flex:1}
.mt-rarity-pct{font-weight:700;color:var(--text);font-size:.9rem}

/* ── Quick Nav ── */
.mt-quick{background:var(--bg2);border:1px solid var(--border);border-radius:4px;padding:1.5rem;margin-bottom:2rem}
.mt-quick h3{font-family:'Montserrat',sans-serif;margin:0 0 1rem;font-size:1.05rem;font-weight:700;color:var(--text)}
.mt-quick-links{display:flex;flex-direction:column;gap:2px}
.mt-quick-link{display:flex;align-items:center;text-decoration:none;color:var(--text);background:var(--bg3);border:1px solid var(--border);border-left:3px solid transparent;border-radius:4px;padding:.55rem 1rem;font-size:.9rem;font-weight:600;transition:border-color .15s,background .15s,color .15s}
.mt-quick-link:hover{border-left-color:var(--accent);color:var(--accent)}

/* ── FAQ ── */
.mt-faq{margin-bottom:2rem}
.mt-faq h2{font-family:'Montserrat',sans-serif;font-size:1.15rem;font-weight:700;color:var(--text);margin:0 0 .75rem}
.mt-faq-item{background:var(--bg2);border:1px solid var(--border);border-radius:4px;margin-bottom:.35rem;overflow:hidden}
.mt-faq-item summary{padding:.75rem 2.5rem .75rem 1rem;font-weight:700;font-size:.9rem;color:var(--text);cursor:pointer;list-style:none;position:relative;transition:background .15s}
.mt-faq-item summary::after{content:'+';position:absolute;right:1.25rem;top:50%;transform:translateY(-50%);font-size:1.2rem;color:var(--accent);font-weight:700}
.mt-faq-item[open] summary::after{content:'\2212'}
.mt-faq-item summary:hover{background:var(--bg3)}
