.md-player-role { font-size: .65rem; font-weight: 600; text-transform: uppercase; color: var(--text3); background: var(--bg3); padding: .1rem .35rem; border-radius: 2px; flex-shrink: 0; }

/* ── Map Pool Comparison ── */
.md-map-pool { background: var(--bg2); border: 1px solid var(--border); border-radius: 4px; margin-bottom: 1.25rem; overflow: hidden; transition: border-color .2s; }
