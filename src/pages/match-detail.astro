.md-map-pool-table tr:last-child td { border-bottom: none; }
.md-map-pool-table tr:hover { background: rgba(255,255,255,.02); }
.md-map-name-cell { display: flex; align-items: center; gap: .5rem; }
.md-map-name-cell img { width: 36px; height: 24px; border-radius: 3px; object-fit: cover; background: var(--bg); border: 1px solid var(--border); }
.md-map-wr { font-weight: 700; font-family: 'Montserrat', sans-serif; }
.md-map-wr.high { color: var(--accent); }
.md-map-wr.mid { color: #f39c12; }
.md-map-wr.low { color: #e74c3c; }

/* ── Team Stats Comparison ── */
.md-player-comp { background: var(--bg2); border: 1px solid var(--border); border-radius: 4px; margin-bottom: 1.25rem; overflow: hidden; transition: border-color .2s; }
.md-player-comp:hover { border-color: var(--accent); }
.md-player-comp-table { width: 100%; border-collapse: collapse; font-size: .8rem; }
.md-player-comp-table th { padding: .6rem .75rem; font-size: .72rem; font-weight: 600; text-transform: uppercase; color: var(--text3); border-bottom: 1px solid var(--border); text-align: center; white-space: nowrap; }
.md-player-comp-table th:first-child { text-align: left; }
.md-player-comp-table td { padding: .45rem .75rem; border-bottom: 1px solid var(--border); text-align: center; font-size: .82rem; }
.md-player-comp-table td:first-child { text-align: left; font-weight: 600; }
.md-player-comp-table tr:last-child td { border-bottom: none; }
.md-player-comp-table tr:hover { background: rgba(255,255,255,.02); }
.md-comp-best { color: var(--accent); font-weight: 700; }

/* ── Recent Form ── */
.md-form { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1.25rem; }
.md-form-card { background: var(--bg2); border: 1px solid var(--border); border-radius: 4px; overflow: hidden; transition: border-color .2s; }
.md-form-card:hover { border-color: var(--accent); }
.md-form-header { display: flex; align-items: center; gap: .5rem; padding: .75rem 1rem; background: var(--bg3); border-bottom: 1px solid var(--border); font-weight: 700; font-family: 'Montserrat', sans-serif; font-size: .85rem; }
.md-form-header img { width: 22px; height: 22px; border-radius: 3px; object-fit: contain; background: rgba(255,255,255,.08); padding: 2px; }
.md-form-list { padding: .25rem 0; }
.md-form-match { display: flex; align-items: center; gap: .5rem; padding: .4rem .75rem; font-size: .8rem; border-bottom: 1px solid rgba(255,255,255,.03); }
.md-form-match:last-child { border-bottom: none; }
.md-form-result { width: 20px; height: 20px; border-radius: 3px; display: flex; align-items: center; justify-content: center; font-size: .65rem; font-weight: 800; flex-shrink: 0; }
.md-form-result.win { background: rgba(46,204,113,.15); color: #2ecc71; border: 1px solid rgba(46,204,113,.3); }
.md-form-result.loss { background: rgba(231,76,60,.12); color: #e74c3c; border: 1px solid rgba(231,76,60,.25); }
.md-form-opp { flex: 1; color: var(--text2); font-weight: 600; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.md-form-score { font-weight: 700; font-family: 'Montserrat', sans-serif; color: var(--text1); min-width: 2rem; text-align: center; }
.md-form-map { font-size: .72rem; color: var(--text3); min-width: 3.5rem; text-align: right; }
.md-form-empty { text-align: center; padding: .75rem; color: var(--text3); font-size: .82rem; }

/* ── New sections responsive ── */
@media (max-width: 600px) {
  .md-insights, .md-lineups, .md-form { grid-template-columns: 1fr; }
  .md-map-pool-table, .md-player-comp-table { font-size: .72rem; }
  .md-map-pool-table th, .md-map-pool-table td,
  .md-player-comp-table th, .md-player-comp-table td { padding: .35rem .4rem; }
  .md-map-name-cell img { display: none; }
  .md-stream-embed iframe { aspect-ratio: 16/10; }
}
</style>

<script>
(function() {
  const matchId = new URLSearchParams(window.location.search).get('id');
  if (!matchId) {
    showError('No match ID found in URL.');
    return;
  }

  const container = document.getElementById('match-detail');
  const loadingEl = document.getElementById('loading');
  const errorEl = document.getElementById('error-state');

  fetchMatch(matchId);

  async function fetchMatch(id) {
    try {
      const res = await fetch(`/api/match-detail?id=${encodeURIComponent(id)}`);
      if (!res.ok) throw new Error(`HTTP ${res.status}`);
      const data = await res.json();
      if (!data || data.error) throw new Error(data?.error || 'Invalid response');
      render(data);
    } catch (err) {
      console.error('Failed to load match:', err);
      showError('Unable to load match details. <a href="/matches/">Back to matches</a>');
    }
  }

  function showError(msg) {
    const loadingEl = document.getElementById('loading');
    const errorEl = document.getElementById('error-state');
    if (loadingEl) loadingEl.style.display = 'none';
    if (errorEl) { errorEl.style.display = 'block'; errorEl.innerHTML = msg; }
  }

  function tierClass(tier) {
    return tier ? `tier-${tier}` : 'tier-d';
  }

  function tierLabel(tier) {
    const labels = { s: 'S-Tier', a: 'A-Tier', b: 'B-Tier', c: 'C-Tier', d: 'D-Tier' };
    return labels[tier] || tier?.toUpperCase() || '';
  }

  function formatDateTime(iso) {
    if (!iso) return '—';
    const d = new Date(iso);
    return d.toLocaleString(undefined, { weekday: 'short', month: 'short', day: 'numeric', year: 'numeric', hour: '2-digit', minute: '2-digit' });
  }

  function formatDuration(beginAt, endAt) {
    if (!beginAt || !endAt) return null;
    const ms = new Date(endAt) - new Date(beginAt);
    if (ms <= 0) return null;
    const mins = Math.floor(ms / 60000);
    if (mins < 60) return `${mins}m`;
    const hrs = Math.floor(mins / 60);
    return `${hrs}h ${mins % 60}m`;
  }

  function formatGameLength(seconds) {
    if (!seconds || seconds <= 0) return null;
    const m = Math.floor(seconds / 60);
    const s = seconds % 60;
    return `${m}:${s.toString().padStart(2, '0')}`;
  }

  function teamLogoHTML(team, size, cssClass) {
    const pad = Math.max(Math.round(size * 0.08), 2);
    if (team.image) {
      return `<img src="${team.image}" alt="${team.name || ''}" class="${cssClass}" style="width:${size}px;height:${size}px;max-width:${size}px;max-height:${size}px;object-fit:contain;border-radius:4px;background:rgba(255,255,255,.08);padding:${pad}px;flex-shrink:0" loading="lazy" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" /><div class="${cssClass}-placeholder" style="display:none;width:${size}px;height:${size}px;border-radius:4px;background:rgba(255,255,255,.08);align-items:center;justify-content:center;font-size:${Math.max(size * 0.2, 10)}px;font-weight:700;color:var(--text3);flex-shrink:0">${team.acronym || team.name?.[0] || '?'}</div>`;
    }
    return `<div class="${cssClass}-placeholder" style="display:flex;width:${size}px;height:${size}px;border-radius:4px;background:rgba(255,255,255,.08);align-items:center;justify-content:center;font-size:${Math.max(size * 0.2, 10)}px;font-weight:700;color:var(--text3);flex-shrink:0">${team.acronym || team.name?.[0] || '?'}</div>`;
  }

  function render(match) {
    const t1 = match.opponents?.[0] || { name: 'TBD' };
    const t2 = match.opponents?.[1] || { name: 'TBD' };
    const r1 = match.results?.find(r => r.team_id === t1.id)?.score ?? 0;
    const r2 = match.results?.find(r => r.team_id === t2.id)?.score ?? 0;
    const isLive = match.status === 'running';
    const isFinished = match.status === 'finished';
    const t1Winner = isFinished && match.winnerId === t1.id;
    const t2Winner = isFinished && match.winnerId === t2.id;
    const statusClass = isLive ? 'live' : (isFinished ? 'finished' : 'upcoming');
    const format = match.numberOfGames > 1 ? `BO${match.numberOfGames}` : 'BO1';
    const duration = formatDuration(match.beginAt, match.endAt);

    // Update breadcrumb
    const bcEl = document.getElementById('breadcrumb-match');
    if (bcEl) {
      const label = t1.name && t2.name ? `${t1.acronym || t1.name} vs ${t2.acronym || t2.name}` : (match.name || 'Match Details');
      bcEl.textContent = label;
    }

    // Update page title
    if (t1.name && t2.name) {
      document.title = `${t1.name} vs ${t2.name} — CS2 Match Details | CSGOLuck Wiki`;
    }

    // Status badge
    let statusBadge = '';
    if (isLive) {
      statusBadge = `<span class="match-status-badge status-running">● LIVE</span>`;
    } else if (isFinished) {
      statusBadge = `<span class="match-status-badge status-finished">Finished</span>`;
    } else {
      statusBadge = `<span class="match-status-badge status-not_started">Upcoming</span>`;
    }

    // Series score or VS
    let scoreCenterHTML = '';
    if (isLive || isFinished) {
      scoreCenterHTML = `
        <span class="sb-score-val ${t1Winner ? 'winner' : ''}">${r1}</span>
        <span class="sb-sep">:</span>
        <span class="sb-score-val ${t2Winner ? 'winner' : ''}">${r2}</span>`;
    } else {
      scoreCenterHTML = `<span class="sb-vs">VS</span>`;
    }

    // Metadata items
    const metaItems = [];
    metaItems.push(`<span class="meta-item"><strong>Format:</strong> ${format}</span>`);
    if (match.beginAt) metaItems.push(`<span class="meta-item"><strong>Start:</strong> ${formatDateTime(match.beginAt)}</span>`);
    if (isFinished && match.endAt) metaItems.push(`<span class="meta-item"><strong>End:</strong> ${formatDateTime(match.endAt)}</span>`);
    if (duration) metaItems.push(`<span class="meta-item"><strong>Duration:</strong> ${duration}</span>`);
    if (match.tournament?.prizepool) metaItems.push(`<span class="meta-item"><strong>Prize Pool:</strong> ${match.tournament.prizepool}</span>`);
    if (match.forfeit) metaItems.push(`<span class="meta-item" style="color:#e74c3c"><strong>Forfeit</strong></span>`);
    if (match.draw) metaItems.push(`<span class="meta-item"><strong>Draw</strong></span>`);

    // Games / Maps
    let gamesHTML = '';
    const games = match.games || [];
    const sortedGames = [...games].sort((a, b) => (a.position || 0) - (b.position || 0));
    // Filter out unplayed maps for forfeited matches
    const playableGames = match.forfeit
      ? sortedGames.filter(g => g.status === 'finished' || g.status === 'running')
      : sortedGames;

    if (match.forfeit) {
      gamesHTML += `<div class="forfeit-notice"><span class="forfeit-icon">⚠</span> This match was decided by forfeit${playableGames.length > 0 ? '. Maps played before the forfeit are shown below.' : '. No maps were played.'}</div>`;
    }

    if (playableGames.length > 0) {
      gamesHTML += `<h2 class="section-title">Map Results</h2>`;
      playableGames.forEach(game => {
        const gt1Raw = game.teams?.find(t => t.id === t1.id) || game.teams?.[0] || {};
        const gt2Raw = game.teams?.find(t => t.id === t2.id) || game.teams?.[1] || {};
        // Compute total score from halves if score is null
        const computeScore = (t) => {
          if (t.score != null) return t.score;
          if (t.firstHalfScore != null || t.secondHalfScore != null)
            return (t.firstHalfScore ?? 0) + (t.secondHalfScore ?? 0) + (t.overtimeScore ?? 0);
          return null;
        };
        const gt1 = { ...gt1Raw, score: computeScore(gt1Raw) };
        const gt2 = { ...gt2Raw, score: computeScore(gt2Raw) };
        const gWinner1 = game.winnerId === t1.id;
        const gWinner2 = game.winnerId === t2.id;
        const mapName = game.map?.name || 'Unknown Map';
        const gameDuration = formatGameLength(game.length);

        // Winner tag
        let winnerTag = '';
        if (game.status === 'finished' && game.winnerName) {
          winnerTag = `<span class="game-winner-tag">${game.winnerName} wins</span>`;
        } else if (game.status === 'running') {
          winnerTag = `<span class="game-status-tag" style="color:#e74c3c">● Live</span>`;
        } else if (game.status === 'not_started') {
          winnerTag = `<span class="game-status-tag">Not Started</span>`;
        }

        // Half breakdown
        let halfHTML = '';
        const hasHalves = (gt1.firstHalfScore != null || gt2.firstHalfScore != null);
        if (hasHalves) {
          halfHTML = `<div class="half-breakdown">`;

          // First half
          if (gt1.firstHalfScore != null || gt2.firstHalfScore != null) {
            const fh1 = gt1.firstHalfScore ?? '—';
            const fh2 = gt2.firstHalfScore ?? '—';
            const fh1w = fh1 > fh2 ? 'winner' : '';
            const fh2w = fh2 > fh1 ? 'winner' : '';
            halfHTML += `
              <div class="half-row">
                <span class="half-score left ${fh1w}">${fh1}</span>
                <span class="half-label">1st Half</span>
                <span class="half-score right ${fh2w}">${fh2}</span>
              </div>`;
          }

          // Second half
          if (gt1.secondHalfScore != null || gt2.secondHalfScore != null) {
            const sh1 = gt1.secondHalfScore ?? '—';
            const sh2 = gt2.secondHalfScore ?? '—';
            const sh1w = sh1 > sh2 ? 'winner' : '';
            const sh2w = sh2 > sh1 ? 'winner' : '';
            halfHTML += `
              <div class="half-row">
                <span class="half-score left ${sh1w}">${sh1}</span>
                <span class="half-label">2nd Half</span>
                <span class="half-score right ${sh2w}">${sh2}</span>
              </div>`;
          }

          // Overtime
          if (gt1.overtimeScore != null || gt2.overtimeScore != null) {
            const ot1 = gt1.overtimeScore ?? '—';
            const ot2 = gt2.overtimeScore ?? '—';
            const ot1w = ot1 > ot2 ? 'winner' : '';
            const ot2w = ot2 > ot1 ? 'winner' : '';
            halfHTML += `
              <div class="half-row">
                <span class="half-score left ${ot1w}">${ot1}</span>
                <span class="half-label">Overtime</span>
                <span class="half-score right ${ot2w}">${ot2}</span>
              </div>`;
          }

          halfHTML += `</div>`;
        }

        gamesHTML += `
          <div class="game-card">
            <div class="game-card-header">
              <div class="game-map-info">
                ${game.map?.image ? `<img src="${game.map.image}" alt="${mapName}" class="game-map-img" style="width:40px;height:26px;border-radius:3px;object-fit:cover;background:var(--bg)" loading="lazy" onerror="this.style.display='none'" />` : ''}
                <span class="game-map-name">${mapName}</span>
                <span class="game-position">Map ${game.position || ''}</span>
              </div>
              ${winnerTag}
            </div>
            <div class="game-card-body">
              <div class="game-scores">
                <div class="game-team">
                  ${gWinner1 ? '<span class="game-w-badge win">W</span>' : (gWinner2 ? '<span class="game-w-badge loss">L</span>' : '')}
                  ${teamLogoHTML(gt1.id ? { id: gt1.id, name: gt1.name, image: t1.image, acronym: t1.acronym } : t1, 24, 'game-team-logo')}
                  <span class="game-team-name ${gWinner1 ? 'winner' : ''}">${gt1.name || t1.name || 'TBD'}</span>
                </div>
                ${(gt1.score != null && gt2.score != null) ? `
                <div class="game-total-score">
                  <span class="game-score-val ${gWinner1 ? 'winner' : ''}">${gt1.score}</span>
                  <span class="game-score-sep">:</span>
                  <span class="game-score-val ${gWinner2 ? 'winner' : ''}">${gt2.score}</span>
                </div>` : (game.winnerId ? `
                <div class="game-total-score game-total-score-noscores">
                  <span class="game-score-val ${gWinner1 ? 'winner' : ''}">${gWinner1 ? 'W' : 'L'}</span>
                  <span class="game-score-sep">–</span>
                  <span class="game-score-val ${gWinner2 ? 'winner' : ''}">${gWinner2 ? 'W' : 'L'}</span>
                </div>` : `
                <div class="game-total-score">
                  <span class="game-score-sep" style="font-size:.85rem">vs</span>
                </div>`)}
                <div class="game-team right">
                  ${gWinner2 ? '<span class="game-w-badge win">W</span>' : (gWinner1 ? '<span class="game-w-badge loss">L</span>' : '')}
                  ${teamLogoHTML(gt2.id ? { id: gt2.id, name: gt2.name, image: t2.image, acronym: t2.acronym } : t2, 24, 'game-team-logo')}
                  <span class="game-team-name ${gWinner2 ? 'winner' : ''}">${gt2.name || t2.name || 'TBD'}</span>
                </div>
              </div>
              ${halfHTML}
              ${(() => {
                const rounds = game.rounds || [];
                if (rounds.length === 0) return '';
                const team1Id = gt1.id || t1.id;
                const team2Id = gt2.id || t2.id;
                // Build round dots: each round is a colored dot for the winning team/side
                const halfPoint = Math.min(12, Math.floor(rounds.length / 2));
                let html = '<div class="round-timeline">';
                html += '<div class="rt-row">';
                rounds.forEach((r, i) => {
                  // Insert half separator
                  if (i === halfPoint) html += '<span class="rt-half-sep"></span>';
                  const isT1 = r.winnerTeam === team1Id;
                  const side = r.winnerSide || '';
                  const cls = isT1 ? 'rt-t1' : 'rt-t2';
                  const sideCls = side === 'ct' ? 'rt-ct' : 'rt-t';
                  html += '<span class="rt-dot ' + cls + ' ' + sideCls + '" title="R' + (i+1) + ' ' + side.toUpperCase() + ' ' + r.outcome + '"></span>';
                });
                html += '</div>';
                html += '<div class="rt-legend">';
                html += '<span class="rt-legend-team">' + escapeHtml(t1.acronym || t1.name || 'T1') + '</span>';
                html += '<span class="rt-legend-item"><span class="rt-swatch rt-t1 rt-ct"></span>CT</span>';
                html += '<span class="rt-legend-item"><span class="rt-swatch rt-t1 rt-t"></span>T</span>';
                html += '<span class="rt-legend-sep">|</span>';
                html += '<span class="rt-legend-team">' + escapeHtml(t2.acronym || t2.name || 'T2') + '</span>';
                html += '<span class="rt-legend-item"><span class="rt-swatch rt-t2 rt-ct"></span>CT</span>';
                html += '<span class="rt-legend-item"><span class="rt-swatch rt-t2 rt-t"></span>T</span>';
                html += '</div>';
                html += '</div>';
                return html;
              })()}
              ${gameDuration ? `<div class="game-duration">Duration: ${gameDuration}</div>` : ''}
              <div class="game-mvp-row" id="mvp-row-${game.id}" style="display:none"></div>
              ${game.id && game.detailedStats ? `<button class="gps-toggle" data-game-id="${game.id}" onclick="window.__togglePlayerStats(this, ${game.id})">Show Player Stats ▾</button><div class="gps-table-wrap" id="gps-wrap-${game.id}" style="display:none"></div>` : ''}
            </div>
          </div>`;
      });
    }

    // Auto-fetch MVP previews for games with detailed stats
    const detailedGames = playableGames.filter(g => g.id && g.detailedStats && g.status === 'finished');
    detailedGames.forEach(function(game) {
      fetch('/api/game-stats?id=' + encodeURIComponent(game.id))
        .then(function(r) { return r.ok ? r.json() : null; })
        .then(function(data) {
          if (!data || !data.teams || data.teams.length === 0) return;
          window.__gpsCache[game.id] = data;
          const allPlayers = [];
          data.teams.forEach(function(team) {
            (team.players || []).forEach(function(p) {
              allPlayers.push({ ...p, teamName: team.name || team.acronym });
            });
          });
          if (allPlayers.length === 0) return;
          allPlayers.sort(function(a, b) { return (b.rating || 0) - (a.rating || 0); });
          const mvp = allPlayers[0];
          const mvpRow = document.getElementById('mvp-row-' + game.id);
          if (!mvpRow) return;
          const kd = (mvp.kills || 0) - (mvp.deaths || 0);
          const kdStr = kd >= 0 ? '+' + kd : '' + kd;
          mvpRow.innerHTML = '<span class="mvp-star">★</span> <span class="mvp-label">MVP</span> '
            + '<strong class="mvp-name">' + escapeHtml(mvp.name) + '</strong>'
            + ' <span class="mvp-team">(' + escapeHtml(mvp.teamName) + ')</span>'
            + ' <span class="mvp-stats">' + (mvp.rating != null ? mvp.rating.toFixed(2) + ' rating' : '')
            + ' · ' + (mvp.kills || 0) + '-' + (mvp.deaths || 0) + '-' + (mvp.assists || 0)
            + ' (' + kdStr + ')'
            + (mvp.adr != null ? ' · ' + mvp.adr.toFixed(0) + ' ADR' : '')
            + '</span>';
          mvpRow.style.display = 'flex';
        })
        .catch(function() {});
    });

    // Streams
    let streamsHTML = '';
    const streams = match.streams || [];
    const validStreams = streams.filter(s => s.url);
    if (validStreams.length > 0) {
      streamsHTML = `
        <h2 class="section-title">Streams</h2>
        <div class="streams-card">
          <div class="stream-list">
            ${validStreams.map(s => `
              <a href="${s.url}" target="_blank" rel="noopener" class="stream-link">
                ▶ ${s.language ? `<span class="stream-lang">[${s.language.toUpperCase()}]</span>` : ''} Watch Stream
              </a>
            `).join('')}
          </div>
        </div>`;
    }

    // Stream embed (Twitch/Kick for live or upcoming matches)
    let streamEmbedHTML = '';
    if ((isLive || !isFinished) && validStreams.length > 0) {
      const twitchStream = validStreams.find(function(s) { return s.url && s.url.indexOf('twitch.tv') !== -1; });
      if (twitchStream) {
        const twitchMatch = twitchStream.url.match(/twitch\.tv\/([^/?#]+)/);
        if (twitchMatch) {
          const channel = twitchMatch[1];
          streamEmbedHTML = '<div id="stream-embed" class="md-stream-embed"><iframe src="https://player.twitch.tv/?channel=' + encodeURIComponent(channel) + '&parent=' + window.location.hostname + '&muted=true" allowfullscreen></iframe><div class="md-stream-embed-label">▶ Live on Twitch · ' + escapeHtml(channel) + '</div></div>';
        }
      }
    }

    // Build full HTML
    const html = `
      <a href="/matches/" class="back-link">← Back to Matches</a>

      <div class="detail-header ${statusClass}">
        <div class="detail-league-row">
          <div class="detail-league">
            ${match.league?.image ? `<img src="${match.league.image}" alt="${match.league?.name || ''}" style="height:24px;max-height:24px;width:auto;max-width:100px;object-fit:contain;border-radius:2px" loading="lazy" onerror="this.style.display='none'" />` : ''}
            <span class="detail-league-text">
              <strong>${match.league?.name || ''}</strong>
              ${match.serie?.name ? ' · ' + match.serie.name : ''}
              ${match.tournament?.name ? ' · ' + match.tournament.name : ''}
            </span>
          </div>
          ${match.tournament?.tier ? `<span class="match-tier ${tierClass(match.tournament.tier)}">${tierLabel(match.tournament.tier)}</span>` : ''}
        </div>

        <div class="scoreboard">
          <div class="sb-team">
            ${teamLogoHTML(t1, 64, 'sb-logo')}
            <div>
              <div class="sb-name ${t1Winner ? 'winner' : ''}">${t1.name || 'TBD'}</div>
              ${t1.location ? `<div class="sb-location">${t1.location}</div>` : ''}
            </div>
          </div>

          <div class="sb-score-center">
            ${scoreCenterHTML}
          </div>

          <div class="sb-team">
            ${teamLogoHTML(t2, 64, 'sb-logo')}
            <div>
              <div class="sb-name ${t2Winner ? 'winner' : ''}">${t2.name || 'TBD'}</div>
              ${t2.location ? `<div class="sb-location">${t2.location}</div>` : ''}
            </div>
          </div>
        </div>

        <div style="text-align:center">
          ${statusBadge}
          ${isLive ? `<span class="auto-refresh-badge"><span class="ar-dot"></span> Auto-refreshing every 30s</span><span class="auto-refresh-ts" id="ar-ts"></span>` : ''}
        </div>

        <div class="meta-row">
          ${metaItems.join('<span class="meta-sep">·</span>')}
        </div>

        ${match.tournament?.id ? `<div class="meta-row" style="border-top:none;margin-top:.25rem;padding-top:0">
          <a href="/tournament-detail/?id=${match.tournament.id}" style="font-size:.8rem;color:var(--accent);text-decoration:none;font-weight:600">🏆 Tournament</a>
        </div>` : ''}
      </div>

      <div id="stream-embed-slot"></div>

      <div class="betting-cta">
        <div class="betting-cta-body">
          <span class="betting-cta-text">Like what you see? Place your bets on live CS2 matches.</span>
          <a href="https://csgoluck.com/r/WIKIPEDIA" target="_blank" rel="noopener" class="betting-cta-btn">Bet on This Match &rarr;</a>
        </div>
      </div>

      <div id="h2h-section"><div class="md-h2h-loading"><div class="spinner"></div> Loading head-to-head…</div></div>

      <div id="insights-section"></div>
      <div id="lineups-section"></div>
      <div id="map-pool-section"></div>
      <div id="player-comp-section"></div>

      ${gamesHTML}

      <div id="form-section"></div>
      ${streamsHTML}
    `;

    loadingEl.style.display = 'none';
    container.insertAdjacentHTML('beforeend', html);

    // Insert stream embed into its slot (first render only)
    if (streamEmbedHTML) {
      const slot = document.getElementById('stream-embed-slot');
      if (slot && !document.getElementById('stream-embed')) {
        slot.insertAdjacentHTML('afterend', streamEmbedHTML);
        slot.remove();
      }
    }

    // ── Auto-refresh for live matches ──
    if (match.status === 'running') {
      function updateTimestamp() {
        const tsEl = document.getElementById('ar-ts');
        if (tsEl) {
          const now = new Date();
          tsEl.textContent = 'Last updated: ' + now.toLocaleTimeString(undefined, { hour: '2-digit', minute: '2-digit', second: '2-digit' });
        }
      }
      updateTimestamp();

      if (window.__autoRefreshInterval) clearInterval(window.__autoRefreshInterval);
      window.__autoRefreshInterval = setInterval(async function() {
        try {
          const res = await fetch(`/api/match-detail?id=${encodeURIComponent(matchId)}`);
          if (!res.ok) return;
          const freshData = await res.json();
          if (!freshData || freshData.error) return;

          // Clear existing rendered content (keep loading/error elements)
          // Detach stream embed temporarily to preserve Twitch player state
          const existingStream = document.getElementById('stream-embed');
          if (existingStream) existingStream.remove();
          const children = Array.from(container.children);
          children.forEach(function(child) {
            if (child.id !== 'loading' && child.id !== 'error-state') {
              child.remove();
            }
          });

          // Clear player stats cache so fresh data can be fetched
          window.__gpsCache = {};

          // Re-render with fresh data
          render(freshData);

          // Re-insert preserved stream embed into its slot
          if (existingStream) {
            const slot = document.getElementById('stream-embed-slot');
            if (slot) slot.replaceWith(existingStream);
          }

          // Stop polling if match is finished
          if (freshData.status === 'finished') {
            clearInterval(window.__autoRefreshInterval);
            window.__autoRefreshInterval = null;
          }
        } catch (e) {
          console.error('Auto-refresh failed:', e);
        }
      }, 30000);
    }

    // ── Fetch H2H & Team Stats for probability ──
    if (t1.id && t2.id) {
      if (window.__h2hData) {
        // Use cached data on re-render (auto-refresh)
        renderH2HSection(window.__h2hData, window.__t1Stats, window.__t2Stats, match, t1, t2);
        renderAnalyticsInsights(window.__t1Stats, window.__t2Stats, match, t1, t2);
        renderTeamLineups(window.__t1Roster, window.__t2Roster, t1, t2);
        renderMapPool(window.__t1Stats, window.__t2Stats, t1, t2);
        renderTeamStatsComparison(window.__t1Stats, window.__t2Stats, t1, t2);
        renderTeamForm(window.__t1Matches, window.__t2Matches, t1, t2);
      } else {
        Promise.all([
          fetch('/api/h2h-matches?team1=' + t1.id + '&team2=' + t2.id + '&per_page=10').then(function(r) { return r.ok ? r.json() : null; }),
          fetch('/api/team-competitive-stats?id=' + t1.id).then(function(r) { return r.ok ? r.json() : null; }),
          fetch('/api/team-competitive-stats?id=' + t2.id).then(function(r) { return r.ok ? r.json() : null; }),
          fetch('/api/team-stats?id=' + t1.id).then(function(r) { return r.ok ? r.json() : null; }),
          fetch('/api/team-stats?id=' + t2.id).then(function(r) { return r.ok ? r.json() : null; }),
          fetch('/api/team-matches?id=' + t1.id + '&per_page=10').then(function(r) { return r.ok ? r.json() : null; }),
          fetch('/api/team-matches?id=' + t2.id + '&per_page=10').then(function(r) { return r.ok ? r.json() : null; }),
        ]).then(function(results) {
          window.__h2hData = results[0];
          window.__t1Stats = results[1];
          window.__t2Stats = results[2];
          window.__t1Roster = results[3];
          window.__t2Roster = results[4];
          window.__t1Matches = results[5];
          window.__t2Matches = results[6];
          renderH2HSection(results[0], results[1], results[2], match, t1, t2);
          renderAnalyticsInsights(results[1], results[2], match, t1, t2);
          renderTeamLineups(results[3], results[4], t1, t2);
          renderMapPool(results[1], results[2], t1, t2);
          renderTeamStatsComparison(results[1], results[2], t1, t2);
          renderTeamForm(results[5], results[6], t1, t2);
        }).catch(function(err) {
          console.error('Failed to load supplementary data:', err);
          var sec = document.getElementById('h2h-section');
          if (sec) sec.innerHTML = '';
        });
      }
    } else {
      var sec = document.getElementById('h2h-section');
      if (sec) sec.innerHTML = '';
    }
  }

  // ── H2H & Win Probability ──
  window.__h2hData = null;
  window.__t1Stats = null;
  window.__t2Stats = null;
  window.__t1Roster = null;
  window.__t2Roster = null;
  window.__t1Matches = null;
  window.__t2Matches = null;

  function calcWinProb(h2hData, t1Stats, t2Stats, match, t1, t2) {
    var isLive = match.status === 'running';
    var isFinished = match.status === 'finished';
    var factors = [];

    // Finished → show actual result
    if (isFinished) {
      if (match.winnerId === t1.id) return { t1Pct: 100, t2Pct: 0, factors: [{ name: 'Result', detail: escapeHtml(t1.acronym||t1.name) + ' won the match', value: 1 }] };
      if (match.winnerId === t2.id) return { t1Pct: 0, t2Pct: 100, factors: [{ name: 'Result', detail: escapeHtml(t2.acronym||t2.name) + ' won the match', value: 0 }] };
      return { t1Pct: 50, t2Pct: 50, factors: [{ name: 'Result', detail: 'Draw', value: 0.50 }] };
    }

    var record = h2hData ? h2hData.record : null;

    // Factor 1: H2H Record
    var h2hRate = 0.50;
    if (record && record.total > 0) {
      h2hRate = record.team1Wins / record.total;
      factors.push({ name: 'H2H Record', detail: escapeHtml(t1.acronym||t1.name) + ' leads ' + record.team1Wins + '-' + record.team2Wins + (record.total > 2 ? ' (' + record.total + ' played)' : ''), value: h2hRate });
    } else {
      factors.push({ name: 'H2H Record', detail: 'No previous meetings', value: 0.50 });
    }

    // Factor 2: Recent Form (from team-competitive-stats)
    var formRate = 0.50;
    if (t1Stats && t2Stats) {
      var t1WR = (t1Stats.record && t1Stats.record.matchWinRate != null) ? t1Stats.record.matchWinRate / 100 : 0.50;
      var t2WR = (t2Stats.record && t2Stats.record.matchWinRate != null) ? t2Stats.record.matchWinRate / 100 : 0.50;
      if (t1WR + t2WR > 0) formRate = t1WR / (t1WR + t2WR);
      var t1Pct = (t1WR * 100).toFixed(0);
      var t2Pct = (t2WR * 100).toFixed(0);
      factors.push({ name: 'Form', detail: escapeHtml(t1.acronym||t1.name) + ' ' + t1Pct + '% match WR, ' + escapeHtml(t2.acronym||t2.name) + ' ' + t2Pct + '% match WR', value: formRate });
    }

    // Factor 3: Map Pool Strength
    var mapRate = 0.50;
    var games = match.games || [];
    var mapsInSeries = [];
    games.forEach(function(g) { if (g.map && g.map.name && mapsInSeries.indexOf(g.map.name) === -1) mapsInSeries.push(g.map.name); });

    if (mapsInSeries.length > 0 && t1Stats && t2Stats) {
      var mapAdvantages = [];
      var mapDetailParts = [];
      mapsInSeries.forEach(function(mapName) {
        var t1Map = (t1Stats.maps || []).find(function(m) { return m.name && m.name.toLowerCase() === mapName.toLowerCase(); });
        var t2Map = (t2Stats.maps || []).find(function(m) { return m.name && m.name.toLowerCase() === mapName.toLowerCase(); });
        var t1wr = t1Map ? t1Map.winRate / 100 : 0.50;
        var t2wr = t2Map ? t2Map.winRate / 100 : 0.50;
        if (t1wr + t2wr > 0) mapAdvantages.push(t1wr / (t1wr + t2wr));
        mapDetailParts.push(mapName + ': ' + (t1Map ? t1Map.winRate.toFixed(0) : '?') + '% vs ' + (t2Map ? t2Map.winRate.toFixed(0) : '?') + '%');
      });
      if (mapAdvantages.length > 0) {
        mapRate = mapAdvantages.reduce(function(a, b) { return a + b; }, 0) / mapAdvantages.length;
        factors.push({ name: 'Map Pool', detail: mapDetailParts.join(', '), value: mapRate });
      }
    }

    // Factor 4: Map-specific H2H (from h2h matches games data)
    var mapH2HRate = h2hRate; // default to overall H2H if no map data
    if (h2hData && h2hData.matches && mapsInSeries.length > 0) {
      var t1MapWins = 0, t2MapWins = 0;
      var t1Id = h2hData.team1Id, t2Id = h2hData.team2Id;
      h2hData.matches.forEach(function(m) {
        (m.games || []).forEach(function(g) {
          if (!g.map) return;
          var isSeriesMap = mapsInSeries.some(function(mn) { return mn.toLowerCase() === g.map.toLowerCase(); });
          if (isSeriesMap) {
            if (g.winnerId === t1Id) t1MapWins++;
            else if (g.winnerId === t2Id) t2MapWins++;
          }
        });
      });
      if (t1MapWins + t2MapWins > 0) {
        mapH2HRate = t1MapWins / (t1MapWins + t2MapWins);
        factors.push({ name: 'Map H2H', detail: escapeHtml(t1.acronym||t1.name) + ' ' + t1MapWins + '-' + t2MapWins + ' on series maps', value: mapH2HRate });
      }
    }

    // Factor 5: Series Score (live/in-progress)
    var seriesProb = 0.50;
    var mapsToWin = Math.ceil((match.numberOfGames || 1) / 2);
    var r1 = 0, r2 = 0;
    if (match.results) {
      var res1 = match.results.find(function(r) { return r.team_id === t1.id; });
      var res2 = match.results.find(function(r) { return r.team_id === t2.id; });
      r1 = res1 ? res1.score : 0;
      r2 = res2 ? res2.score : 0;
    }
    if (isLive || r1 > 0 || r2 > 0) {
      if (r1 >= mapsToWin) seriesProb = 0.95;
      else if (r2 >= mapsToWin) seriesProb = 0.05;
      else {
        var t1Need = mapsToWin - r1;
        var t2Need = mapsToWin - r2;
        seriesProb = t2Need / (t1Need + t2Need);
      }
      if (r1 !== r2) {
        factors.push({ name: 'Series', detail: escapeHtml(t1.acronym||t1.name) + ' ' + r1 + '-' + r2 + ' ' + escapeHtml(t2.acronym||t2.name) + ' (BO' + (match.numberOfGames || 1) + ')', value: seriesProb });
      }
    }

    // Factor 6: Live Map Score
    var mapProb = 0.50;
    var hasLiveMap = false;
    var liveGame = (match.games || []).find(function(g) { return g.status === 'running'; });
    if (liveGame && isLive) {
      var gT1 = (liveGame.teams || []).find(function(t) { return t.id === t1.id; }) || (liveGame.teams || [])[0] || {};
      var gT2 = (liveGame.teams || []).find(function(t) { return t.id === t2.id; }) || (liveGame.teams || [])[1] || {};
      var s1 = gT1.score != null ? gT1.score : ((gT1.firstHalfScore||0) + (gT1.secondHalfScore||0) + (gT1.overtimeScore||0));
      var s2 = gT2.score != null ? gT2.score : ((gT2.firstHalfScore||0) + (gT2.secondHalfScore||0) + (gT2.overtimeScore||0));
      var roundDiff = s1 - s2;
      mapProb = 1 / (1 + Math.exp(-0.15 * roundDiff));
      hasLiveMap = true;
      factors.push({ name: 'Map Score', detail: s1 + '-' + s2 + ' on ' + (liveGame.map && liveGame.map.name ? liveGame.map.name : 'current map'), value: mapProb });
    }

    // Combine with weights (pro trader style)
    var winProb;
    if (isLive) {
      if (hasLiveMap) {
        // Live with active map: match state dominates
        winProb = 0.05 * h2hRate + 0.05 * formRate + 0.05 * mapRate + 0.10 * mapH2HRate + 0.40 * seriesProb + 0.35 * mapProb;
      } else {
        // Live between maps: series score dominates
        winProb = 0.08 * h2hRate + 0.07 * formRate + 0.05 * mapRate + 0.10 * mapH2HRate + 0.70 * seriesProb;
      }
    } else {
      // Upcoming: form and map pool matter most
      winProb = 0.20 * h2hRate + 0.30 * formRate + 0.25 * mapRate + 0.25 * mapH2HRate;
    }

    // Clamp between 5% and 95%
    var finalT1 = Math.round(Math.min(95, Math.max(5, winProb * 100)));
    return { t1Pct: finalT1, t2Pct: 100 - finalT1, factors: factors };
  }

  function generateAnalysisBlurb(prob, h2hData, t1Stats, t2Stats, match, t1, t2) {
    var t1Name = escapeHtml(t1.acronym || t1.name || 'Team 1');
    var t2Name = escapeHtml(t2.acronym || t2.name || 'Team 2');
    var fav = prob.t1Pct >= prob.t2Pct ? t1Name : t2Name;
    var dog = prob.t1Pct >= prob.t2Pct ? t2Name : t1Name;
    var favPct = Math.max(prob.t1Pct, prob.t2Pct);
    var dogPct = Math.min(prob.t1Pct, prob.t2Pct);
    var isLive = match.status === 'running';
    var format = match.numberOfGames ? 'BO' + match.numberOfGames : '';

    var parts = [];

    // Opening sentence — who's favoured and by how much
    if (favPct >= 70) {
      parts.push(fav + ' are heavy favourites at ' + favPct + '% heading into this ' + format + '.');
    } else if (favPct >= 60) {
      parts.push(fav + ' hold a solid edge at ' + favPct + '% in this ' + format + ' matchup.');
    } else if (favPct >= 55) {
      parts.push(fav + ' are slight favourites at ' + favPct + '%, but this ' + format + ' could go either way.');
    } else {
      parts.push('This ' + format + ' is essentially a coin flip — ' + fav + ' edge ' + dog + ' by just ' + (favPct - dogPct) + ' percentage points.');
    }

    // H2H context
    var record = h2hData ? h2hData.record : null;
    if (record && record.total > 0) {
      var h2hLeader = record.team1Wins > record.team2Wins ? t1Name : record.team2Wins > record.team1Wins ? t2Name : null;
      if (h2hLeader && record.total >= 3) {
        var leadWins = Math.max(record.team1Wins, record.team2Wins);
        var trailWins = Math.min(record.team1Wins, record.team2Wins);
        parts.push(h2hLeader + ' own the head-to-head ' + leadWins + '-' + trailWins + ' across ' + record.total + ' meetings' + (record.total >= 5 ? ', giving them a meaningful psychological edge.' : '.'));
      } else if (h2hLeader) {
        parts.push('The head-to-head is limited to just ' + record.total + ' match' + (record.total > 1 ? 'es' : '') + ', so sample size is a factor.');
      } else if (record.total > 0) {
        parts.push('These two are dead even in the head-to-head at ' + record.team1Wins + '-' + record.team2Wins + '.');
      }
    } else {
      parts.push('This is a first-time meeting between these two rosters, so there\'s no historical edge to lean on.');
    }

    // Form
    if (t1Stats && t2Stats && t1Stats.record && t2Stats.record) {
      var t1WR = t1Stats.record.matchWinRate != null ? t1Stats.record.matchWinRate : null;
      var t2WR = t2Stats.record.matchWinRate != null ? t2Stats.record.matchWinRate : null;
      if (t1WR != null && t2WR != null) {
        var formDiff = Math.abs(t1WR - t2WR);
        if (formDiff > 15) {
          var hotTeam = t1WR > t2WR ? t1Name : t2Name;
          var hotWR = Math.max(t1WR, t2WR).toFixed(0);
          var coldWR = Math.min(t1WR, t2WR).toFixed(0);
          parts.push(hotTeam + ' are in significantly better form with a ' + hotWR + '% win rate versus ' + coldWR + '%, which is the biggest differentiator in this matchup.');
        } else if (formDiff > 5) {
          var betterTeam = t1WR > t2WR ? t1Name : t2Name;
          parts.push(betterTeam + ' have the slight form advantage, though both teams are performing at a similar level recently.');
        } else {
          parts.push('Form-wise, both teams are closely matched with near-identical recent win rates.');
        }
      }
    }

    // Map pool insight
    var games = match.games || [];
    var maps = [];
    games.forEach(function(g) { if (g.map && g.map.name && maps.indexOf(g.map.name) === -1) maps.push(g.map.name); });
    if (maps.length > 0 && t1Stats && t2Stats) {
      var t1Advantages = 0, t2Advantages = 0;
      maps.forEach(function(mapName) {
        var t1Map = (t1Stats.maps || []).find(function(m) { return m.name && m.name.toLowerCase() === mapName.toLowerCase(); });
        var t2Map = (t2Stats.maps || []).find(function(m) { return m.name && m.name.toLowerCase() === mapName.toLowerCase(); });
        var t1wr = t1Map ? t1Map.winRate : 50;
        var t2wr = t2Map ? t2Map.winRate : 50;
        if (t1wr > t2wr + 5) t1Advantages++;
        else if (t2wr > t1wr + 5) t2Advantages++;
      });
      if (t1Advantages > t2Advantages) {
        parts.push(t1Name + ' have the stronger map pool for this series, holding an advantage on ' + t1Advantages + ' of ' + maps.length + ' maps.');
      } else if (t2Advantages > t1Advantages) {
        parts.push(t2Name + ' have the stronger map pool for this series, holding an advantage on ' + t2Advantages + ' of ' + maps.length + ' maps.');
      } else if (maps.length > 1) {
        parts.push('The map pool is evenly split with no clear veto advantage for either side.');
      }
    }

    // Live match context
    if (isLive) {
      var r1 = 0, r2 = 0;
      if (match.results) {
        var res1 = match.results.find(function(r) { return r.team_id === t1.id; });
        var res2 = match.results.find(function(r) { return r.team_id === t2.id; });
        r1 = res1 ? res1.score : 0;
        r2 = res2 ? res2.score : 0;
      }
      if (r1 !== r2) {
        var leader = r1 > r2 ? t1Name : t2Name;
        var high = Math.max(r1, r2);
        var low = Math.min(r1, r2);
        parts.push(leader + ' lead the series ' + high + '-' + low + ', which heavily shifts the probability in their favour.');
      }
    }

    return parts.join(' ');
  }

  function renderH2HSection(h2hData, t1Stats, t2Stats, match, t1, t2) {
    var section = document.getElementById('h2h-section');
    if (!section) return;

    var prob = calcWinProb(h2hData, t1Stats, t2Stats, match, t1, t2);
    var html = '<div class="md-h2h">';

    // Win probability bar
    html += '<div class="md-h2h-prob">';
    html += '<div class="md-h2h-prob-header">Win Probability</div>';
    html += '<div class="md-h2h-bar-labels">';
    html += '<span class="md-h2h-bar-team">' + escapeHtml(t1.acronym || t1.name || 'T1') + ' <strong>' + prob.t1Pct + '%</strong></span>';
    html += '<span class="md-h2h-bar-team"><strong>' + prob.t2Pct + '%</strong> ' + escapeHtml(t2.acronym || t2.name || 'T2') + '</span>';
    html += '</div>';
    html += '<div class="md-h2h-bar"><div class="md-h2h-bar-fill" style="width:' + prob.t1Pct + '%"></div></div>';

    // Analysis blurb
    if (match.status !== 'finished') {
      html += '<div class="md-h2h-blurb">' + generateAnalysisBlurb(prob, h2hData, t1Stats, t2Stats, match, t1, t2) + '</div>';
    }

    // Odds breakdown dropdown
    if (prob.factors.length > 0 && !(match.status === 'finished')) {
      html += '<details class="md-odds-breakdown">';
      html += '<summary>Why these odds?</summary>';
      html += '<div class="md-odds-factors">';
      prob.factors.forEach(function(f) {
        var impact = f.value !== undefined ? f.value - 0.50 : 0;
        var impactStr, impactCls;
        if (Math.abs(impact) < 0.03) {
          impactStr = 'Even';
          impactCls = 'even';
        } else if (impact > 0) {
          impactStr = '\u2192 ' + escapeHtml(t1.acronym || t1.name);
          impactCls = 't1';
        } else {
          impactStr = '\u2192 ' + escapeHtml(t2.acronym || t2.name);
          impactCls = 't2';
        }
        html += '<div class="md-odds-factor">';
        html += '<span class="md-odds-factor-name">' + f.name + '</span>';
        html += '<span class="md-odds-factor-detail">' + f.detail + '</span>';
        html += '<span class="md-odds-factor-impact ' + impactCls + '">' + impactStr + '</span>';
        html += '</div>';
      });
      html += '</div></details>';
    }

    html += '</div>'; // close md-h2h-prob

    // Previous meetings
    var record = h2hData ? h2hData.record : { total: 0 };
    var matches = h2hData ? (h2hData.matches || []).slice(0, 5) : [];

    html += '<div class="md-h2h-meetings">';
    html += '<div class="md-h2h-meetings-header">Previous Meetings' + (record.total > 0 ? ' (' + record.total + ' total)' : '') + '</div>';

    if (matches.length === 0) {
      html += '<div class="md-h2h-empty">No previous meetings found</div>';
    } else {
      matches.forEach(function(m) {
        var date = m.beginAt ? new Date(m.beginAt) : null;
        var dateStr = date ? date.toLocaleDateString(undefined, { day: 'numeric', month: 'short' }) : '\u2014';
        var opp1 = m.opponents && m.opponents[0] ? m.opponents[0] : {};
        var opp2 = m.opponents && m.opponents[1] ? m.opponents[1] : {};
        var s1 = '?', s2 = '?';
        if (m.results) {
          var mr1 = m.results.find(function(r) { return r.team_id === opp1.id; });
          var mr2 = m.results.find(function(r) { return r.team_id === opp2.id; });
          if (mr1) s1 = mr1.score;
          if (mr2) s2 = mr2.score;
        }
        var w1 = m.winnerId === opp1.id;
        var w2 = m.winnerId === opp2.id;
        var tier = m.tournament ? m.tournament.tier : null;

        html += '<div class="md-h2h-match">';
        html += '<span class="md-h2h-match-date">' + dateStr + '</span>';
        html += '<span class="md-h2h-match-team ' + (w1 ? 'winner' : '') + '">' + escapeHtml(opp1.acronym || opp1.name || '?') + '</span>';
        html += '<span class="md-h2h-match-score">' + s1 + ':' + s2 + '</span>';
        html += '<span class="md-h2h-match-team ' + (w2 ? 'winner' : '') + '">' + escapeHtml(opp2.acronym || opp2.name || '?') + '</span>';
        html += '<span class="md-h2h-match-event">' + escapeHtml(m.tournament ? m.tournament.name : (m.league ? m.league.name : '')) + '</span>';
        if (tier) html += '<span class="match-tier ' + tierClass(tier) + '" style="font-size:.6rem;padding:.1rem .3rem">' + tier.toUpperCase() + '</span>';
        html += '</div>';
      });
    }

    html += '</div>'; // close md-h2h-meetings
    html += '</div>'; // close md-h2h

    section.innerHTML = html;
  }

  // ── Player Stats per Map ──
  window.__gpsCache = {};

  window.__togglePlayerStats = async function(btn, gameId) {
    const wrap = document.getElementById('gps-wrap-' + gameId);
    if (!wrap) return;

    // Toggle visibility
    if (wrap.style.display !== 'none') {
      wrap.style.display = 'none';
      btn.classList.remove('open');
      btn.textContent = 'Show Player Stats \u25BE';
      return;
    }

    wrap.style.display = 'block';
    btn.classList.add('open');
    btn.textContent = 'Hide Player Stats \u25B4';

    // If already loaded from cache, don't re-fetch
    if (window.__gpsCache[gameId]) {
      renderPlayerStats(wrap, window.__gpsCache[gameId]);
      return;
    }

    // Show loading
    wrap.innerHTML = '<div class="gps-loading"><div class="spinner"></div> Loading player stats\u2026</div>';

    try {
      const res = await fetch('/api/game-stats?id=' + encodeURIComponent(gameId));
      if (!res.ok) throw new Error('HTTP ' + res.status);
      const data = await res.json();
      if (!data || data.error) throw new Error(data?.error || 'Invalid response');

      window.__gpsCache[gameId] = data;
      renderPlayerStats(wrap, data);
    } catch (err) {
      console.error('Failed to load player stats for game ' + gameId + ':', err);
      wrap.innerHTML = '<div class="gps-error">Unable to load player stats.</div>';
    }
  };

  function renderPlayerStats(wrap, data) {
    if (!data.teams || data.teams.length === 0) {
      wrap.innerHTML = '<div class="gps-error">No player stats available.</div>';
      return;
    }

    let html = '';
    data.teams.forEach(function(team) {
      if (!team.players || team.players.length === 0) return;

      // Sort players by rating descending
      const sorted = [...team.players].sort(function(a, b) { return (b.rating || 0) - (a.rating || 0); });
      const mvpRating = sorted[0]?.rating || 0;

      html += '<div class="gps-team-label">' + escapeHtml(team.name || team.acronym || 'Team') + '</div>';
      html += '<table class="gps-table"><thead><tr>';
      html += '<th>Player</th><th>K</th><th>D</th><th>A</th><th>+/-</th><th>ADR</th><th>KAST%</th><th>Rating</th>';
      html += '</tr></thead><tbody>';

      sorted.forEach(function(p) {
        const isMvp = p.rating === mvpRating && mvpRating > 0;
        const kd = (p.kills || 0) - (p.deaths || 0);
        const kdStr = kd > 0 ? '+' + kd : '' + kd;
        const kastPct = p.kast != null ? p.kast.toFixed(0) + '%' : '\u2014';
        const ratingStr = p.rating != null ? p.rating.toFixed(2) : '\u2014';
        const adrStr = p.adr != null ? p.adr.toFixed(1) : '\u2014';
        const playerLink = p.slug ? '<a href="/pro-players/' + encodeURIComponent(p.slug) + '/">' + escapeHtml(p.name) + '</a>' : escapeHtml(p.name);

        html += '<tr class="' + (isMvp ? 'gps-mvp' : '') + '">';
        html += '<td>' + playerLink + '</td>';
        html += '<td>' + (p.kills ?? '\u2014') + '</td>';
        html += '<td>' + (p.deaths ?? '\u2014') + '</td>';
        html += '<td>' + (p.assists ?? '\u2014') + '</td>';
        html += '<td>' + kdStr + '</td>';
        html += '<td>' + adrStr + '</td>';
        html += '<td>' + kastPct + '</td>';
        html += '<td>' + ratingStr + '</td>';
        html += '</tr>';
      });

      html += '</tbody></table>';
    });

    wrap.innerHTML = html;
  }

  // ── Country flag emoji from 2-letter code ──
  function countryFlag(code) {
    if (!code || code.length !== 2) return '';
    var cc = code.toUpperCase();
    return String.fromCodePoint(0x1F1E6 + cc.charCodeAt(0) - 65) + String.fromCodePoint(0x1F1E6 + cc.charCodeAt(1) - 65);
  }

  // ── Analytics Insights ──
  function renderAnalyticsInsights(t1Stats, t2Stats, match, t1, t2) {
    var section = document.getElementById('insights-section');
    if (!section || !t1Stats || !t2Stats) return;
    if (match.status === 'finished') return; // skip for finished matches

    var t1Name = escapeHtml(t1.acronym || t1.name || 'T1');
    var t2Name = escapeHtml(t2.acronym || t2.name || 'T2');

    function generateInsights(stats) {
      var insights = [];
      var record = stats.record || {};
      var maps = stats.maps || [];
      var rounds = stats.rounds || {};
      var fragging = stats.fragging || {};

      var wr = record.matchWinRate || 0;
      if (wr >= 60) {
        insights.push({ type: 'positive', text: 'Strong ' + wr + '% match win rate across ' + (record.matchesPlayed || 0) + ' matches' });
      } else if (wr >= 45) {
        insights.push({ type: 'neutral', text: wr + '% match win rate across ' + (record.matchesPlayed || 0) + ' matches' });
      } else {
        insights.push({ type: 'negative', text: 'Struggling with only ' + wr + '% match win rate' });
      }

      var sortedMaps = maps.filter(function(m) { return m.played >= 3; }).sort(function(a, b) { return b.winRate - a.winRate; });
      if (sortedMaps.length > 0) {
        var bestMap = sortedMaps[0];
        if (bestMap.winRate >= 60) {
          insights.push({ type: 'positive', text: 'Dominant on ' + bestMap.name + ': ' + bestMap.winRate + '% win rate (' + bestMap.played + ' maps)' });
        } else {
          insights.push({ type: 'neutral', text: 'Best map is ' + bestMap.name + ' at ' + bestMap.winRate + '% (' + bestMap.played + ' maps)' });
        }
      }

      if (sortedMaps.length > 1) {
        var worstMap = sortedMaps[sortedMaps.length - 1];
        if (worstMap.winRate < 40) {
          insights.push({ type: 'negative', text: 'Weak on ' + worstMap.name + ': only ' + worstMap.winRate + '% win rate across ' + worstMap.played + ' maps' });
        }
      }

      var ctWR = rounds.ctWinRate || 50;
      var tWR = rounds.tWinRate || 50;
      if (Math.abs(ctWR - tWR) > 8) {
        if (ctWR > tWR) {
          insights.push({ type: 'neutral', text: 'CT-sided: ' + ctWR + '% CT round WR vs ' + tWR + '% T-side' });
        } else {
          insights.push({ type: 'neutral', text: 'T-sided: ' + tWR + '% T round WR vs ' + ctWR + '% CT-side' });
        }
      }

      var pistolWR = rounds.pistolWinRate || 50;
      if (pistolWR >= 55) {
        insights.push({ type: 'positive', text: 'Strong pistol rounds at ' + pistolWR + '% win rate' });
      } else if (pistolWR < 40) {
        insights.push({ type: 'negative', text: 'Weak pistol rounds at only ' + pistolWR + '% win rate' });
      }

      var hsRate = fragging.hsRate || 0;
      if (hsRate >= 52) {
        insights.push({ type: 'positive', text: 'Excellent ' + hsRate + '% headshot rate' });
      } else if (hsRate < 42) {
        insights.push({ type: 'negative', text: 'Below-average ' + hsRate + '% headshot rate' });
      }

      return insights.slice(0, 4);
    }

    var t1Insights = generateInsights(t1Stats);
    var t2Insights = generateInsights(t2Stats);
    if (t1Insights.length === 0 && t2Insights.length === 0) return;

    var html = '<h2 class="section-title">Analytics Insights</h2><div class="md-insights">';

    html += '<div class="md-insight-card"><div class="md-insight-header">';
    if (t1.image) html += '<img src="' + t1.image + '" alt="" onerror="this.style.display=\'none\'" />';
    html += t1Name + '</div><ul class="md-insight-list">';
    t1Insights.forEach(function(i) {
      html += '<li class="md-insight-item"><span class="md-insight-dot ' + i.type + '"></span>' + i.text + '</li>';
    });
    html += '</ul></div>';

    html += '<div class="md-insight-card"><div class="md-insight-header">';
    if (t2.image) html += '<img src="' + t2.image + '" alt="" onerror="this.style.display=\'none\'" />';
    html += t2Name + '</div><ul class="md-insight-list">';
    t2Insights.forEach(function(i) {
      html += '<li class="md-insight-item"><span class="md-insight-dot ' + i.type + '"></span>' + i.text + '</li>';
    });
    html += '</ul></div>';

    html += '</div>';
    section.innerHTML = html;
  }

  // ── Team Lineups ──
  function renderTeamLineups(t1Roster, t2Roster, t1, t2) {
    var section = document.getElementById('lineups-section');
    if (!section) return;

    var t1Players = [];
    var t2Players = [];
    if (t1Roster) {
      t1Players = t1Roster.players || (t1Roster.teams && t1Roster.teams[0] ? t1Roster.teams[0].players : []);
    }
    if (t2Roster) {
      t2Players = t2Roster.players || (t2Roster.teams && t2Roster.teams[0] ? t2Roster.teams[0].players : []);
    }
    t1Players = (t1Players || []).filter(function(p) { return p.active !== false; });
    t2Players = (t2Players || []).filter(function(p) { return p.active !== false; });
    if (!t1Roster && !t2Roster) return;

    var t1Name = escapeHtml(t1.acronym || t1.name || 'T1');
    var t2Name = escapeHtml(t2.acronym || t2.name || 'T2');

    function renderPlayerRow(p) {
      var img = p.image
        ? '<img src="' + p.image + '" alt="' + escapeHtml(p.name) + '" class="md-player-img" loading="lazy" onerror="this.style.display=\'none\';this.nextElementSibling.style.display=\'flex\'" /><div class="md-player-img-placeholder" style="display:none">' + escapeHtml(p.name ? p.name[0] : '?') + '</div>'
        : '<div class="md-player-img-placeholder">' + escapeHtml(p.name ? p.name[0] : '?') + '</div>';
      var realName = (p.firstName && p.lastName) ? escapeHtml(p.firstName) + ' ' + escapeHtml(p.lastName) : '';
      var role = p.role ? '<span class="md-player-role">' + escapeHtml(p.role) + '</span>' : '';
      var flag = p.nationality ? '<span class="md-player-flag" title="' + escapeHtml(p.nationality) + '">' + countryFlag(p.nationality) + '</span>' : '';
      var nameLink = p.slug ? '<a href="/pro-players/' + encodeURIComponent(p.slug) + '/">' + escapeHtml(p.name) + '</a>' : escapeHtml(p.name);
      return '<div class="md-player-row">' + img + '<div class="md-player-info"><div class="md-player-name">' + nameLink + '</div>' + (realName ? '<div class="md-player-real">' + realName + '</div>' : '') + '</div>' + flag + role + '</div>';
    }

    var html = '<h2 class="section-title">Team Lineups</h2><div class="md-lineups">';

    html += '<div class="md-lineup-card"><div class="md-lineup-header">';
    if (t1.image) html += '<img src="' + t1.image + '" alt="" onerror="this.style.display=\'none\'" />';
    html += t1Name + ' Lineup</div><div class="md-lineup-players">';
    t1Players.forEach(function(p) { html += renderPlayerRow(p); });
    if (t1Players.length === 0) html += '<div class="md-form-empty">Roster unavailable</div>';
    html += '</div></div>';

    html += '<div class="md-lineup-card"><div class="md-lineup-header">';
    if (t2.image) html += '<img src="' + t2.image + '" alt="" onerror="this.style.display=\'none\'" />';
    html += t2Name + ' Lineup</div><div class="md-lineup-players">';
    t2Players.forEach(function(p) { html += renderPlayerRow(p); });
    if (t2Players.length === 0) html += '<div class="md-form-empty">Roster unavailable</div>';
    html += '</div></div>';

    html += '</div>';
    section.innerHTML = html;
  }

  // ── Map Pool Comparison ──
  function renderMapPool(t1Stats, t2Stats, t1, t2) {
    var section = document.getElementById('map-pool-section');
    if (!section || !t1Stats || !t2Stats) return;

    var t1Maps = t1Stats.maps || [];
    var t2Maps = t2Stats.maps || [];
    if (t1Maps.length === 0 && t2Maps.length === 0) return;

    var t1Name = escapeHtml(t1.acronym || t1.name || 'T1');
    var t2Name = escapeHtml(t2.acronym || t2.name || 'T2');

    var allMaps = {};
    t1Maps.forEach(function(m) { allMaps[m.name] = allMaps[m.name] || {}; allMaps[m.name].t1 = m; });
    t2Maps.forEach(function(m) { allMaps[m.name] = allMaps[m.name] || {}; allMaps[m.name].t2 = m; });

    var mapNames = Object.keys(allMaps).sort(function(a, b) {
      var aTotal = (allMaps[a].t1 ? allMaps[a].t1.played : 0) + (allMaps[a].t2 ? allMaps[a].t2.played : 0);
      var bTotal = (allMaps[b].t1 ? allMaps[b].t1.played : 0) + (allMaps[b].t2 ? allMaps[b].t2.played : 0);
      return bTotal - aTotal;
    });

    function wrClass(wr) {
      if (wr >= 55) return 'high';
      if (wr >= 45) return 'mid';
      return 'low';
    }

    var html = '<h2 class="section-title">Map Pool Comparison</h2>';
    html += '<div class="md-map-pool"><table class="md-map-pool-table"><thead><tr>';
    html += '<th>Map</th>';
    html += '<th class="t1-col">' + t1Name + ' WR</th><th class="t1-col">W-L</th>';
    html += '<th class="t2-col">' + t2Name + ' WR</th><th class="t2-col">W-L</th>';
    html += '</tr></thead><tbody>';

    mapNames.forEach(function(name) {
      var d = allMaps[name];
      var m1 = d.t1;
      var m2 = d.t2;
      var wr1 = m1 ? m1.winRate : 0;
      var wr2 = m2 ? m2.winRate : 0;
      var mapImg = (m1 && m1.image) ? m1.image : (m2 && m2.image ? m2.image : '');
      var imgTag = mapImg ? '<img src="' + mapImg + '" alt="" loading="lazy" onerror="this.style.display=\'none\'" />' : '';

      html += '<tr>';
      html += '<td><div class="md-map-name-cell">' + imgTag + '<span>' + escapeHtml(name) + '</span></div></td>';
      html += '<td><span class="md-map-wr ' + wrClass(wr1) + '">' + (m1 ? wr1 + '%' : '\u2014') + '</span></td>';
      html += '<td>' + (m1 ? m1.wins + '-' + m1.losses : '\u2014') + '</td>';
      html += '<td><span class="md-map-wr ' + wrClass(wr2) + '">' + (m2 ? wr2 + '%' : '\u2014') + '</span></td>';
      html += '<td>' + (m2 ? m2.wins + '-' + m2.losses : '\u2014') + '</td>';
      html += '</tr>';
    });

    html += '</tbody></table></div>';
    section.innerHTML = html;
  }

  // ── Team Stats Comparison ──
  function renderTeamStatsComparison(t1Stats, t2Stats, t1, t2) {
    var section = document.getElementById('player-comp-section');
    if (!section || !t1Stats || !t2Stats) return;

    var t1Name = escapeHtml(t1.acronym || t1.name || 'T1');
    var t2Name = escapeHtml(t2.acronym || t2.name || 'T2');

    var stats = [
      { label: 'Match Win Rate', t1: (t1Stats.record || {}).matchWinRate, t2: (t2Stats.record || {}).matchWinRate, suffix: '%' },
      { label: 'Map Win Rate', t1: (t1Stats.record || {}).gameWinRate, t2: (t2Stats.record || {}).gameWinRate, suffix: '%' },
      { label: 'Round Win Rate', t1: (t1Stats.rounds || {}).winRate, t2: (t2Stats.rounds || {}).winRate, suffix: '%' },
      { label: 'CT Win Rate', t1: (t1Stats.rounds || {}).ctWinRate, t2: (t2Stats.rounds || {}).ctWinRate, suffix: '%' },
      { label: 'T Win Rate', t1: (t1Stats.rounds || {}).tWinRate, t2: (t2Stats.rounds || {}).tWinRate, suffix: '%' },
      { label: 'Pistol Win Rate', t1: (t1Stats.rounds || {}).pistolWinRate, t2: (t2Stats.rounds || {}).pistolWinRate, suffix: '%' },
      { label: 'HS Rate', t1: (t1Stats.fragging || {}).hsRate, t2: (t2Stats.fragging || {}).hsRate, suffix: '%' },
      { label: 'Avg ADR / Map', t1: (t1Stats.averages || {}).adrPerGame, t2: (t2Stats.averages || {}).adrPerGame, suffix: '', decimal: 1 },
      { label: 'Avg Kills / Map', t1: (t1Stats.averages || {}).killsPerGame, t2: (t2Stats.averages || {}).killsPerGame, suffix: '', decimal: 1 },
    ];

    stats = stats.filter(function(s) { return s.t1 != null || s.t2 != null; });
    if (stats.length === 0) return;

    var html = '<h2 class="section-title">Team Stats Comparison</h2>';
    html += '<div class="md-player-comp"><table class="md-player-comp-table"><thead><tr>';
    html += '<th>Stat</th><th>' + t1Name + '</th><th>' + t2Name + '</th>';
    html += '</tr></thead><tbody>';

    stats.forEach(function(s) {
      var v1 = s.t1 != null ? (s.decimal != null ? (+s.t1).toFixed(s.decimal) : s.t1) : '\u2014';
      var v2 = s.t2 != null ? (s.decimal != null ? (+s.t2).toFixed(s.decimal) : s.t2) : '\u2014';
      var cls1 = '', cls2 = '';
      if (s.t1 != null && s.t2 != null) {
        if (+s.t1 > +s.t2) cls1 = ' class="md-comp-best"';
        else if (+s.t2 > +s.t1) cls2 = ' class="md-comp-best"';
      }
      html += '<tr><td>' + s.label + '</td><td' + cls1 + '>' + v1 + s.suffix + '</td><td' + cls2 + '>' + v2 + s.suffix + '</td></tr>';
    });

    html += '</tbody></table></div>';
    section.innerHTML = html;
  }

  // ── Recent Team Form ──
  function renderTeamForm(t1Matches, t2Matches, t1, t2) {
    var section = document.getElementById('form-section');
    if (!section) return;

    var t1Past = (t1Matches && t1Matches.past) ? t1Matches.past.slice(0, 5) : [];
    var t2Past = (t2Matches && t2Matches.past) ? t2Matches.past.slice(0, 5) : [];
    if (t1Past.length === 0 && t2Past.length === 0) return;

    var t1Id = t1Matches ? t1Matches.teamId : t1.id;
    var t2Id = t2Matches ? t2Matches.teamId : t2.id;

    function renderFormCard(matches, team, teamId) {
      var teamName = escapeHtml(team.acronym || team.name || '?');
      var html = '<div class="md-form-card"><div class="md-form-header">';
      if (team.image) html += '<img src="' + team.image + '" alt="" onerror="this.style.display=\'none\'" />';
      html += teamName + ' Recent Form</div><div class="md-form-list">';

      if (matches.length === 0) {
        html += '<div class="md-form-empty">No recent matches</div>';
      } else {
        matches.forEach(function(m) {
          var isWin = m.winnerId === teamId;
          var resultCls = isWin ? 'win' : 'loss';
          var resultTxt = isWin ? 'W' : 'L';
          var opponents = m.opponents || [];
          var opp = opponents.find(function(o) { return o.id !== teamId; }) || opponents[1] || {};
          var results = m.results || [];
          var usResult = results.find(function(r) { return r.team_id === teamId; }) || {};
          var oppResult = results.find(function(r) { return r.team_id !== teamId; }) || {};
          var score = (usResult.score != null && oppResult.score != null) ? usResult.score + ':' + oppResult.score : '\u2014';
          var tourney = (m.tournament && m.tournament.name) ? m.tournament.name : '';

          html += '<div class="md-form-match">';
          html += '<span class="md-form-result ' + resultCls + '">' + resultTxt + '</span>';
          html += '<span class="md-form-opp">' + escapeHtml(opp.name || opp.acronym || '?') + '</span>';
          html += '<span class="md-form-score">' + score + '</span>';
          html += '<span class="md-form-map">' + escapeHtml(tourney) + '</span>';
          html += '</div>';
        });
      }

      html += '</div></div>';
      return html;
    }

    var html = '<h2 class="section-title">Recent Form</h2><div class="md-form">';
    html += renderFormCard(t1Past, t1, t1Id);
    html += renderFormCard(t2Past, t2, t2Id);
    html += '</div>';
    section.innerHTML = html;
  }

  function escapeHtml(str) {
    if (!str) return '';
    return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
  }
})();
</script>

