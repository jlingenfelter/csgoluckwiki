---
import Base from '../layouts/Base.astro';
import ExploreMore from '../components/ExploreMore.astro';
import { faqSchema, breadcrumbSchema } from '../lib/weapons';

const title = 'CS2 Patch Notes & Update History — All Updates | CSGOLuck Wiki';
const description = 'Complete archive of Counter-Strike 2 patch notes, balance updates, and changelog history. Auto-updated from official Steam sources. Filter by weapon, map, anticheat, economy, and more.';

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Patch Notes', url: '/patch-notes/' },
];

const faqs = [
  {
    question: "How often does CS2 receive updates?",
    answer: "CS2 typically receives updates every 1-4 weeks. Balance patches and bug fixes are deployed frequently, while larger content updates with new cases or operations happen less often."
  },
  {
    question: "Where do these patch notes come from?",
    answer: "These patch notes are pulled automatically from the official Steam News API. They update in real-time whenever Valve publishes a new Counter-Strike 2 announcement."
  },
  {
    question: "How are balance changes decided?",
    answer: "Valve uses data from millions of matches, professional esports feedback, and community testing to inform balance decisions. Major changes are often tested in limited scenarios before full deployment."
  },
  {
    question: "What's the difference between balance patches and content updates?",
    answer: "Balance patches adjust weapon stats, economy, or map design. Content updates add new items, cases, operations, or major features. Both types are essential for keeping CS2 fresh."
  },
  {
    question: "Can I get notified about new updates?",
    answer: "Follow the official Counter-Strike social media accounts, check Steam news, or bookmark this page — it auto-updates from the official Steam feed whenever Valve posts a new update."
  }
];
---

<Base title={title} description={description} currentNav="/">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema(breadcrumbs))} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema(faqs))} />
  </Fragment>

<style is:inline>
  /* -- Breadcrumb -- */
  .pn-breadcrumb{font-size:.82rem;color:var(--text2);margin-bottom:1.25rem;display:flex;gap:.35rem;flex-wrap:wrap}
  .pn-breadcrumb a{color:var(--accent);text-decoration:none}
  .pn-breadcrumb a:hover{text-decoration:underline}

  /* -- Hero (left-aligned, no gradient) -- */
  .pn-hero{background:var(--bg2);border:1px solid var(--border);border-radius:4px;padding:2rem;margin-bottom:1.5rem}
  .pn-hero h1{font-family:'Montserrat',sans-serif;font-size:2rem;font-weight:800;margin:0 0 .35rem;color:var(--text)}
  .pn-hero p{font-size:.95rem;color:var(--text2);margin:0 0 .75rem;line-height:1.6}
  .pn-live-badge{display:inline-block;background:rgba(46,204,113,.15);color:var(--accent);padding:.2rem .65rem;border-radius:4px;font-size:.78rem;font-weight:700;border:1px solid rgba(46,204,113,.3)}
  .pn-live-badge::before{content:'';display:inline-block;width:8px;height:8px;background:var(--accent);border-radius:50%;margin-right:6px;animation:pn-pulse 1.5s infinite}
  @keyframes pn-pulse{0%,100%{opacity:1}50%{opacity:.4}}

  /* -- Controls -- */
  .pn-controls{margin-bottom:1.5rem}
  .pn-search{width:100%;padding:.65rem 1rem;background:var(--bg2);border:1px solid var(--border);border-radius:4px;font-size:.9rem;color:var(--text);margin-bottom:.75rem;transition:border-color .15s;font-family:'Montserrat',sans-serif}
  .pn-search:focus{outline:none;border-color:var(--accent)}
  .pn-tags{display:flex;gap:.35rem;flex-wrap:wrap}
  .pn-tag-btn{padding:.3rem .7rem;background:var(--bg2);border:1px solid var(--border);color:var(--text2);border-radius:4px;cursor:pointer;font-size:.82rem;font-weight:600;font-family:'Montserrat',sans-serif;transition:border-color .15s,color .15s}
  .pn-tag-btn:hover{border-color:var(--accent);color:var(--text)}
  .pn-tag-btn.active{background:var(--accent);color:#000;border-color:var(--accent)}

  /* -- Latest Update -- */
  .pn-latest{background:var(--bg2);border:1px solid var(--border);border-left:3px solid var(--accent);border-radius:4px;padding:1.5rem;margin-bottom:1.5rem}
  .pn-latest h2{font-family:'Montserrat',sans-serif;font-size:.88rem;font-weight:600;color:var(--text2);margin:0 0 .25rem;text-transform:uppercase;letter-spacing:.03em}
  .pn-latest-title{font-family:'Montserrat',sans-serif;font-size:1.3rem;font-weight:800;color:var(--text);margin-bottom:.35rem}
  .pn-latest-date{color:var(--text2);font-size:.88rem;margin-bottom:.75rem}
  .pn-latest-changes{list-style:none;padding:0;margin:0}
  .pn-latest-changes li{padding:.3rem 0 .3rem 1.25rem;position:relative;color:var(--text2);font-size:.88rem}
  .pn-latest-changes li::before{content:'\25B8';position:absolute;left:0;color:var(--accent)}
  .pn-latest-link{display:inline-block;margin-top:.75rem;color:var(--accent);font-weight:700;font-size:.85rem;text-decoration:none}
  .pn-latest-link:hover{text-decoration:underline}

  /* -- Loading -- */
  .pn-loading{text-align:center;padding:2.5rem;color:var(--text2)}
  .pn-loading-spinner{display:inline-block;width:28px;height:28px;border:3px solid var(--border);border-top-color:var(--accent);border-radius:50%;animation:pn-spin .8s linear infinite;margin-bottom:.75rem}
  @keyframes pn-spin{to{transform:rotate(360deg)}}

  /* -- Card Grid -- */
  .pn-grid{display:flex;flex-direction:column;gap:2px;margin-bottom:2rem}
  .pn-card{background:var(--bg2);border:1px solid var(--border);border-left:3px solid transparent;border-radius:4px;padding:1.25rem;transition:border-color .15s,background .15s}
  .pn-card:hover{border-left-color:var(--accent);background:var(--bg3)}
  .pn-card-head{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:.5rem;flex-wrap:wrap;gap:.5rem}
  .pn-card h3{font-family:'Montserrat',sans-serif;font-size:1.05rem;font-weight:700;margin:0 0 .15rem;color:var(--text)}
  .pn-card-date{color:var(--text2);font-size:.82rem}
  .pn-card-tags{display:flex;gap:.3rem;flex-wrap:wrap;margin-bottom:.5rem}
  .pn-tag{display:inline-block;padding:.12rem .45rem;background:var(--bg3);color:var(--text2);border-radius:4px;font-size:.72rem;border:1px solid var(--border)}
  .pn-tag.weapon{border-left:3px solid #42a5f5}
  .pn-tag.map{border-left:3px solid #ab47bc}
  .pn-tag.economy{border-left:3px solid var(--accent)}
  .pn-tag.anticheat{border-left:3px solid #ef5350}
  .pn-tag.cosmetics{border-left:3px solid #e8b992}
  .pn-tag.balance{border-left:3px solid #ff9800}
  .pn-tag.competitive{border-left:3px solid #ef5350}
  .pn-tag.bugfix{border-left:3px solid #4caf50}
  .pn-tag.performance{border-left:3px solid #42a5f5}
  .pn-tag.audio{border-left:3px solid #ab47bc}
  .pn-tag.server{border-left:3px solid #ff9800}
  .pn-tag.ui{border-left:3px solid #42a5f5}
  .pn-tag.update{border-left:3px solid var(--accent)}

  .pn-card-changes{border-top:1px solid var(--border);padding-top:.6rem}
  .pn-card-changes ul{list-style:none;padding:0;margin:0}
  .pn-card-changes li{padding:.25rem 0 .25rem 1.25rem;position:relative;color:var(--text2);font-size:.85rem}
  .pn-card-changes li::before{content:'\25B8';position:absolute;left:0;color:var(--accent)}
  .pn-card-link{display:inline-block;margin-top:.5rem;color:var(--accent);text-decoration:none;font-size:.82rem;font-weight:600}
  .pn-card-link:hover{text-decoration:underline}

  /* -- Error -- */
  .pn-error{text-align:center;padding:1.5rem;background:var(--bg2);border:1px solid var(--border);border-radius:4px;color:var(--text2);margin-bottom:2rem}
  .pn-error-retry{margin-top:.75rem;padding:.4rem 1rem;background:var(--accent);color:#000;border:none;border-radius:4px;cursor:pointer;font-size:.88rem;font-weight:700;font-family:'Montserrat',sans-serif}

  /* -- FAQ -- */
  .pn-faq{margin:2rem 0}
  .pn-faq h2{font-family:'Montserrat',sans-serif;font-size:1.15rem;font-weight:700;color:var(--text);margin:0 0 .75rem}
  .pn-faq-item{background:var(--bg2);border:1px solid var(--border);border-radius:4px;margin-bottom:.35rem;overflow:hidden}
  .pn-faq-item summary{padding:.75rem 1rem;font-weight:700;font-size:.9rem;color:var(--text);cursor:pointer;list-style:none;display:flex;align-items:center;gap:.5rem;transition:background .15s}
  .pn-faq-item summary::before{content:'+';font-size:1.05rem;font-weight:700;color:var(--accent);flex-shrink:0;width:18px;text-align:center}
  .pn-faq-item[open] summary::before{content:'\2212'}
  .pn-faq-item summary:hover{background:var(--bg3)}
  .pn-faq-item summary::-webkit-details-marker{display:none}
  .pn-faq-item p{padding:0 1rem .85rem 2.25rem;margin:0;color:var(--text2);font-size:.88rem;line-height:1.6}

  /* -- Related Links -- */
  .pn-links{background:var(--bg2);border:1px solid var(--border);border-radius:4px;padding:1.5rem;margin-top:2rem}
  .pn-links h2{font-family:'Montserrat',sans-serif;font-size:1.15rem;font-weight:700;color:var(--text);margin:0 0 .75rem}
  .pn-links-list{display:flex;flex-direction:column;gap:2px}
  .pn-links-list a{display:block;padding:.55rem .85rem;background:var(--bg3);border:1px solid var(--border);border-left:3px solid transparent;border-radius:4px;color:var(--text2);text-decoration:none;font-size:.88rem;font-weight:600;transition:border-color .15s,background .15s,color .15s}
  .pn-links-list a:hover{border-left-color:var(--accent);color:var(--text)}

  /* -- Responsive -- */
  @media(max-width:768px){
    .pn-hero h1{font-size:1.5rem}
    .pn-card-head{flex-direction:column}
  }
</style>

  <nav class="pn-breadcrumb">
    <a href="/">Home</a> / <span>Patch Notes</span>
  </nav>

  <section class="pn-hero">
    <h1>CS2 Patch Notes</h1>
    <p>Auto-updated from official Steam sources</p>
    <div class="pn-live-badge">Live Feed</div>
  </section>

  <div class="pn-controls">
    <input type="text" class="pn-search" placeholder="Search updates..." id="pnSearch" />
    <div class="pn-tags" id="pnTags">
      <button class="pn-tag-btn active" data-tag="">All</button>
      <button class="pn-tag-btn" data-tag="weapon">Weapon</button>
      <button class="pn-tag-btn" data-tag="map">Map</button>
      <button class="pn-tag-btn" data-tag="balance">Balance</button>
      <button class="pn-tag-btn" data-tag="bugfix">Bug Fix</button>
      <button class="pn-tag-btn" data-tag="cosmetics">Cosmetics</button>
      <button class="pn-tag-btn" data-tag="competitive">Competitive</button>
      <button class="pn-tag-btn" data-tag="performance">Performance</button>
      <button class="pn-tag-btn" data-tag="audio">Audio</button>
    </div>
  </div>

  <div id="pnLatest"></div>
  <div id="pnContent">
    <div class="pn-loading">
      <div class="pn-loading-spinner"></div>
      <p>Fetching latest patch notes from Steam...</p>
    </div>
  </div>

  <section class="pn-faq">
    <h2>Frequently Asked Questions</h2>
    {faqs.map(f => (
      <details class="pn-faq-item">
        <summary>{f.question}</summary>
        <p>{f.answer}</p>
      </details>
    ))}
  </section>

  <div class="pn-links">
    <h2>Related Resources</h2>
    <div class="pn-links-list">
      <a href="/cs2-weapons/">Weapon Statistics</a>
      <a href="/cs2-maps/">Map Guide</a>
      <a href="/cs2-guides/">Strategy Guides</a>
      <a href="/spray-trainer/">Spray Trainer</a>
      <a href="/cs2-skins/">Skin Database</a>
      <a href="/pro-players/">Pro Player Settings</a>
      <a href="/cs2-tools/">All Tools</a>
      <a href="/cs2-rank-distribution/">Rank Distribution</a>
    </div>
  </div>

<ExploreMore context="general" />

<script is:inline>
(function() {
  let allUpdates = [];
  let activeTag = '';

  function formatDate(dateStr) {
    const d = new Date(dateStr + 'T00:00:00');
    return d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
  }

  function escapeHtml(s) {
    const div = document.createElement('div');
    div.textContent = s;
    return div.innerHTML;
  }

  function renderLatest(update) {
    const el = document.getElementById('pnLatest');
    if (!update) { el.innerHTML = ''; return; }
    el.innerHTML = `
      <div class="pn-latest">
        <h2>Latest Update</h2>
        <div class="pn-latest-title">${escapeHtml(update.title)}</div>
        <div class="pn-latest-date">${formatDate(update.date)}</div>
        ${update.changes.length > 0 ? `
          <ul class="pn-latest-changes">
            ${update.changes.slice(0, 8).map(c => `<li>${escapeHtml(c)}</li>`).join('')}
          </ul>
        ` : ''}
        ${update.url ? `<a href="${escapeHtml(update.url)}" target="_blank" rel="noopener" class="pn-latest-link">View on Steam &rarr;</a>` : ''}
      </div>
    `;
  }

  function renderCards(updates) {
    const el = document.getElementById('pnContent');
    if (updates.length === 0) {
      el.innerHTML = '<div class="pn-error"><p>No updates match your search.</p></div>';
      return;
    }
    el.innerHTML = `<div class="pn-grid">${updates.map(u => `
      <div class="pn-card" data-tags="${u.tags.join(',')}" data-text="${escapeHtml((u.title + ' ' + u.changes.join(' ')).toLowerCase())}">
        <div class="pn-card-head">
          <div>
            <h3>${escapeHtml(u.title)}</h3>
            <div class="pn-card-date">${formatDate(u.date)}</div>
          </div>
        </div>
        <div class="pn-card-tags">
          ${u.tags.map(t => `<span class="pn-tag ${t}">${t}</span>`).join('')}
        </div>
        ${u.changes.length > 0 ? `
          <div class="pn-card-changes">
            <ul>${u.changes.slice(0, 15).map(c => `<li>${escapeHtml(c)}</li>`).join('')}</ul>
          </div>
        ` : ''}
        ${u.url ? `<a href="${escapeHtml(u.url)}" target="_blank" rel="noopener" class="pn-card-link">View on Steam &rarr;</a>` : ''}
      </div>
    `).join('')}</div>`;
  }

  function filterUpdates() {
    const query = document.getElementById('pnSearch').value.toLowerCase();
    const filtered = allUpdates.filter(u => {
      const tagMatch = !activeTag || u.tags.includes(activeTag);
      const textMatch = !query || (u.title + ' ' + u.changes.join(' ')).toLowerCase().includes(query);
      return tagMatch && textMatch;
    });
    // Skip first one if it's the latest (already shown above)
    const cardsData = allUpdates.length > 0 && filtered[0] === allUpdates[0] ? filtered.slice(1) : filtered;
    renderCards(cardsData);
  }

  // Tag filter buttons
  document.getElementById('pnTags').addEventListener('click', function(e) {
    const btn = e.target.closest('.pn-tag-btn');
    if (!btn) return;
    document.querySelectorAll('.pn-tag-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    activeTag = btn.dataset.tag || '';
    filterUpdates();
  });

  // Search
  document.getElementById('pnSearch').addEventListener('input', filterUpdates);

  // Fetch from API
  async function loadPatchNotes() {
    try {
      const res = await fetch('/api/patch-notes?count=50');
      if (!res.ok) throw new Error('API returned ' + res.status);
      const data = await res.json();

      if (!data.updates || data.updates.length === 0) {
        throw new Error('No updates returned');
      }

      allUpdates = data.updates;
      renderLatest(allUpdates[0]);
      renderCards(allUpdates.slice(1));
    } catch (err) {
      console.warn('Failed to fetch live patch notes:', err);
      document.getElementById('pnContent').innerHTML = `
        <div class="pn-error">
          <p>Could not load live patch notes from Steam. This may be temporary.</p>
          <button class="pn-error-retry" onclick="location.reload()">Try Again</button>
        </div>
      `;
    }
  }

  loadPatchNotes();
})();
</script>
</Base>
