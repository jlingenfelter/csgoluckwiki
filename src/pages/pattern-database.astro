<script is:inline>
  document.addEventListener('DOMContentLoaded', function () {
    var lookupBtn = document.getElementById('lookupBtn');
    var skinNameInput = document.getElementById('skinName');
    var seedInput = document.getElementById('seedInput');
    var resultBox = document.getElementById('lookupResult');
    var resultMessage = document.getElementById('lookupMessage');

    // Notable seeds lookup table
    var knownPatterns = {
      'ak-47 | case hardened': {
        661: 'Blue Gem (#1 Pattern) — the most famous and valuable AK-47 Case Hardened pattern with ~95%+ blue top coverage.',
        670: 'Reverse Scar (#2 Pattern) — second most sought-after pattern with ~90%+ blue top coverage.',
        387: 'Honorable Mention — strong blue top with ~85%+ coverage, highly valued.',
        784: 'Gold Gem — clean gold pattern with minimal blue, popular among collectors.'
      },
      'karambit | case hardened': {
        387: 'Blue Gem (Playside) — full blue playside, one of the most expensive CS2 skins.',
        442: 'Partial Blue Gem — strong blue playside coverage (~80%+).',
        868: 'Blue Ring — distinctive blue ring around the Karambit hole.'
      },
      'butterfly knife | fade': {
        665: 'Full Fade (100%) — maximum fade with full purple tip visibility.',
        458: '95% Fade — near-perfect fade with excellent color distribution.',
        72: '90% Fade — good fade with visible but not fully saturated purple.'
      },
      'karambit | marble fade': {
        412: 'Fire & Ice — only red and blue visible, no yellow. Most desirable pattern.',
        253: 'Fake Fire & Ice — tiny yellow sliver, visually close to true F&I.',
        152: 'Tricolor — standard pattern with all three colors visible.'
      }
    };

    if (lookupBtn) {
      lookupBtn.addEventListener('click', function () {
        var skinName = (skinNameInput.value || '').trim();
        var seed = parseInt(seedInput.value, 10);

        if (!skinName && isNaN(seed)) {
          resultBox.style.display = 'block';
          resultMessage.innerHTML = '<strong>Enter a skin name and seed number above.</strong><br>For example, try "AK-47 | Case Hardened" with seed 661.';
          return;
        }

        if (!skinName) {
          resultBox.style.display = 'block';
          resultMessage.innerHTML = '<strong>Please enter a skin name.</strong><br>Try names like "AK-47 | Case Hardened", "Karambit | Marble Fade", or "Butterfly Knife | Fade".';
          return;
        }

        if (isNaN(seed) || seed < 0 || seed > 999) {
          resultBox.style.display = 'block';
          resultMessage.innerHTML = '<strong>Please enter a valid seed (0–999).</strong>';
          return;
        }

        var skinKey = skinName.toLowerCase().trim();
        var found = false;

        for (var key in knownPatterns) {
          if (skinKey.indexOf(key) !== -1 || key.indexOf(skinKey) !== -1) {
            if (knownPatterns[key][seed]) {
              resultBox.style.display = 'block';
              resultMessage.innerHTML = '<strong>' + skinName + ' — Seed #' + seed + '</strong><br>' + knownPatterns[key][seed] + '<br><br><span style="color:var(--text2);font-size:0.85rem;">This is a well-known pattern. For detailed screenshots and current pricing, check CSFloat or Buff163.</span>';
              found = true;
            } else {
              resultBox.style.display = 'block';
              resultMessage.innerHTML = '<strong>' + skinName + ' — Seed #' + seed + '</strong><br>This seed is not in our notable patterns list, but it may still have value depending on the specific color distribution.' + '<br><br><span style="color:var(--text2);font-size:0.85rem;">For a full visual inspection, paste the item\'s inspect link into CSFloat. Full pattern database integration with the CSFloat API is planned as a future feature.</span>';
              found = true;
            }
            break;
          }
        }

        if (!found) {
          resultBox.style.display = 'block';
          resultMessage.innerHTML = '<strong>' + skinName + ' — Seed #' + seed + '</strong><br>Pattern seeds primarily affect value for Case Hardened, Fade, Marble Fade, and Crimson Web finishes. For other skin types, the pattern difference between seeds is minimal.' + '<br><br><span style="color:var(--text2);font-size:0.85rem;">Full pattern database with CSFloat API integration is coming soon. In the meantime, use CSFloat\'s inspect tool for detailed pattern analysis.</span>';
        }
      });
    }

    // Allow Enter key to trigger lookup
    if (seedInput) {
      seedInput.addEventListener('keydown', function (e) {
        if (e.key === 'Enter') lookupBtn.click();
      });
    }
    if (skinNameInput) {
      skinNameInput.addEventListener('keydown', function (e) {
        if (e.key === 'Enter') lookupBtn.click();
      });
    }
  });
</script>
