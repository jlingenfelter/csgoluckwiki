  </style>

  <!-- Read-only banner (shown when viewing shared picks) -->
  <div class="pk-readonly-banner" id="pkReadonly">
    You are viewing someone else's picks (read-only). <a href="/pickems/" style="color:#3498db;text-decoration:underline;">Make your own picks</a>
  </div>

  <!-- Toast -->
  <div class="pk-toast" id="pkToast"></div>

  <!-- Client-side logic -->
  <script define:vars={{ tournamentJson, challengesJson }}>
    // ── Parse server data ──────────────────────────────────────
    const tournament = JSON.parse(tournamentJson);
    const challengeDescs = JSON.parse(challengesJson);

    // ── State ──────────────────────────────────────────────────
    const STORAGE_KEY = `pickem_${tournament.id}`;
    let state = {
      picks: {},    // { 'opening-stage': { '3-0': ['team1','team2'], '0-3': [...], 'advance': [...] } }
      bracket: {},  // { qf1: 'team-id', sf1: 'team-id', final: 'team-id' }
      locked: {},   // { 'opening-stage': true }
    };
    let selectedTeam = null;   // currently highlighted chip team ID
    let activeStage = tournament.stages[0].id;
    let readOnly = false;

    // Team lookup
    const teamMap = {};
    for (const t of tournament.teams) teamMap[t.id] = t;

    // ── Persistence ────────────────────────────────────────────
    function saveState() {
      if (readOnly) return;
      try { localStorage.setItem(STORAGE_KEY, JSON.stringify(state)); } catch {}
    }

    function loadState() {
      try {
        const raw = localStorage.getItem(STORAGE_KEY);
        if (raw) {
          const parsed = JSON.parse(raw);
          state = { picks: parsed.picks || {}, bracket: parsed.bracket || {}, locked: parsed.locked || {} };
        }
      } catch {}
    }

    // ── URL Sharing ────────────────────────────────────────────
    function encodeShareUrl() {
      const data = JSON.stringify({ picks: state.picks, bracket: state.bracket });
      return window.location.origin + '/pickems/?picks=' + btoa(unescape(encodeURIComponent(data)));
    }

    function decodeShareUrl() {
      const params = new URLSearchParams(window.location.search);
      const encoded = params.get('picks');
      if (!encoded) return null;
      try {
        const json = decodeURIComponent(escape(atob(encoded)));
        return JSON.parse(json);
      } catch { return null; }
    }

    // ── Toast ──────────────────────────────────────────────────
    const toastEl = document.getElementById('pkToast');
    let toastTimer = null;
    function showToast(msg) {
      toastEl.textContent = msg;
      toastEl.classList.add('pk-toast--show');
      clearTimeout(toastTimer);
      toastTimer = setTimeout(() => toastEl.classList.remove('pk-toast--show'), 2500);
    }

    // ── Initialize ─────────────────────────────────────────────
    const shared = decodeShareUrl();
    if (shared) {
      state.picks = shared.picks || {};
      state.bracket = shared.bracket || {};
      state.locked = {};
      // Mark all as locked in read-only mode
      for (const key of Object.keys(state.picks)) state.locked[key] = true;
      readOnly = true;
      document.getElementById('pkReadonly').classList.add('pk-readonly-banner--visible');
    } else {
      loadState();
    }

    // ── Stage tabs ─────────────────────────────────────────────
    const tabBtns = document.querySelectorAll('.pk-tab');
    tabBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const stageId = btn.dataset.stage;
        activeStage = stageId;
        selectedTeam = null;
        // Update tab styles
        tabBtns.forEach(b => b.classList.remove('pk-tab--active'));
        btn.classList.add('pk-tab--active');
        // Show/hide stages
        document.querySelectorAll('.pk-stage').forEach(el => {
          el.classList.toggle('pk-stage--hidden', el.id !== `stage-${stageId}`);
        });
        renderStage(stageId);
      });
    });

    // ── Get picks for a stage ──────────────────────────────────
    function getStagePicks(stageId) {
      if (!state.picks[stageId]) {
        state.picks[stageId] = { '3-0': [], '0-3': [], 'advance': [] };
      }
      return state.picks[stageId];
    }

    function allPickedTeams(stageId) {
      const p = getStagePicks(stageId);
      return [...(p['3-0'] || []), ...(p['0-3'] || []), ...(p['advance'] || [])];
    }

    // ── Render Swiss stage ─────────────────────────────────────
    function renderStage(stageId) {
      const stageEl = document.getElementById(`stage-${stageId}`);
      if (!stageEl) return;
      const stageType = stageEl.dataset.stageType;

      if (stageType === 'bracket') {
        renderBracket();
        return;
      }

      const picks = getStagePicks(stageId);
      const placed = allPickedTeams(stageId);
      const isLocked = state.locked[stageId];

      // Update chips
      const chipsContainer = document.getElementById(`chips-${stageId}`);
      if (chipsContainer) {
        chipsContainer.querySelectorAll('.pk-chip').forEach(chip => {
          const tid = chip.dataset.teamId;
          chip.classList.toggle('pk-chip--placed', placed.includes(tid));
          chip.classList.toggle('pk-chip--selected', tid === selectedTeam);
        });
      }

      // Update slots
      const zones = stageEl.querySelectorAll('.pk-slots');
      zones.forEach(zone => {
        const zoneName = zone.dataset.zone;
        const slots = zone.querySelectorAll('.pk-slot');
        const zoneTeams = picks[zoneName] || [];

        slots.forEach((slot, idx) => {
          const teamId = zoneTeams[idx] || null;
          slot.innerHTML = '';
          slot.classList.remove('pk-slot--filled', 'pk-slot--correct', 'pk-slot--incorrect');

          if (teamId && teamMap[teamId]) {
            const team = teamMap[teamId];
            slot.classList.add('pk-slot--filled');
            if (team.logo) {
              const img = document.createElement('img');
              img.src = team.logo;
              img.alt = team.name;
              img.className = 'pk-slot-logo';
              slot.appendChild(img);
            } else {
              const letter = document.createElement('span');
              letter.className = 'pk-chip-letter';
              letter.style.width = '36px';
              letter.style.height = '36px';
              letter.textContent = team.shortName.charAt(0);
              slot.appendChild(letter);
            }
            const name = document.createElement('span');
            name.className = 'pk-slot-name';
            name.textContent = team.shortName;
            slot.appendChild(name);
          } else {
            const ph = document.createElement('span');
            ph.className = 'pk-slot-placeholder';
            ph.textContent = '+';
            slot.appendChild(ph);
          }
        });
      });

      // Update pick count
      const countEl = document.getElementById(`count-${stageId}`);
      if (countEl) countEl.textContent = `${placed.length} / 10 picks`;

      // Update lock button
      const lockBtn = document.getElementById(`lock-${stageId}`);
      if (lockBtn) {
        lockBtn.disabled = placed.length < 10 || isLocked || readOnly;
        if (isLocked) {
          lockBtn.textContent = 'Picks Locked';
          lockBtn.disabled = true;
        }
      }

      // Disable interactions if locked or read-only
      if (isLocked || readOnly) {
        if (chipsContainer) {
          chipsContainer.querySelectorAll('.pk-chip').forEach(chip => {
            chip.style.pointerEvents = 'none';
            chip.style.opacity = '0.5';
          });
        }
      }
    }

    // ── Render Bracket ─────────────────────────────────────────
    function renderBracket() {
      const bracket = state.bracket || {};
      const matches = document.querySelectorAll('#pkBracket .pk-match');

      // Get advancement stage teams (if any are set)
      const advStage = tournament.stages.find(s => s.id === 'advancement-stage');
      const playoffStage = tournament.stages.find(s => s.id === 'playoffs');
      const bracketTeamIds = playoffStage?.teamIds?.length > 0
        ? playoffStage.teamIds
        : (advStage?.teamIds?.length > 0 ? advStage.teamIds.slice(0, 8) : []);

      // Seed matchups for QFs
      const qfMatchups = [
        { match: 'qf1', teams: bracketTeamIds.length >= 2 ? [bracketTeamIds[0], bracketTeamIds[7]] : [] },
        { match: 'qf2', teams: bracketTeamIds.length >= 4 ? [bracketTeamIds[3], bracketTeamIds[4]] : [] },
        { match: 'qf3', teams: bracketTeamIds.length >= 6 ? [bracketTeamIds[1], bracketTeamIds[6]] : [] },
        { match: 'qf4', teams: bracketTeamIds.length >= 8 ? [bracketTeamIds[2], bracketTeamIds[5]] : [] },
      ];

      // Render each match
      matches.forEach(matchEl => {
        const matchId = matchEl.dataset.match;
        const team1Slot = matchEl.querySelector('[data-match-slot="team1"]');
        const team2Slot = matchEl.querySelector('[data-match-slot="team2"]');
        if (!team1Slot || !team2Slot) return;

        let t1 = null, t2 = null;

        if (matchId.startsWith('qf')) {
          const qf = qfMatchups.find(q => q.match === matchId);
          if (qf && qf.teams.length === 2) {
            t1 = teamMap[qf.teams[0]] || null;
            t2 = teamMap[qf.teams[1]] || null;
          }
        } else if (matchId === 'sf1') {
          const w1 = bracket['qf1'] ? teamMap[bracket['qf1']] : null;
          const w2 = bracket['qf2'] ? teamMap[bracket['qf2']] : null;
          t1 = w1; t2 = w2;
        } else if (matchId === 'sf2') {
          const w3 = bracket['qf3'] ? teamMap[bracket['qf3']] : null;
          const w4 = bracket['qf4'] ? teamMap[bracket['qf4']] : null;
          t1 = w3; t2 = w4;
        } else if (matchId === 'final') {
          const w1 = bracket['sf1'] ? teamMap[bracket['sf1']] : null;
          const w2 = bracket['sf2'] ? teamMap[bracket['sf2']] : null;
          t1 = w1; t2 = w2;
        }

        renderMatchSlot(team1Slot, t1, matchId, 'team1');
        renderMatchSlot(team2Slot, t2, matchId, 'team2');

        // Highlight picked team
        const picked = bracket[matchId];
        team1Slot.classList.toggle('pk-match-team--picked', picked && t1 && picked === t1.id);
        team2Slot.classList.toggle('pk-match-team--picked', picked && t2 && picked === t2.id);
      });

      // Champion
      const champEl = document.getElementById('pkChampion');
      const champId = bracket['final'];
      champEl.innerHTML = '';
      champEl.classList.remove('pk-champ-slot--filled');
      if (champId && teamMap[champId]) {
        const team = teamMap[champId];
        champEl.classList.add('pk-champ-slot--filled');
        if (team.logo) {
          const img = document.createElement('img');
          img.src = team.logo;
          img.alt = team.name;
          img.className = 'pk-champ-logo';
          champEl.appendChild(img);
        }
        const name = document.createElement('span');
        name.className = 'pk-champ-name';
        name.textContent = team.shortName;
        champEl.appendChild(name);
      } else {
        const ph = document.createElement('span');
        ph.className = 'pk-slot-placeholder';
        ph.textContent = '?';
        ph.style.fontSize = '2rem';
        ph.style.color = 'rgba(228,174,57,0.4)';
        champEl.appendChild(ph);
      }

      // Lock button for playoffs
      const lockBtn = document.getElementById('lock-playoffs');
      if (lockBtn) {
        const hasAllPicks = bracket['qf1'] && bracket['qf2'] && bracket['qf3'] && bracket['qf4'] &&
                            bracket['sf1'] && bracket['sf2'] && bracket['final'];
        lockBtn.disabled = !hasAllPicks || state.locked['playoffs'] || readOnly;
        if (state.locked['playoffs']) {
          lockBtn.textContent = 'Picks Locked';
          lockBtn.disabled = true;
        }
      }
    }

    function renderMatchSlot(slotEl, team, matchId, slotName) {
      slotEl.innerHTML = '';
      slotEl.dataset.teamId = team ? team.id : '';
      slotEl.dataset.matchId = matchId;
      slotEl.dataset.matchSlot = slotName;

      if (team) {
        if (team.logo) {
          const img = document.createElement('img');
          img.src = team.logo;
          img.alt = team.name;
          img.className = 'pk-match-team-logo';
          slotEl.appendChild(img);
        }
        const name = document.createElement('span');
        name.textContent = team.shortName;
        slotEl.appendChild(name);
      } else {
        slotEl.textContent = 'TBD';
      }
    }

    // ── Challenges & Coin ──────────────────────────────────────
    const COIN_TIERS = [
      { min: 0, name: 'No Coin', cls: 'pk-coin--none', icon: '?' },
      { min: 3, name: 'Bronze', cls: 'pk-coin--bronze', icon: '🥉' },
      { min: 5, name: 'Silver', cls: 'pk-coin--silver', icon: '🥈' },
      { min: 8, name: 'Gold', cls: 'pk-coin--gold', icon: '🥇' },
      { min: 10, name: 'Diamond', cls: 'pk-coin--diamond', icon: '💎' },
    ];

    function countChallenges() {
      // For now, count based on picks placed (simplified — real scoring needs results)
      let score = 0;
      const picks = state.picks;
      const bracket = state.bracket;

      // Check each swiss stage: did user place all 10 picks?
      for (const stageId of ['opening-stage', 'elimination-stage', 'advancement-stage']) {
        const p = picks[stageId];
        if (p) {
          const total = (p['3-0']?.length || 0) + (p['0-3']?.length || 0) + (p['advance']?.length || 0);
          if (total >= 10) score++;
        }
      }

      // Bracket picks placed
      if (bracket['qf1'] && bracket['qf2'] && bracket['qf3'] && bracket['qf4']) score++;
      if (bracket['sf1'] && bracket['sf2']) score++;
      if (bracket['final']) score++;

      return Math.min(score, 10);
    }

    function renderChallenges() {
      const score = countChallenges();

      // Update coin
      const coinEl = document.getElementById('pkCoin');
      const labelEl = document.getElementById('pkCoinLabel');
      const progressEl = document.getElementById('pkCoinProgress');

      let tier = COIN_TIERS[0];
      for (const t of COIN_TIERS) {
        if (score >= t.min) tier = t;
      }

      coinEl.className = 'pk-coin ' + tier.cls;
      coinEl.querySelector('.pk-coin-icon').textContent = tier.icon;
      labelEl.textContent = tier.name;
      progressEl.textContent = `${score} / 10 points`;

      // Update challenge list
      const listEl = document.getElementById('pkChallengeList');
      listEl.innerHTML = '';
      challengeDescs.forEach((ch, i) => {
        const li = document.createElement('li');
        li.className = 'pk-challenge-item';
        // Simplified: mark first N challenges as done
        if (i < score) li.classList.add('pk-challenge-item--done');
        const check = document.createElement('span');
        check.className = 'pk-challenge-check';
        check.textContent = i < score ? '✓' : '';
        const desc = document.createElement('span');
        desc.textContent = ch.description;
        li.appendChild(check);
        li.appendChild(desc);
        listEl.appendChild(li);
      });
    }

    // ── Event Handlers ─────────────────────────────────────────

    // Click on team chip (select)
    document.addEventListener('click', e => {
      const chip = e.target.closest('.pk-chip');
      if (chip && !readOnly) {
        const stageId = chip.closest('.pk-stage')?.dataset?.stageId;
        if (!stageId || state.locked[stageId]) return;
        const tid = chip.dataset.teamId;
        const placed = allPickedTeams(stageId);
        if (placed.includes(tid)) return; // already placed

        if (selectedTeam === tid) {
          selectedTeam = null; // deselect
        } else {
          selectedTeam = tid;
        }
        renderStage(stageId);
      }
    });

    // Click on slot (place or remove)
    document.addEventListener('click', e => {
      const slot = e.target.closest('.pk-slot');
      if (!slot || readOnly) return;

      const slotsContainer = slot.closest('.pk-slots');
      if (!slotsContainer) return;
      const zone = slotsContainer.dataset.zone;
      const stageId = slotsContainer.dataset.stage;
      if (!stageId || state.locked[stageId]) return;

      const idx = parseInt(slot.dataset.slotIdx);
      const picks = getStagePicks(stageId);

      // If slot is filled, remove
      if (picks[zone] && picks[zone][idx]) {
        picks[zone].splice(idx, 1);
        selectedTeam = null;
        saveState();
        renderStage(stageId);
        renderChallenges();
        return;
      }

      // If a team is selected, place it
      if (selectedTeam) {
        if (!picks[zone]) picks[zone] = [];
        // Check zone capacity
        const maxSlots = zone === 'advance' ? 6 : 2;
        if (picks[zone].length >= maxSlots) return;

        picks[zone].push(selectedTeam);
        selectedTeam = null;
        saveState();
        renderStage(stageId);
        renderChallenges();
      }
    });

    // Click on bracket match team (pick winner)
    document.addEventListener('click', e => {
      const teamSlot = e.target.closest('.pk-match-team');
      if (!teamSlot || readOnly || state.locked['playoffs']) return;
      const teamId = teamSlot.dataset.teamId;
      const matchId = teamSlot.dataset.matchId;
      if (!teamId || !matchId) return;

      state.bracket[matchId] = teamId;
      saveState();
      renderBracket();
      renderChallenges();
    });

    // Lock picks button
    document.querySelectorAll('.pk-btn--lock').forEach(btn => {
      btn.addEventListener('click', () => {
        const stageId = btn.id.replace('lock-', '');
        state.locked[stageId] = true;
        saveState();
        renderStage(stageId);
        renderChallenges();
        showToast('Picks locked!');
      });
    });

    // Reset stage button
    document.querySelectorAll('[data-reset-stage]').forEach(btn => {
      btn.addEventListener('click', () => {
        if (readOnly) return;
        const stageId = btn.dataset.resetStage;
        if (state.locked[stageId]) {
          if (!confirm('Your picks are locked. Are you sure you want to reset?')) return;
        }
        if (stageId === 'playoffs') {
          state.bracket = {};
        } else {
          state.picks[stageId] = { '3-0': [], '0-3': [], 'advance': [] };
        }
        state.locked[stageId] = false;
        selectedTeam = null;
        saveState();
        renderStage(stageId);
        renderChallenges();
        showToast('Picks reset');
      });
    });

    // Share button
    document.getElementById('pkShare')?.addEventListener('click', () => {
      const url = encodeShareUrl();
      navigator.clipboard.writeText(url).then(() => {
        showToast('Share URL copied to clipboard!');
      }).catch(() => {
        // Fallback
        prompt('Copy this URL to share your picks:', url);
      });
    });

    // Reset all button
    document.getElementById('pkResetAll')?.addEventListener('click', () => {
      if (readOnly) return;
      if (!confirm('Reset ALL picks across all stages? This cannot be undone.')) return;
      state = { picks: {}, bracket: {}, locked: {} };
      selectedTeam = null;
      saveState();
      renderStage(activeStage);
      renderChallenges();
      showToast('All picks reset');
    });

    // ── Initial render ─────────────────────────────────────────
    renderStage(activeStage);
    renderChallenges();
  </script>

  <!-- Model Hints Enhancement -->
  <script>
    (function() {
      const hintsToggle = document.getElementById('pkHintsToggle');
      const modelStatus = document.getElementById('pkModelStatus');
      const modelDesc = document.getElementById('pkModelDesc');
      const modelLegend = document.getElementById('pkModelLegend');

      // Team slug → PandaScore lookup mapping
      // Pickem team IDs are slugs that mostly match PandaScore slugs
      const SLUG_OVERRIDES = {
        'pain-gaming': 'pain-gaming',
        'g2-esports': 'g2-esports',
        'ninjas-in-pyjamas': 'ninjas-in-pyjamas',
        'team-spirit': 'team-spirit',
        'team-liquid': 'team-liquid',
        'natus-vincere': 'natus-vincere',
        'faze-clan': 'faze-clan',
        'imperial-esports': 'imperial-esports',
        'red-canids': 'red-canids',
        'the-mongolz': 'the-mongolz',
        'the-huns': 'the-huns',
        'lynn-vision': 'lynn-vision',
        'rare-atom': 'rare-atom',
        'passion-ua': 'passion-ua',
      };

      // State
      let hintsEnabled = false;
      let teamStats = {}; // slug → { winRate, mapPool, form, tier, pandaId }
      let fetchedSlugs = new Set();
      let fetchQueue = [];
      let isFetching = false;

      function getPandaSlug(pickemSlug) {
        return SLUG_OVERRIDES[pickemSlug] || pickemSlug;
      }

      // Fetch stats for a team
      async function fetchTeamStats(pickemSlug) {
        if (teamStats[pickemSlug] || fetchedSlugs.has(pickemSlug)) return;
        fetchedSlugs.add(pickemSlug);

        try {
          const pandaSlug = getPandaSlug(pickemSlug);
          const res = await fetch(`/api/team-competitive-stats?slug=${encodeURIComponent(pandaSlug)}`);
          if (!res.ok) {
            // Try name fallback
            const nameRes = await fetch(`/api/team-competitive-stats?name=${encodeURIComponent(pickemSlug.replace(/-/g, ' '))}`);
            if (!nameRes.ok) { teamStats[pickemSlug] = null; return; }
            const data = await nameRes.json();
            processStats(pickemSlug, data);
            return;
          }
          const data = await res.json();
          processStats(pickemSlug, data);
        } catch {
          teamStats[pickemSlug] = null;
        }
      }

      function processStats(slug, data) {
        if (!data || !data.record) { teamStats[slug] = null; return; }

        const winRate = data.record.matchWinRate || 0;
        const mapsPlayed = (data.maps || []).reduce((sum, m) => sum + (m.played || 0), 0);
        const activeMaps = (data.maps || []).filter(m => (m.played || 0) >= 3).length;
        const recentForm = (data.lastGames || []).slice(0, 5);
        const recentWins = recentForm.filter(g => g.result === 'win').length;
        const recentRate = recentForm.length ? recentWins / recentForm.length : winRate;

        // Composite strength score: 50% win rate + 30% recent form + 20% map pool depth
        const mapPoolScore = Math.min(activeMaps / 7, 1);
        const strength = (winRate * 0.5) + (recentRate * 0.3) + (mapPoolScore * 0.2);

        teamStats[slug] = {
          winRate: Math.round(winRate * 100),
          strength: Math.round(strength * 100),
          recentRate: Math.round(recentRate * 100),
          activeMaps,
          mapsPlayed,
          pandaId: data.id || null,
          tier: strength >= 0.60 ? 'strong' : strength >= 0.45 ? 'average' : 'weak',
        };
      }

      // Process batch of slugs
      async function fetchBatch(slugs) {
        const BATCH = 4;
        for (let i = 0; i < slugs.length; i += BATCH) {
          const batch = slugs.slice(i, i + BATCH);
          await Promise.all(batch.map(s => fetchTeamStats(s)));
          if (i + BATCH < slugs.length) await new Promise(r => setTimeout(r, 300));
        }
      }

      // Get all visible team slugs
      function getVisibleSlugs() {
        const slugs = new Set();
        document.querySelectorAll('.pk-chip[data-team-id]').forEach(chip => {
          slugs.add(chip.dataset.teamId);
        });
        document.querySelectorAll('.pk-match-team[data-team-id]').forEach(el => {
          if (el.dataset.teamId) slugs.add(el.dataset.teamId);
        });
        return [...slugs];
      }

      // Render hint badges on chips
      function renderChipHints() {
        document.querySelectorAll('.pk-chip[data-team-id]').forEach(chip => {
          // Remove existing hints
          chip.querySelectorAll('.pk-hint-badge, .pk-hint-bar').forEach(el => el.remove());

          if (!hintsEnabled) return;

          const slug = chip.dataset.teamId;
          const stats = teamStats[slug];
          if (!stats) return;

          // Badge
          const badge = document.createElement('span');
          badge.className = `pk-hint-badge pk-hint-badge--${stats.tier}`;
          badge.textContent = `${stats.strength}`;
          badge.title = `Win rate: ${stats.winRate}% | Recent form: ${stats.recentRate}% | Maps: ${stats.activeMaps}`;
          chip.appendChild(badge);

          // Strength bar
          const bar = document.createElement('div');
          bar.className = 'pk-hint-bar';
          const fill = document.createElement('div');
          fill.className = 'pk-hint-bar-fill';
          fill.style.width = `${stats.strength}%`;
          fill.style.background = stats.tier === 'strong' ? '#2ecc71' : stats.tier === 'average' ? '#f39c12' : '#e74c3c';
          bar.appendChild(fill);
          chip.appendChild(bar);
        });
      }

      // Render probability on bracket matches
      function renderBracketHints() {
        document.querySelectorAll('#pkBracket .pk-match').forEach(matchEl => {
          // Remove existing probability bars
          matchEl.querySelectorAll('.pk-match-prob').forEach(el => el.remove());
          // Remove existing WR badges
          matchEl.querySelectorAll('.pk-bracket-wr').forEach(el => el.remove());

          if (!hintsEnabled) return;

          const team1Slot = matchEl.querySelector('[data-match-slot="team1"]');
          const team2Slot = matchEl.querySelector('[data-match-slot="team2"]');
          if (!team1Slot || !team2Slot) return;

          const t1Id = team1Slot.dataset.teamId;
          const t2Id = team2Slot.dataset.teamId;

          // Add WR badges to team slots
          [team1Slot, team2Slot].forEach(slot => {
            const tid = slot.dataset.teamId;
            const stats = teamStats[tid];
            if (!stats || !tid) return;
            const wr = document.createElement('span');
            wr.className = `pk-bracket-wr pk-bracket-wr--${stats.tier}`;
            wr.textContent = `${stats.winRate}%`;
            wr.title = `Strength: ${stats.strength} | Recent: ${stats.recentRate}% | Maps: ${stats.activeMaps}`;
            slot.appendChild(wr);
          });

          // Probability bar between teams
          if (!t1Id || !t2Id) return;
          const s1 = teamStats[t1Id];
          const s2 = teamStats[t2Id];
          if (!s1 || !s2) return;

          // Simple head-to-head probability from strength scores
          const total = s1.strength + s2.strength;
          if (total === 0) return;
          const t1Pct = Math.round((s1.strength / total) * 100);
          const t2Pct = 100 - t1Pct;

          const probDiv = document.createElement('div');
          probDiv.className = 'pk-match-prob';

          const pct1 = document.createElement('span');
          pct1.className = `pk-match-prob-pct ${t1Pct >= t2Pct ? 'pk-match-prob-pct--fav' : ''}`;
          pct1.textContent = `${t1Pct}%`;

          const bar = document.createElement('div');
          bar.className = 'pk-match-prob-bar';
          const fill1 = document.createElement('div');
          fill1.className = 'pk-match-prob-t1';
          fill1.style.width = `${t1Pct}%`;
          const fill2 = document.createElement('div');
          fill2.className = 'pk-match-prob-t2';
          fill2.style.width = `${t2Pct}%`;
          bar.appendChild(fill1);
          bar.appendChild(fill2);

          const pct2 = document.createElement('span');
          pct2.className = `pk-match-prob-pct ${t2Pct > t1Pct ? 'pk-match-prob-pct--fav' : ''}`;
          pct2.textContent = `${t2Pct}%`;

          probDiv.appendChild(pct1);
          probDiv.appendChild(bar);
          probDiv.appendChild(pct2);
          matchEl.appendChild(probDiv);
        });
      }

      function renderAllHints() {
        renderChipHints();
        renderBracketHints();
      }

      // Toggle handler
      hintsToggle.addEventListener('change', async () => {
        hintsEnabled = hintsToggle.checked;

        if (hintsEnabled) {
          modelDesc.style.display = 'none';
          modelStatus.style.display = 'block';
          modelLegend.style.display = 'none';

          // Fetch all visible teams
          const slugs = getVisibleSlugs().filter(s => !teamStats[s]);
          if (slugs.length > 0) {
            await fetchBatch(slugs);
          }

          modelStatus.style.display = 'none';
          modelLegend.style.display = 'flex';
          renderAllHints();
        } else {
          modelDesc.style.display = 'block';
          modelLegend.style.display = 'none';
          renderAllHints(); // removes hints
        }
      });

      // Re-render hints when tabs change (MutationObserver on stage visibility)
      const observer = new MutationObserver(() => {
        if (hintsEnabled) {
          // Check for new teams that need fetching
          const newSlugs = getVisibleSlugs().filter(s => !teamStats[s] && !fetchedSlugs.has(s));
          if (newSlugs.length > 0) {
            fetchBatch(newSlugs).then(() => renderAllHints());
          } else {
            renderAllHints();
          }
        }
      });

      document.querySelectorAll('.pk-stage').forEach(stage => {
        observer.observe(stage, { attributes: true, attributeFilter: ['class'] });
      });

      // Also re-render when bracket state changes (picks update the DOM)
      const bracketObserver = new MutationObserver(() => {
        if (hintsEnabled) {
          setTimeout(() => {
            const newSlugs = getVisibleSlugs().filter(s => !teamStats[s] && !fetchedSlugs.has(s));
            if (newSlugs.length > 0) {
              fetchBatch(newSlugs).then(() => renderAllHints());
            } else {
              renderAllHints();
            }
          }, 100);
        }
      });

      const bracketEl = document.getElementById('pkBracket');
      if (bracketEl) {
        bracketObserver.observe(bracketEl, { childList: true, subtree: true });
      }
    })();
  </script>
