---
import Base from '../layouts/Base.astro';
import BettingCTA from '../components/BettingCTA.astro';
import { TOURNAMENTS, CHALLENGES, getTournament, getTeamById } from '../lib/pickem-data';
import type { PickemTeam, PickemStage, PickemTournament } from '../lib/pickem-data';
import { optimizeImage } from '../lib/imageOptimize';
import { breadcrumbSchema } from '../lib/weapons';

const tournament = TOURNAMENTS[0]; // Budapest 2025

// Serialize for client-side
const tournamentJson = JSON.stringify(tournament);
const challengesJson = JSON.stringify(CHALLENGES.map(c => ({ id: c.id, description: c.description })));

// Breadcrumbs
const breadcrumbs = [
  { name: 'Home', href: '/' },
  { name: 'Tools', href: '/tools/' },
  { name: "Pick'em Predictions", href: '/pickems/' },
];
const bcSchema = breadcrumbSchema(breadcrumbs);

const title = `CS2 Pick'em Predictions – ${tournament.name}`;
const description = `Make your CS2 Major Pick'em predictions for ${tournament.name}. Predict Swiss stage results and playoff bracket winners. Share your picks and earn coins!`;
---

<Base title={title} description={description} currentNav="/pickems/">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(bcSchema)} />
  </Fragment>

  <!-- Breadcrumb -->
  <nav class="pk-breadcrumb">
    {breadcrumbs.map((b, i) => (
      <Fragment>
        {i > 0 && <span class="pk-bc-sep">›</span>}
        {i < breadcrumbs.length - 1
          ? <a href={b.href}>{b.name}</a>
          : <span class="pk-bc-current">{b.name}</span>}
      </Fragment>
    ))}
  </nav>

  <!-- Hero -->
  <section class="pk-hero">
    <h1>CS2 Major Pick'Ems</h1>
    <p class="pk-hero-sub">{tournament.name} · {tournament.location}</p>
    <p class="pk-hero-dates">{tournament.dates.start} — {tournament.dates.end}</p>
  </section>

  <BettingCTA variant="pickems" />

  <!-- Stage Tabs -->
  <div class="pk-tabs-wrap">
    <div class="pk-tabs" id="stageTabs">
      {tournament.stages.map((stage, i) => (
        <button
          class={`pk-tab ${i === 0 ? 'pk-tab--active' : ''}`}
          data-stage={stage.id}
        >
          {stage.name}
        </button>
      ))}
    </div>
  </div>

  <!-- Main Content Area -->
  <div class="pk-layout">
    <!-- Main Panel (Swiss / Bracket) -->
    <div class="pk-main" id="pkMain">
      <!-- Swiss Stage Views (Opening, Elimination, Advancement) -->
      {tournament.stages.filter(s => s.type === 'swiss').map((stage, i) => (
        <div
          class={`pk-stage ${i === 0 ? '' : 'pk-stage--hidden'}`}
          id={`stage-${stage.id}`}
          data-stage-type="swiss"
          data-stage-id={stage.id}
        >
          <!-- Team chip bar -->
          <div class="pk-team-bar">
            <h3 class="pk-section-title">Select Teams</h3>
            <div class="pk-team-chips" id={`chips-${stage.id}`}>
              {stage.teamIds.map(tid => {
                const team = getTeamById(tournament.id, tid);
                if (!team) return null;
                return (
                  <button
                    class="pk-chip"
                    data-team-id={team.id}
                    title={team.name}
                  >
                    {team.logo ? (
                      <img
                        src={optimizeImage(team.logo, { width: 80, quality: 75 })}
                        alt={team.name}
                        class="pk-chip-logo"
                        loading="lazy"
                      />
                    ) : (
                      <span class="pk-chip-letter">{team.shortName.charAt(0)}</span>
                    )}
                    <span class="pk-chip-name">{team.shortName}</span>
                  </button>
                );
              })}
            </div>
          </div>

          <!-- Pick zones -->
          <div class="pk-zones">
            <!-- 3:0 Zone -->
            <div class="pk-zone pk-zone--30">
              <div class="pk-zone-header">
                <span class="pk-zone-label">3 : 0</span>
                <span class="pk-zone-desc">Advance undefeated</span>
              </div>
              <div class="pk-slots" data-zone="3-0" data-stage={stage.id}>
                <div class="pk-slot" data-slot-idx="0"></div>
                <div class="pk-slot" data-slot-idx="1"></div>
              </div>
            </div>

            <!-- 0:3 Zone -->
            <div class="pk-zone pk-zone--03">
              <div class="pk-zone-header">
                <span class="pk-zone-label">0 : 3</span>
                <span class="pk-zone-desc">Eliminated without a win</span>
              </div>
              <div class="pk-slots" data-zone="0-3" data-stage={stage.id}>
                <div class="pk-slot" data-slot-idx="0"></div>
                <div class="pk-slot" data-slot-idx="1"></div>
              </div>
            </div>

            <!-- Advance Zone (3:1 / 3:2) -->
            <div class="pk-zone pk-zone--advance">
              <div class="pk-zone-header">
                <span class="pk-zone-label">Advance</span>
                <span class="pk-zone-desc">Advance 3-1 or 3-2</span>
              </div>
              <div class="pk-slots pk-slots--wide" data-zone="advance" data-stage={stage.id}>
                <div class="pk-slot" data-slot-idx="0"></div>
                <div class="pk-slot" data-slot-idx="1"></div>
                <div class="pk-slot" data-slot-idx="2"></div>
                <div class="pk-slot" data-slot-idx="3"></div>
                <div class="pk-slot" data-slot-idx="4"></div>
                <div class="pk-slot" data-slot-idx="5"></div>
              </div>
            </div>
          </div>

          <!-- Actions -->
          <div class="pk-actions">
            <span class="pk-pick-count" id={`count-${stage.id}`}>0 / 10 picks</span>
            <button class="pk-btn pk-btn--lock" id={`lock-${stage.id}`} disabled>Lock Picks</button>
            <button class="pk-btn pk-btn--reset" data-reset-stage={stage.id}>Reset</button>
          </div>
        </div>
      ))}

      <!-- Playoffs Bracket View -->
      <div class="pk-stage pk-stage--hidden" id="stage-playoffs" data-stage-type="bracket" data-stage-id="playoffs">
        <h3 class="pk-section-title">Playoff Bracket</h3>
        <p class="pk-bracket-note">Teams will be seeded from the Advancement Stage. Click a team to predict the winner of each match.</p>
        <div class="pk-bracket" id="pkBracket">
          <!-- Quarter-finals -->
          <div class="pk-bracket-round pk-bracket-qf">
            <h4 class="pk-round-title">Quarter-Finals</h4>
            <div class="pk-match" data-match="qf1">
              <div class="pk-match-team" data-match-slot="team1"></div>
              <div class="pk-match-vs">vs</div>
              <div class="pk-match-team" data-match-slot="team2"></div>
            </div>
            <div class="pk-match" data-match="qf2">
              <div class="pk-match-team" data-match-slot="team1"></div>
              <div class="pk-match-vs">vs</div>
              <div class="pk-match-team" data-match-slot="team2"></div>
            </div>
            <div class="pk-match" data-match="qf3">
              <div class="pk-match-team" data-match-slot="team1"></div>
              <div class="pk-match-vs">vs</div>
              <div class="pk-match-team" data-match-slot="team2"></div>
            </div>
            <div class="pk-match" data-match="qf4">
              <div class="pk-match-team" data-match-slot="team1"></div>
              <div class="pk-match-vs">vs</div>
              <div class="pk-match-team" data-match-slot="team2"></div>
            </div>
          </div>

          <!-- Semi-finals -->
          <div class="pk-bracket-round pk-bracket-sf">
            <h4 class="pk-round-title">Semi-Finals</h4>
            <div class="pk-match" data-match="sf1">
              <div class="pk-match-team" data-match-slot="team1"></div>
              <div class="pk-match-vs">vs</div>
              <div class="pk-match-team" data-match-slot="team2"></div>
            </div>
            <div class="pk-match" data-match="sf2">
              <div class="pk-match-team" data-match-slot="team1"></div>
              <div class="pk-match-vs">vs</div>
              <div class="pk-match-team" data-match-slot="team2"></div>
            </div>
          </div>

          <!-- Grand Final -->
          <div class="pk-bracket-round pk-bracket-final">
            <h4 class="pk-round-title">Grand Final</h4>
            <div class="pk-match" data-match="final">
              <div class="pk-match-team" data-match-slot="team1"></div>
              <div class="pk-match-vs">vs</div>
              <div class="pk-match-team" data-match-slot="team2"></div>
            </div>
          </div>

          <!-- Champion -->
          <div class="pk-bracket-round pk-bracket-champ">
            <h4 class="pk-round-title">Champion</h4>
            <div class="pk-champ-slot" id="pkChampion"></div>
          </div>
        </div>

        <div class="pk-actions">
          <button class="pk-btn pk-btn--lock" id="lock-playoffs" disabled>Lock Picks</button>
          <button class="pk-btn pk-btn--reset" data-reset-stage="playoffs">Reset</button>
        </div>
      </div>
    </div>

    <!-- Sidebar: Challenges + Coin -->
    <aside class="pk-sidebar" id="pkSidebar">
      <!-- Coin Display -->
      <div class="pk-coin-wrap">
        <div class="pk-coin pk-coin--none" id="pkCoin">
          <span class="pk-coin-icon">?</span>
        </div>
        <span class="pk-coin-label" id="pkCoinLabel">No Coin</span>
        <span class="pk-coin-progress" id="pkCoinProgress">0 / 10</span>
      </div>

      <!-- Challenges -->
      <div class="pk-challenges">
        <h3 class="pk-sidebar-title">Challenges</h3>
        <ul class="pk-challenge-list" id="pkChallengeList">
          <!-- populated by JS -->
        </ul>
      </div>

      <!-- Model Hints -->
      <div class="pk-model-hints">
        <div class="pk-model-header">
          <h3 class="pk-sidebar-title">📊 Model Hints</h3>
          <label class="pk-toggle">
            <input type="checkbox" id="pkHintsToggle" />
            <span class="pk-toggle-slider"></span>
          </label>
        </div>
        <p class="pk-model-desc" id="pkModelDesc">Enable AI-powered team strength indicators on chips and bracket matches to guide your picks.</p>
        <div class="pk-model-status" id="pkModelStatus" style="display:none;">
          <div class="pk-model-loading"><div class="pk-model-spinner"></div> Analysing teams…</div>
        </div>
        <div class="pk-model-legend" id="pkModelLegend" style="display:none;">
          <div class="pk-legend-row"><span class="pk-legend-dot pk-legend--strong"></span> Strong (60%+ WR)</div>
          <div class="pk-legend-row"><span class="pk-legend-dot pk-legend--average"></span> Average (45-60%)</div>
          <div class="pk-legend-row"><span class="pk-legend-dot pk-legend--weak"></span> Weak (&lt;45% WR)</div>
          <div class="pk-legend-row pk-legend-note">Based on recent match win rate, map pool depth, and form</div>
        </div>
      </div>

      <!-- Share / URL -->
      <div class="pk-share">
        <button class="pk-btn pk-btn--share" id="pkShare">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 12v8a2 2 0 002 2h12a2 2 0 002-2v-8"/><polyline points="16 6 12 2 8 6"/><line x1="12" y1="2" x2="12" y2="15"/></svg>
          Share Picks
        </button>
        <button class="pk-btn pk-btn--reset-all" id="pkResetAll">Reset All</button>
      </div>
    </aside>
  </div>

  <!-- FAQ -->
  <section class="pk-faq">
    <h2>How Do Pick'Ems Work?</h2>
    <div class="pk-faq-grid">
      <div class="pk-faq-item">
        <h3>Swiss Stages</h3>
        <p>In each Swiss stage, 16 teams compete. Pick 2 teams you think will go 3-0 (undefeated), 2 teams that will go 0-3 (eliminated), and 6 teams that will advance with a 3-1 or 3-2 record. Get 5+ correct per stage to earn challenge points.</p>
      </div>
      <div class="pk-faq-item">
        <h3>Playoffs</h3>
        <p>The top 8 teams from the Advancement Stage enter a single-elimination bracket. Predict the winner of each Quarter-Final, Semi-Final, and the Grand Final to earn challenge points.</p>
      </div>
      <div class="pk-faq-item">
        <h3>Coins & Rewards</h3>
        <p>Earn challenge points by making correct predictions. Reach different coin tiers: Bronze (3 pts), Silver (5 pts), Gold (8 pts), and Diamond (10 pts — perfect Pick'em!).</p>
      </div>
      <div class="pk-faq-item">
        <h3>Sharing</h3>
        <p>Click "Share Picks" to generate a URL with your predictions encoded. Anyone with the link can see your picks in read-only mode. Your picks are saved locally in your browser.</p>
      </div>
    </div>
  </section>

  <!-- Styles -->
  <style is:inline>
    /* ── Layout ─────────────────────────────────────────────────── */
    .pk-breadcrumb {
      max-width: 1200px;
      margin: 0 auto;
      padding: 16px 20px 0;
      font-size: 0.85rem;
      color: var(--text-muted, #888);
    }
    .pk-breadcrumb a { color: var(--text-muted, #888); text-decoration: none; }
    .pk-breadcrumb a:hover { color: #2ecc71; }
    .pk-bc-sep { margin: 0 6px; }
    .pk-bc-current { color: var(--text, #eee); }

    .pk-hero {
      text-align: center;
      padding: 40px 20px 20px;
      max-width: 1200px;
      margin: 0 auto;
    }
    .pk-hero h1 {
      font-size: 2.2rem;
      margin: 0;
      background: linear-gradient(135deg, #2ecc71, #27ae60);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .pk-hero-sub {
      font-size: 1.1rem;
      color: var(--text, #eee);
      margin: 8px 0 4px;
    }
    .pk-hero-dates {
      font-size: 0.9rem;
      color: var(--text-muted, #888);
      margin: 0;
    }

    /* ── Tabs ───────────────────────────────────────────────────── */
    .pk-tabs-wrap {
      max-width: 1200px;
      margin: 20px auto 0;
      padding: 0 20px;
    }
    .pk-tabs {
      display: flex;
      gap: 4px;
      background: var(--bg2, #13141a);
      border-radius: 8px;
      padding: 4px;
      overflow-x: auto;
    }
    .pk-tab {
      flex: 1;
      padding: 10px 16px;
      border: none;
      background: transparent;
      color: var(--text-muted, #888);
      font-size: 0.9rem;
      font-weight: 600;
      cursor: pointer;
      border-radius: 6px;
      transition: all .2s ease;
      white-space: nowrap;
      font-family: inherit;
    }
    .pk-tab:hover { color: var(--text, #eee); background: rgba(255,255,255,0.05); box-shadow: 0 0 8px rgba(46,204,113,.15); }
    .pk-tab--active {
      background: linear-gradient(135deg, #2ecc71, #27ae60);
      color: #fff;
      box-shadow: 0 4px 15px rgba(46,204,113,.3);
    }
    .pk-tab--active:hover { background: #27ae60; color: #000; }

    /* ── Main Layout ───────────────────────────────────────────── */
    .pk-layout {
      max-width: 1200px;
      margin: 20px auto 0;
      padding: 0 20px 60px;
      display: grid;
      grid-template-columns: 1fr 280px;
      gap: 24px;
      align-items: start;
    }

    .pk-main {
      min-width: 0;
    }

    .pk-stage { }
    .pk-stage--hidden { display: none; }

    .pk-section-title {
      font-size: 1rem;
      color: var(--text, #eee);
      margin: 0 0 12px;
      font-weight: 600;
    }

    /* ── Team Chips ────────────────────────────────────────────── */
    .pk-team-bar {
      margin-bottom: 24px;
    }
    .pk-team-chips {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }
    .pk-chip {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 4px;
      padding: 8px 6px;
      background: var(--bg2, #13141a);
      border: 2px solid var(--border, #222);
      border-radius: 8px;
      cursor: pointer;
      transition: all 0.15s;
      width: 72px;
      font-family: inherit;
      color: var(--text, #eee);
    }
    .pk-chip:hover {
      border-color: #2ecc71;
      background: rgba(46,204,113,0.08);
    }
    .pk-chip--selected {
      border-color: #2ecc71;
      background: rgba(46,204,113,0.15);
      box-shadow: 0 0 12px rgba(46,204,113,0.25);
    }
    .pk-chip--placed {
      opacity: 0.3;
      pointer-events: none;
    }
    .pk-chip--correct {
      border-color: #2ecc71;
      opacity: 1;
    }
    .pk-chip--incorrect {
      border-color: #e74c3c;
      opacity: 1;
    }
    .pk-chip-logo {
      width: 40px;
      height: 40px;
      object-fit: contain;
    }
    .pk-chip-letter {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 40px;
      height: 40px;
      background: rgba(46,204,113,0.15);
      border-radius: 50%;
      font-size: 1.1rem;
      font-weight: 700;
      color: #2ecc71;
    }
    .pk-chip-name {
      font-size: 0.7rem;
      text-align: center;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      max-width: 64px;
    }

    /* ── Pick Zones ────────────────────────────────────────────── */
    .pk-zones {
      display: flex;
      flex-direction: column;
      gap: 16px;
    }
    .pk-zone {
      background: var(--bg2, #13141a);
      border-radius: 10px;
      padding: 16px;
      border: 1px solid var(--border, #222);
    }
    .pk-zone--30 { border-left: 3px solid #2ecc71; }
    .pk-zone--03 { border-left: 3px solid #e74c3c; }
    .pk-zone--advance { border-left: 3px solid #3498db; }
    .pk-zone-header {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-bottom: 12px;
    }
    .pk-zone-label {
      font-size: 1.3rem;
      font-weight: 700;
      color: var(--text, #eee);
      font-variant-numeric: tabular-nums;
    }
    .pk-zone--30 .pk-zone-label { color: #2ecc71; }
    .pk-zone--03 .pk-zone-label { color: #e74c3c; }
    .pk-zone--advance .pk-zone-label { color: #3498db; }
    .pk-zone-desc {
      font-size: 0.8rem;
      color: var(--text-muted, #888);
    }

    /* ── Slots ──────────────────────────────────────────────────── */
    .pk-slots {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
    }
    .pk-slot {
      width: 80px;
      height: 90px;
      border: 2px dashed rgba(255,255,255,0.15);
      border-radius: 8px;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      transition: all 0.15s;
      position: relative;
      background: rgba(255,255,255,0.02);
    }
    .pk-slot:hover {
      border-color: rgba(255,255,255,0.3);
      background: rgba(255,255,255,0.04);
    }
    .pk-slot--filled {
      border-style: solid;
      border-color: rgba(255,255,255,0.2);
      background: rgba(255,255,255,0.05);
      cursor: pointer;
    }
    .pk-slot--filled:hover {
      border-color: #e74c3c;
    }
    .pk-slot--correct {
      border-color: #2ecc71 !important;
      background: rgba(46,204,113,0.1);
    }
    .pk-slot--incorrect {
      border-color: #e74c3c !important;
      background: rgba(231,76,60,0.1);
    }
    .pk-slot-logo {
      width: 36px;
      height: 36px;
      object-fit: contain;
    }
    .pk-slot-name {
      font-size: 0.65rem;
      color: var(--text, #eee);
      margin-top: 4px;
      text-align: center;
      max-width: 70px;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }
    .pk-slot-result {
      position: absolute;
      top: 4px;
      right: 4px;
      font-size: 0.7rem;
      font-weight: 700;
    }
    .pk-slot-result--correct { color: #2ecc71; }
    .pk-slot-result--incorrect { color: #e74c3c; }

    .pk-slot-placeholder {
      color: rgba(255,255,255,0.15);
      font-size: 1.5rem;
    }

    /* ── Actions ────────────────────────────────────────────────── */
    .pk-actions {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-top: 20px;
      flex-wrap: wrap;
    }
    .pk-pick-count {
      font-size: 0.9rem;
      color: var(--text-muted, #888);
      font-variant-numeric: tabular-nums;
    }
    .pk-btn {
      padding: 8px 20px;
      border: none;
      border-radius: 6px;
      font-size: 0.85rem;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.15s;
      font-family: inherit;
      display: inline-flex;
      align-items: center;
      gap: 6px;
    }
    .pk-btn--lock {
      background: linear-gradient(135deg, #2ecc71, #27ae60);
      color: #fff;
      box-shadow: 0 4px 15px rgba(46,204,113,.3);
    }
    .pk-btn--lock:hover { background: linear-gradient(135deg, #27ae60, #219a52); transform: translateY(-2px); box-shadow: 0 6px 20px rgba(46,204,113,.45); }
    .pk-btn--lock:disabled {
      opacity: 0.4;
      cursor: not-allowed;
    }
    .pk-btn--reset {
      background: rgba(255,255,255,0.08);
      color: var(--text, #eee);
      border: 1px solid rgba(46,204,113,.4);
      box-shadow: 0 0 8px rgba(46,204,113,.1);
    }
    .pk-btn--reset:hover { background: rgba(46,204,113,.08); box-shadow: 0 0 12px rgba(46,204,113,.2); }
    .pk-btn--share {
      background: linear-gradient(135deg, #3498db, #2980b9);
      color: #fff;
      width: 100%;
      justify-content: center;
      box-shadow: 0 4px 15px rgba(52,152,219,.3);
    }
    .pk-btn--share:hover { background: linear-gradient(135deg, #2980b9, #2471a3); transform: translateY(-2px); box-shadow: 0 6px 20px rgba(52,152,219,.45); }
    .pk-btn--reset-all {
      background: rgba(231,76,60,0.15);
      color: #e74c3c;
      width: 100%;
      justify-content: center;
      padding: 8px 20px;
      border: 1px solid rgba(231,76,60,.4);
      border-radius: 6px;
      font-size: 0.85rem;
      font-weight: 600;
      cursor: pointer;
      font-family: inherit;
      box-shadow: 0 0 8px rgba(231,76,60,.1);
    }
    .pk-btn--reset-all:hover { background: rgba(231,76,60,0.25); box-shadow: 0 0 12px rgba(231,76,60,.2); }

    /* ── Bracket ────────────────────────────────────────────────── */
    .pk-bracket-note {
      font-size: 0.85rem;
      color: var(--text-muted, #888);
      margin: 0 0 20px;
    }
