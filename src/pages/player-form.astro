---
import Base from '../layouts/Base.astro';
import ExploreMore from '../components/ExploreMore.astro';
import BettingCTA from '../components/BettingCTA.astro';

const explore = [
  { title: 'Match Predictions', href: '/predictions/', desc: 'Trading-grade match win probabilities' },
  { title: 'Hot Picks', href: '/hot-picks/', desc: 'Best value bets for today' },
  { title: 'H2H Comparator', href: '/h2h/', desc: 'Compare any two teams head-to-head' },
  { title: 'Pro Settings', href: '/pro-settings/', desc: 'Pro player configs and gear' },
];
---
<Base title="CS2 Player Form Impact — Individual Performance Analysis | CSGOLuck Wiki" description="See how individual player form impacts team win probability. Analyse player ratings, ADR, KAST, and recent performance trends for CS2 pro teams." currentNav="/player-form/">

<nav class="breadcrumb" aria-label="Breadcrumb">
<a href="/">Home</a> <span class="sep">›</span> <a href="/esports/">Esports</a> <span class="sep">›</span> <span>Player Form</span>
</nav>

<h1>Player Form Impact</h1>
<p class="page-intro">Analyse how individual player form impacts team performance. Search for any CS2 pro team to see per-player ratings, recent trends, and how each player's current form shifts the team's overall win probability.</p>

<BettingCTA text="Found a team in peak form? Back them with confidence." cta="Bet on CS2 Matches" variant="matches" />

<!-- Search -->
<div class="pf-search-wrap">
  <div class="pf-search">
    <svg class="pf-search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
    <input type="text" id="teamSearch" class="pf-search-input" placeholder="Search team (e.g. NAVI, FaZe, Vitality…)" autocomplete="off" />
    <div class="pf-search-results" id="searchResults"></div>
  </div>
</div>

<!-- Quick Access -->
<div class="pf-quick">
  <span class="pf-quick-label">Popular:</span>
  <button class="pf-quick-btn" data-team="natus-vincere">NAVI</button>
  <button class="pf-quick-btn" data-team="team-spirit">Spirit</button>
  <button class="pf-quick-btn" data-team="vitality">Vitality</button>
  <button class="pf-quick-btn" data-team="faze-clan">FaZe</button>
  <button class="pf-quick-btn" data-team="g2-esports">G2</button>
  <button class="pf-quick-btn" data-team="mouz">MOUZ</button>
  <button class="pf-quick-btn" data-team="the-mongolz">Mongolz</button>
  <button class="pf-quick-btn" data-team="furia">FURIA</button>
</div>

<!-- Team Overview -->
<div id="teamContainer" style="display:none;">
  <!-- Header -->
  <div class="pf-team-header" id="teamHeader"></div>

  <!-- Form Impact Summary -->
  <div class="pf-impact-summary" id="impactSummary"></div>

  <!-- Player Cards -->
  <div class="pf-players" id="playerCards"></div>

  <!-- Methodology -->
  <div class="pf-method">
    <h3>How Form Impact Works</h3>
    <p>Each player's <strong>form score</strong> compares their recent 5-game performance to their career averages across three key metrics:</p>
    <ul>
      <li><strong>Rating 2.0</strong> — HLTV-style game rating (weight: 40%)</li>
      <li><strong>ADR</strong> — Average damage per round (weight: 35%)</li>
      <li><strong>KAST</strong> — % rounds with Kill, Assist, Survived, or Traded (weight: 25%)</li>
    </ul>
    <p>A form score of <span style="color:#2ecc71;">100</span> means performing at career average. Above 100 = hot streak, below 100 = slumping. The team's overall form impact is the average of all player form scores, weighted slightly towards the star player (highest career rating).</p>
    <p>Form impact shifts the team's base win probability by up to ±8%. A team with all players in peak form (120+) gets a meaningful boost, while a team with multiple slumping players (80 or below) gets penalised.</p>
  </div>
</div>

<!-- Empty state -->
<div id="emptyState" class="pf-empty">
  <div class="pf-empty-icon">📊</div>
  <h3>Search for a Team</h3>
  <p>Enter a team name above or click a popular team to see how individual player form impacts their win probability.</p>
</div>

<ExploreMore items={explore} />

<style is:inline>
  .pf-search-wrap {
    max-width: 600px;
    margin: 0 auto 16px;
  }
  .pf-search {
    position: relative;
  }
  .pf-search-icon {
    position: absolute;
    left: 14px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--text-muted, #888);
    pointer-events: none;
  }
  .pf-search-input {
    width: 100%;
    padding: 14px 16px 14px 44px;
    background: var(--bg2, #13141a);
    border: 2px solid var(--border, #222);
    border-radius: 10px;
    color: var(--text, #eee);
    font-size: 1rem;
    font-family: inherit;
    outline: none;
    transition: border-color 0.2s;
    box-sizing: border-box;
  }
  .pf-search-input:focus {
    border-color: #2ecc71;
  }
  .pf-search-results {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    background: var(--bg2, #13141a);
    border: 1px solid var(--border, #222);
    border-radius: 8px;
    margin-top: 4px;
    display: none;
    z-index: 100;
    max-height: 300px;
    overflow-y: auto;
    box-shadow: 0 8px 24px rgba(0,0,0,0.4);
  }
  .pf-search-item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 14px;
    cursor: pointer;
    transition: background 0.15s;
    border-bottom: 1px solid var(--border, #222);
  }
  .pf-search-item:last-child { border-bottom: none; }
  .pf-search-item:hover { background: rgba(46,204,113,0.08); }
  .pf-search-item img {
    width: 28px;
    height: 28px;
    object-fit: contain;
  }
  .pf-search-item-name {
    font-weight: 600;
    color: var(--text, #eee);
  }

  .pf-quick {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
    justify-content: center;
    margin-bottom: 32px;
  }
  .pf-quick-label {
    font-size: 0.8rem;
    color: var(--text-muted, #888);
  }
  .pf-quick-btn {
    padding: 6px 14px;
    background: var(--bg2, #13141a);
    border: 1px solid var(--border, #222);
    border-radius: 20px;
    color: var(--text, #eee);
    font-size: 0.8rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.15s;
    font-family: inherit;
  }
  .pf-quick-btn:hover {
    border-color: #2ecc71;
    background: rgba(46,204,113,0.08);
    color: #2ecc71;
  }

  /* Team Header */
  .pf-team-header {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 20px 24px;
    background: var(--bg2, #13141a);
    border: 1px solid var(--border, #222);
    border-radius: 10px;
    margin-bottom: 16px;
  }
  .pf-team-logo {
    width: 56px;
    height: 56px;
    object-fit: contain;
  }
  .pf-team-info {
    flex: 1;
  }
  .pf-team-name {
    font-size: 1.4rem;
    font-weight: 700;
    margin: 0;
    color: var(--text, #eee);
  }
  .pf-team-meta {
    font-size: 0.85rem;
    color: var(--text-muted, #888);
    margin: 2px 0 0;
  }
  .pf-team-record {
    display: flex;
    gap: 16px;
    font-variant-numeric: tabular-nums;
  }
  .pf-record-item {
    text-align: center;
  }
  .pf-record-val {
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--text, #eee);
  }
  .pf-record-label {
    font-size: 0.65rem;
