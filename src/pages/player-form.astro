  .pf-empty h3 { color: var(--text, #eee); margin: 0 0 8px; }
  .pf-empty p { font-size: 0.9rem; max-width: 400px; margin: 0 auto; }

  /* Loading */
  .pf-loading {
    text-align: center;
    padding: 40px;
    color: #2ecc71;
    font-size: 0.9rem;
  }
  .pf-loading .spinner {
    width: 24px;
    height: 24px;
    border: 3px solid rgba(46,204,113,0.2);
    border-top-color: #2ecc71;
    border-radius: 50%;
    animation: spin 0.7s linear infinite;
    margin: 0 auto 12px;
