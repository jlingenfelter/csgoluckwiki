    letter-spacing: 0.05em;
  }

  /* Impact Summary */
  .pf-impact-summary {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 12px;
    margin-bottom: 20px;
  }
  .pf-impact-card {
    background: var(--bg2, #13141a);
    border: 1px solid var(--border, #222);
    border-radius: 10px;
    padding: 16px;
    text-align: center;
  }
  .pf-impact-label {
    font-size: 0.75rem;
    color: var(--text-muted, #888);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 6px;
  }
  .pf-impact-val {
    font-size: 1.6rem;
    font-weight: 700;
    font-variant-numeric: tabular-nums;
  }
  .pf-impact-sub {
    font-size: 0.7rem;
    color: var(--text-muted, #888);
    margin-top: 4px;
  }
  .pf-impact-val--hot { color: #2ecc71; }
  .pf-impact-val--neutral { color: #f39c12; }
  .pf-impact-val--cold { color: #e74c3c; }
  .pf-impact-val--boost { color: #2ecc71; }
  .pf-impact-val--drag { color: #e74c3c; }

  /* Player Cards */
  .pf-players {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 12px;
    margin-bottom: 32px;
  }
  .pf-player {
    background: var(--bg2, #13141a);
    border: 1px solid var(--border, #222);
    border-radius: 10px;
    overflow: hidden;
    transition: border-color 0.2s;
  }
  .pf-player--hot { border-color: rgba(46,204,113,0.4); }
  .pf-player--cold { border-color: rgba(231,76,60,0.4); }

  .pf-player-head {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 12px 14px;
    border-bottom: 1px solid var(--border, #222);
  }
  .pf-player-img {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    object-fit: cover;
    background: var(--bg3, #1a1b22);
  }
  .pf-player-info {
    flex: 1;
    min-width: 0;
  }
  .pf-player-name {
    font-weight: 700;
    font-size: 0.95rem;
    color: var(--text, #eee);
    display: block;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .pf-player-role {
    font-size: 0.7rem;
    color: var(--text-muted, #888);
    text-transform: capitalize;
  }
  .pf-player-form-badge {
    font-size: 0.8rem;
    font-weight: 700;
    padding: 3px 8px;
    border-radius: 6px;
    font-variant-numeric: tabular-nums;
  }
  .pf-form--hot { background: rgba(46,204,113,0.15); color: #2ecc71; }
  .pf-form--neutral { background: rgba(243,156,18,0.15); color: #f39c12; }
  .pf-form--cold { background: rgba(231,76,60,0.15); color: #e74c3c; }

  .pf-player-stats {
    padding: 10px 14px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .pf-stat-row {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .pf-stat-label {
    font-size: 0.7rem;
    color: var(--text-muted, #888);
    min-width: 48px;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }
  .pf-stat-bar-wrap {
    flex: 1;
    height: 6px;
    background: rgba(255,255,255,0.08);
    border-radius: 3px;
    overflow: hidden;
    position: relative;
  }
  .pf-stat-bar {
    height: 100%;
    border-radius: 3px;
    transition: width 0.4s;
  }
  .pf-stat-bar--career {
    position: absolute;
    top: 0;
    height: 100%;
    width: 2px;
    background: rgba(255,255,255,0.4);
    z-index: 1;
  }
  .pf-stat-val {
    font-size: 0.7rem;
    font-weight: 600;
    color: var(--text, #eee);
    min-width: 36px;
    text-align: right;
    font-variant-numeric: tabular-nums;
  }

  /* Recent games sparkline */
  .pf-player-recent {
    padding: 8px 14px 12px;
    border-top: 1px solid var(--border, #222);
  }
  .pf-recent-label {
    font-size: 0.6rem;
    color: var(--text-muted, #888);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 6px;
  }
  .pf-recent-games {
    display: flex;
    gap: 4px;
    align-items: flex-end;
    height: 30px;
  }
  .pf-recent-bar {
    flex: 1;
    border-radius: 2px;
    min-height: 4px;
    transition: height 0.3s;
    position: relative;
  }
  .pf-recent-bar::after {
    content: attr(data-rating);
    position: absolute;
    bottom: -14px;
    left: 50%;
    transform: translateX(-50%);
    font-size: 0.5rem;
    color: var(--text-muted, #666);
    font-variant-numeric: tabular-nums;
  }

  /* Impact arrow on player card */
  .pf-impact-arrow {
    font-size: 0.7rem;
    font-weight: 700;
    padding: 2px 6px;
    border-radius: 4px;
  }
  .pf-impact-arrow--up { color: #2ecc71; }
  .pf-impact-arrow--down { color: #e74c3c; }
  .pf-impact-arrow--flat { color: var(--text-muted, #888); }

  /* Methodology */
  .pf-method {
    background: var(--bg2, #13141a);
    border: 1px solid var(--border, #222);
    border-radius: 10px;
    padding: 20px 24px;
    margin-bottom: 32px;
  }
  .pf-method h3 {
    font-size: 1rem;
    color: var(--text, #eee);
    margin: 0 0 10px;
  }
  .pf-method p {
    font-size: 0.85rem;
    color: var(--text-muted, #888);
    line-height: 1.6;
    margin: 0 0 10px;
  }
  .pf-method ul {
    margin: 8px 0 12px 20px;
    padding: 0;
  }
