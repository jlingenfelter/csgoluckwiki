  @media (max-width: 600px) {
    .pf-players { grid-template-columns: 1fr; }
    .pf-impact-summary { grid-template-columns: 1fr 1fr; }
    .pf-team-header { flex-direction: column; text-align: center; }
    .pf-team-record { justify-content: center; }
  }
</style>

<script>
  const searchInput = document.getElementById('teamSearch');
  const searchResults = document.getElementById('searchResults');
  const teamContainer = document.getElementById('teamContainer');
  const emptyState = document.getElementById('emptyState');
  const teamHeader = document.getElementById('teamHeader');
  const impactSummary = document.getElementById('impactSummary');
  const playerCards = document.getElementById('playerCards');

  let searchTimeout = null;
  const statsCache = {};

  // ── Search ──────────────────────────────────────────────────
  searchInput.addEventListener('input', () => {
    clearTimeout(searchTimeout);
    const q = searchInput.value.trim();
    if (q.length < 2) { searchResults.style.display = 'none'; return; }

    searchTimeout = setTimeout(async () => {
      try {
        const res = await fetch(`/api/team-stats?name=${encodeURIComponent(q)}`);
        if (!res.ok) return;
        const data = await res.json();
        const teams = data.teams || [data];
        if (!teams.length) { searchResults.style.display = 'none'; return; }

        searchResults.innerHTML = teams.slice(0, 8).map(t => `
          <div class="pf-search-item" data-slug="${t.slug}" data-id="${t.id}">
            ${t.image ? `<img src="${t.image}" alt="" />` : '<span style="width:28px;height:28px;display:block;"></span>'}
            <span class="pf-search-item-name">${t.name}</span>
          </div>
        `).join('');
        searchResults.style.display = 'block';

        searchResults.querySelectorAll('.pf-search-item').forEach(item => {
          item.addEventListener('click', () => {
            loadTeam(item.dataset.slug, item.dataset.id);
            searchResults.style.display = 'none';
            searchInput.value = '';
          });
        });
      } catch {}
    }, 400);
  });

  // Hide results on click outside
  document.addEventListener('click', e => {
    if (!e.target.closest('.pf-search')) searchResults.style.display = 'none';
  });

  // Quick access buttons
  document.querySelectorAll('.pf-quick-btn').forEach(btn => {
    btn.addEventListener('click', () => loadTeam(btn.dataset.team));
  });

  // ── Load Team ──────────────────────────────────────────────
  async function loadTeam(slug, id) {
    emptyState.style.display = 'none';
    teamContainer.style.display = 'block';
    teamHeader.innerHTML = '<div class="pf-loading"><div class="spinner"></div>Loading team data…</div>';
    impactSummary.innerHTML = '';
    playerCards.innerHTML = '';

    try {
      // Step 1: Get team roster
      const teamParam = id ? `id=${id}` : `slug=${encodeURIComponent(slug)}`;
      const teamRes = await fetch(`/api/team-stats?${teamParam}`);
      if (!teamRes.ok) throw new Error('Team not found');
      const teamRaw = await teamRes.json();
      const team = teamRaw.teams ? teamRaw.teams[0] : teamRaw;
      if (!team) throw new Error('Team not found');

      // Also get competitive stats
      const compRes = await fetch(`/api/team-competitive-stats?${teamParam}`);
      const compData = compRes.ok ? await compRes.json() : null;

      // Render header
      renderHeader(team, compData);

      // Step 2: Fetch player stats (batch of 3 to avoid rate limiting)
      const activePlayers = (team.players || []).filter(p => p.active !== false).slice(0, 6);
      if (!activePlayers.length) {
        playerCards.innerHTML = '<p style="color:var(--text-muted);text-align:center;padding:40px;">No active players found for this team.</p>';
        return;
      }

      playerCards.innerHTML = '<div class="pf-loading"><div class="spinner"></div>Fetching player stats…</div>';

      const playerData = [];
      for (let i = 0; i < activePlayers.length; i += 3) {
        const batch = activePlayers.slice(i, i + 3);
        const results = await Promise.all(batch.map(async p => {
          if (statsCache[p.id]) return { player: p, stats: statsCache[p.id] };
          try {
            const res = await fetch(`/api/player-stats?id=${p.id}`);
            if (!res.ok) return { player: p, stats: null };
            const data = await res.json();
            statsCache[p.id] = data;
            return { player: p, stats: data };
          } catch {
            return { player: p, stats: null };
          }
        }));
        playerData.push(...results);
        if (i + 3 < activePlayers.length) await new Promise(r => setTimeout(r, 300));
      }

      // Step 3: Calculate form scores
      const formResults = playerData.map(({ player, stats }) => {
        if (!stats || !stats.stats) return { player, stats: null, formScore: 100, tier: 'neutral' };

        const career = stats.stats.averages || {};
        const recent = stats.lastGames || [];

        // Career averages
        const careerRating = career.rating || 1.0;
        const careerAdr = career.adr || 70;
        const careerKast = career.kast || 65;

        // Recent averages (last 5 games)
        const recentRating = recent.length ? recent.reduce((s, g) => s + (g.rating || 1.0), 0) / recent.length : careerRating;
        const recentAdr = recent.length ? recent.reduce((s, g) => s + (g.adr || 70), 0) / recent.length : careerAdr;
        const recentKast = recent.length ? recent.reduce((s, g) => s + (g.kast || 65), 0) / recent.length : careerKast;

        // Form ratios (1.0 = at career average)
        const ratingForm = careerRating > 0 ? recentRating / careerRating : 1;
        const adrForm = careerAdr > 0 ? recentAdr / careerAdr : 1;
        const kastForm = careerKast > 0 ? recentKast / careerKast : 1;

        // Weighted composite form score (100 = career average)
        const formScore = Math.round((ratingForm * 0.40 + adrForm * 0.35 + kastForm * 0.25) * 100);

        const tier = formScore >= 110 ? 'hot' : formScore >= 95 ? 'neutral' : 'cold';

        return {
          player,
          stats,
          formScore,
          tier,
          careerRating,
          careerAdr,
          careerKast,
          recentRating: Math.round(recentRating * 100) / 100,
          recentAdr: Math.round(recentAdr * 10) / 10,
          recentKast: Math.round(recentKast * 10) / 10,
          recent,
        };
      });

      // Step 4: Calculate team form impact
      // Star player weight: highest career rating gets 1.3x weight, others 1.0x
      const starIdx = formResults.reduce((best, r, i) =>
        (r.careerRating || 0) > (formResults[best]?.careerRating || 0) ? i : best, 0);

      let weightSum = 0;
      let formSum = 0;
      formResults.forEach((r, i) => {
        const w = i === starIdx ? 1.3 : 1.0;
        formSum += r.formScore * w;
        weightSum += w;
      });
      const teamFormScore = Math.round(formSum / weightSum);

      // Win prob shift: (teamForm - 100) * 0.08, clamped to ±8%
      const probShift = Math.max(-8, Math.min(8, (teamFormScore - 100) * 0.08 * 100));

      // Render summary
      renderImpactSummary(teamFormScore, probShift, formResults);

      // Render player cards
      renderPlayers(formResults, starIdx);

    } catch (err) {
      teamHeader.innerHTML = `<p style="color:#e74c3c;text-align:center;padding:20px;">${err.message || 'Failed to load team data'}</p>`;
    }
  }

  // ── Render Functions ────────────────────────────────────────

  function renderHeader(team, compData) {
    const record = compData?.record || {};
    teamHeader.innerHTML = `
      ${team.image ? `<img src="${team.image}" alt="${team.name}" class="pf-team-logo" />` : ''}
      <div class="pf-team-info">
        <h2 class="pf-team-name">${team.name}</h2>
        <p class="pf-team-meta">${team.location || ''} · ${(team.players || []).filter(p => p.active !== false).length} active players</p>
      </div>
      <div class="pf-team-record">
        <div class="pf-record-item">
          <div class="pf-record-val">${record.matchesPlayed || '—'}</div>
          <div class="pf-record-label">Matches</div>
        </div>
        <div class="pf-record-item">
          <div class="pf-record-val">${record.matchesWon || '—'}</div>
          <div class="pf-record-label">Wins</div>
        </div>
        <div class="pf-record-item">
          <div class="pf-record-val" style="color:${(record.matchWinRate || 0) >= 0.5 ? '#2ecc71' : '#e74c3c'}">${record.matchWinRate ? Math.round(record.matchWinRate * 100) + '%' : '—'}</div>
          <div class="pf-record-label">Win Rate</div>
        </div>
      </div>
    `;
  }

  function renderImpactSummary(teamForm, probShift, formResults) {
    const hotCount = formResults.filter(r => r.tier === 'hot').length;
    const coldCount = formResults.filter(r => r.tier === 'cold').length;
    const formTier = teamForm >= 110 ? 'hot' : teamForm >= 95 ? 'neutral' : 'cold';
    const shiftStr = probShift >= 0 ? `+${probShift.toFixed(1)}%` : `${probShift.toFixed(1)}%`;

    impactSummary.innerHTML = `
      <div class="pf-impact-card">
        <div class="pf-impact-label">Team Form Score</div>
        <div class="pf-impact-val pf-impact-val--${formTier}">${teamForm}</div>
        <div class="pf-impact-sub">${teamForm >= 110 ? 'In peak form' : teamForm >= 95 ? 'Near average form' : 'Below average form'}</div>
      </div>
      <div class="pf-impact-card">
        <div class="pf-impact-label">Win Prob Impact</div>
        <div class="pf-impact-val ${probShift >= 0 ? 'pf-impact-val--boost' : 'pf-impact-val--drag'}">${shiftStr}</div>
        <div class="pf-impact-sub">${probShift >= 0 ? 'Form advantage' : 'Form disadvantage'}</div>
      </div>
      <div class="pf-impact-card">
        <div class="pf-impact-label">Hot Players</div>
        <div class="pf-impact-val pf-impact-val--hot">${hotCount}</div>
        <div class="pf-impact-sub">Performing above average</div>
      </div>
      <div class="pf-impact-card">
        <div class="pf-impact-label">Cold Players</div>
        <div class="pf-impact-val pf-impact-val--cold">${coldCount}</div>
        <div class="pf-impact-sub">Below career average</div>
      </div>
    `;
  }

  function renderPlayers(formResults, starIdx) {
    playerCards.innerHTML = formResults.map((r, i) => {
      const p = r.player;
      const s = r.stats;
      const isStar = i === starIdx;
      const formClass = r.tier === 'hot' ? 'pf-form--hot' : r.tier === 'cold' ? 'pf-form--cold' : 'pf-form--neutral';
      const cardClass = r.tier === 'hot' ? 'pf-player--hot' : r.tier === 'cold' ? 'pf-player--cold' : '';

      // Rating bar (out of 2.0, scaled)
      const ratingPct = Math.min(100, (r.recentRating / 1.8) * 100);
      const careerRatingPct = Math.min(100, ((r.careerRating || 1.0) / 1.8) * 100);
      // ADR bar (out of 120)
      const adrPct = Math.min(100, (r.recentAdr / 120) * 100);
      const careerAdrPct = Math.min(100, ((r.careerAdr || 70) / 120) * 100);
      // KAST bar (out of 100)
      const kastPct = Math.min(100, r.recentKast);
      const careerKastPct = Math.min(100, r.careerKast || 65);

      const barColor = r.tier === 'hot' ? '#2ecc71' : r.tier === 'cold' ? '#e74c3c' : '#f39c12';

      // Recent games sparkline
      const recent = r.recent || [];
      const sparkline = recent.length ? recent.map(g => {
        const rating = g.rating || 1.0;
        const h = Math.max(4, Math.round((rating / 1.8) * 30));
        const color = rating >= 1.15 ? '#2ecc71' : rating >= 0.95 ? '#f39c12' : '#e74c3c';
        return `<div class="pf-recent-bar" style="height:${h}px;background:${color};" data-rating="${rating.toFixed(2)}"></div>`;
      }).join('') : '<span style="font-size:0.65rem;color:var(--text-muted);">No recent data</span>';

      return `
        <div class="pf-player ${cardClass}">
          <div class="pf-player-head">
            ${s?.image ? `<img src="${s.image}" alt="${s?.name || p.name}" class="pf-player-img" />` : `<div class="pf-player-img" style="display:flex;align-items:center;justify-content:center;background:rgba(46,204,113,0.1);color:#2ecc71;font-weight:700;font-size:1.1rem;">${(s?.name || p.name).charAt(0)}</div>`}
            <div class="pf-player-info">
              <span class="pf-player-name">${s?.name || p.name}${isStar ? ' ⭐' : ''}</span>
              <span class="pf-player-role">${p.role || s?.role || 'Player'}${isStar ? ' · Star Player' : ''}</span>
            </div>
            <span class="pf-player-form-badge ${formClass}">${r.formScore}</span>
          </div>
          <div class="pf-player-stats">
            <div class="pf-stat-row">
              <span class="pf-stat-label">Rating</span>
              <div class="pf-stat-bar-wrap">
                <div class="pf-stat-bar" style="width:${ratingPct}%;background:${barColor};"></div>
                <div class="pf-stat-bar--career" style="left:${careerRatingPct}%;"></div>
              </div>
              <span class="pf-stat-val">${r.recentRating.toFixed(2)}</span>
            </div>
            <div class="pf-stat-row">
              <span class="pf-stat-label">ADR</span>
              <div class="pf-stat-bar-wrap">
                <div class="pf-stat-bar" style="width:${adrPct}%;background:${barColor};"></div>
                <div class="pf-stat-bar--career" style="left:${careerAdrPct}%;"></div>
              </div>
              <span class="pf-stat-val">${r.recentAdr.toFixed(1)}</span>
            </div>
            <div class="pf-stat-row">
              <span class="pf-stat-label">KAST</span>
              <div class="pf-stat-bar-wrap">
                <div class="pf-stat-bar" style="width:${kastPct}%;background:${barColor};"></div>
                <div class="pf-stat-bar--career" style="left:${careerKastPct}%;"></div>
              </div>
              <span class="pf-stat-val">${r.recentKast.toFixed(1)}%</span>
            </div>
          </div>
          <div class="pf-player-recent">
            <div class="pf-recent-label">Last ${recent.length} Games</div>
            <div class="pf-recent-games">${sparkline}</div>
          </div>
        </div>
      `;
    }).join('');
  }

  // Auto-load from URL hash
  if (window.location.hash) {
    const slug = window.location.hash.slice(1);
    if (slug) loadTeam(slug);
  }
</script>
</Base>
