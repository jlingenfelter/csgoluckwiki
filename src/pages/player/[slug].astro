---
import Base from '../../layouts/Base.astro';
import ExploreMore from '../../components/ExploreMore.astro';
import { PRO_PLAYERS, getAverageEdpi, amazonSearchUrl, getGearImageUrl, type ProPlayer } from '../../lib/pro-players';
import { breadcrumbSchema, faqSchema } from '../../lib/weapons';
import { getSkinBySlug, RARITY_COLORS } from '../../lib/skins';

export function getStaticPaths() {
  return PRO_PLAYERS.map(p => ({
    params: { slug: p.slug },
    props: { player: p },
  }));
}

const { player } = Astro.props as { player: ProPlayer };
const avgEdpi = getAverageEdpi();
const cm360 = Math.round((2.54 * 360) / (player.edpi * 0.022));

// Find similar players (same role or close eDPI)
const similar = PRO_PLAYERS
  .filter(p => p.slug !== player.slug)
  .map(p => ({ ...p, diff: Math.abs(p.edpi - player.edpi) }))
  .sort((a, b) => {
    if (a.role === player.role && b.role !== player.role) return -1;
    if (b.role === player.role && a.role !== player.role) return 1;
    return a.diff - b.diff;
  })
  .slice(0, 6);

// Teammates — exclude non-team entries like Free Agent, Retired, Inactive, etc.
const NON_TEAMS = ['free agent', 'retired', 'inactive', 'no team', 'none', 'benched', 'n/a', ''];
const isRealTeam = !NON_TEAMS.includes(player.team.toLowerCase().trim());
const teammates = isRealTeam
  ? PRO_PLAYERS.filter(p => p.team === player.team && p.slug !== player.slug)
  : [];

const title = `${player.name} CS2 Settings — Crosshair, Sensitivity, Gear & Config | CSDB.gg`;
const description = `${player.name}${player.realName ? ` (${player.realName})` : ''} CS2 settings: ${player.dpi} DPI, ${player.sens} sensitivity (${player.edpi} eDPI), ${player.res} ${player.stretch}, ${player.mouse}. Full crosshair code, gear, and config.`;

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Pro Players', url: '/pro-players/' },
  { name: `${player.name} Settings`, url: `/player/${player.slug}/` },
];

// Build intro text
const sensDesc = player.edpi < 600 ? 'a low' : player.edpi < 900 ? 'a medium' : 'a high';
const sensComparison = player.edpi < avgEdpi ? `below the pro average of ${avgEdpi}` : player.edpi > avgEdpi ? `above the pro average of ${avgEdpi}` : `right at the pro average of ${avgEdpi}`;
const teamText = isRealTeam ? ` currently playing for ${player.team}` : '';
const introText = `${player.name} is a professional CS2 ${player.role.toLowerCase()}${teamText} from ${player.country}. ${player.name} plays with ${sensDesc} sensitivity setup at ${player.edpi} eDPI (${player.dpi} DPI × ${player.sens} sens), which is ${sensComparison}. ${player.name} uses ${player.res} resolution (${player.aspect} ${player.stretch}) on a ${player.monitor || 'gaming monitor'}, paired with a ${player.mouse || 'gaming mouse'}.`;

// Crosshair color map for preview
const xhairColorMap: Record<string, string> = {
  'Green': '#00ff00', 'Red': '#ff0000', 'Yellow': '#ffff00', 'Blue': '#2020ff',
  'Cyan': '#00ffff', 'White': '#ffffff', 'Pink': '#ff69b4', 'Orange': '#ff8c00',
  'Custom': '#00ff00', '': '#00ff00',
};
const xhairColor = xhairColorMap[player.crosshairColor] || '#00ff00';

// Build autoexec config
const configLines = [
  `// ${player.name}'s CS2 Config — Generated by CSDB.gg`,
  `// https://csdb.gg/player/${player.slug}/`,
  '',
  '// Sensitivity',
  `sensitivity "${player.sens}"`,
  `zoom_sensitivity_ratio_mouse "${player.zoomSens}"`,
  '',
  '// Crosshair',
  `cl_crosshairstyle "4"`,
  `cl_crosshairsize "${player.crosshairSize}"`,
  `cl_crosshairgap "${player.crosshairGap}"`,
  `cl_crosshairthickness "${player.crosshairThickness}"`,
  `cl_crosshairdot "${player.crosshairDot ? 1 : 0}"`,
  `cl_crosshair_drawoutline "${player.crosshairOutline ? 1 : 0}"`,
  '',
  '// Viewmodel',
  `viewmodel_fov "${player.vmFov}"`,
  `viewmodel_offset_x "${player.vmX}"`,
  `viewmodel_offset_y "${player.vmY}"`,
  `viewmodel_offset_z "${player.vmZ}"`,
];

if (player.launchOptions) {
  configLines.push('', `// Launch Options: ${player.launchOptions}`);
}

const configText = configLines.join('\n');

// Console commands one-liner
const allCmds = `sensitivity ${player.sens}; zoom_sensitivity_ratio_mouse ${player.zoomSens}; cl_crosshairstyle 4; cl_crosshairsize ${player.crosshairSize}; cl_crosshairgap ${player.crosshairGap}; cl_crosshairthickness ${player.crosshairThickness}; cl_crosshairdot ${player.crosshairDot ? 1 : 0}; cl_crosshair_drawoutline ${player.crosshairOutline ? 1 : 0}; viewmodel_fov ${player.vmFov}; viewmodel_offset_x ${player.vmX}; viewmodel_offset_y ${player.vmY}; viewmodel_offset_z ${player.vmZ}`;

// Resolve loadout skin slugs to full skin objects
const loadoutSlots = ['knife', 'gloves', 'rifle', 'pistol', 'awp'] as const;
const loadoutLabels: Record<string, string> = { knife: 'Knife', gloves: 'Gloves', rifle: 'Rifle', pistol: 'Pistol', awp: 'AWP' };
const resolvedLoadout = loadoutSlots
  .filter(slot => player.loadout?.[slot])
  .map(slot => {
    const skinSlug = player.loadout![slot]!;
    const skin = getSkinBySlug(skinSlug);
    return {
      slot,
      label: loadoutLabels[slot],
      slug: skinSlug,
      skin,
      name: skin ? `${skin.weapon} | ${skin.name}` : skinSlug.replace(/-/g, ' ').replace(/\b\w/g, c => c.toUpperCase()),
      image: skin?.image || null,
      rarity: skin?.rarity || null,
      rarityColor: skin?.rarityColor || (skin?.rarity ? RARITY_COLORS[skin.rarity] : null),
    };
  });
const hasLoadout = resolvedLoadout.length > 0;

// Check which extended sections have data
const hasVideoSettings = player.videoSettings && Object.keys(player.videoSettings).length > 0;
const hasBobSettings = player.bobSettings && Object.keys(player.bobSettings).length > 0;
const hasRadarSettings = player.radarSettings && Object.keys(player.radarSettings).length > 0;
const hasHudSettings = player.hudSettings && Object.keys(player.hudSettings).length > 0;
const hasMonitorSettings = player.monitorSettings && Object.keys(player.monitorSettings).length > 0;
const hasCrosshairSettings = player.crosshairSettings && Object.keys(player.crosshairSettings).length > 0;

// Sidebar sections
const sections = [
  { id: 'sensitivity', label: 'Mouse & Sensitivity' },
  { id: 'crosshair', label: 'Crosshair' },
  { id: 'video', label: 'Video & Display' },
  { id: 'viewmodel', label: 'Viewmodel' },
];
if (hasRadarSettings || hasHudSettings) sections.push({ id: 'gamehud', label: 'Radar & HUD' });
if (hasMonitorSettings) sections.push({ id: 'monitorsettings', label: 'Monitor Settings' });
sections.push({ id: 'config', label: 'Config & Download' });
sections.push({ id: 'gear', label: 'Gear & Peripherals' });
if (hasLoadout) sections.push({ id: 'loadout', label: 'Weapon Skins' });
if (player.gpu) sections.push({ id: 'pcspecs', label: 'PC Specs' });
if (player.launchOptions) sections.push({ id: 'launch', label: 'Launch Options' });
if (teammates.length > 0) sections.push({ id: 'teammates', label: 'Teammates' });
sections.push({ id: 'similar', label: 'Similar Players' });
sections.push({ id: 'faq', label: 'FAQ' });

const faqs = [
  { question: `What sensitivity does ${player.name} use in CS2?`, answer: `${player.name} uses ${player.dpi} DPI with ${player.sens} in-game sensitivity, resulting in ${player.edpi} eDPI. This translates to approximately ${cm360} cm per 360-degree turn. ${player.edpi < avgEdpi ? `This is below the pro average of ${avgEdpi} eDPI, suggesting a preference for precision over speed.` : player.edpi > avgEdpi ? `This is above the pro average of ${avgEdpi} eDPI, suggesting a preference for faster target acquisition.` : `This is right at the pro average of ${avgEdpi} eDPI.`}` },
  { question: `What mouse does ${player.name} use?`, answer: `${player.name} currently uses the ${player.mouse} at ${player.dpi} DPI with a ${player.pollingRate}Hz polling rate, paired with a ${player.mousepad} mousepad.` },
  { question: `What resolution does ${player.name} play on?`, answer: `${player.name} plays on ${player.res} (${player.aspect}) with ${player.stretch} display mode at ${player.refreshRate}Hz on a ${player.monitor}.` },
  { question: `What is ${player.name}'s crosshair code?`, answer: player.crosshairCode ? `${player.name}'s crosshair code is ${player.crosshairCode}. To apply it, open CS2, go to Settings → Crosshair → Share or Import, and paste the code.` : `${player.name}'s crosshair code is not currently available. Check back later as we regularly update player settings.` },
];
---

<Base {title} {description} currentNav="/pro-players/" ogImage={player.image || undefined}>
<Fragment slot="head">
<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema(breadcrumbs))} />
<script type="application/ld+json" set:html={JSON.stringify(faqSchema(faqs))} />
<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Person",
  "name": player.realName || player.name,
  "alternateName": player.name,
  "url": `https://csdb.gg/player/${player.slug}/`,
  ...(player.image ? { "image": player.image } : {}),
  "jobTitle": `Professional CS2 ${player.role}`,
  ...(isRealTeam ? { "memberOf": { "@type": "SportsTeam", "name": player.team } } : {}),
  ...(player.country && player.country !== 'Unknown' ? { "nationality": player.country } : {}),
  ...(player.birthday ? { "birthDate": (() => { try { return new Date(player.birthday).toISOString().split('T')[0]; } catch { return undefined; } })() } : {}),
  "knowsAbout": "Counter-Strike 2",
})} />
</Fragment>

<nav class="breadcrumb"><a href="/">Home</a> <span>/</span> <a href="/pro-players/">Pro Players</a> <span>/</span> <span>{player.name}</span></nav>

<!-- Player Hero -->
<section class="pl-hero">
  <div class="pl-hero-top">
    <div class="pl-hero-info">
      {player.image && <img class="pl-avatar" src={player.image} alt={player.name} width="80" height="80" loading="eager" onerror="this.style.display='none'" />}
      <h1>{player.flag} {player.name}</h1>
      <p class="pl-realname">{player.realName}</p>
      <div class="pl-meta">
        <span class="pl-team">{player.team}</span>
        <span class="pp-role" data-r={player.role.toLowerCase().replace(/\s/g,'-')}>{player.role}</span>
        <span class="pl-country">{player.country}</span>
        {player.age && <span class="pl-age">Age {player.age}</span>}
      </div>
    </div>
    <div class="pl-hero-quickstats">
      <div class="pl-qs"><span class="pl-qv">{player.edpi}</span><span class="pl-ql">eDPI</span></div>
      <div class="pl-qs"><span class="pl-qv">{player.res}</span><span class="pl-ql">{player.aspect} {player.stretch}</span></div>
      <div class="pl-qs"><span class="pl-qv">{cm360}cm</span><span class="pl-ql">cm/360°</span></div>
      <div class="pl-qs"><span class="pl-qv">{player.refreshRate}Hz</span><span class="pl-ql">Refresh Rate</span></div>
    </div>
  </div>
</section>

<!-- Intro Text -->
<section class="pl-intro">
  <p>{introText}</p>
  {player.bio && <p class="pl-bio-text">{player.bio}</p>}
</section>

<!-- Main Content with Sidebar -->
<div class="pl-layout">

  <!-- Sticky Sidebar Navigation -->
  <aside class="pl-sidebar" id="plSidebar">
    <nav class="pl-sidebar-nav">
      <span class="pl-sidebar-title">Jump to</span>
      {sections.map(s => (
        <a href={`#${s.id}`} class="pl-sidebar-link" data-section={s.id}>{s.label}</a>
      ))}
    </nav>
  </aside>

  <!-- Main Content Column -->
  <div class="pl-content">

    <!-- Mouse & Sensitivity -->
    <section class="pl-section" id="sensitivity">
      <h2>Mouse & Sensitivity Settings</h2>
      <div class="pl-grid-2">
        <div class="pl-detail-card">
          <h3>Sensitivity</h3>
          <div class="pl-detail-grid">
            <div class="pl-di"><span class="pl-dk">DPI</span><span class="pl-dv">{player.dpi}</span></div>
            <div class="pl-di"><span class="pl-dk">In-Game Sensitivity</span><span class="pl-dv">{player.sens}</span></div>
            <div class="pl-di pl-highlight"><span class="pl-dk">eDPI</span><span class="pl-dv">{player.edpi}</span></div>
            <div class="pl-di"><span class="pl-dk">Zoom Sensitivity</span><span class="pl-dv">{player.zoomSens}</span></div>
            <div class="pl-di"><span class="pl-dk">Polling Rate</span><span class="pl-dv">{player.pollingRate}Hz</span></div>
            <div class="pl-di"><span class="pl-dk">cm/360°</span><span class="pl-dv">{cm360}cm</span></div>
          </div>
          <div class="pl-edpi-meter">
            <div class="pl-edpi-track">
              <div class="pl-edpi-marker" style={`left:${Math.min(100, Math.max(0, ((player.edpi - 400) / (1700 - 400)) * 100))}%`}>
                <span>{player.edpi}</span>
              </div>
              <div class="pl-edpi-avg" style={`left:${((avgEdpi - 400) / (1700 - 400)) * 100}%`}>
                <span>Avg {avgEdpi}</span>
              </div>
            </div>
            <div class="pl-edpi-labels">
              <span>Low</span><span>Medium</span><span>High</span>
            </div>
          </div>
        </div>
        <div class="pl-detail-card">
          <h3>Mouse & Mousepad</h3>
          <div class="pl-detail-grid">
            <div class="pl-di"><span class="pl-dk">Mouse</span><span class="pl-dv">{player.mouse}</span></div>
            <div class="pl-di"><span class="pl-dk">Mousepad</span><span class="pl-dv">{player.mousepad}</span></div>
          </div>
        </div>
      </div>
    </section>

    <!-- Crosshair Settings -->
    <section class="pl-section" id="crosshair">
      <h2>Crosshair Settings</h2>
      <div class="pl-detail-card">
        <!-- Crosshair Visual Preview -->
        <div class="pl-xhair-preview-wrap">
          <div class="pl-xhair-preview" id="xhairPreview">
            <div class="pl-xhair-crosshair" id="xhairRender"></div>
            <span class="pl-xhair-label">{player.name}'s Crosshair</span>
          </div>
          <a href="/crosshair-generator/" class="pl-xhair-try">Try in Crosshair Generator →</a>
        </div>

        <div class="pl-crosshair-code">
          <code id="xhairCode">{player.crosshairCode || 'Not available'}</code>
          {player.crosshairCode && <button class="pl-copy-btn" id="copyXhair">Copy Crosshair Code</button>}
        </div>
        <div class="pl-detail-grid pl-grid-3col">
          <div class="pl-di"><span class="pl-dk">Style</span><span class="pl-dv">{hasCrosshairSettings ? player.crosshairSettings!.style || player.crosshairStyle : player.crosshairStyle}</span></div>
          <div class="pl-di"><span class="pl-dk">Color</span><span class="pl-dv">{hasCrosshairSettings ? player.crosshairSettings!.color || player.crosshairColor || 'N/A' : player.crosshairColor || 'N/A'}</span></div>
          <div class="pl-di"><span class="pl-dk">Size</span><span class="pl-dv">{hasCrosshairSettings ? player.crosshairSettings!.size || player.crosshairSize : player.crosshairSize}</span></div>
          <div class="pl-di"><span class="pl-dk">Thickness</span><span class="pl-dv">{hasCrosshairSettings ? player.crosshairSettings!.thickness || player.crosshairThickness : player.crosshairThickness}</span></div>
          <div class="pl-di"><span class="pl-dk">Gap</span><span class="pl-dv">{hasCrosshairSettings ? player.crosshairSettings!.gap ?? player.crosshairGap : player.crosshairGap}</span></div>
          <div class="pl-di"><span class="pl-dk">Dot</span><span class="pl-dv">{hasCrosshairSettings ? player.crosshairSettings!.dot || (player.crosshairDot ? 'Yes' : 'No') : (player.crosshairDot ? 'Yes' : 'No')}</span></div>
          <div class="pl-di"><span class="pl-dk">Outline</span><span class="pl-dv">{hasCrosshairSettings ? player.crosshairSettings!.outline || (player.crosshairOutline ? 'Yes' : 'No') : (player.crosshairOutline ? 'Yes' : 'No')}</span></div>
        </div>
        {hasCrosshairSettings && (
        <details class="pl-advanced-toggle">
          <summary>Advanced Crosshair Settings</summary>
          <div class="pl-detail-grid pl-grid-3col">
            {player.crosshairSettings!.followRecoil && <div class="pl-di"><span class="pl-dk">Follow Recoil</span><span class="pl-dv">{player.crosshairSettings!.followRecoil}</span></div>}
            {player.crosshairSettings!.tStyle && <div class="pl-di"><span class="pl-dk">T-Style</span><span class="pl-dv">{player.crosshairSettings!.tStyle}</span></div>}
            {player.crosshairSettings!.red !== undefined && <div class="pl-di"><span class="pl-dk">Red</span><span class="pl-dv">{player.crosshairSettings!.red}</span></div>}
            {player.crosshairSettings!.green !== undefined && <div class="pl-di"><span class="pl-dk">Green</span><span class="pl-dv">{player.crosshairSettings!.green}</span></div>}
            {player.crosshairSettings!.blue !== undefined && <div class="pl-di"><span class="pl-dk">Blue</span><span class="pl-dv">{player.crosshairSettings!.blue}</span></div>}
            {player.crosshairSettings!.useAlpha && <div class="pl-di"><span class="pl-dk">Use Alpha</span><span class="pl-dv">{player.crosshairSettings!.useAlpha}</span></div>}
            {player.crosshairSettings!.alphaValue && <div class="pl-di"><span class="pl-dk">Alpha</span><span class="pl-dv">{player.crosshairSettings!.alphaValue}</span></div>}
            {player.crosshairSettings!.outlineThickness && <div class="pl-di"><span class="pl-dk">Outline Thickness</span><span class="pl-dv">{player.crosshairSettings!.outlineThickness}</span></div>}
            {player.crosshairSettings!.deployedWeaponGap && <div class="pl-di"><span class="pl-dk">Deployed Weapon Gap</span><span class="pl-dv">{player.crosshairSettings!.deployedWeaponGap}</span></div>}
            {player.crosshairSettings!.splitDistance && <div class="pl-di"><span class="pl-dk">Split Distance</span><span class="pl-dv">{player.crosshairSettings!.splitDistance}</span></div>}
            {player.crosshairSettings!.fixedGap && <div class="pl-di"><span class="pl-dk">Fixed Gap</span><span class="pl-dv">{player.crosshairSettings!.fixedGap}</span></div>}
            {player.crosshairSettings!.innerSplitAlpha && <div class="pl-di"><span class="pl-dk">Inner Split Alpha</span><span class="pl-dv">{player.crosshairSettings!.innerSplitAlpha}</span></div>}
            {player.crosshairSettings!.outerSplitAlpha && <div class="pl-di"><span class="pl-dk">Outer Split Alpha</span><span class="pl-dv">{player.crosshairSettings!.outerSplitAlpha}</span></div>}
            {player.crosshairSettings!.splitSizeRatio && <div class="pl-di"><span class="pl-dk">Split Size Ratio</span><span class="pl-dv">{player.crosshairSettings!.splitSizeRatio}</span></div>}
            {player.crosshairSettings!.sniperWidth && <div class="pl-di"><span class="pl-dk">Sniper Width</span><span class="pl-dv">{player.crosshairSettings!.sniperWidth}</span></div>}
          </div>
        </details>
        )}
      </div>
    </section>

    <!-- Video Settings -->
    <section class="pl-section" id="video">
      <h2>Video & Display Settings</h2>
      <div class="pl-detail-card">
        <h3>Display</h3>
        <div class="pl-detail-grid pl-grid-3col">
          <div class="pl-di pl-highlight"><span class="pl-dk">Resolution</span><span class="pl-dv">{player.res}</span></div>
          <div class="pl-di"><span class="pl-dk">Aspect Ratio</span><span class="pl-dv">{player.aspect}</span></div>
          <div class="pl-di"><span class="pl-dk">Scaling Mode</span><span class="pl-dv">{player.stretch}</span></div>
          <div class="pl-di"><span class="pl-dk">Refresh Rate</span><span class="pl-dv">{player.refreshRate}Hz</span></div>
          <div class="pl-di"><span class="pl-dk">Monitor</span><span class="pl-dv">{player.monitor}</span></div>
          {player.videoSettings?.displayMode && <div class="pl-di"><span class="pl-dk">Display Mode</span><span class="pl-dv">{player.videoSettings.displayMode}</span></div>}
          {player.videoSettings?.brightness && <div class="pl-di"><span class="pl-dk">Brightness</span><span class="pl-dv">{player.videoSettings.brightness}</span></div>}
          {player.videoSettings?.boostPlayerContrast && <div class="pl-di"><span class="pl-dk">Boost Player Contrast</span><span class="pl-dv">{player.videoSettings.boostPlayerContrast}</span></div>}
          {player.videoSettings?.vsync && <div class="pl-di"><span class="pl-dk">V-Sync</span><span class="pl-dv">{player.videoSettings.vsync}</span></div>}
          {player.videoSettings?.nvidiaReflex && <div class="pl-di"><span class="pl-dk">NVIDIA Reflex</span><span class="pl-dv">{player.videoSettings.nvidiaReflex}</span></div>}
          {player.videoSettings?.nvidiaGSync && <div class="pl-di"><span class="pl-dk">NVIDIA G-Sync</span><span class="pl-dv">{player.videoSettings.nvidiaGSync}</span></div>}
          {player.videoSettings?.maxFPS && <div class="pl-di"><span class="pl-dk">Max FPS</span><span class="pl-dv">{player.videoSettings.maxFPS}</span></div>}
        </div>
        {hasVideoSettings && (
        <>
        <h3 style="margin-top:1.25rem">Advanced Video</h3>
        <div class="pl-detail-grid pl-grid-3col">
          {player.videoSettings!.msaa && <div class="pl-di"><span class="pl-dk">Anti-Aliasing</span><span class="pl-dv">{player.videoSettings!.msaa}</span></div>}
          {player.videoSettings!.globalShadowQuality && <div class="pl-di"><span class="pl-dk">Shadow Quality</span><span class="pl-dv">{player.videoSettings!.globalShadowQuality}</span></div>}
          {player.videoSettings!.dynamicShadows && <div class="pl-di"><span class="pl-dk">Dynamic Shadows</span><span class="pl-dv">{player.videoSettings!.dynamicShadows}</span></div>}
          {player.videoSettings!.modelTextureDetail && <div class="pl-di"><span class="pl-dk">Texture Detail</span><span class="pl-dv">{player.videoSettings!.modelTextureDetail}</span></div>}
          {player.videoSettings!.textureFilteringMode && <div class="pl-di"><span class="pl-dk">Texture Filtering</span><span class="pl-dv">{player.videoSettings!.textureFilteringMode}</span></div>}
          {player.videoSettings!.shaderDetail && <div class="pl-di"><span class="pl-dk">Shader Detail</span><span class="pl-dv">{player.videoSettings!.shaderDetail}</span></div>}
          {player.videoSettings!.particleDetail && <div class="pl-di"><span class="pl-dk">Particle Detail</span><span class="pl-dv">{player.videoSettings!.particleDetail}</span></div>}
          {player.videoSettings!.ambientOcclusion && <div class="pl-di"><span class="pl-dk">Ambient Occlusion</span><span class="pl-dv">{player.videoSettings!.ambientOcclusion}</span></div>}
          {player.videoSettings!.hdr && <div class="pl-di"><span class="pl-dk">HDR</span><span class="pl-dv">{player.videoSettings!.hdr}</span></div>}
          {player.videoSettings!.fidelityFX && <div class="pl-di"><span class="pl-dk">FidelityFX</span><span class="pl-dv">{player.videoSettings!.fidelityFX}</span></div>}
        </div>
        </>
        )}
      </div>
    </section>

    <!-- Viewmodel Settings -->
    <section class="pl-section" id="viewmodel">
      <h2>Viewmodel{hasBobSettings ? ' & Bob' : ''} Settings</h2>
      <div class="pl-detail-card">
        <h3>Viewmodel</h3>
        <div class="pl-detail-grid pl-grid-3col">
          <div class="pl-di"><span class="pl-dk">viewmodel_fov</span><span class="pl-dv">{player.vmFov}</span></div>
          <div class="pl-di"><span class="pl-dk">viewmodel_offset_x</span><span class="pl-dv">{player.vmX}</span></div>
          <div class="pl-di"><span class="pl-dk">viewmodel_offset_y</span><span class="pl-dv">{player.vmY}</span></div>
          <div class="pl-di"><span class="pl-dk">viewmodel_offset_z</span><span class="pl-dv">{player.vmZ}</span></div>
          {player.vmPresetpos && <div class="pl-di"><span class="pl-dk">viewmodel_presetpos</span><span class="pl-dv">{player.vmPresetpos}</span></div>}
        </div>
        <div class="pl-console-cmds">
          <h4>Console Commands</h4>
          <code id="vmCmds">viewmodel_fov {player.vmFov}; viewmodel_offset_x {player.vmX}; viewmodel_offset_y {player.vmY}; viewmodel_offset_z {player.vmZ}</code>
          <button class="pl-copy-btn pl-copy-sm" id="copyVm">Copy</button>
        </div>
        {hasBobSettings && (
        <>
        <h3 style="margin-top:1.25rem">Weapon Bob</h3>
        <div class="pl-detail-grid pl-grid-3col">
          {player.bobSettings!.lowerAmt && <div class="pl-di"><span class="pl-dk">cl_bob_lower_amt</span><span class="pl-dv">{player.bobSettings!.lowerAmt}</span></div>}
          {player.bobSettings!.amtLat && <div class="pl-di"><span class="pl-dk">cl_bobamt_lat</span><span class="pl-dv">{player.bobSettings!.amtLat}</span></div>}
          {player.bobSettings!.amtVert && <div class="pl-di"><span class="pl-dk">cl_bobamt_vert</span><span class="pl-dv">{player.bobSettings!.amtVert}</span></div>}
          {player.bobSettings!.cycle && <div class="pl-di"><span class="pl-dk">cl_bobcycle</span><span class="pl-dv">{player.bobSettings!.cycle}</span></div>}
        </div>
        </>
        )}
      </div>
    </section>

    <!-- Radar & HUD -->
    {(hasRadarSettings || hasHudSettings) && (
    <section class="pl-section" id="gamehud">
      <h2>Radar & HUD Settings</h2>
      <div class="pl-detail-card">
        {hasRadarSettings && (
        <>
        <h3>Radar</h3>
        <div class="pl-detail-grid pl-grid-3col">
          {player.radarSettings!.centersPlayer && <div class="pl-di"><span class="pl-dk">Centers Player</span><span class="pl-dv">{player.radarSettings!.centersPlayer}</span></div>}
          {player.radarSettings!.rotating && <div class="pl-di"><span class="pl-dk">Rotating</span><span class="pl-dv">{player.radarSettings!.rotating}</span></div>}
          {player.radarSettings!.toggleShape && <div class="pl-di"><span class="pl-dk">Toggle Shape</span><span class="pl-dv">{player.radarSettings!.toggleShape}</span></div>}
          {player.radarSettings!.hudSize && <div class="pl-di"><span class="pl-dk">Radar HUD Size</span><span class="pl-dv">{player.radarSettings!.hudSize}</span></div>}
          {player.radarSettings!.mapZoom && <div class="pl-di"><span class="pl-dk">Radar Map Zoom</span><span class="pl-dv">{player.radarSettings!.mapZoom}</span></div>}
        </div>
        </>
        )}
        {hasHudSettings && (
        <>
        <h3 style={hasRadarSettings ? "margin-top:1.25rem" : ""}>HUD</h3>
        <div class="pl-detail-grid pl-grid-3col">
          {player.hudSettings!.scale && <div class="pl-di"><span class="pl-dk">HUD Scale</span><span class="pl-dv">{player.hudSettings!.scale}</span></div>}
          {player.hudSettings!.color && <div class="pl-di"><span class="pl-dk">HUD Color</span><span class="pl-dv">{player.hudSettings!.color}</span></div>}
        </div>
        </>
        )}
      </div>
    </section>
    )}

    <!-- Monitor Settings -->
    {hasMonitorSettings && (
    <section class="pl-section" id="monitorsettings">
      <h2>Monitor Settings</h2>
      <div class="pl-detail-card">
        <div class="pl-detail-grid pl-grid-3col">
          {player.monitorSettings!.dyac && <div class="pl-di"><span class="pl-dk">DyAc</span><span class="pl-dv">{player.monitorSettings!.dyac}</span></div>}
          {player.monitorSettings!.blackEqualizer && <div class="pl-di"><span class="pl-dk">Black eQualizer</span><span class="pl-dv">{player.monitorSettings!.blackEqualizer}</span></div>}
          {player.monitorSettings!.colorVibrance && <div class="pl-di"><span class="pl-dk">Color Vibrance</span><span class="pl-dv">{player.monitorSettings!.colorVibrance}</span></div>}
          {player.monitorSettings!.lowBlueLight && <div class="pl-di"><span class="pl-dk">Low Blue Light</span><span class="pl-dv">{player.monitorSettings!.lowBlueLight}</span></div>}
          {player.monitorSettings!.pictureMode && <div class="pl-di"><span class="pl-dk">Picture Mode</span><span class="pl-dv">{player.monitorSettings!.pictureMode}</span></div>}
          {player.monitorSettings!.contrast && <div class="pl-di"><span class="pl-dk">Contrast</span><span class="pl-dv">{player.monitorSettings!.contrast}</span></div>}
          {player.monitorSettings!.sharpness && <div class="pl-di"><span class="pl-dk">Sharpness</span><span class="pl-dv">{player.monitorSettings!.sharpness}</span></div>}
          {player.monitorSettings!.gamma && <div class="pl-di"><span class="pl-dk">Gamma</span><span class="pl-dv">{player.monitorSettings!.gamma}</span></div>}
          {player.monitorSettings!.colorTemperature && <div class="pl-di"><span class="pl-dk">Color Temperature</span><span class="pl-dv">{player.monitorSettings!.colorTemperature}</span></div>}
          {player.monitorSettings!.ama && <div class="pl-di"><span class="pl-dk">AMA</span><span class="pl-dv">{player.monitorSettings!.ama}</span></div>}
        </div>
      </div>
    </section>
    )}

    <!-- Config Download & Copy All -->
    <section class="pl-section" id="config">
      <h2>Config & Download</h2>
      <div class="pl-detail-card">
        <p class="pl-config-desc">Download {player.name}'s complete CS2 config as an autoexec file, or copy all console commands at once.</p>
        <div class="pl-config-actions">
          <button class="pl-config-btn pl-config-download" id="downloadConfig">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            Download autoexec.cfg
          </button>
          <button class="pl-config-btn pl-config-copy" id="copyAllCmds">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
            Copy All Console Commands
          </button>
        </div>
        <div class="pl-config-preview">
          <div class="pl-config-header">
            <span>autoexec.cfg preview</span>
            <button class="pl-copy-btn pl-copy-sm" id="copyConfig">Copy</button>
          </div>
          <pre id="configPreview">{configText}</pre>
        </div>
      </div>
    </section>

    <!-- Full Gear Setup -->
    <section class="pl-section" id="gear">
      <h2>Full Gear & Peripherals</h2>
      <div class="pl-gear-grid">
        {[
          { key: 'mouse' as const, icon: '🖱️', label: 'Mouse', value: player.mouse },
          { key: 'monitor' as const, icon: '🖥️', label: 'Monitor', value: player.monitor },
          { key: 'keyboard' as const, icon: '⌨️', label: 'Keyboard', value: player.keyboard },
          { key: 'headset' as const, icon: '🎧', label: 'Headset', value: player.headset },
          { key: 'mousepad' as const, icon: '🎯', label: 'Mousepad', value: player.mousepad },
        ].map(g => (
          <div class="pl-gear-item">
            {getGearImageUrl(g.value) ? (
              <img class="pl-gear-img" src={getGearImageUrl(g.value)} alt={g.value} width="48" height="48" loading="lazy" onerror="this.style.display='none';this.nextElementSibling.style.display=''" />
              <span class="pl-gear-icon" style="display:none">{g.icon}</span>
            ) : (
              <span class="pl-gear-icon">{g.icon}</span>
            )}
            <div>
              <span class="pl-gear-label">{g.label}</span>
              <a href={amazonSearchUrl(g.value)} target="_blank" rel="nofollow noopener" class="pl-gear-value pl-gear-link">{g.value}</a>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Weapon Skins / Loadout -->
    {hasLoadout && (
    <section class="pl-section" id="loadout">
      <h2>{player.name}'s Weapon Skins</h2>
      <div class="pl-loadout-grid">
        {resolvedLoadout.map(item => (
          <a href={item.skin ? `/skin/${item.slug}/` : '#'} class={`pl-loadout-card${item.skin ? '' : ' pl-loadout-nolink'}`} style={item.rarityColor ? `border-color:${item.rarityColor}` : ''}>
            {item.image ? (
              <img class="pl-loadout-img" src={item.image} alt={item.name} width="160" height="120" loading="lazy" onerror="this.style.display='none'" />
            ) : (
              <div class="pl-loadout-placeholder">
                <span>{item.label}</span>
              </div>
            )}
            <div class="pl-loadout-info">
              <span class="pl-loadout-slot">{item.label}</span>
              <span class="pl-loadout-name">{item.name}</span>
              {item.rarity && <span class="pl-loadout-rarity" style={`color:${item.rarityColor}`}>{item.rarity}</span>}
            </div>
          </a>
        ))}
      </div>
    </section>
    )}

    <!-- PC Specs (GPU) -->
    {player.gpu && (
    <section class="pl-section" id="pcspecs">
      <h2>PC Specs</h2>
      <div class="pl-detail-card">
        <div class="pl-gear-grid">
          <div class="pl-gear-item">
            <span class="pl-gear-icon">🎮</span>
            <div>
              <span class="pl-gear-label">GPU</span>
              <span class="pl-gear-value">{player.gpu}</span>
            </div>
          </div>
        </div>
      </div>
    </section>
    )}

    <!-- Launch Options -->
    {player.launchOptions && (
    <section class="pl-section" id="launch">
      <h2>Launch Options</h2>
      <div class="pl-detail-card">
        <div class="pl-console-cmds">
          <code id="launchOpts">{player.launchOptions}</code>
          <button class="pl-copy-btn pl-copy-sm" id="copyLaunch">Copy</button>
        </div>
      </div>
    </section>
    )}

    <!-- Teammates -->
    {teammates.length > 0 && (
    <section class="pl-section" id="teammates">
      <h2>{player.team} Teammates</h2>
      <div class="pl-related-grid">
        {teammates.map(t => (
          <a href={`/player/${t.slug}/`} class="pl-related-card">
            <div class="pl-rc-top">
              {t.image && <img class="pl-rc-img" src={t.image} alt={t.name} width="36" height="36" loading="lazy" onerror="this.style.display='none'" />}
              <div class="pl-rc-name">{t.flag} {t.name}</div>
            </div>
            <div class="pl-rc-meta">
              <span class="pp-role pp-role-sm" data-r={t.role.toLowerCase().replace(/\s/g,'-')}>{t.role}</span>
              <span>{t.edpi} eDPI</span>
            </div>
          </a>
        ))}
      </div>
    </section>
    )}

    <!-- Similar Players -->
    <section class="pl-section" id="similar">
      <h2>Players With Similar Settings</h2>
      <div class="pl-related-grid">
        {similar.map(s => (
          <a href={`/player/${s.slug}/`} class="pl-related-card">
            <div class="pl-rc-top">
              {s.image && <img class="pl-rc-img" src={s.image} alt={s.name} width="36" height="36" loading="lazy" onerror="this.style.display='none'" />}
              <div class="pl-rc-name">{s.flag} {s.name}</div>
            </div>
            <div class="pl-rc-meta">
              <span class="pp-role pp-role-sm" data-r={s.role.toLowerCase().replace(/\s/g,'-')}>{s.role}</span>
              <span>{s.team}</span>
              <span>{s.edpi} eDPI</span>
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- FAQ -->
    <section class="pl-section" id="faq">
      <h2>Frequently Asked Questions</h2>
      <dl class="faq">
        {faqs.map(f => (
          <>
            <dt>{f.question}</dt>
            <dd>{f.answer}</dd>
          </>
        ))}
      </dl>
    </section>

    <!-- Internal Links -->
    <div class="internal-links">
      <strong>Related:</strong>
      <a href="/pro-players/">All Pro Settings</a>
      <a href="/crosshair-codes/">Crosshair Codes</a>
      <a href="/crosshair-generator/">Crosshair Generator</a>
      <a href="/sensitivity-converter/">Sensitivity Converter</a>
      <a href="/edpi-calculator/">eDPI Calculator</a>
      <a href="/cm360-calculator/">cm/360 Calculator</a>
      <a href="/resolution-calculator/">Resolution Calculator</a>
      <a href="/loadout-builder/">Loadout Builder</a>
      <a href="/autoexec-generator/">Autoexec Generator</a>
      <a href="/bind-generator/">Bind Generator</a>
      <a href="/weapons/">Weapon Database</a>
      <a href="/tools/">All Tools</a>
    </div>

  </div><!-- /pl-content -->
</div><!-- /pl-layout -->

<ExploreMore context="general" />

</Base>

<style>
/* ── Hero ──────────────────────────────────────────────────────────────────── */
.pl-hero{background:linear-gradient(135deg,var(--bg2),var(--bg3));border:1px solid var(--border);border-radius:12px;padding:2rem;margin-bottom:2rem}
.pl-hero-top{display:flex;gap:2rem;align-items:flex-start}
.pl-hero-info{flex:1}
.pl-avatar{width:80px;height:80px;border-radius:50%;object-fit:cover;border:3px solid var(--accent);float:left;margin-right:1.25rem;margin-bottom:.5rem;background:var(--bg3)}
.pl-hero-info h1{font-size:2.4rem;margin:0 0 .3rem}
.pl-intro{background:var(--bg2);border:1px solid var(--border);border-radius:10px;padding:1.25rem 1.5rem;margin-bottom:2rem;line-height:1.7}
.pl-intro p{color:var(--text2);font-size:.95rem;margin:0}
.pl-intro .pl-bio-text{margin-top:.75rem;color:var(--text);font-style:italic;border-left:3px solid var(--accent);padding-left:1rem}
.pl-realname{color:var(--text2);font-size:1rem;margin:0 0 .75rem}
.pl-meta{display:flex;gap:.6rem;flex-wrap:wrap;align-items:center;margin-bottom:1rem}
.pl-team{color:var(--accent);font-weight:700;font-size:.95rem}
.pl-country,.pl-age{color:var(--text2);font-size:.85rem}
.pl-hero-quickstats{display:grid;grid-template-columns:1fr 1fr;gap:.75rem;min-width:240px}
.pl-qs{background:var(--bg);border:1px solid var(--border);border-radius:8px;padding:.75rem 1rem;text-align:center}
.pl-qv{display:block;font-size:1.3rem;font-weight:800;color:var(--accent)}
.pl-ql{display:block;font-size:.7rem;color:var(--text2);margin-top:.15rem;text-transform:uppercase}

/* ── Layout (Sidebar + Content) ────────────────────────────────────────────── */
.pl-layout{display:flex;gap:2rem;align-items:flex-start;position:relative}
.pl-content{flex:1;min-width:0}

/* ── Sticky Sidebar ────────────────────────────────────────────────────────── */
.pl-sidebar{width:200px;flex-shrink:0;position:sticky;top:80px;align-self:flex-start}
.pl-sidebar-nav{background:var(--bg2);border:1px solid var(--border);border-radius:10px;padding:1rem;display:flex;flex-direction:column;gap:.25rem}
.pl-sidebar-title{font-size:.7rem;text-transform:uppercase;font-weight:700;color:var(--text2);letter-spacing:.05em;margin-bottom:.5rem;padding-bottom:.5rem;border-bottom:1px solid var(--border)}
.pl-sidebar-link{color:var(--text2);text-decoration:none;font-size:.82rem;padding:.35rem .6rem;border-radius:5px;border-left:2px solid transparent;transition:all .15s}
.pl-sidebar-link:hover{color:var(--text);background:var(--bg3)}
.pl-sidebar-link.active{color:var(--accent);border-left-color:var(--accent);background:rgba(212,149,110,.08);font-weight:600}

/* ── Sections ──────────────────────────────────────────────────────────────── */
.pl-section{margin-bottom:2.5rem;scroll-margin-top:70px}
.pl-section h2{font-size:1.3rem;margin:0 0 1rem;color:var(--text);font-weight:700}

/* ── Detail Cards ──────────────────────────────────────────────────────────── */
.pl-detail-card{background:var(--bg2);border:1px solid var(--border);border-radius:10px;padding:1.5rem}
.pl-detail-card h3{margin:0 0 1rem;font-size:1.05rem;color:var(--text)}
.pl-grid-2{display:grid;grid-template-columns:1fr 1fr;gap:1.25rem}
.pl-detail-grid{display:grid;grid-template-columns:1fr 1fr;gap:.5rem}
.pl-grid-3col .pl-detail-grid,.pl-detail-grid.pl-grid-3col{grid-template-columns:repeat(auto-fill,minmax(180px,1fr))}
.pl-di{display:flex;justify-content:space-between;align-items:center;padding:.6rem .8rem;background:var(--bg);border:1px solid var(--border);border-radius:6px}
.pl-di.pl-highlight{border-color:var(--accent);background:rgba(212,149,110,.08)}
.pl-dk{color:var(--text2);font-size:.85rem;font-weight:600}
.pl-dv{color:var(--text);font-weight:700;font-size:.95rem}
.pl-highlight .pl-dv{color:var(--accent)}

/* ── Advanced Toggle (collapsible details) ────────────────────────────────── */
.pl-advanced-toggle{margin-top:1rem;border-top:1px solid var(--border);padding-top:1rem}
.pl-advanced-toggle summary{cursor:pointer;color:var(--accent);font-size:.88rem;font-weight:600;padding:.4rem 0;user-select:none}
.pl-advanced-toggle summary:hover{text-decoration:underline}
.pl-advanced-toggle[open] summary{margin-bottom:.75rem}

/* ── Crosshair Preview ────────────────────────────────────────────────────── */
.pl-xhair-preview-wrap{margin-bottom:1.25rem}
.pl-xhair-preview{width:100%;max-width:400px;height:200px;background:linear-gradient(135deg,#2a2a2a 0%,#1a1a1a 50%,#2a2a2a 100%);border-radius:8px;position:relative;overflow:hidden;border:1px solid var(--border);margin-bottom:.5rem}
.pl-xhair-preview::before{content:'';position:absolute;inset:0;background:radial-gradient(circle at center,transparent 0%,rgba(0,0,0,.4) 100%)}
.pl-xhair-crosshair{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);z-index:1}
.pl-xhair-label{position:absolute;bottom:.5rem;left:.75rem;font-size:.7rem;color:rgba(255,255,255,.4);z-index:1}
.pl-xhair-try{font-size:.82rem;color:var(--accent);text-decoration:none;font-weight:600}
.pl-xhair-try:hover{text-decoration:underline}

/* ── Crosshair Code ────────────────────────────────────────────────────────── */
.pl-crosshair-code{display:flex;gap:.75rem;align-items:center;background:var(--bg);border:1px solid var(--border);border-radius:8px;padding:.75rem 1rem;margin-bottom:1.25rem}
.pl-crosshair-code code{flex:1;font-size:.85rem;color:var(--accent);word-break:break-all}
.pl-copy-btn{background:var(--accent);color:#000;border:none;padding:.5rem 1rem;border-radius:6px;font-weight:700;font-size:.85rem;cursor:pointer;white-space:nowrap;font-family:inherit;transition:opacity .2s}
.pl-copy-btn:hover{opacity:.85}
.pl-copy-btn.copied{background:var(--green);color:#fff}
.pl-copy-sm{padding:.35rem .75rem;font-size:.8rem}

/* ── Console Commands ──────────────────────────────────────────────────────── */
.pl-console-cmds{display:flex;gap:.75rem;align-items:center;background:var(--bg);border:1px solid var(--border);border-radius:6px;padding:.5rem .75rem;margin-top:1rem}
.pl-console-cmds h4{display:none}
.pl-console-cmds code{flex:1;font-size:.82rem;color:var(--text);word-break:break-all}

/* ── Config Download ──────────────────────────────────────────────────────── */
.pl-config-desc{color:var(--text2);font-size:.9rem;margin:0 0 1.25rem}
.pl-config-actions{display:flex;gap:.75rem;flex-wrap:wrap;margin-bottom:1.25rem}
.pl-config-btn{display:inline-flex;align-items:center;gap:.5rem;padding:.65rem 1.25rem;border:none;border-radius:8px;font-size:.9rem;font-weight:700;cursor:pointer;font-family:inherit;transition:opacity .2s,transform .2s}
.pl-config-btn:hover{opacity:.9;transform:translateY(-1px)}
.pl-config-download{background:var(--accent);color:#000}
.pl-config-copy{background:var(--bg3);color:var(--text);border:1px solid var(--border)}
.pl-config-copy.copied{background:var(--green);color:#fff;border-color:var(--green)}
.pl-config-preview{background:var(--bg);border:1px solid var(--border);border-radius:8px;overflow:hidden}
.pl-config-header{display:flex;justify-content:space-between;align-items:center;padding:.5rem .75rem;background:var(--bg3);border-bottom:1px solid var(--border)}
.pl-config-header span{font-size:.75rem;color:var(--text2);font-weight:600}
.pl-config-preview pre{padding:.75rem;margin:0;font-size:.78rem;color:var(--text2);line-height:1.6;overflow-x:auto;max-height:250px;overflow-y:auto}

/* ── eDPI Meter ────────────────────────────────────────────────────────────── */
.pl-edpi-meter{margin-top:1.25rem}
.pl-edpi-track{position:relative;height:28px;background:linear-gradient(90deg,var(--green),var(--accent),var(--red));border-radius:6px;opacity:.3}
.pl-edpi-marker{position:absolute;top:-8px;transform:translateX(-50%);z-index:2}
.pl-edpi-marker span{background:var(--accent);color:#000;font-size:.7rem;font-weight:800;padding:.2rem .5rem;border-radius:4px;display:block;white-space:nowrap}
.pl-edpi-avg{position:absolute;bottom:-8px;transform:translateX(-50%);z-index:1}
.pl-edpi-avg span{font-size:.6rem;color:var(--text2);font-weight:600;white-space:nowrap}
.pl-edpi-labels{display:flex;justify-content:space-between;margin-top:.5rem;font-size:.7rem;color:var(--text2)}

/* ── Gear Grid ─────────────────────────────────────────────────────────────── */
.pl-gear-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(250px,1fr));gap:1rem}
.pl-gear-item{background:var(--bg2);border:1px solid var(--border);border-radius:10px;padding:1rem 1.25rem;display:flex;gap:1rem;align-items:center;transition:border-color .2s}
.pl-gear-item:hover{border-color:var(--accent)}
.pl-gear-icon{font-size:1.5rem}
.pl-gear-img{width:48px;height:48px;object-fit:contain;flex-shrink:0;border-radius:6px;background:var(--bg1)}
.pl-gear-label{display:block;font-size:.75rem;color:var(--text2);text-transform:uppercase;font-weight:600;letter-spacing:.03em}
.pl-gear-value{display:block;color:var(--text);font-weight:700;font-size:.95rem;margin-top:.15rem}
.pl-gear-link{text-decoration:none;transition:color .2s}.pl-gear-link:hover{color:var(--accent);text-decoration:underline}

/* ── Loadout / Weapon Skins ───────────────────────────────────────────────── */
.pl-loadout-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:1rem}
.pl-loadout-card{background:var(--bg2);border:2px solid var(--border);border-radius:10px;overflow:hidden;text-decoration:none;transition:border-color .2s,transform .2s}
.pl-loadout-card:hover{transform:translateY(-2px)}
.pl-loadout-card.pl-loadout-nolink{pointer-events:none}
.pl-loadout-img{width:100%;height:120px;object-fit:contain;background:linear-gradient(135deg,var(--bg3),var(--bg));padding:.75rem;display:block}
.pl-loadout-placeholder{width:100%;height:120px;display:flex;align-items:center;justify-content:center;background:var(--bg3);color:var(--text2);font-size:.9rem;font-weight:600}
.pl-loadout-info{padding:.75rem 1rem}
.pl-loadout-slot{display:block;font-size:.7rem;text-transform:uppercase;font-weight:700;color:var(--text2);letter-spacing:.04em;margin-bottom:.2rem}
.pl-loadout-name{display:block;font-size:.9rem;font-weight:700;color:var(--text);line-height:1.3}
.pl-loadout-rarity{display:block;font-size:.72rem;font-weight:600;margin-top:.25rem}

/* ── Related Players ───────────────────────────────────────────────────────── */
.pl-related-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:1rem}
.pl-related-card{background:var(--bg2);border:1px solid var(--border);border-radius:8px;padding:1rem;text-decoration:none;transition:border-color .2s,transform .2s}
.pl-related-card:hover{border-color:var(--accent);transform:translateY(-2px)}
.pl-rc-top{display:flex;align-items:center;gap:.6rem;margin-bottom:.4rem}
.pl-rc-img{width:36px;height:36px;border-radius:50%;object-fit:cover;border:2px solid var(--border);flex-shrink:0;background:var(--bg3)}
.pl-rc-name{font-weight:700;font-size:1.05rem;color:var(--text)}
.pl-rc-meta{display:flex;gap:.5rem;flex-wrap:wrap;align-items:center;font-size:.8rem;color:var(--text2)}

/* ── Role Badge (reuse from listing) ───────────────────────────────────────── */
.pp-role{font-size:.72rem;font-weight:700;padding:.2rem .5rem;border-radius:4px;text-transform:uppercase;letter-spacing:.03em;background:var(--bg3);color:var(--text2);border:1px solid var(--border)}
.pp-role[data-r="awper"]{background:rgba(239,83,80,.15);color:var(--red);border-color:var(--red)}
.pp-role[data-r="rifler"]{background:rgba(66,165,245,.15);color:var(--blue);border-color:var(--blue)}
.pp-role[data-r="igl"]{background:rgba(171,71,188,.15);color:var(--purple);border-color:var(--purple)}
.pp-role[data-r="entry-fragger"]{background:rgba(212,149,110,.15);color:var(--accent);border-color:var(--accent)}
.pp-role[data-r="support"]{background:rgba(76,175,80,.15);color:var(--green);border-color:var(--green)}
.pp-role-sm{font-size:.65rem;padding:.15rem .4rem}

/* ── Responsive ────────────────────────────────────────────────────────────── */
@media(max-width:1024px){
  .pl-sidebar{display:none}
  .pl-layout{flex-direction:column}
}
@media(max-width:768px){
  .pl-hero-top{flex-direction:column}
  .pl-hero-quickstats{min-width:100%}
  .pl-hero-info h1{font-size:1.8rem}
  .pl-grid-2{grid-template-columns:1fr}
  .pl-gear-grid{grid-template-columns:1fr}
  .pl-loadout-grid{grid-template-columns:1fr 1fr}
  .pl-related-grid{grid-template-columns:1fr 1fr}
  .pl-crosshair-code{flex-direction:column;align-items:stretch}
  .pl-config-actions{flex-direction:column}
  .pl-config-btn{justify-content:center}
}
</style>

<script is:inline define:vars={{ xhairColor, crosshairSize: player.crosshairSize, crosshairGap: player.crosshairGap, crosshairThickness: player.crosshairThickness, crosshairDot: player.crosshairDot, crosshairOutline: player.crosshairOutline, configText, allCmds, playerName: player.name }}>
(function(){
  // ── Copy buttons ──
  function bindCopy(btnId, codeId) {
    var btn = document.getElementById(btnId);
    var code = document.getElementById(codeId);
    if (!btn || !code) return;
    btn.addEventListener('click', function(){
      navigator.clipboard.writeText(code.textContent.trim()).then(function(){
        var orig = btn.textContent;
        btn.textContent = 'Copied!';
        btn.classList.add('copied');
        setTimeout(function(){ btn.textContent = orig; btn.classList.remove('copied'); }, 1500);
      });
    });
  }
  bindCopy('copyXhair', 'xhairCode');
  bindCopy('copyVm', 'vmCmds');
  bindCopy('copyLaunch', 'launchOpts');
  bindCopy('copyConfig', 'configPreview');

  // ── Copy All Commands ──
  var copyAllBtn = document.getElementById('copyAllCmds');
  if (copyAllBtn) {
    copyAllBtn.addEventListener('click', function(){
      navigator.clipboard.writeText(allCmds).then(function(){
        copyAllBtn.querySelector('svg').style.display = 'none';
        copyAllBtn.classList.add('copied');
        var origText = copyAllBtn.childNodes[copyAllBtn.childNodes.length - 1];
        origText.textContent = ' Copied!';
        setTimeout(function(){
          copyAllBtn.querySelector('svg').style.display = '';
          copyAllBtn.classList.remove('copied');
          origText.textContent = ' Copy All Console Commands';
        }, 1500);
      });
    });
  }

  // ── Download Config ──
  var dlBtn = document.getElementById('downloadConfig');
  if (dlBtn) {
    dlBtn.addEventListener('click', function(){
      var blob = new Blob([configText], { type: 'text/plain' });
      var url = URL.createObjectURL(blob);
      var a = document.createElement('a');
      a.href = url;
      a.download = playerName.toLowerCase().replace(/[^a-z0-9]/g, '_') + '_autoexec.cfg';
      document.body.appendChild(a);
      a.click();
      document.body.removeChild(a);
      URL.revokeObjectURL(url);
    });
  }

  // ── Crosshair Preview Render ──
  var ch = document.getElementById('xhairRender');
  if (ch) {
    var s = crosshairSize;
    var g = crosshairGap;
    var t = Math.max(crosshairThickness, 0.5);
    var gapPx = Math.round((g + 5) * 3);
    var thickPx = Math.max(Math.round(t * 2), 1);
    var armLen = s * 6;
    var shadow = crosshairOutline ? '0 0 0 1px rgba(0,0,0,0.8)' : 'none';

    var arms = [
      { x: -gapPx - armLen, y: -thickPx / 2, w: armLen, h: thickPx },
      { x: gapPx, y: -thickPx / 2, w: armLen, h: thickPx },
      { x: -thickPx / 2, y: -gapPx - armLen, w: thickPx, h: armLen },
      { x: -thickPx / 2, y: gapPx, w: thickPx, h: armLen },
    ];
    arms.forEach(function(arm) {
      var d = document.createElement('div');
      d.style.cssText = 'position:absolute;left:50%;top:50%;background:' + xhairColor + ';box-shadow:' + shadow + ';transform:translate(' + arm.x + 'px,' + arm.y + 'px);width:' + arm.w + 'px;height:' + arm.h + 'px;';
      ch.appendChild(d);
    });
    if (crosshairDot) {
      var dotEl = document.createElement('div');
      var dotSize = Math.max(thickPx + 2, 3);
      dotEl.style.cssText = 'position:absolute;left:50%;top:50%;background:' + xhairColor + ';width:' + dotSize + 'px;height:' + dotSize + 'px;transform:translate(-50%,-50%);box-shadow:' + shadow;
      ch.appendChild(dotEl);
    }
  }

  // ── Sidebar Active State (IntersectionObserver) ──
  var sidebarLinks = document.querySelectorAll('.pl-sidebar-link');
  if (sidebarLinks.length > 0 && 'IntersectionObserver' in window) {
    var sectionEls = [];
    sidebarLinks.forEach(function(link) {
      var sec = document.getElementById(link.dataset.section);
      if (sec) sectionEls.push(sec);
    });

    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          sidebarLinks.forEach(function(l) { l.classList.remove('active'); });
          var activeLink = document.querySelector('.pl-sidebar-link[data-section="' + entry.target.id + '"]');
          if (activeLink) activeLink.classList.add('active');
        }
      });
    }, { rootMargin: '-80px 0px -60% 0px', threshold: 0 });

    sectionEls.forEach(function(sec) { observer.observe(sec); });
  }
})();
</script>
