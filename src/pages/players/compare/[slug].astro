---
import Base from '../../../layouts/Base.astro';
import ExploreMore from '../../../components/ExploreMore.astro';
import { PRO_PLAYERS, getAverageEdpi, type ProPlayer } from '../../../lib/pro-players';
import { breadcrumbSchema, faqSchema } from '../../../lib/weapons';
import { getSkinBySlug } from '../../../lib/skins';

export function getStaticPaths() {
  const topSlugs = ['s1mple', 'zywoo', 'niko', 'donk', 'device', 'm0nesy', 'ropz', 'twistzz', 'electronic', 'broky', 'rain', 'frozen', 'b1t', 'jl', 'spinx', 'ax1le', 'hobbit', 'xantares', 'kopite', 'w0nderful'];
  const topPlayers = topSlugs.map(s => PRO_PLAYERS.find(p => p.slug === s)).filter(Boolean) as ProPlayer[];
  const paths: { params: { slug: string }; props: { p1: ProPlayer; p2: ProPlayer } }[] = [];
  for (let i = 0; i < topPlayers.length; i++) {
    for (let j = i + 1; j < topPlayers.length; j++) {
      paths.push({
        params: { slug: `${topPlayers[i].slug}-vs-${topPlayers[j].slug}` },
        props: { p1: topPlayers[i], p2: topPlayers[j] },
      });
    }
  }
  return paths;
}

const { p1, p2 } = Astro.props as { p1: ProPlayer; p2: ProPlayer };
const avgEdpi = getAverageEdpi();

function sensLabel(edpi: number) {
  return edpi < 600 ? 'Low' : edpi < 900 ? 'Medium' : 'High';
}

function slugify(s: string) {
  return s.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
}
function gearHref(type: string, name: string) {
  return name ? `/gear/${type}-${slugify(name)}/` : undefined;
}
function teamHref(team: string) {
  const skip = ['free agent', 'retired', 'inactive', 'no team', 'none', 'benched', 'n/a', ''];
  return skip.includes(team.toLowerCase().trim()) ? undefined : `/team/${slugify(team)}/`;
}

const title = `${p1.name} vs ${p2.name} Settings Comparison — CS2 Pro Settings | CSDB.gg`;
const description = `Compare ${p1.name} and ${p2.name} CS2 settings side by side. Sensitivity, crosshair, resolution, gear, and configs compared for ${p1.team} vs ${p2.team}.`;

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Pro Players', url: '/pro-players/' },
  { name: `${p1.name} vs ${p2.name}`, url: `/players/compare/${p1.slug}-vs-${p2.slug}/` },
];

const faqs = [
  { question: `Who has higher sensitivity — ${p1.name} or ${p2.name}?`, answer: `${p1.name} plays at ${p1.edpi} eDPI while ${p2.name} plays at ${p2.edpi} eDPI. ${p1.edpi > p2.edpi ? `${p1.name} uses a higher sensitivity (${sensLabel(p1.edpi)})` : p1.edpi < p2.edpi ? `${p2.name} uses a higher sensitivity (${sensLabel(p2.edpi)})` : 'Both use the same eDPI'}. The pro average is ${avgEdpi} eDPI.` },
  { question: `Do ${p1.name} and ${p2.name} use the same resolution?`, answer: `${p1.name} plays on ${p1.res} (${p1.aspect} ${p1.stretch}) while ${p2.name} plays on ${p2.res} (${p2.aspect} ${p2.stretch}). ${p1.res === p2.res ? 'Both use the same resolution.' : ''}` },
  { question: `What mouse does ${p1.name} use vs ${p2.name}?`, answer: `${p1.name} uses the ${p1.mouse} at ${p1.dpi} DPI, while ${p2.name} uses the ${p2.mouse} at ${p2.dpi} DPI.` },
];

type Row = { label: string; v1: string; v2: string; highlight?: boolean; href1?: string; href2?: string };
const rows: Row[] = [
  { label: 'Team', v1: p1.team, v2: p2.team, href1: teamHref(p1.team), href2: teamHref(p2.team) },
  { label: 'Role', v1: p1.role, v2: p2.role },
  { label: 'DPI', v1: String(p1.dpi), v2: String(p2.dpi) },
  { label: 'In-Game Sens', v1: String(p1.sens), v2: String(p2.sens) },
  { label: 'eDPI', v1: String(p1.edpi), v2: String(p2.edpi), highlight: true },
  { label: 'Zoom Sens', v1: String(p1.zoomSens), v2: String(p2.zoomSens) },
  { label: 'Resolution', v1: p1.res, v2: p2.res },
  { label: 'Aspect Ratio', v1: p1.aspect, v2: p2.aspect },
  { label: 'Stretch', v1: p1.stretch, v2: p2.stretch },
  { label: 'Crosshair Code', v1: p1.crosshairCode || '—', v2: p2.crosshairCode || '—', href1: p1.crosshairCode ? `/player/${p1.slug}/` : undefined, href2: p2.crosshairCode ? `/player/${p2.slug}/` : undefined },
  { label: 'Mouse', v1: p1.mouse, v2: p2.mouse, href1: gearHref('mouse', p1.mouse), href2: gearHref('mouse', p2.mouse) },
  { label: 'Polling Rate', v1: `${p1.pollingRate}Hz`, v2: `${p2.pollingRate}Hz` },
  { label: 'Mousepad', v1: p1.mousepad, v2: p2.mousepad, href1: gearHref('mousepad', p1.mousepad), href2: gearHref('mousepad', p2.mousepad) },
  { label: 'Monitor', v1: p1.monitor, v2: p2.monitor, href1: gearHref('monitor', p1.monitor), href2: gearHref('monitor', p2.monitor) },
  { label: 'Keyboard', v1: p1.keyboard, v2: p2.keyboard, href1: gearHref('keyboard', p1.keyboard), href2: gearHref('keyboard', p2.keyboard) },
  { label: 'Headset', v1: p1.headset, v2: p2.headset, href1: gearHref('headset', p1.headset), href2: gearHref('headset', p2.headset) },
];

// Loadout comparison data
type LoadoutSlot = { label: string; slug1?: string; slug2?: string; name1?: string; name2?: string };
const loadoutSlots: LoadoutSlot[] = [];
if (p1.loadout || p2.loadout) {
  const slots = ['knife', 'gloves', 'rifle', 'pistol', 'awp'] as const;
  const slotLabels: Record<string, string> = { knife: 'Knife', gloves: 'Gloves', rifle: 'Rifle Skin', pistol: 'Pistol Skin', awp: 'AWP Skin' };
  for (const slot of slots) {
    const s1 = p1.loadout?.[slot];
    const s2 = p2.loadout?.[slot];
    if (s1 || s2) {
      const skin1 = s1 ? getSkinBySlug(s1) : undefined;
      const skin2 = s2 ? getSkinBySlug(s2) : undefined;
      loadoutSlots.push({
        label: slotLabels[slot],
        slug1: s1, slug2: s2,
        name1: skin1 ? `${skin1.weapon} | ${skin1.name}` : s1 || '—',
        name2: skin2 ? `${skin2.weapon} | ${skin2.name}` : s2 || '—',
      });
    }
  }
}
---

<Base title={title} description={description} currentNav="/pro-players/">
<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema(breadcrumbs))} />
<script type="application/ld+json" set:html={JSON.stringify(faqSchema(faqs))} />

<nav class="breadcrumb">
  <a href="/">Home</a> / <a href="/pro-players/">Pro Players</a> / <span>{p1.name} vs {p2.name}</span>
</nav>

<div class="pc-header">
  <div class="pc-player">
    {p1.image && <img src={p1.image} alt={p1.name} width="64" height="64" class="pc-avatar" />}
    <div>
      <h2><a href={`/player/${p1.slug}/`}>{p1.name}</a></h2>
      <span>{teamHref(p1.team) ? <a href={teamHref(p1.team)} class="pc-team-link">{p1.team}</a> : p1.team} · {p1.role}</span>
    </div>
  </div>
  <div class="pc-vs">VS</div>
  <div class="pc-player pc-player-right">
    <div>
      <h2><a href={`/player/${p2.slug}/`}>{p2.name}</a></h2>
      <span>{teamHref(p2.team) ? <a href={teamHref(p2.team)} class="pc-team-link">{p2.team}</a> : p2.team} · {p2.role}</span>
    </div>
    {p2.image && <img src={p2.image} alt={p2.name} width="64" height="64" class="pc-avatar" />}
  </div>
</div>

<h1>{p1.name} vs {p2.name} — CS2 Settings Comparison</h1>

<table class="pc-table">
  <thead>
    <tr><th>Setting</th><th>{p1.name}</th><th>{p2.name}</th></tr>
  </thead>
  <tbody>
    {rows.map(r => (
      <tr class={r.highlight ? 'pc-highlight' : ''}>
        <td class="pc-label">{r.label}</td>
        <td>{r.href1 ? <a href={r.href1}>{r.v1}</a> : r.v1}</td>
        <td>{r.href2 ? <a href={r.href2}>{r.v2}</a> : r.v2}</td>
      </tr>
    ))}
  </tbody>
</table>

{loadoutSlots.length > 0 && (
  <section class="pc-loadout">
    <h2>Loadout Comparison</h2>
    <table class="pc-table">
      <thead>
        <tr><th>Slot</th><th>{p1.name}</th><th>{p2.name}</th></tr>
      </thead>
      <tbody>
        {loadoutSlots.map(s => (
          <tr>
            <td class="pc-label">{s.label}</td>
            <td>{s.slug1 ? <a href={`/skin/${s.slug1}/`}>{s.name1}</a> : s.name1 || '—'}</td>
            <td>{s.slug2 ? <a href={`/skin/${s.slug2}/`}>{s.name2}</a> : s.name2 || '—'}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </section>
)}

<section class="pc-faq">
  <h2>Frequently Asked Questions</h2>
  <dl class="faq">
    {faqs.map(f => (
      <Fragment>
        <dt>{f.question}</dt>
        <dd>{f.answer}</dd>
      </Fragment>
    ))}
  </dl>
</section>

<ExploreMore context="players" />
</Base>

<style>
  .pc-header{display:flex;align-items:center;justify-content:space-between;background:var(--bg2);border:1px solid var(--border);border-radius:12px;padding:1.5rem 2rem;margin-bottom:1.5rem;gap:1rem}
  .pc-player{display:flex;align-items:center;gap:1rem}
  .pc-player-right{text-align:right}
  .pc-avatar{width:64px;height:64px;border-radius:10px;object-fit:cover}
  .pc-player h2{margin:0;font-size:1.3rem}
  .pc-player h2 a{color:inherit;text-decoration:none}
  .pc-player h2 a:hover{color:var(--accent)}
  .pc-player span{font-size:.85rem;color:var(--text2)}
  .pc-vs{font-size:1.5rem;font-weight:900;color:var(--text2);flex-shrink:0}
  h1{font-size:1.1rem;color:var(--text2);font-weight:400;margin:0 0 1.5rem}
  .pc-table{width:100%;border-collapse:collapse;background:var(--bg2);border:1px solid var(--border);border-radius:10px;overflow:hidden;margin-bottom:2rem}
  .pc-table th,.pc-table td{padding:.75rem 1rem;text-align:left;border-bottom:1px solid var(--border)}
  .pc-table th{background:var(--bg3);font-size:.82rem;text-transform:uppercase;color:var(--text2);letter-spacing:.03em}
  .pc-label{font-weight:600;color:var(--text2);font-size:.85rem}
  .pc-highlight{background:rgba(212,149,110,0.06)}
  .pc-highlight td{font-weight:700;color:var(--accent)}
  .pc-highlight .pc-label{color:var(--accent)}
  .pc-table td a{color:var(--accent);text-decoration:none}
  .pc-table td a:hover{text-decoration:underline}
  .pc-team-link{color:var(--accent);text-decoration:none}
  .pc-team-link:hover{text-decoration:underline}
  .pc-loadout{margin-bottom:2rem}
  .pc-loadout h2{margin:0 0 1rem}
  .pc-faq{margin-bottom:2rem}
  .pc-faq h2{margin:0 0 1rem}
  @media(max-width:600px){
    .pc-header{flex-direction:column;text-align:center}
    .pc-player,.pc-player-right{text-align:center;flex-direction:column}
    .pc-table th:first-child,.pc-table td:first-child{min-width:80px}
    .pc-table{font-size:.85rem}
  }
</style>
