---
import Base from '../../../layouts/Base.astro';
import ExploreMore from '../../../components/ExploreMore.astro';
import { getRoles, getAverageEdpi, type RoleInfo } from '../../../lib/pro-players';
import { breadcrumbSchema, faqSchema } from '../../../lib/weapons';

export function getStaticPaths() {
  return getRoles().map(r => ({
    params: { slug: r.slug },
    props: { role: r },
  }));
}

const { role } = Astro.props as { role: RoleInfo };
const allRoles = getRoles();
const globalAvgEdpi = getAverageEdpi();

// Role-specific stats
const players = role.players;
const roleAvgEdpi = players.length > 0
  ? Math.round(players.reduce((s, p) => s + p.edpi, 0) / players.length)
  : 0;

// eDPI stats
const edpis = players.map(p => p.edpi).sort((a, b) => a - b);
const edpiMin = edpis[0] || 0;
const edpiMax = edpis[edpis.length - 1] || 0;
const edpiMedian = edpis[Math.floor(edpis.length / 2)] || 0;

// Sensitivity range (middle 80%)
const lowIdx = Math.floor(edpis.length * 0.1);
const highIdx = Math.floor(edpis.length * 0.9);
const sensRangeLow = edpis[lowIdx] || edpiMin;
const sensRangeHigh = edpis[highIdx] || edpiMax;

// Most common mouse
const mouseCount: Record<string, number> = {};
players.forEach(p => { mouseCount[p.mouse] = (mouseCount[p.mouse] || 0) + 1; });
const mouseBreakdown = Object.entries(mouseCount)
  .sort((a, b) => b[1] - a[1])
  .map(([name, count]) => ({ name, count, pct: Math.round((count / players.length) * 100) }));
const topMouse = mouseBreakdown[0]?.name || 'N/A';

// Most common resolution
const resCount: Record<string, number> = {};
players.forEach(p => { resCount[p.res] = (resCount[p.res] || 0) + 1; });
const resBreakdown = Object.entries(resCount)
  .sort((a, b) => b[1] - a[1])
  .map(([res, count]) => ({ res, count, pct: Math.round((count / players.length) * 100) }));
const topRes = resBreakdown[0]?.res || 'N/A';

// Stretched/BB/Native breakdown
let stretched = 0, bars = 0, native = 0;
players.forEach(p => {
  if (p.stretch === 'Stretched') stretched++;
  else if (p.stretch === 'Black Bars') bars++;
  else native++;
});

// DPI breakdown
const dpiCount: Record<number, number> = {};
players.forEach(p => { dpiCount[p.dpi] = (dpiCount[p.dpi] || 0) + 1; });
const topDpi = Number(Object.entries(dpiCount).sort((a, b) => b[1] - a[1])[0]?.[0] || 0);

// Country breakdown
const countryCount: Record<string, { flag: string; count: number }> = {};
players.forEach(p => {
  if (!countryCount[p.country]) countryCount[p.country] = { flag: p.flag, count: 0 };
  countryCount[p.country].count++;
});
const topCountries = Object.entries(countryCount)
  .sort((a, b) => b[1].count - a[1].count)
  .slice(0, 5);

const title = `Best CS2 ${role.name} Settings \u2014 ${role.players.length} Pro Players | CSDB.gg`;
const description = `${role.description} Browse settings from ${players.length} professional CS2 ${role.name.toLowerCase()} players including sensitivity, crosshair codes, resolution, and gear.`;

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Pro Players', url: '/pro-players/' },
  { name: 'Roles', url: '/pro-players/' },
  { name: role.name, url: `/players/role/${role.slug}/` },
];

const faqs = [
  { question: `What sensitivity do CS2 ${role.name.toLowerCase()}s use?`, answer: `The average eDPI among professional ${role.name.toLowerCase()} players is ${roleAvgEdpi}, which is ${roleAvgEdpi < globalAvgEdpi ? 'below' : roleAvgEdpi > globalAvgEdpi ? 'above' : 'right at'} the overall pro average of ${globalAvgEdpi}. Most ${role.name.toLowerCase()}s fall between ${sensRangeLow} and ${sensRangeHigh} eDPI. The most common DPI setting is ${topDpi}.` },
  { question: `What resolution do pro ${role.name.toLowerCase()}s prefer?`, answer: `The most popular resolution among professional ${role.name.toLowerCase()} players is ${topRes}, used by ${resBreakdown[0]?.pct || 0}% of players. ${stretched > 0 ? `${Math.round((stretched / players.length) * 100)}% use stretched, ` : ''}${bars > 0 ? `${Math.round((bars / players.length) * 100)}% use black bars, ` : ''}and ${Math.round((native / players.length) * 100)}% use native resolution.` },
  { question: `What makes a good ${role.name.toLowerCase()} in CS2?`, answer: role.description },
];
---

<Base {title} {description} currentNav="/pro-players/">
<Fragment slot="head">
<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema(breadcrumbs))} />
<script type="application/ld+json" set:html={JSON.stringify(faqSchema(faqs))} />
</Fragment>

<nav class="breadcrumb"><a href="/">Home</a> <span>/</span> <a href="/pro-players/">Pro Players</a> <span>/</span> <span>Roles</span> <span>/</span> <span>{role.name}</span></nav>

<!-- Hero -->
<section class="role-hero">
  <span class="pp-role pp-role-hero" data-r={role.slug}>{role.name}</span>
  <h1>CS2 {role.name} Settings &amp; Configs</h1>
  <p class="role-desc">{role.description}</p>
  <div class="role-hero-stats">
    <div class="role-hstat"><span class="role-hval">{players.length}</span><span class="role-hlbl">Pro {role.name}s</span></div>
    <div class="role-hstat"><span class="role-hval">{roleAvgEdpi}</span><span class="role-hlbl">Avg eDPI</span></div>
    <div class="role-hstat"><span class="role-hval">{topRes}</span><span class="role-hlbl">Top Resolution</span></div>
    <div class="role-hstat"><span class="role-hval">{topMouse}</span><span class="role-hlbl">Top Mouse</span></div>
  </div>
</section>

<!-- Player Cards Grid -->
<section class="role-section">
  <h2>All {role.name} Player Settings</h2>
  <div class="pp-grid">
    {players.map(p => (
      <a href={`/player/${p.slug}/`} class="pp-card" data-role={p.role} data-name={p.name.toLowerCase()} data-team={p.team.toLowerCase()}>
        <div class="pp-card-top">
          {p.image && <img class="pp-avatar" src={p.image} alt={p.name} width="56" height="56" loading="lazy" onerror="this.style.display='none'" />}
          <div class="pp-card-info">
            <h3 class="pp-name">{p.flag} {p.name}</h3>
            <div class="pp-team-role">
              <span class="pp-team">{p.team}</span>
              <span class="pp-role" data-r={p.role.toLowerCase().replace(/\s/g,'-')}>{p.role}</span>
            </div>
            {p.realName && <div class="pp-realname">{p.realName}</div>}
          </div>
        </div>

        <div class="pp-stats">
          <div class="pp-s"><span class="pp-sv">{p.dpi}</span><span class="pp-sl">DPI</span></div>
          <div class="pp-s"><span class="pp-sv">{p.sens}</span><span class="pp-sl">Sens</span></div>
          <div class="pp-s pp-edpi"><span class="pp-sv">{p.edpi}</span><span class="pp-sl">eDPI</span></div>
          <div class="pp-s"><span class="pp-sv">{p.res}</span><span class="pp-sl">{p.aspect} {p.stretch}</span></div>
        </div>

        {p.crosshairCode && (
          <div class="pp-xhair" onclick="event.preventDefault();">
            <code>{p.crosshairCode}</code>
            <button class="pp-copy" data-code={p.crosshairCode}>Copy</button>
          </div>
        )}

        <div class="pp-gear">
          <div class="pp-gi"><span class="pp-gk">Mouse</span><span class="pp-gv">{p.mouse}</span></div>
          <div class="pp-gi"><span class="pp-gk">Monitor</span><span class="pp-gv">{p.monitor}</span></div>
          <div class="pp-gi"><span class="pp-gk">Keyboard</span><span class="pp-gv">{p.keyboard}</span></div>
          <div class="pp-gi"><span class="pp-gk">Headset</span><span class="pp-gv">{p.headset}</span></div>
          <div class="pp-gi"><span class="pp-gk">Mousepad</span><span class="pp-gv">{p.mousepad}</span></div>
        </div>

        <div class="pp-edpi-bar">
          <div class="pp-ebar-fill" style={`width:${Math.min(100, Math.round(((p.edpi - 400) / (1700 - 400)) * 100))}%`}></div>
          <span class="pp-ebar-label">{p.edpi} eDPI — {p.edpi < 600 ? 'Low' : p.edpi < 900 ? 'Medium' : 'High'} sens</span>
        </div>

        <div class="pp-view-more">View Full Profile &rarr;</div>
      </a>
    ))}
  </div>
</section>

<!-- Settings Analysis -->
<section class="role-section">
  <h2>{role.name} Settings Analysis</h2>
  <div class="role-analysis-grid">
    <div class="role-acard">
      <h3>Sensitivity Range</h3>
      <div class="role-astat">{sensRangeLow} – {sensRangeHigh} eDPI</div>
      <p>Range used by the middle 80% of {role.name.toLowerCase()} players. Average is {roleAvgEdpi}, median is {edpiMedian}. Full range spans {edpiMin} to {edpiMax}.</p>
      <div class="role-edpi-meter">
        <div class="role-edpi-track">
          <div class="role-edpi-zone" style={`left:${Math.max(0, ((sensRangeLow - 400) / (1700 - 400)) * 100)}%;width:${Math.min(100, ((sensRangeHigh - sensRangeLow) / (1700 - 400)) * 100)}%`}></div>
          <div class="role-edpi-marker" style={`left:${Math.min(100, Math.max(0, ((roleAvgEdpi - 400) / (1700 - 400)) * 100))}%`}>
            <span>{roleAvgEdpi}</span>
          </div>
        </div>
        <div class="role-edpi-labels">
          <span>Low</span><span>Medium</span><span>High</span>
        </div>
      </div>
    </div>
    <div class="role-acard">
      <h3>Resolution Breakdown</h3>
      {resBreakdown.map(r => (
        <div class="role-bar-row">
          <span class="role-bar-name">{r.res}</span>
          <div class="role-bar-fill" style={`width:${r.pct}%`}></div>
          <span class="role-bar-pct">{r.pct}%</span>
        </div>
      ))}
    </div>
    <div class="role-acard">
      <h3>Display Mode</h3>
      <div class="role-stretch-grid">
        <div class="role-stretch-item">
          <span class="role-stretch-val">{stretched}</span>
          <span class="role-stretch-lbl">Stretched</span>
          <span class="role-stretch-pct">{Math.round((stretched / players.length) * 100)}%</span>
        </div>
        <div class="role-stretch-item">
          <span class="role-stretch-val">{native}</span>
          <span class="role-stretch-lbl">Native</span>
          <span class="role-stretch-pct">{Math.round((native / players.length) * 100)}%</span>
        </div>
        <div class="role-stretch-item">
          <span class="role-stretch-val">{bars}</span>
          <span class="role-stretch-lbl">Black Bars</span>
          <span class="role-stretch-pct">{Math.round((bars / players.length) * 100)}%</span>
        </div>
      </div>
    </div>
    <div class="role-acard">
      <h3>Most Popular Mice</h3>
      {mouseBreakdown.slice(0, 5).map(m => (
        <div class="role-bar-row">
          <span class="role-bar-name">{m.name}</span>
          <div class="role-bar-fill" style={`width:${m.pct}%`}></div>
          <span class="role-bar-pct">{m.pct}%</span>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- Comparison Table -->
<section class="role-section">
  <h2>{role.name} Settings Comparison Table</h2>
  <div class="pp-table-wrap">
    <table class="pp-table">
      <thead>
        <tr>
          <th>Player</th><th>Team</th><th>Country</th><th>Mouse</th><th>DPI</th><th>Sens</th><th>eDPI</th><th>Resolution</th><th>Aspect</th><th>Display</th>
        </tr>
      </thead>
      <tbody>
        {players.map(p => (
          <tr>
            <td><a href={`/player/${p.slug}/`} class="pp-tlink"><strong>{p.flag} {p.name}</strong></a></td>
            <td>{p.team}</td>
            <td>{p.flag} {p.country}</td>
            <td>{p.mouse}</td>
            <td>{p.dpi}</td>
            <td>{p.sens}</td>
            <td><strong>{p.edpi}</strong></td>
            <td>{p.res}</td>
            <td>{p.aspect}</td>
            <td>{p.stretch}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</section>

<!-- FAQ -->
<section class="role-section">
  <h2>Frequently Asked Questions</h2>
  <dl class="faq">
    {faqs.map(f => (
      <>
        <dt>{f.question}</dt>
        <dd>{f.answer}</dd>
      </>
    ))}
  </dl>
</section>

<!-- Internal Links -->
<div class="internal-links">
  <strong>Related:</strong>
  <a href="/pro-players/">All Pro Settings</a>
  {allRoles.filter(r => r.slug !== role.slug).map(r => (
    <a href={`/players/role/${r.slug}/`}>{r.name} Settings</a>
  ))}
  <a href="/crosshair-codes/">Crosshair Codes</a>
  <a href="/sensitivity-converter/">Sensitivity Converter</a>
  <a href="/edpi-calculator/">eDPI Calculator</a>
  <a href="/resolution-calculator/">Resolution Calculator</a>
</div>

<ExploreMore context="general" />

</Base>

<style>
.role-hero{background:linear-gradient(135deg,var(--bg2),var(--bg3));border:1px solid var(--border);border-radius:12px;padding:2rem;margin-bottom:2rem;text-align:center}
.pp-role-hero{font-size:1rem;padding:.35rem .8rem;margin-bottom:.75rem;display:inline-block}
.role-hero h1{font-size:2.2rem;margin:.75rem 0}
.role-desc{color:var(--text2);font-size:1.05rem;margin:0 0 1.5rem;max-width:700px;margin-left:auto;margin-right:auto}
.role-hero-stats{display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:.75rem}
.role-hstat{background:var(--bg);border:1px solid var(--border);border-radius:8px;padding:1rem;text-align:center}
.role-hval{display:block;font-size:1.4rem;font-weight:800;color:var(--accent)}
.role-hlbl{display:block;font-size:.75rem;color:var(--text2);margin-top:.25rem}

.role-section{margin-bottom:3rem}
.role-section h2{margin-bottom:1.25rem}

/* Analysis */
.role-analysis-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:1.25rem}
.role-acard{background:var(--bg2);border:1px solid var(--border);border-radius:10px;padding:1.25rem}
.role-acard h3{margin:0 0 .75rem;font-size:1.05rem}
.role-astat{font-size:1.8rem;font-weight:800;color:var(--accent);margin-bottom:.5rem}
.role-acard p{font-size:.88rem;color:var(--text2);margin:0 0 .75rem}

.role-bar-row{display:flex;align-items:center;gap:.5rem;margin-bottom:.5rem}
.role-bar-name{min-width:100px;font-size:.82rem;color:var(--text);font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.role-bar-fill{height:20px;background:var(--accent);border-radius:3px;min-width:4px;opacity:.7;flex-shrink:0}
.role-bar-pct{font-size:.78rem;color:var(--text2);font-weight:600;white-space:nowrap}

.role-stretch-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:.75rem;text-align:center}
.role-stretch-item{background:var(--bg);border:1px solid var(--border);border-radius:8px;padding:.75rem}
.role-stretch-val{display:block;font-size:1.6rem;font-weight:800;color:var(--accent)}
.role-stretch-lbl{display:block;font-size:.75rem;color:var(--text2);margin-top:.2rem}
.role-stretch-pct{display:block;font-size:.7rem;color:var(--text2);margin-top:.15rem;opacity:.7}

/* eDPI Meter */
.role-edpi-meter{margin-top:.5rem}
.role-edpi-track{position:relative;height:28px;background:linear-gradient(90deg,var(--green),var(--accent),var(--red));border-radius:6px;opacity:.3}
.role-edpi-zone{position:absolute;top:0;height:100%;background:var(--accent);opacity:.5;border-radius:4px}
.role-edpi-marker{position:absolute;top:-8px;transform:translateX(-50%);z-index:2}
.role-edpi-marker span{background:var(--accent);color:#000;font-size:.7rem;font-weight:800;padding:.2rem .5rem;border-radius:4px;display:block;white-space:nowrap}
.role-edpi-labels{display:flex;justify-content:space-between;margin-top:.5rem;font-size:.7rem;color:var(--text2)}

/* Player cards — same as main pro-players page */
.pp-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(380px,1fr));gap:1.25rem;margin-bottom:2rem}
.pp-card{display:block;text-decoration:none;color:inherit;background:var(--bg2);border:1px solid var(--border);border-radius:10px;padding:1.25rem;transition:border-color .2s,transform .2s,box-shadow .2s}
.pp-card:hover{border-color:var(--accent);transform:translateY(-2px);box-shadow:0 4px 16px rgba(212,149,110,.1)}
.pp-card-top{display:flex;align-items:flex-start;margin-bottom:1rem;gap:.75rem}
.pp-avatar{width:56px;height:56px;border-radius:50%;object-fit:cover;border:2px solid var(--border);flex-shrink:0;background:var(--bg3)}
.pp-card-info{flex:1;min-width:0}
.pp-name{margin:0;font-size:1.3rem;font-weight:800}
.pp-team-role{display:flex;gap:.5rem;align-items:center;margin-top:.3rem}
.pp-team{color:var(--accent);font-size:.85rem;font-weight:600}
.pp-role{font-size:.72rem;font-weight:700;padding:.2rem .5rem;border-radius:4px;text-transform:uppercase;letter-spacing:.03em;background:var(--bg3);color:var(--text2);border:1px solid var(--border)}
.pp-role[data-r="awper"]{background:rgba(239,83,80,.15);color:var(--red);border-color:var(--red)}
.pp-role[data-r="rifler"]{background:rgba(66,165,245,.15);color:var(--blue);border-color:var(--blue)}
.pp-role[data-r="igl"]{background:rgba(171,71,188,.15);color:var(--purple);border-color:var(--purple)}
.pp-role[data-r="entry-fragger"]{background:rgba(212,149,110,.15);color:var(--accent);border-color:var(--accent)}
.pp-role[data-r="support"]{background:rgba(76,175,80,.15);color:var(--green);border-color:var(--green)}
.pp-role-sm{font-size:.65rem;padding:.15rem .4rem}
.pp-realname{color:var(--text2);font-size:.78rem;margin-top:.2rem}
.pp-view-more{text-align:center;color:var(--accent);font-size:.82rem;font-weight:700;margin-top:.75rem;padding-top:.5rem;border-top:1px solid var(--border)}

.pp-stats{display:grid;grid-template-columns:repeat(4,1fr);gap:.5rem;margin-bottom:1rem}
.pp-s{background:var(--bg);border:1px solid var(--border);border-radius:6px;padding:.5rem;text-align:center}
.pp-s.pp-edpi{border-color:var(--accent)}
.pp-sv{display:block;font-size:1.1rem;font-weight:700;color:var(--text)}
.pp-edpi .pp-sv{color:var(--accent)}
.pp-sl{display:block;font-size:.65rem;color:var(--text2);text-transform:uppercase;margin-top:.15rem}

.pp-xhair{display:flex;gap:.5rem;background:var(--bg);border:1px solid var(--border);border-radius:6px;padding:.4rem;margin-bottom:1rem;align-items:center}
.pp-xhair code{flex:1;font-size:.75rem;color:var(--text2);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;padding:0 .4rem}
.pp-copy{background:var(--accent);color:#000;border:none;padding:.3rem .6rem;border-radius:4px;font-size:.75rem;font-weight:700;cursor:pointer;white-space:nowrap;font-family:inherit}
.pp-copy:hover{opacity:.9}
.pp-copy.copied{background:var(--green);color:#fff}

.pp-gear{display:grid;grid-template-columns:1fr 1fr;gap:.3rem .75rem;margin-bottom:.75rem;font-size:.82rem}
.pp-gi{display:flex;gap:.3rem}
.pp-gk{color:var(--text2);font-weight:600;white-space:nowrap}
.pp-gk::after{content:':'}
.pp-gv{color:var(--text);overflow:hidden;text-overflow:ellipsis;white-space:nowrap}

.pp-edpi-bar{position:relative;background:var(--bg);border:1px solid var(--border);border-radius:4px;height:22px;overflow:hidden}
.pp-ebar-fill{position:absolute;top:0;left:0;height:100%;background:linear-gradient(90deg,var(--green),var(--accent),var(--red));opacity:.25;border-radius:4px}
.pp-ebar-label{position:absolute;top:50%;left:.5rem;transform:translateY(-50%);font-size:.7rem;color:var(--text2);font-weight:600}

.pp-table-wrap{overflow-x:auto;border:1px solid var(--border);border-radius:8px}
.pp-table{width:100%;border-collapse:collapse;background:var(--bg2);font-size:.82rem}
.pp-table thead{background:var(--bg3)}
.pp-table th{padding:.65rem .5rem;text-align:left;font-weight:700;color:var(--text);text-transform:uppercase;font-size:.7rem;letter-spacing:.03em;white-space:nowrap}
.pp-table td{padding:.5rem;border-bottom:1px solid var(--border);color:var(--text2);white-space:nowrap}
.pp-table tbody tr:hover td{background:var(--bg3)}
.pp-table td strong{color:var(--text)}
.pp-tlink{color:var(--accent);text-decoration:none;font-weight:600}
.pp-tlink:hover{text-decoration:underline}

@media(max-width:768px){
  .role-hero h1{font-size:1.6rem}
  .role-hero-stats{grid-template-columns:repeat(2,1fr)}
  .role-desc{font-size:.95rem}
  .role-analysis-grid{grid-template-columns:1fr}
  .role-stretch-grid{grid-template-columns:repeat(3,1fr)}
  .pp-grid{grid-template-columns:1fr}
  .pp-stats{grid-template-columns:repeat(2,1fr)}
  .pp-gear{grid-template-columns:1fr}
}
</style>

<script is:inline>
(function(){
  document.querySelectorAll('.pp-copy').forEach(function(btn){
    btn.addEventListener('click', function(e){
      e.preventDefault();
      e.stopPropagation();
      navigator.clipboard.writeText(btn.dataset.code).then(function(){
        btn.textContent = 'Copied!';
        btn.classList.add('copied');
        setTimeout(function(){ btn.textContent = 'Copy'; btn.classList.remove('copied'); }, 1500);
      });
    });
  });
})();
</script>
