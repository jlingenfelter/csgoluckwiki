---
import Base from '../layouts/Base.astro';
import ExploreMore from '../components/ExploreMore.astro';
import { SKINS, getLowestPrice, getHighestPrice } from '../lib/skins';
import { breadcrumbSchema, faqSchema } from '../lib/weapons';

const title = 'CS2 Skin Price Alerts — Get Notified on Price Drops | CSGOLuck Wiki';
const description = 'Set custom price alerts for any CS2 skin. Track target prices, monitor drops, and never miss a deal on your favorite skins. Free tool — all data saved locally in your browser.';

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Tools', url: '/cs2-tools/' },
  { name: 'Price Alerts', url: '/price-alerts/' },
];

const faqs = [
  { question: 'How do CS2 skin price alerts work on CSGOLuck Wiki?', answer: 'Price alerts are saved in your browser using localStorage. Each time you visit this page, your alerts are checked against the latest build-time prices sourced from multiple marketplaces. If a skin\'s current lowest price has dropped to or below your target, the alert is marked as triggered.' },
  { question: 'Are price alerts real-time push notifications?', answer: 'No. Since CSGOLuck Wiki is a statically generated site, alerts are checked when you load the page rather than in real time. For the most up-to-date checks, simply revisit this page. Prices are updated regularly at build time from marketplace data.' },
  { question: 'Will I lose my alerts if I clear my browser data?', answer: 'Yes. Alerts are stored in your browser\'s localStorage. Clearing your browsing data, cookies, or site data will remove your saved alerts. They are also specific to the browser and device you set them on.' },
  { question: 'How many price alerts can I set?', answer: 'There is no hard limit. You can set as many alerts as you like. All alerts are stored locally in your browser, so performance depends on your device. We recommend keeping your list manageable for the best experience.' },
  { question: 'What prices are used to check my alerts?', answer: 'Alerts are checked against the lowest available price across all tracked marketplaces at the time the site was last built. This gives you the best deal from sources like Skinport, DMarket, CSFloat, and more.' },
  { question: 'Can I set alerts for StatTrak or Souvenir variants?', answer: 'Yes. The skin search includes all variants in the database, including StatTrak and Souvenir versions. Simply search for the specific variant you want and set your target price.' },
];

// Build a lightweight JSON blob for client-side search
// Only include skins that have at least one price
const skinsData = SKINS
  .filter(s => s.prices.length > 0)
  .map(s => ({
    slug: s.slug,
    name: s.name,
    weapon: s.weapon,
    lowestPrice: getLowestPrice(s),
  }));

const skinsWithPrices = SKINS.filter(s => s.prices.length > 0);
const totalTracked = skinsWithPrices.length;
---

<Base title={title} description={description} currentNav="/cs2-tools/">
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema(breadcrumbs))}></script>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema(faqs))}></script>

  <nav class="pa-breadcrumb">
    <a href="/">Home</a> / <a href="/cs2-tools/">Tools</a> / <span>Price Alerts</span>
  </nav>

  <section class="pa-hero">
    <h1>CS2 Skin Price Alerts</h1>
    <p>Set target prices for any CS2 skin and check back to see when your price has been reached. Alerts are saved locally in your browser and checked against the latest marketplace data each time you visit. Track {totalTracked.toLocaleString()}+ skins across all categories.</p>
  </section>

  <!-- Stats overview -->
  <div class="pa-stats">
    <div class="pa-stat">
      <div class="pa-stat-val" id="alertCount">0</div>
      <div class="pa-stat-label">Active Alerts</div>
    </div>
    <div class="pa-stat">
      <div class="pa-stat-val" id="triggeredCount">0</div>
      <div class="pa-stat-label">Triggered</div>
    </div>
    <div class="pa-stat">
      <div class="pa-stat-val" id="watchingCount">0</div>
      <div class="pa-stat-label">Watching</div>
    </div>
    <div class="pa-stat">
      <div class="pa-stat-val">{totalTracked.toLocaleString()}</div>
      <div class="pa-stat-label">Skins Tracked</div>
    </div>
  </div>

  <!-- Search & Add Alert Section -->
  <section class="pa-builder">
    <h2>Add a Price Alert</h2>
    <p>Search for a skin, then set your target price. You'll see the current lowest price to help you decide.</p>

    <div class="pa-search-box">
      <label for="skinSearch">Search Skins</label>
      <input type="text" id="skinSearch" placeholder="Type a skin name, e.g. Dragon Lore, Asiimov, Fade..." autocomplete="off" />
      <div id="searchResults" class="pa-search-results"></div>
    </div>

    <div id="selectedSkin" class="pa-selected" style="display:none">
      <div class="pa-selected-info">
        <div class="pa-selected-name" id="selectedName"></div>
        <div class="pa-selected-weapon" id="selectedWeapon"></div>
        <div class="pa-selected-price">Current lowest: <strong id="selectedPrice"></strong></div>
        <a id="selectedLink" href="#" class="pa-selected-link">View skin details</a>
      </div>
      <div class="pa-target-row">
        <label for="targetPrice">Target Price ($)</label>
        <input type="number" id="targetPrice" min="0.01" step="0.01" placeholder="0.00" />
      </div>
      <button id="addAlertBtn" class="pa-add-btn">Add Alert</button>
      <button id="cancelBtn" class="pa-cancel-btn">Cancel</button>
    </div>
  </section>

  <!-- Active Alerts List -->
  <section class="pa-alerts">
    <h2>Your Alerts</h2>
    <p id="alertsEmpty" class="pa-alerts-empty">No alerts yet. Search for a skin above to add your first price alert.</p>
    <div id="alertsList" class="pa-alerts-list"></div>
  </section>

  <!-- How It Works -->
  <section class="pa-how">
    <h2>How Price Alerts Work</h2>
    <div class="pa-steps">
      <div class="pa-step">
        <div class="pa-step-num">1</div>
        <div class="pa-step-body">
          <h3>Search & Select</h3>
          <p>Find the skin you want to track using the search bar. We index {totalTracked.toLocaleString()}+ skins with live marketplace pricing.</p>
        </div>
      </div>
      <div class="pa-step">
        <div class="pa-step-num">2</div>
        <div class="pa-step-body">
          <h3>Set Your Target</h3>
          <p>Enter the price you want to pay. You can see the current lowest price to set a realistic target below market value.</p>
        </div>
      </div>
      <div class="pa-step">
        <div class="pa-step-num">3</div>
        <div class="pa-step-body">
          <h3>Check Back</h3>
          <p>Visit this page anytime to check your alerts. When a skin's price drops to or below your target, the alert is triggered automatically.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Tips Section -->
  <section class="pa-tips">
    <h2>Tips for Setting Price Alerts</h2>
    <ul class="pa-tip-list">
      <li>Set target prices 10-20% below current market value for realistic alerts that may trigger within weeks.</li>
      <li>Watch for major Steam sales and CS2 updates, which often cause temporary price dips across the market.</li>
      <li>Track multiple wear conditions of the same skin to catch the best deal regardless of float.</li>
      <li>Bookmark this page and check regularly. Prices update at each site build with fresh marketplace data.</li>
      <li>Combine price alerts with the <a href="/market-trends/">Market Trends</a> tool to identify skins that are trending downward.</li>
      <li>Use the <a href="/price-tracker/">Price Tracker</a> to research price ranges before setting your target.</li>
    </ul>
  </section>

  <!-- FAQ -->
  <section class="pa-faq">
    <h2>Frequently Asked Questions</h2>
    {faqs.map(f => (
      <details class="pa-faq-item">
        <summary>{f.question}</summary>
        <p>{f.answer}</p>
      </details>
    ))}
  </section>

  <!-- Internal Links -->
  <section class="pa-related">
    <h2>Related Tools & Guides</h2>
    <div class="pa-related-list">
      <a href="/cs2-skins/" class="pa-related-row">Skin Database</a>
      <a href="/price-tracker/" class="pa-related-row">Price Tracker</a>
      <a href="/market-trends/" class="pa-related-row">Market Trends</a>
      <a href="/skin-compare/" class="pa-related-row">Compare Skins</a>
      <a href="/float-checker/" class="pa-related-row">Float Checker</a>
      <a href="/tradeup-calculator/" class="pa-related-row">Trade-Up Calculator</a>
      <a href="/inventory-lookup/" class="pa-related-row">Inventory Lookup</a>
      <a href="/loadout-builder/" class="pa-related-row">Loadout Builder</a>
      <a href="/cs2-guides/trading-guide/" class="pa-related-row">Trading Guide</a>
      <a href="/cs2-guides/skins-investing-guide/" class="pa-related-row">Skins Investing Guide</a>
      <a href="/cs2-guides/float-guide/" class="pa-related-row">Float Value Guide</a>
    </div>
  </section>

  <ExploreMore context="skins" />
</Base>

<!-- Embed build-time skin data for client-side JS -->
<script is:inline define:vars={{ skinsData }}>
  // ── Skin price alert data (build-time) ──────────────────────────────────────
  var SKINS_DATA = skinsData;
  var STORAGE_KEY = 'csgoluck_price_alerts';

  // ── Helpers ─────────────────────────────────────────────────────────────────
  function loadAlerts() {
    try {
      var raw = localStorage.getItem(STORAGE_KEY);
      return raw ? JSON.parse(raw) : [];
    } catch (e) {
      return [];
    }
  }

  function saveAlerts(alerts) {
    try {
      localStorage.setItem(STORAGE_KEY, JSON.stringify(alerts));
    } catch (e) {
      // localStorage full or unavailable
    }
  }

  function formatPrice(num) {
    return '$' + Number(num).toFixed(2);
  }

  function findSkinData(slug) {
    for (var i = 0; i < SKINS_DATA.length; i++) {
      if (SKINS_DATA[i].slug === slug) return SKINS_DATA[i];
    }
    return null;
  }

  // ── Search functionality ────────────────────────────────────────────────────
  var searchInput = document.getElementById('skinSearch');
  var resultsContainer = document.getElementById('searchResults');
  var selectedSkinEl = document.getElementById('selectedSkin');
  var selectedNameEl = document.getElementById('selectedName');
  var selectedWeaponEl = document.getElementById('selectedWeapon');
  var selectedPriceEl = document.getElementById('selectedPrice');
  var selectedLinkEl = document.getElementById('selectedLink');
  var targetPriceInput = document.getElementById('targetPrice');
  var addAlertBtn = document.getElementById('addAlertBtn');
  var cancelBtn = document.getElementById('cancelBtn');
  var alertsList = document.getElementById('alertsList');
  var alertsEmpty = document.getElementById('alertsEmpty');
  var alertCountEl = document.getElementById('alertCount');
  var triggeredCountEl = document.getElementById('triggeredCount');
  var watchingCountEl = document.getElementById('watchingCount');

  var currentSelection = null;
  var debounceTimer = null;

  searchInput.addEventListener('input', function() {
    clearTimeout(debounceTimer);
    var query = this.value.trim().toLowerCase();
    if (query.length < 2) {
      resultsContainer.innerHTML = '';
      resultsContainer.style.display = 'none';
      return;
    }
    debounceTimer = setTimeout(function() {
      var matches = [];
      for (var i = 0; i < SKINS_DATA.length; i++) {
        var s = SKINS_DATA[i];
        if (s.name.toLowerCase().indexOf(query) !== -1 || s.weapon.toLowerCase().indexOf(query) !== -1) {
          matches.push(s);
          if (matches.length >= 15) break;
        }
      }
      renderResults(matches);
    }, 200);
  });

  function renderResults(matches) {
    if (matches.length === 0) {
      resultsContainer.innerHTML = '<div class="pa-no-results">No skins found. Try a different search term.</div>';
      resultsContainer.style.display = 'block';
      return;
    }
    var html = '';
    for (var i = 0; i < matches.length; i++) {
      var m = matches[i];
      html += '<button class="pa-result-item" data-slug="' + m.slug + '">';
      html += '<span class="pa-result-name">' + escapeHtml(m.name) + '</span>';
      html += '<span class="pa-result-meta">' + escapeHtml(m.weapon) + ' &middot; ' + formatPrice(m.lowestPrice) + '</span>';
      html += '</button>';
    }
    resultsContainer.innerHTML = html;
    resultsContainer.style.display = 'block';

    // Attach click handlers
    var items = resultsContainer.querySelectorAll('.pa-result-item');
    for (var j = 0; j < items.length; j++) {
      items[j].addEventListener('click', function() {
        var slug = this.getAttribute('data-slug');
        selectSkin(slug);
      });
    }
  }

  function escapeHtml(str) {
    var div = document.createElement('div');
    div.textContent = str;
    return div.innerHTML;
  }

  function selectSkin(slug) {
    var skin = findSkinData(slug);
    if (!skin) return;

    currentSelection = skin;
    selectedNameEl.textContent = skin.name;
    selectedWeaponEl.textContent = skin.weapon;
    selectedPriceEl.textContent = formatPrice(skin.lowestPrice);
    selectedLinkEl.href = '/cs2-skin/' + skin.slug + '/';
    targetPriceInput.value = '';
    selectedSkinEl.style.display = 'block';

    // Suggest a target price slightly below current
    var suggested = Math.max(0.01, skin.lowestPrice * 0.85);
    targetPriceInput.placeholder = suggested.toFixed(2);

    resultsContainer.innerHTML = '';
    resultsContainer.style.display = 'none';
    searchInput.value = '';
    targetPriceInput.focus();
  }

  // Cancel selection
  cancelBtn.addEventListener('click', function() {
    selectedSkinEl.style.display = 'none';
    currentSelection = null;
    searchInput.focus();
  });

  // Close results on outside click
  document.addEventListener('click', function(e) {
    if (!resultsContainer.contains(e.target) && e.target !== searchInput) {
      resultsContainer.style.display = 'none';
    }
  });

  // ── Add alert ───────────────────────────────────────────────────────────────
  addAlertBtn.addEventListener('click', function() {
    if (!currentSelection) return;
    var target = parseFloat(targetPriceInput.value);
    if (isNaN(target) || target <= 0) {
      targetPriceInput.style.borderColor = 'var(--red)';
      setTimeout(function() { targetPriceInput.style.borderColor = ''; }, 1500);
      return;
    }

    var alerts = loadAlerts();

    // Check for duplicate
    for (var i = 0; i < alerts.length; i++) {
      if (alerts[i].slug === currentSelection.slug && alerts[i].targetPrice === target) {
        // Already exists
        targetPriceInput.style.borderColor = 'var(--red)';
        setTimeout(function() { targetPriceInput.style.borderColor = ''; }, 1500);
        return;
      }
    }

    var newAlert = {
      id: Date.now().toString(36) + Math.random().toString(36).substr(2, 5),
      slug: currentSelection.slug,
      name: currentSelection.name,
      weapon: currentSelection.weapon,
      targetPrice: target,
      createdAt: new Date().toISOString(),
      triggered: false,
    };

    alerts.push(newAlert);
    saveAlerts(alerts);

    // Reset UI
    selectedSkinEl.style.display = 'none';
    currentSelection = null;

    renderAlerts();
  });

  // ── Render alerts ───────────────────────────────────────────────────────────
  function renderAlerts() {
    var alerts = loadAlerts();

    // Check alerts against current prices
    var triggeredTotal = 0;
    var watchingTotal = 0;

    for (var i = 0; i < alerts.length; i++) {
      var skin = findSkinData(alerts[i].slug);
      if (skin && skin.lowestPrice <= alerts[i].targetPrice) {
        alerts[i].triggered = true;
        triggeredTotal++;
      } else {
        alerts[i].triggered = false;
        watchingTotal++;
      }
    }

    saveAlerts(alerts);

    // Update stats
    alertCountEl.textContent = alerts.length;
    triggeredCountEl.textContent = triggeredTotal;
    watchingCountEl.textContent = watchingTotal;

    if (alerts.length === 0) {
      alertsEmpty.style.display = 'block';
      alertsList.innerHTML = '';
      return;
    }

    alertsEmpty.style.display = 'none';

    // Sort: triggered first, then by created date descending
    var sorted = alerts.slice().sort(function(a, b) {
      if (a.triggered && !b.triggered) return -1;
      if (!a.triggered && b.triggered) return 1;
      return new Date(b.createdAt) - new Date(a.createdAt);
    });

    var html = '';
    for (var i = 0; i < sorted.length; i++) {
      var a = sorted[i];
      var skin = findSkinData(a.slug);
      var currentPrice = skin ? formatPrice(skin.lowestPrice) : 'N/A';
      var statusClass = a.triggered ? 'pa-status-triggered' : 'pa-status-watching';
      var statusLabel = a.triggered ? 'Triggered' : 'Watching';
      var createdDate = new Date(a.createdAt).toLocaleDateString();

      html += '<div class="pa-alert-card ' + (a.triggered ? 'pa-alert-triggered' : '') + '">';
      html += '<div class="pa-alert-header">';
      html += '<div class="pa-alert-skin-info">';
      html += '<a href="/cs2-skin/' + a.slug + '/" class="pa-alert-name">' + escapeHtml(a.name) + '</a>';
      html += '<span class="pa-alert-weapon">' + escapeHtml(a.weapon) + '</span>';
      html += '</div>';
      html += '<span class="pa-alert-status ' + statusClass + '">' + statusLabel + '</span>';
      html += '</div>';
      html += '<div class="pa-alert-prices">';
      html += '<div class="pa-alert-price-item"><span class="pa-alert-price-label">Current Price</span><span class="pa-alert-price-value">' + currentPrice + '</span></div>';
      html += '<div class="pa-alert-price-item"><span class="pa-alert-price-label">Target Price</span><span class="pa-alert-price-value pa-alert-target">' + formatPrice(a.targetPrice) + '</span></div>';
      if (skin && !a.triggered) {
        var diff = skin.lowestPrice - a.targetPrice;
        var pct = ((diff / skin.lowestPrice) * 100).toFixed(1);
        html += '<div class="pa-alert-price-item"><span class="pa-alert-price-label">Difference</span><span class="pa-alert-price-value pa-alert-diff">-' + formatPrice(diff) + ' (' + pct + '%)</span></div>';
      }
      html += '</div>';
      html += '<div class="pa-alert-footer">';
      html += '<span class="pa-alert-date">Added ' + createdDate + '</span>';
      html += '<button class="pa-alert-delete" data-id="' + a.id + '">Remove</button>';
      html += '</div>';
      html += '</div>';
    }
    alertsList.innerHTML = html;

    // Attach delete handlers
    var deleteBtns = alertsList.querySelectorAll('.pa-alert-delete');
    for (var d = 0; d < deleteBtns.length; d++) {
      deleteBtns[d].addEventListener('click', function() {
        var id = this.getAttribute('data-id');
        deleteAlert(id);
      });
    }
  }

  // ── Delete alert ────────────────────────────────────────────────────────────
  function deleteAlert(id) {
    var alerts = loadAlerts();
    alerts = alerts.filter(function(a) { return a.id !== id; });
    saveAlerts(alerts);
    renderAlerts();
  }

  // ── Initialize on page load ─────────────────────────────────────────────────
  renderAlerts();
</script>

<style is:inline>
/* ── Breadcrumb ── */
.pa-breadcrumb{font-size:.82rem;color:var(--text2);margin-bottom:1.25rem;display:flex;gap:.35rem;flex-wrap:wrap}
.pa-breadcrumb a{color:var(--accent);text-decoration:none}
.pa-breadcrumb a:hover{text-decoration:underline}

/* ── Hero ── */
.pa-hero{background:var(--bg2);border:1px solid var(--border);border-radius:4px;padding:2rem;margin-bottom:1.5rem}
.pa-hero h1{font-family:'Montserrat',sans-serif;font-size:2rem;font-weight:800;margin:0 0 .5rem;color:var(--text)}
.pa-hero p{color:var(--text2);font-size:.95rem;line-height:1.6;margin:0}

/* ── Stats ── */
.pa-stats{display:flex;gap:2px;margin-bottom:2rem;flex-wrap:wrap}
.pa-stat{flex:1;min-width:120px;background:var(--bg2);border:1px solid var(--border);border-radius:4px;padding:1rem;text-align:center}
.pa-stat-val{font-family:'Montserrat',sans-serif;font-size:1.5rem;font-weight:800;color:var(--accent)}
.pa-stat-label{font-size:.78rem;color:var(--text2);text-transform:uppercase;letter-spacing:.04em;font-weight:600;margin-top:.25rem}

/* ── Alert Builder ── */
.pa-builder{background:var(--bg2);border:1px solid var(--border);border-radius:4px;padding:1.5rem;margin-bottom:2rem}
.pa-builder h2{font-family:'Montserrat',sans-serif;color:var(--text);margin:0 0 .5rem;font-size:1.15rem;font-weight:700}
.pa-builder>p{color:var(--text2);margin-bottom:1.5rem;font-size:.95rem}

/* ── Search Box ── */
.pa-search-box{position:relative;margin-bottom:1rem}
.pa-search-box label{display:block;font-size:.85rem;font-weight:600;color:var(--text2);margin-bottom:.4rem;text-transform:uppercase;letter-spacing:.04em}
.pa-search-box input{width:100%;background:var(--bg3);color:var(--text);border:1px solid var(--border);padding:.65rem 1rem;border-radius:4px;font-size:.95rem;font-family:inherit;transition:border-color .2s}
.pa-search-box input:focus{outline:none;border-color:var(--accent)}
.pa-search-box input::placeholder{color:var(--text2);opacity:.6}

/* ── Search Results Dropdown ── */
.pa-search-results{display:none;position:absolute;top:100%;left:0;right:0;background:var(--bg2);border:1px solid var(--border);border-radius:0 0 4px 4px;max-height:320px;overflow-y:auto;z-index:50}
.pa-result-item{display:flex;justify-content:space-between;align-items:center;width:100%;padding:.6rem 1rem;background:none;border:none;border-bottom:1px solid var(--border);color:var(--text);font-family:inherit;font-size:.9rem;cursor:pointer;text-align:left;transition:background .15s;gap:.75rem}
.pa-result-item:last-child{border-bottom:none}
.pa-result-item:hover{background:var(--bg3)}
.pa-result-name{font-weight:600;flex:1;min-width:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.pa-result-meta{color:var(--text2);font-size:.82rem;white-space:nowrap;flex-shrink:0}
.pa-no-results{padding:1rem;color:var(--text2);text-align:center;font-size:.9rem}

/* ── Selected Skin ── */
.pa-selected{background:var(--bg3);border:2px solid var(--accent);border-radius:4px;padding:1.25rem;margin-top:1rem}
.pa-selected-info{margin-bottom:1rem}
.pa-selected-name{font-size:1.15rem;font-weight:700;color:var(--text);margin-bottom:.2rem}
.pa-selected-weapon{font-size:.85rem;color:var(--text2);margin-bottom:.4rem}
.pa-selected-price{font-size:.95rem;color:var(--text2);margin-bottom:.3rem}
.pa-selected-price strong{color:var(--green);font-size:1.1rem}
.pa-selected-link{font-size:.82rem;color:var(--accent);text-decoration:none;font-weight:600}
.pa-selected-link:hover{text-decoration:underline}

.pa-target-row{display:flex;align-items:center;gap:.75rem;margin:1rem 0;flex-wrap:wrap}
.pa-target-row label{font-weight:600;font-size:.9rem;color:var(--text);white-space:nowrap}
.pa-target-row input{background:var(--bg2);color:var(--text);border:1px solid var(--border);padding:.5rem .75rem;border-radius:4px;font-size:.95rem;font-family:inherit;width:140px;transition:border-color .2s}
.pa-target-row input:focus{outline:none;border-color:var(--accent)}

.pa-add-btn{background:var(--accent);color:var(--bg);border:none;padding:.55rem 1.5rem;border-radius:4px;font-size:.9rem;font-weight:700;font-family:inherit;cursor:pointer;transition:background .2s;margin-right:.5rem}
.pa-add-btn:hover{background:var(--accent2)}
.pa-cancel-btn{background:var(--bg2);color:var(--text2);border:1px solid var(--border);padding:.55rem 1rem;border-radius:4px;font-size:.9rem;font-weight:600;font-family:inherit;cursor:pointer;transition:background .2s,color .2s}
.pa-cancel-btn:hover{background:var(--bg3);color:var(--text)}

/* ── Alerts Section ── */
.pa-alerts{margin-bottom:2rem}
