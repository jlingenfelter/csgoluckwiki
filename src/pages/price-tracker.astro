---
import Base from '../layouts/Base.astro';
import ExploreMore from '../components/ExploreMore.astro';
import { SKINS, getLowestPrice, getHighestPrice, RARITY_COLORS, fmtPrice } from '../lib/skins';
import { faqSchema, breadcrumbSchema, toolAppSchema } from '../lib/weapons';

const title = 'CS2 Skin Price Tracker & Market Overview | CSGOLuck Wiki';
const description = 'Real-time CS2 skin price tracking and market analysis. Compare prices across all skins, find the cheapest deals, track market trends, and analyze price distributions by rarity and category.';

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Tools', url: '/' },
  { name: 'Price Tracker', url: '/price-tracker/' },
];

// Compute market stats from SKINS data
const allSkins = [...SKINS];
const skinsWithPrices = allSkins.filter(s => s.prices.length > 0);
const totalValue = skinsWithPrices.reduce((sum, s) => sum + getHighestPrice(s), 0);
const avgPrice = skinsWithPrices.length > 0 ? totalValue / skinsWithPrices.length : 0;
const mostExpensive = [...skinsWithPrices].sort((a, b) => getHighestPrice(b) - getHighestPrice(a)).slice(0, 20);
const cheapest = [...skinsWithPrices].sort((a, b) => getLowestPrice(a) - getLowestPrice(b)).slice(0, 20);

// Category breakdowns
const categories: Record<string, { count: number; total: number; avg: number }> = {};
for (const s of skinsWithPrices) {
  if (!categories[s.category]) categories[s.category] = { count: 0, total: 0, avg: 0 };
  categories[s.category].count++;
  categories[s.category].total += getHighestPrice(s);
}
for (const c in categories) {
  categories[c].avg = categories[c].total / categories[c].count;
}

// Rarity breakdowns
const rarities: Record<string, { count: number; total: number; avg: number }> = {};
for (const s of skinsWithPrices) {
  if (!rarities[s.rarity]) rarities[s.rarity] = { count: 0, total: 0, avg: 0 };
  rarities[s.rarity].count++;
  rarities[s.rarity].total += getHighestPrice(s);
}
for (const r in rarities) {
  rarities[r].avg = rarities[r].total / rarities[r].count;
}

// Price range distribution
const ranges = [
  { label: 'Under $1', min: 0, max: 1, count: 0 },
  { label: '$1 – $5', min: 1, max: 5, count: 0 },
  { label: '$5 – $25', min: 5, max: 25, count: 0 },
  { label: '$25 – $100', min: 25, max: 100, count: 0 },
  { label: '$100 – $500', min: 100, max: 500, count: 0 },
  { label: '$500 – $2,000', min: 500, max: 2000, count: 0 },
  { label: '$2,000+', min: 2000, max: Infinity, count: 0 },
];
for (const s of skinsWithPrices) {
  const p = getHighestPrice(s);
  const range = ranges.find(r => p >= r.min && p < r.max);
  if (range) range.count++;
}

// Get category labels
const categoryLabels: Record<string, string> = {
  rifle: 'Rifles',
  pistol: 'Pistols',
  smg: 'SMGs',
  heavy: 'Heavy',
  knife: 'Knives',
  glove: 'Gloves',
  other: 'Other',
};

const faqs = [
  { question: 'What factors affect CS2 skin prices?', answer: 'CS2 skin prices are influenced by rarity tier, wear condition (float), whether the skin is StatTrak or Souvenir, case discontinuation, pro player popularity, in-game meta shifts, and overall market supply and demand.' },
  { question: 'Why do some cheap skins cost less than a dollar?', answer: 'Consumer Grade and Industrial Grade skins have lower rarity and are more common drops from cases or trades. These entry-level skins are perfect for beginners or players building a collection on a budget.' },
  { question: 'Do knife prices follow the same trends as weapon skins?', answer: 'Knives are rarer and typically much more expensive than weapon skins. While they follow general market trends, knife prices are more volatile because supply is extremely limited and demand is high among collectors.' },
  { question: 'What is a Factory New skin worth compared to Battle-Scarred?', answer: 'Factory New (FN) skins are typically 2–10x more expensive than Battle-Scarred versions of the same skin, depending on rarity and demand. The price difference reflects both aesthetics and collector preference.' },
  { question: 'How often do skin prices update?', answer: 'Prices on CSGOLuck Wiki are sourced from multiple marketplaces and updated regularly. The exact update frequency varies by marketplace, but prices typically reflect current market conditions within hours.' },
  { question: 'Should I invest in expensive skins or cheap skins?', answer: 'Investment potential varies. Cheap skins can appreciate quickly if a case is discontinued or a pro uses the skin in-game. Expensive skins (Covert, knives) tend to hold value better but require more capital. Diversification is key.' },
];
---

<Base title={title} description={description} currentNav="/cs2-tools/">
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema(breadcrumbs))}></script>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema(faqs))}></script>
  <script type="application/ld+json" set:html={JSON.stringify(toolAppSchema({ name: 'CS2 Skin Price Tracker', url: 'https://wiki.csgoluck.com/price-tracker/', description }))}></script>

  <nav class="pt-breadcrumb">
    <a href="/">Home</a> / <a href="/">Tools</a> / <span>Price Tracker</span>
  </nav>

  <section class="pt-hero">
    <h1>CS2 Skin Price Tracker</h1>
    <p>Explore live pricing data for all CS2 weapon skins, knives, and gloves. Track market trends, find the best deals, and analyze price distributions by rarity and weapon category.</p>
  </section>

  <!-- Market Overview Stats -->
  <section class="pt-overview">
    <h2>Market Overview</h2>
    <div class="pt-stats">
      <div class="pt-stat">
        <div class="pt-stat-val">{skinsWithPrices.length}</div>
        <div class="pt-stat-label">Skins Tracked</div>
      </div>
      <div class="pt-stat">
        <div class="pt-stat-val">${fmtPrice(totalValue).split('.')[0]}</div>
        <div class="pt-stat-label">Total Market Value</div>
      </div>
      <div class="pt-stat">
        <div class="pt-stat-val">${fmtPrice(avgPrice)}</div>
        <div class="pt-stat-label">Average Skin Price</div>
      </div>
      <div class="pt-stat">
        <div class="pt-stat-val">${fmtPrice(getHighestPrice(mostExpensive[0]))}</div>
        <div class="pt-stat-label">Most Expensive Skin</div>
      </div>
    </div>
  </section>

  <!-- Price Distribution -->
  <section class="pt-distribution">
    <h2>Price Range Distribution</h2>
    <p>How many CS2 skins fall into each price bracket.</p>
    <div class="pt-chart">
      {ranges.map((range) => {
        const maxCount = Math.max(...ranges.map(r => r.count));
        const percentage = maxCount > 0 ? (range.count / maxCount) * 100 : 0;
        return (
          <div class="pt-chart-row">
            <div class="pt-chart-label">{range.label}</div>
            <div class="pt-chart-bar-wrap">
              <div
                class="pt-chart-bar"
                style={`width: ${percentage}%`}
                title={`${range.count} skins`}
              ></div>
            </div>
            <div class="pt-chart-count">{range.count}</div>
          </div>
        );
      })}
    </div>
  </section>

  <!-- Most Expensive Skins Table -->
  <section class="pt-section">
    <h2>Most Expensive Skins</h2>
    <p>The top 20 highest-priced CS2 skins on the market.</p>
    <div class="pt-table-wrap">
      <table class="pt-table">
        <thead>
          <tr>
            <th class="pt-col-rank">Rank</th>
            <th class="pt-col-name">Skin Name</th>
            <th class="pt-col-weapon">Weapon</th>
            <th class="pt-col-rarity">Rarity</th>
            <th class="pt-col-price">Highest Price</th>
          </tr>
        </thead>
        <tbody>
          {mostExpensive.map((skin, idx) => {
            const rarityColor = RARITY_COLORS[skin.rarity] || '#fff';
            return (
              <tr>
                <td class="pt-col-rank">{idx + 1}</td>
                <td class="pt-col-name">
                  <a href={`/cs2-skin/${skin.slug}/`} class="pt-skin-link">{skin.name}</a>
                </td>
                <td class="pt-col-weapon">{skin.weapon}</td>
                <td class="pt-col-rarity">
                  <span class="pt-rarity-badge" style={`color: ${rarityColor}`}>
                    {skin.rarity}
                  </span>
                </td>
                <td class="pt-col-price">${fmtPrice(getHighestPrice(skin))}</td>
              </tr>
            );
          })}
        </tbody>
      </table>
    </div>
  </section>

  <!-- Cheapest Skins Table -->
  <section class="pt-section">
    <h2>Best Budget Skins</h2>
    <p>The 20 cheapest CS2 skins to start your collection.</p>
    <div class="pt-table-wrap">
      <table class="pt-table">
        <thead>
          <tr>
            <th class="pt-col-rank">Rank</th>
            <th class="pt-col-name">Skin Name</th>
            <th class="pt-col-weapon">Weapon</th>
            <th class="pt-col-rarity">Rarity</th>
            <th class="pt-col-price">Lowest Price</th>
          </tr>
        </thead>
        <tbody>
          {cheapest.map((skin, idx) => {
            const rarityColor = RARITY_COLORS[skin.rarity] || '#fff';
            return (
              <tr>
                <td class="pt-col-rank">{idx + 1}</td>
                <td class="pt-col-name">
                  <a href={`/cs2-skin/${skin.slug}/`} class="pt-skin-link">{skin.name}</a>
                </td>
                <td class="pt-col-weapon">{skin.weapon}</td>
                <td class="pt-col-rarity">
                  <span class="pt-rarity-badge" style={`color: ${rarityColor}`}>
                    {skin.rarity}
                  </span>
                </td>
                <td class="pt-col-price">${fmtPrice(getLowestPrice(skin))}</td>
              </tr>
            );
          })}
        </tbody>
      </table>
    </div>
  </section>

  <!-- Category Price Analysis -->
  <section class="pt-section">
    <h2>Average Price by Category</h2>
    <p>Compare average skin prices across weapon categories.</p>
    <div class="pt-cat-list">
      {Object.entries(categories)
        .sort((a, b) => b[1].avg - a[1].avg)
        .map(([cat, data]) => (
          <div class="pt-cat-row">
            <span class="pt-cat-name">{categoryLabels[cat] || cat}</span>
            <span class="pt-cat-count">{data.count} skins</span>
            <span class="pt-cat-avg">${fmtPrice(data.avg)}</span>
          </div>
        ))}
    </div>
  </section>

  <!-- Rarity Value Analysis -->
  <section class="pt-section">
    <h2>Average Price by Rarity</h2>
    <p>How rarity tier correlates with average skin value.</p>
    <div class="pt-rarity-list">
      {Object.entries(rarities)
        .sort((a, b) => b[1].avg - a[1].avg)
        .map(([rarity, data]) => {
          const rarityColor = RARITY_COLORS[rarity] || '#fff';
          return (
            <div class="pt-rarity-row" style={`--rarity-color: ${rarityColor}`}>
              <span class="pt-rarity-name">{rarity}</span>
              <span class="pt-rarity-count">{data.count} skins</span>
              <span class="pt-rarity-price">${fmtPrice(data.avg)}</span>
            </div>
          );
        })}
    </div>
  </section>

  <!-- Price Trends Tips -->
  <section class="pt-section">
    <h2>What Drives CS2 Skin Prices?</h2>
    <div class="pt-drivers-list">
      <div class="pt-driver-row">
        <h3>Case Discontinuation</h3>
        <p>When Valve retires a case from rotation, supply decreases and prices often increase. Discontinued skins tend to become more valuable over time as supply dwindles.</p>
      </div>
      <div class="pt-driver-row">
        <h3>Game Updates & Meta</h3>
        <p>Major weapon balance changes can shift player preference. When a gun gets buffed or nerfed, skins for that weapon often see price fluctuations within hours.</p>
      </div>
      <div class="pt-driver-row">
        <h3>Pro Player Usage</h3>
        <p>Pro esports players have enormous influence. When a famous player uses a specific skin in a tournament, its popularity and price can spike dramatically.</p>
      </div>
      <div class="pt-driver-row">
        <h3>Float Condition</h3>
        <p>Factory New (FN) skins are always more expensive than Battle-Scarred versions. The float value (wear condition) can affect prices by a factor of 2x–10x or more.</p>
      </div>
      <div class="pt-driver-row">
        <h3>StatTrak & Souvenir</h3>
        <p>StatTrak versions (with kill counter) and Souvenir drops from major tournaments are rarer and command significant premiums—sometimes 2–5x the base price.</p>
      </div>
      <div class="pt-driver-row">
        <h3>Rarity Tier</h3>
        <p>Covert and Classified skins are inherently rarer and more expensive. Consumer and Industrial Grade skins are abundant and cheap, making them perfect for budget collectors.</p>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="pt-faq">
    <h2>Frequently Asked Questions</h2>
    {faqs.map(f => (
      <details class="pt-faq-item">
        <summary>{f.question}</summary>
        <p>{f.answer}</p>
      </details>
    ))}
  </section>

  <!-- Internal Links -->
  <section class="pt-related">
    <h2>Related Tools & Guides</h2>
    <div class="pt-related-list">
      <a href="/cs2-skins/" class="pt-related-row">Skin Database</a>
      <a href="/skin-compare/" class="pt-related-row">Compare Skins</a>
      <a href="/market-trends/" class="pt-related-row">Market Trends</a>
      <a href="/float-checker/" class="pt-related-row">Float Checker</a>
      <a href="/tradeup-calculator/" class="pt-related-row">Trade-Up Calculator</a>
      <a href="/case-odds-calculator/" class="pt-related-row">Case Odds Calculator</a>
      <a href="/case-simulator/" class="pt-related-row">Case Simulator</a>
      <a href="/cs2-cases/" class="pt-related-row">Cases & Collections</a>
      <a href="/inventory-lookup/" class="pt-related-row">Inventory Lookup</a>
      <a href="/loadout-builder/" class="pt-related-row">Loadout Builder</a>
      <a href="/cs2-weapons/" class="pt-related-row">Weapon Database</a>
      <a href="/cs2-guides/trading-guide/" class="pt-related-row">Trading Guide</a>
      <a href="/cs2-guides/float-guide/" class="pt-related-row">Float Value Guide</a>
      <a href="/cs2-guides/skins-investing-guide/" class="pt-related-row">Skins Investing Guide</a>
    </div>
  </section>

  <ExploreMore context="skins" />
</Base>

<style>
/* ── Breadcrumb ── */
.pt-breadcrumb{font-size:.82rem;color:var(--text2);margin-bottom:1.25rem;display:flex;gap:.35rem;flex-wrap:wrap}
.pt-breadcrumb a{color:var(--accent);text-decoration:none}
.pt-breadcrumb a:hover{text-decoration:underline}

/* ── Hero ── */
.pt-hero{background:var(--bg2);border:1px solid var(--border);border-radius:4px;padding:2rem;margin-bottom:1.5rem}
.pt-hero h1{font-family:'Montserrat',sans-serif;font-size:2rem;font-weight:800;margin:0 0 .5rem;color:var(--text)}
.pt-hero p{color:var(--text2);font-size:.95rem;line-height:1.6;margin:0}

/* ── Overview Stats ── */
.pt-overview{margin-bottom:2rem}
.pt-overview h2{font-family:'Montserrat',sans-serif;font-size:1.15rem;font-weight:700;color:var(--text);margin:0 0 .75rem}
.pt-stats{display:flex;gap:2px;flex-wrap:wrap}
.pt-stat{flex:1;min-width:140px;background:var(--bg2);border:1px solid var(--border);border-radius:4px;padding:1rem;text-align:center}
.pt-stat-val{font-family:'Montserrat',sans-serif;font-size:1.4rem;font-weight:800;color:var(--accent)}
.pt-stat-label{font-size:.78rem;color:var(--text2);text-transform:uppercase;letter-spacing:.04em;font-weight:600;margin-top:.25rem}

/* ── Price Distribution ── */
.pt-distribution{background:var(--bg2);border:1px solid var(--border);border-radius:4px;padding:1.5rem;margin-bottom:2rem}
.pt-distribution h2{font-family:'Montserrat',sans-serif;font-size:1.15rem;font-weight:700;color:var(--text);margin:0 0 .5rem}
.pt-distribution>p{color:var(--text2);margin-bottom:1.5rem;font-size:.95rem}
.pt-chart{display:flex;flex-direction:column;gap:1rem}
.pt-chart-row{display:grid;grid-template-columns:100px 1fr 50px;align-items:center;gap:1rem}
.pt-chart-label{color:var(--text2);font-size:.9rem;font-weight:600;text-align:right}
.pt-chart-bar-wrap{background:var(--bg3);border-radius:4px;overflow:hidden;min-height:28px;display:flex;align-items:center}
.pt-chart-bar{height:24px;background:var(--accent);border-radius:4px;min-width:4px}
.pt-chart-count{color:var(--text);font-weight:700;font-size:.9rem;text-align:right}

/* ── Sections ── */
.pt-section{margin-bottom:2rem}
.pt-section h2{font-family:'Montserrat',sans-serif;font-size:1.15rem;font-weight:700;color:var(--text);margin:0 0 .5rem}
.pt-section>p{color:var(--text2);margin-bottom:1rem;font-size:.95rem}

/* ── Tables ── */
.pt-table-wrap{overflow-x:auto;border-radius:4px;border:1px solid var(--border)}
.pt-table{width:100%;border-collapse:collapse;background:var(--bg2);font-size:.95rem}
.pt-table thead{background:var(--bg3);border-bottom:2px solid var(--border)}
.pt-table th{color:var(--text);padding:.75rem;text-align:left;font-weight:700;font-size:.9rem}
.pt-table td{padding:.75rem;border-bottom:1px solid var(--border);color:var(--text)}
.pt-table tbody tr:hover{background:var(--bg3)}
.pt-col-rank{width:60px;text-align:center;font-weight:700;color:var(--accent)}
.pt-col-name{min-width:200px}
.pt-skin-link{color:var(--accent);text-decoration:none;font-weight:600}
.pt-skin-link:hover{text-decoration:underline}
.pt-col-weapon{width:120px;color:var(--text2);font-weight:500}
.pt-col-rarity{width:140px}
.pt-rarity-badge{font-weight:700;padding:.3rem .6rem;border-radius:4px;display:inline-block}
.pt-col-price{width:130px;text-align:right;font-weight:700;color:var(--green)}

/* ── Category List ── */
.pt-cat-list{display:flex;flex-direction:column;gap:2px}
.pt-cat-row{display:flex;align-items:center;gap:1rem;background:var(--bg2);border:1px solid var(--border);border-left:3px solid transparent;border-radius:4px;padding:.75rem 1rem;transition:border-color .15s,background .15s}
.pt-cat-row:hover{border-left-color:var(--accent);background:var(--bg3)}
.pt-cat-name{font-weight:700;font-size:.95rem;color:var(--text);min-width:80px}
.pt-cat-count{font-size:.82rem;color:var(--text2);flex:1}
.pt-cat-avg{font-weight:700;font-size:1rem;color:var(--accent)}

/* ── Rarity List ── */
.pt-rarity-list{display:flex;flex-direction:column;gap:2px}
.pt-rarity-row{display:flex;align-items:center;gap:1rem;background:var(--bg2);border:1px solid var(--border);border-left:3px solid var(--rarity-color);border-radius:4px;padding:.75rem 1rem;transition:background .15s}
.pt-rarity-row:hover{background:var(--bg3)}
.pt-rarity-name{font-weight:700;font-size:.95rem;color:var(--rarity-color);min-width:100px}
.pt-rarity-count{font-size:.82rem;color:var(--text2);flex:1}
.pt-rarity-price{font-weight:700;font-size:1rem;color:var(--rarity-color)}

/* ── Price Drivers ── */
.pt-drivers-list{display:flex;flex-direction:column;gap:2px}
.pt-driver-row{background:var(--bg2);border:1px solid var(--border);border-left:3px solid transparent;border-radius:4px;padding:1rem 1.25rem;transition:border-color .15s,background .15s}
.pt-driver-row:hover{border-left-color:var(--accent);background:var(--bg3)}
.pt-driver-row h3{font-family:'Montserrat',sans-serif;color:var(--text);font-size:1rem;font-weight:700;margin:0 0 .35rem}
.pt-driver-row p{color:var(--text2);font-size:.9rem;line-height:1.6;margin:0}

/* ── FAQ ── */
.pt-faq{margin-bottom:2rem}
.pt-faq h2{font-family:'Montserrat',sans-serif;font-size:1.15rem;font-weight:700;color:var(--text);margin:0 0 .75rem}
.pt-faq-item{background:var(--bg2);border:1px solid var(--border);border-radius:4px;margin-bottom:.35rem;overflow:hidden}
.pt-faq-item summary{padding:.75rem 2.5rem .75rem 1rem;font-weight:700;font-size:.9rem;color:var(--text);cursor:pointer;list-style:none;position:relative;transition:background .15s}
.pt-faq-item summary::after{content:'+';position:absolute;right:1.25rem;top:50%;transform:translateY(-50%);font-size:1.2rem;color:var(--accent);font-weight:700}
.pt-faq-item[open] summary::after{content:'\2212'}
.pt-faq-item summary:hover{background:var(--bg3)}
.pt-faq-item summary::-webkit-details-marker{display:none}
.pt-faq-item p{padding:0 1rem .85rem 1rem;margin:0;color:var(--text2);font-size:.88rem;line-height:1.6}

/* ── Related ── */
.pt-related{margin-bottom:2rem}
.pt-related h2{font-family:'Montserrat',sans-serif;font-size:1.15rem;font-weight:700;color:var(--text);margin:0 0 .75rem}
.pt-related-list{display:flex;flex-direction:column;gap:2px}
.pt-related-row{display:flex;align-items:center;text-decoration:none;color:var(--text);background:var(--bg2);border:1px solid var(--border);border-left:3px solid transparent;border-radius:4px;padding:.6rem 1rem;font-size:.9rem;font-weight:600;transition:border-color .15s,background .15s}
.pt-related-row:hover{border-left-color:var(--accent);background:var(--bg3)}

/* ── Responsive ── */
@media(max-width:768px){
  .pt-hero h1{font-size:1.5rem}
  .pt-stats{flex-direction:column}
  .pt-chart-row{grid-template-columns:1fr;gap:.5rem}
  .pt-chart-label{text-align:left}
  .pt-chart-count{text-align:left}
  .pt-table{font-size:.85rem}
  .pt-table th,.pt-table td{padding:.5rem}
}
</style>
