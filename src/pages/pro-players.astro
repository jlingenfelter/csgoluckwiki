---
import Base from '../layouts/Base.astro';
import ExploreMore from '../components/ExploreMore.astro';
import { faqSchema } from '../lib/weapons';
import { PRO_PLAYERS, getAverageEdpi, getMostCommonRes, getMostCommonDpi, getMouseBrandBreakdown, getStretchedBreakdown, getRoleBreakdown, getTeams, getRoles, getCountries, getGearByType } from '../lib/pro-players';

const title = 'CS2 Pro Player Settings — Sensitivity, Crosshairs & Gear | CSGOLuck Wiki';
const description = `Browse ${PRO_PLAYERS.length}+ CS2 pro player settings including sensitivity, crosshair codes, resolution, mouse, and monitor choices from s1mple, ZywOo, NiKo, donk, and every other top-tier CS2 competitor.`;

const avgEdpi = getAverageEdpi();
const topRes = getMostCommonRes();
const topDpi = getMostCommonDpi();
const mouseBrands = getMouseBrandBreakdown();
const stretchData = getStretchedBreakdown();
const roles = getRoleBreakdown();
const uniqueRoles = roles.map(r => r.role);
const uniqueTeams = [...new Set(PRO_PLAYERS.map(p => p.team))].sort();
const edpiMin = Math.min(...PRO_PLAYERS.map(p => p.edpi));
const edpiMax = Math.max(...PRO_PLAYERS.map(p => p.edpi));
const edpiMedian = PRO_PLAYERS.map(p => p.edpi).sort((a, b) => a - b)[Math.floor(PRO_PLAYERS.length / 2)];

// Resolution breakdown for template
const resCounts: Record<string, number> = {};
PRO_PLAYERS.forEach(p => resCounts[p.res] = (resCounts[p.res] || 0) + 1);
const resBreakdown = Object.entries(resCounts).sort((a, b) => b[1] - a[1]).map(([res, count]) => ({
  res, count, pct: Math.round((count / PRO_PLAYERS.length) * 100)
}));

const faqs = [
  { question: 'Which sensitivity range is popular among professional players?', answer: `Pro players typically land around ${avgEdpi} eDPI on average. The sweet spot for most competitors sits between 480 and 880 eDPI, and ${topDpi} DPI is the go-to hardware setting. Snipers generally opt for the lower end of that spectrum for steadier aim, while aggressive fraggers may push higher to whip around corners faster.` },
  { question: 'Is it smart to mirror a pro\'s exact configuration?', answer: 'Think of pro configs as a useful benchmark rather than a prescription. Your physical setup — available desk real estate, pad dimensions, how you grip your mouse — all influence what actually works for you. Start within the pro range, then spend a couple of weeks adjusting until the sensitivity feels natural. Sticking with your choice matters more than picking the "perfect" number.' },
  { question: 'How does eDPI work and why should I care about it?', answer: 'eDPI stands for effective dots per inch — you get it by multiplying your hardware DPI by your CS2 sensitivity value. It creates a universal comparison metric: someone on 400 DPI with 2.0 sens ends up at 800 eDPI, identical in speed to 800 DPI at 1.0 sens. When browsing pro configs, eDPI lets you make apples-to-apples sensitivity comparisons regardless of each player\'s DPI choice.' },
  { question: 'What draws so many pros to 4:3 stretched resolution?', answer: `Roughly ${Math.round((stretchData.stretched / PRO_PLAYERS.length) * 100)}% of competitive players run stretched mode. The appeal is threefold: character models look physically wider on screen, frame rates tend to climb, and many veterans have thousands of hours of muscle memory trained on that aspect ratio. That said, ${Math.round((stretchData.native / PRO_PLAYERS.length) * 100)}% stick with native 16:9 to benefit from the extended field of view — neither option is categorically superior.` },
  { question: 'Which mouse brand dominates the CS2 pro scene?', answer: `${mouseBrands[0]?.name} leads the pack at ${mouseBrands[0]?.pct}% adoption, with ${mouseBrands[1]?.name} at ${mouseBrands[1]?.pct}% and ${mouseBrands[2]?.name} at ${mouseBrands[2]?.pct}% rounding out the top three. The modern trend heavily favours ultra-light wireless designs equipped with flagship sensors — models like the GPX Superlight and Zowie EC2 show up on desks at virtually every tournament.` },
  { question: 'Do professionals frequently tweak their configs?', answer: 'Hardly ever. Once a pro locks in settings that feel right, they tend to leave them alone for years. At the top level, muscle memory is everything, and even a small sensitivity shift can take weeks to readjust. Plenty of players have run the same sens since their CS:GO days. The general advice is to only make changes when you have a clear, specific reason — not just because you hit a rough patch.' },
  { question: 'How important is monitor refresh rate in competitive CS2?', answer: 'It is a massive factor. Every pro competes on a 240Hz or 360Hz display without exception. The higher refresh rate delivers noticeably smoother motion, cuts perceived input delay, and makes it far easier to track moving targets. Upgrading from a standard 60Hz panel to 240Hz is widely considered one of the single largest hardware improvements a competitive player can make.' },
  { question: 'Is there a universally ideal crosshair in CS2?', answer: 'No single crosshair suits everyone — it comes down to what your eyes lock onto best. The majority of professionals run a compact, static design with a centre gap, no dot, and a clean colour like green, cyan, or white. Your goal is a crosshair that stands out against all map backgrounds without cluttering your view. Check out our crosshair codes section to test configurations used by top-tier players.' },
];

// Browse sections data
const topTeams = getTeams().slice(0, 12);
const allRoles = getRoles();
const topCountries = getCountries().slice(0, 12);
const topMice = getGearByType('mouse').slice(0, 8);
---

<Base {title} {description}>
<Fragment slot="head">
<script type="application/ld+json" set:html={JSON.stringify(faqSchema(faqs))} />
</Fragment>

<nav class="breadcrumb"><a href="/">Home</a> <span>/</span> <span>Players</span></nav>

<!-- Hero: Left-aligned with stat pills -->
<section class="pph-hero">
  <div class="pph-hero-text">
    <h1 class="pph-title">CS2 Pro Player Settings</h1>
    <p class="pph-subtitle">Verified competitive settings, peripheral choices, and <a href="/crosshair-codes/" style="color:var(--accent)">crosshair share codes</a> from the CS2 pro scene. Use our <a href="/edpi-calculator/" style="color:var(--accent)">eDPI calculator</a> to compare your sensitivity against the pros.</p>
  </div>
  <div class="pph-stat-pills">
    <span class="pph-pill"><span class="pph-pill-val">{PRO_PLAYERS.length}+</span><span class="pph-pill-lbl">Configs</span></span>
    <span class="pph-pill"><span class="pph-pill-val">{avgEdpi}</span><span class="pph-pill-lbl">Avg eDPI</span></span>
    <span class="pph-pill"><span class="pph-pill-val">{topRes}</span><span class="pph-pill-lbl">Top Res</span></span>
    <span class="pph-pill"><span class="pph-pill-val">{topDpi}</span><span class="pph-pill-lbl">Common DPI</span></span>
    <span class="pph-pill"><span class="pph-pill-val">{Math.round((stretchData.stretched / PRO_PLAYERS.length) * 100)}%</span><span class="pph-pill-lbl">Stretched</span></span>
    <span class="pph-pill"><span class="pph-pill-val">{mouseBrands[0]?.name}</span><span class="pph-pill-lbl">Top Mouse</span></span>
  </div>
</section>

<!-- Role Filter: Horizontal pill tabs -->
<section class="pph-filters">
  <div class="pph-role-tabs" id="roleTabs">
    <button class="pph-role-pill active" data-role="all">All ({PRO_PLAYERS.length})</button>
    {uniqueRoles.map(r => {
      const count = PRO_PLAYERS.filter(p => p.role === r).length;
      return <button class="pph-role-pill" data-role={r}>{r} ({count})</button>;
    })}
  </div>
  <div class="pph-filter-row">
    <input type="text" id="playerSearch" class="pph-search" placeholder="Search by name or team..." />
    <select id="teamFilter" class="pph-select">
      <option value="all">All Teams</option>
      {uniqueTeams.map(t => <option value={t.toLowerCase()}>{t}</option>)}
    </select>
    <select id="sortFilter" class="pph-select">
      <option value="default">Sort: Default</option>
      <option value="edpi-asc">eDPI: Low to High</option>
      <option value="edpi-desc">eDPI: High to Low</option>
      <option value="name-az">Name: A-Z</option>
      <option value="name-za">Name: Z-A</option>
    </select>
  </div>
  <div class="pph-count"><span id="visibleCount">{PRO_PLAYERS.length}</span> players shown</div>
</section>

<!-- Featured Players: 2-column spotlight cards (first 4) -->
<section class="pph-featured">
  <h2 class="pph-section-title">Featured Players</h2>
  <div class="pph-spotlight-grid">
    {PRO_PLAYERS.slice(0, 4).map(p => (
      <a href={`/pro-players/${p.slug}/`} class="pph-spotlight-card">
        <div class="pph-spotlight-img-wrap">
          {p.image && <img class="pph-spotlight-img" src={p.image} alt={p.name} width="80" height="80" loading="eager" onerror="this.style.display='none'" />}
        </div>
        <div class="pph-spotlight-info">
          <span class="pph-spotlight-name">{p.flag} {p.name}</span>
          <span class="pph-spotlight-team">{p.team}</span>
          <span class="pph-spotlight-role" data-r={p.role.toLowerCase().replace(/\s/g,'-')}>{p.role}</span>
          <div class="pph-spotlight-stats">
            <span><strong>{p.edpi}</strong> eDPI</span>
            <span><strong>{p.res}</strong></span>
            <span><strong>{p.mouse}</strong></span>
          </div>
        </div>
      </a>
    ))}
  </div>
</section>

<!-- Player Cards Grid -->
<section class="pph-grid" id="cfgList">
  {PRO_PLAYERS.map((p, i) => (
    <a href={`/pro-players/${p.slug}/`} class={`pph-card${i >= 48 ? ' pph-paginated' : ''}`} data-role={p.role} data-name={p.name.toLowerCase()} data-team={p.team.toLowerCase()} data-edpi={p.edpi} data-idx={i}>
      <div class="pph-card-img">
        {p.image ? <img class="pph-card-avatar" src={p.image} alt={p.name} width="80" height="80" loading="lazy" onerror="this.style.display='none'" /> : <span class="pph-card-placeholder">{p.name.charAt(0)}</span>}
        <span class="pph-card-role" data-r={p.role.toLowerCase().replace(/\s/g,'-')}>{p.role}</span>
      </div>
      <div class="pph-card-body">
        <span class="pph-card-name">{p.flag} {p.name}</span>
        <span class="pph-card-team">{p.team}</span>
        <div class="pph-card-stats">
          <span class="pph-card-stat"><strong>{p.edpi}</strong> eDPI</span>
          <span class="pph-card-stat"><strong>{p.res}</strong></span>
        </div>
        <span class="pph-card-mouse">{p.mouse}</span>
      </div>
    </a>
  ))}
</section>
<div class="pph-loadmore-wrap" id="loadMoreWrap">
  <button class="pph-loadmore-btn" id="loadMoreBtn">Load More Players <span id="loadMoreCount"></span></button>
</div>

<!-- Scene Overview: 3-column layout with left border accents -->
<section class="pph-overview">
  <h2 class="pph-section-title">Scene Overview</h2>
  <div class="pph-overview-grid">
    <div class="pph-overview-block">
      <div class="pph-overview-header">Sensitivity Range</div>
      <div class="pph-overview-big">{edpiMin} &ndash; {edpiMax} eDPI</div>
      <p class="pph-overview-desc">Full range across all pros. The median sits at {edpiMedian} eDPI, with most falling between 560 and 840.</p>
      <div class="pph-range-bar">
        <div class="pph-range-seg pph-range-low"><span>Low</span></div>
        <div class="pph-range-seg pph-range-mid"><span>Sweet Spot</span></div>
        <div class="pph-range-seg pph-range-high"><span>High</span></div>
      </div>
    </div>
    <div class="pph-overview-block">
      <div class="pph-overview-header">Resolution Split</div>
      {resBreakdown.map(r => (
        <div class="pph-bar-row">
          <span class="pph-bar-label">{r.res}</span>
          <div class="pph-bar-track"><div class="pph-bar-fill" style={`width:${r.pct}%`}></div></div>
          <span class="pph-bar-pct">{r.pct}%</span>
        </div>
      ))}
    </div>
    <div class="pph-overview-block">
      <div class="pph-overview-header">Popular Mice</div>
      {mouseBrands.slice(0, 5).map(b => (
        <div class="pph-bar-row">
          <span class="pph-bar-label">{b.name}</span>
          <div class="pph-bar-track"><div class="pph-bar-fill" style={`width:${b.pct}%`}></div></div>
          <span class="pph-bar-pct">{b.pct}%</span>
        </div>
      ))}
    </div>
  </div>
  <div class="pph-aspect-strip">
    <div class="pph-aspect-item"><span class="pph-aspect-num">{stretchData.stretched}</span><span class="pph-aspect-lbl">Stretched</span></div>
    <div class="pph-aspect-item"><span class="pph-aspect-num">{stretchData.native}</span><span class="pph-aspect-lbl">Native</span></div>
    <div class="pph-aspect-item"><span class="pph-aspect-num">{stretchData.bars}</span><span class="pph-aspect-lbl">Black Bars</span></div>
  </div>
</section>

<!-- Full Comparison Table -->
<section class="pph-table-section">
  <h2 class="pph-section-title">Full Settings Comparison</h2>
  <div class="pph-table-filter">
    <input type="text" id="tableSearch" placeholder="Filter table by player..." />
  </div>
  <div class="pph-table-wrap">
    <table class="pph-table">
      <thead>
        <tr>
          <th>Player</th><th>Team</th><th>Role</th><th>Mouse</th><th>DPI</th><th>Sens</th><th>eDPI</th><th>Resolution</th><th>Aspect</th><th>Display</th><th>Mousepad</th><th>Style</th>
        </tr>
      </thead>
      <tbody id="tableBody">
        {PRO_PLAYERS.map((p, i) => (
          <tr class={i >= 50 ? 'pph-trow-hidden' : ''}>
            <td><a href={`/pro-players/${p.slug}/`} class="pph-tlink"><strong>{p.flag} {p.name}</strong></a></td>
            <td>{p.team}</td>
            <td><span class="pph-card-role pph-role-sm" data-r={p.role.toLowerCase().replace(/\s/g,'-')}>{p.role}</span></td>
            <td>{p.mouse}</td>
            <td>{p.dpi}</td>
            <td>{p.sens}</td>
            <td><strong>{p.edpi}</strong></td>
            <td>{p.res}</td>
            <td>{p.aspect}</td>
            <td>{p.stretch}</td>
            <td>{p.mousepad}</td>
            <td>{p.style}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
  <div class="pph-loadmore-wrap" id="tableLoadMoreWrap">
    <button class="pph-loadmore-btn" id="tableLoadMoreBtn">Show All {PRO_PLAYERS.length} Rows</button>
  </div>
</section>

<!-- Tips -->
<h2 class="pph-section-title">Finding Your Setup</h2>
<ul class="pph-tips">
  <li><strong>Use {avgEdpi} eDPI as a baseline:</strong> That is the pro average. Lower works better with large mousepads and arm-aiming; higher suits wrist players with limited desk space.</li>
  <li><strong>Role matters:</strong> AWPers tend toward lower eDPI for precision. Entry fraggers lean higher for faster 180-degree checks. Pick a range that matches how you play.</li>
  <li><strong>Stretched is not required:</strong> {Math.round((stretchData.stretched / PRO_PLAYERS.length) * 100)}% of pros run stretched, but {Math.round((stretchData.native / PRO_PLAYERS.length) * 100)}% play native 16:9. Both are viable at the highest level. Try each for at least a week.</li>
  <li><strong>Lighter mice help:</strong> Sub-80g wireless mice dominate the pro scene now. Less weight means less fatigue and more precise micro-corrections.</li>
  <li><strong>Mousepad surface changes everything:</strong> Speed surfaces let you flick faster; control pads give more stopping power. Match the surface to your sensitivity and role.</li>
  <li><strong>Commit to changes:</strong> Allow two full weeks after any sensitivity change before judging it. Muscle memory takes time to recalibrate.</li>
  <li><strong>There is no single answer:</strong> Pro eDPI ranges from {edpiMin} to {edpiMax}. Consistency matters far more than copying any one player exactly.</li>
</ul>

<!-- FAQ: <details> accordion -->
<section class="pph-faq-section">
  <h2 class="pph-section-title">Common Questions</h2>
  {faqs.map(f => (
    <details class="pph-faq">
      <summary class="pph-faq-q">{f.question}</summary>
      <p class="pph-faq-a">{f.answer}</p>
    </details>
  ))}
</section>

<!-- Browse by Team: inline tag cloud -->
<section class="pph-browse">
  <h2 class="pph-section-title">Browse by Team</h2>
  <div class="pph-tag-cloud">
    {topTeams.map(t => (
      <a href={`/pro-teams/${t.slug}/`} class="pph-tag">{t.name} <span class="pph-tag-count">{t.players.length}</span></a>
    ))}
  </div>
</section>

<!-- Browse by Role: inline tag cloud -->
<section class="pph-browse">
  <h2 class="pph-section-title">Browse by Role</h2>
  <div class="pph-tag-cloud">
    {allRoles.map(r => (
      <a href={`/pro-players/role/${r.slug}/`} class="pph-tag">{r.name} <span class="pph-tag-count">{r.players.length}</span></a>
    ))}
  </div>
</section>

<!-- Browse by Country: inline tag cloud -->
<section class="pph-browse">
  <h2 class="pph-section-title">Browse by Country</h2>
  <div class="pph-tag-cloud">
    {topCountries.map(c => (
      <a href={`/pro-players/country/${c.slug}/`} class="pph-tag">{c.flag} {c.name} <span class="pph-tag-count">{c.players.length}</span></a>
    ))}
  </div>
</section>

<!-- Popular Mice: inline tag cloud -->
<section class="pph-browse">
  <h2 class="pph-section-title">Popular Mice</h2>
  <div class="pph-tag-cloud">
    {topMice.map(g => (
      <a href={`/pro-gaming-gear/${g.slug}/`} class="pph-tag">{g.name} <span class="pph-tag-count">{g.players.length}</span></a>
    ))}
  </div>
</section>

<ExploreMore context="general" />

<!-- Internal Links -->
<div class="internal-links">
  <a href="/crosshair-codes/">Crosshair Codes</a>
  <a href="/sensitivity-converter/">Sensitivity Converter</a>
  <a href="/edpi-calculator/">eDPI Calculator</a>
  <a href="/cm360-calculator/">cm/360 Calculator</a>
  <a href="/resolution-calculator/">Resolution Calculator</a>
  <a href="/crosshair-generator/">Crosshair Generator</a>
  <a href="/bind-generator/">Bind Generator</a>
  <a href="/cs2-weapons/">Weapon Stats</a>
  <a href="/cs2-rank-distribution/">Rank Distribution</a>
  <a href="/cs2-guides/crosshair-guide/">Crosshair Guide</a>
  <a href="/damage-calculator/">Damage Calculator</a>
  <a href="/cs2-maps/">Map Database</a>
  <a href="/cs2-guides/ranks-guide/">Ranking Guide</a>
  <a href="/cs2-tools/">All Tools</a>
</div>

</Base>

<style>
/* ── Hero: Left-aligned with stat pills ──────────────────────────────────── */
.pph-hero{margin-bottom:2rem;padding-bottom:1.5rem;border-bottom:1px solid var(--border)}
.pph-title{font-size:2rem;font-weight:800;margin:0 0 .4rem;letter-spacing:-.02em}
.pph-subtitle{color:var(--text2);font-size:.9rem;margin:0 0 1.25rem;line-height:1.6;max-width:680px}
.pph-stat-pills{display:flex;flex-wrap:wrap;gap:.5rem}
.pph-pill{display:flex;flex-direction:column;align-items:center;padding:.5rem 1rem;background:var(--bg2);border:1px solid var(--border);border-radius:4px;min-width:80px}
.pph-pill-val{font-size:1rem;font-weight:800;color:var(--accent);line-height:1.2}
.pph-pill-lbl{font-size:.65rem;color:var(--text2);text-transform:uppercase;letter-spacing:.04em;margin-top:.15rem}

/* ── Role Pill Tabs & Filter Row ─────────────────────────────────────────── */
.pph-filters{margin-bottom:1.5rem}
.pph-role-tabs{display:flex;flex-wrap:wrap;gap:.35rem;margin-bottom:.75rem}
.pph-role-pill{background:var(--bg2);color:var(--text2);border:1px solid var(--border);padding:.35rem .85rem;border-radius:4px;font-size:.78rem;font-weight:600;cursor:pointer;font-family:inherit;transition:all .15s}
.pph-role-pill:hover{border-color:var(--accent);color:var(--text)}
.pph-role-pill.active{background:var(--accent);color:#000;border-color:var(--accent)}
.pph-filter-row{display:flex;gap:.6rem;flex-wrap:wrap;align-items:center}
.pph-search{flex:1;min-width:180px;background:var(--bg2);color:var(--text);border:1px solid var(--border);padding:.5rem .75rem;border-radius:4px;font-size:.88rem;font-family:inherit}
.pph-search:focus{border-color:var(--accent);outline:none}
.pph-select{background:var(--bg2);color:var(--text);border:1px solid var(--border);padding:.5rem .6rem;border-radius:4px;font-size:.84rem;font-family:inherit;cursor:pointer}
.pph-select:focus{border-color:var(--accent);outline:none}
.pph-count{font-size:.78rem;color:var(--text2);margin-top:.5rem}

/* ── Featured: 2-column spotlight cards ──────────────────────────────────── */
.pph-featured{margin-bottom:2rem}
.pph-section-title{font-size:1.2rem;font-weight:700;margin:0 0 .85rem}
.pph-spotlight-grid{display:grid;grid-template-columns:1fr 1fr;gap:.75rem;margin-bottom:.5rem}
.pph-spotlight-card{display:flex;align-items:center;gap:1rem;padding:1rem 1.25rem;background:var(--bg2);border:1px solid var(--border);border-left:3px solid transparent;border-radius:4px;text-decoration:none;color:inherit;transition:border-left-color .15s}
.pph-spotlight-card:hover{border-left-color:var(--accent)}
.pph-spotlight-img-wrap{flex-shrink:0;width:80px;height:80px;display:flex;align-items:center;justify-content:center}
.pph-spotlight-img{width:80px;height:80px;border-radius:4px;object-fit:cover;border:2px solid var(--border);background:var(--bg3)}
.pph-spotlight-info{display:flex;flex-direction:column;gap:.2rem;min-width:0}
.pph-spotlight-name{font-size:1.05rem;font-weight:800;color:var(--text)}
.pph-spotlight-team{font-size:.8rem;color:var(--accent);font-weight:600}
.pph-spotlight-role{font-size:.62rem;font-weight:700;padding:.15rem .4rem;border-radius:4px;text-transform:uppercase;letter-spacing:.03em;background:var(--bg3);color:var(--text2);border:1px solid var(--border);align-self:flex-start}
.pph-spotlight-role[data-r="awper"]{background:rgba(239,83,80,.12);color:var(--red);border-color:var(--red)}
.pph-spotlight-role[data-r="rifler"]{background:rgba(66,165,245,.12);color:var(--blue);border-color:var(--blue)}
.pph-spotlight-role[data-r="igl"]{background:rgba(171,71,188,.12);color:var(--purple);border-color:var(--purple)}
.pph-spotlight-role[data-r="entry-fragger"]{background:rgba(46,204,113,.12);color:var(--accent);border-color:var(--accent)}
.pph-spotlight-role[data-r="support"]{background:rgba(76,175,80,.12);color:var(--green);border-color:var(--green)}
.pph-spotlight-stats{display:flex;gap:.75rem;font-size:.78rem;color:var(--text2);margin-top:.25rem;flex-wrap:wrap}
.pph-spotlight-stats strong{color:var(--text);font-weight:700}

/* ── Player Cards: Grid ───────────────────────────────────────────────────── */
.pph-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:.75rem;margin-bottom:2rem}
.pph-card{display:flex;flex-direction:column;background:var(--bg2);border:1px solid var(--border);border-radius:8px;text-decoration:none;color:inherit;overflow:hidden;transition:transform .15s,border-color .15s,box-shadow .15s}
.pph-card:hover{transform:translateY(-3px);border-color:var(--accent);box-shadow:0 8px 24px rgba(0,0,0,.3)}
.pph-card.hidden{display:none}

.pph-card-img{position:relative;background:var(--bg3);display:flex;align-items:center;justify-content:center;height:120px;overflow:hidden}
.pph-card-avatar{width:80px;height:80px;border-radius:50%;object-fit:cover;border:2px solid var(--border)}
.pph-card-placeholder{width:60px;height:60px;border-radius:50%;background:var(--bg2);border:2px solid var(--border);display:flex;align-items:center;justify-content:center;font-size:1.4rem;font-weight:900;color:var(--text2)}

.pph-card-role{position:absolute;top:.4rem;left:.4rem;font-size:.55rem;font-weight:700;padding:.12rem .35rem;border-radius:4px;text-transform:uppercase;letter-spacing:.03em;background:var(--bg3);color:var(--text2);border:1px solid var(--border)}
.pph-card-role[data-r="awper"]{background:rgba(239,83,80,.12);color:var(--red);border-color:var(--red)}
.pph-card-role[data-r="rifler"]{background:rgba(66,165,245,.12);color:var(--blue);border-color:var(--blue)}
.pph-card-role[data-r="igl"]{background:rgba(171,71,188,.12);color:var(--purple);border-color:var(--purple)}
.pph-card-role[data-r="entry-fragger"]{background:rgba(46,204,113,.12);color:var(--accent);border-color:var(--accent)}
.pph-card-role[data-r="support"]{background:rgba(76,175,80,.12);color:var(--green);border-color:var(--green)}

.pph-card-body{padding:.6rem .7rem;display:flex;flex-direction:column;gap:.2rem}
.pph-card-name{font-weight:700;font-size:.85rem;color:var(--text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.pph-card-team{font-size:.72rem;color:var(--text2)}
.pph-card-stats{display:flex;gap:.6rem;font-size:.75rem;color:var(--text2);margin-top:.15rem}
.pph-card-stats strong{color:var(--accent);font-weight:700}
.pph-card-mouse{font-size:.68rem;color:var(--text2);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}

/* ── Load More ───────────────────────────────────────────────────────────── */
.pph-loadmore-wrap{text-align:center;padding:1.25rem 0}
.pph-loadmore-btn{background:var(--accent);color:#000;border:none;padding:.55rem 1.5rem;border-radius:4px;font-size:.88rem;font-weight:700;cursor:pointer;font-family:inherit;transition:opacity .15s}
.pph-loadmore-btn:hover{opacity:.85}
.pph-loadmore-btn span{font-weight:400;opacity:.8}
.pph-paginated{display:none}
.pph-card.pph-paginated.pph-revealed{display:grid}

/* ── Scene Overview: 3-column grid ───────────────────────────────────────── */
.pph-overview{margin-bottom:2.5rem}
.pph-overview-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1rem;margin-bottom:1rem}
.pph-overview-block{background:var(--bg2);border:1px solid var(--border);border-left:3px solid var(--accent);border-radius:4px;padding:1.25rem}
.pph-overview-header{font-size:.9rem;font-weight:700;color:var(--text);margin-bottom:.5rem}
.pph-overview-big{font-size:1.4rem;font-weight:800;color:var(--accent);margin-bottom:.35rem}
.pph-overview-desc{font-size:.82rem;color:var(--text2);margin:0 0 .6rem;line-height:1.5}

.pph-range-bar{display:flex;height:18px;border-radius:4px;overflow:hidden;background:var(--bg3)}
.pph-range-seg{display:flex;align-items:center;justify-content:center}
.pph-range-seg span{font-size:.58rem;font-weight:600;color:var(--text2)}
.pph-range-low{width:15%}
.pph-range-mid{width:50%;background:rgba(46,204,113,.12)}
.pph-range-high{width:35%}

.pph-bar-row{display:flex;align-items:center;gap:.5rem;margin-bottom:.35rem}
.pph-bar-label{min-width:80px;font-size:.78rem;color:var(--text);font-weight:600}
.pph-bar-track{flex:1;height:14px;background:var(--bg3);border-radius:4px;overflow:hidden}
.pph-bar-fill{height:100%;background:var(--accent);border-radius:4px;opacity:.6;min-width:3px}
.pph-bar-pct{font-size:.72rem;color:var(--text2);font-weight:600;min-width:28px;text-align:right}

.pph-aspect-strip{display:flex;gap:.75rem}
.pph-aspect-item{flex:1;text-align:center;padding:.65rem;background:var(--bg2);border:1px solid var(--border);border-radius:4px}
.pph-aspect-num{display:block;font-size:1.2rem;font-weight:800;color:var(--accent)}
.pph-aspect-lbl{display:block;font-size:.68rem;color:var(--text2);margin-top:.1rem}

/* ── Table ────────────────────────────────────────────────────────────────── */
.pph-table-section{margin-bottom:2.5rem}
.pph-table-filter{margin-bottom:.6rem}
.pph-table-filter input{width:100%;max-width:340px;background:var(--bg2);color:var(--text);border:1px solid var(--border);padding:.45rem .7rem;border-radius:4px;font-size:.88rem;font-family:inherit}
.pph-table-filter input:focus{border-color:var(--accent);outline:none}
.pph-table-wrap{overflow-x:auto;border:1px solid var(--border);border-radius:4px}
.pph-table{width:100%;border-collapse:collapse;background:var(--bg2);font-size:.78rem}
.pph-table thead{background:var(--bg3);border-bottom:2px solid var(--accent)}
.pph-table th{padding:.5rem .4rem;text-align:left;font-weight:700;color:var(--text);text-transform:uppercase;font-size:.65rem;letter-spacing:.03em;white-space:nowrap}
.pph-table td{padding:.4rem;border-bottom:1px solid var(--border);color:var(--text2);white-space:nowrap}
.pph-table tbody tr:hover td{background:var(--bg3)}
.pph-table td strong{color:var(--text)}
.pph-tlink{color:var(--accent);text-decoration:none;font-weight:600}
.pph-tlink:hover{text-decoration:underline}
.pph-trow-hidden{display:none}

/* ── Tips ─────────────────────────────────────────────────────────────────── */
.pph-tips{list-style:none;padding:0;margin:0 0 2rem}
.pph-tips li{padding:.65rem .85rem;margin-bottom:.35rem;background:var(--bg2);border:1px solid var(--border);border-left:3px solid var(--accent);border-radius:4px;font-size:.88rem;color:var(--text2);line-height:1.55}
.pph-tips li strong{color:var(--text);font-weight:700}

/* ── FAQ: <details> accordion ────────────────────────────────────────────── */
.pph-faq-section{margin-bottom:2.5rem}
.pph-faq{background:var(--bg2);border:1px solid var(--border);border-radius:4px;margin-bottom:.35rem;overflow:hidden}
.pph-faq-q{padding:.7rem 1rem;font-size:.9rem;font-weight:700;color:var(--text);cursor:pointer;user-select:none;list-style:none;display:flex;justify-content:space-between;align-items:center}
.pph-faq-q::-webkit-details-marker{display:none}
.pph-faq-q::after{content:'+';font-size:1.1rem;color:var(--accent);font-weight:700;flex-shrink:0;margin-left:.5rem}
.pph-faq[open] .pph-faq-q::after{content:'\2212'}
.pph-faq[open] .pph-faq-q{border-bottom:1px solid var(--border)}
.pph-faq-a{padding:.7rem 1rem;font-size:.85rem;color:var(--text2);line-height:1.65;margin:0}

/* ── Browse: Tag Cloud ───────────────────────────────────────────────────── */
.pph-browse{margin-bottom:2rem}
.pph-tag-cloud{display:flex;flex-wrap:wrap;gap:.4rem}
.pph-tag{display:inline-flex;align-items:center;gap:.3rem;padding:.35rem .7rem;background:var(--bg2);border:1px solid var(--border);border-radius:4px;color:var(--accent);text-decoration:none;font-size:.82rem;font-weight:600;transition:border-color .15s}
.pph-tag:hover{border-color:var(--accent)}
.pph-tag-count{color:var(--text2);font-weight:400;font-size:.72rem}

/* ── Responsive ──────────────────────────────────────────────────────────── */
@media(max-width:960px){
  .pph-spotlight-grid{grid-template-columns:1fr}
  .pph-overview-grid{grid-template-columns:1fr}
}
@media(max-width:640px){
  .pph-title{font-size:1.5rem}
  .pph-stat-pills{gap:.35rem}
  .pph-pill{padding:.4rem .6rem;min-width:65px}
  .pph-pill-val{font-size:.85rem}
  .pph-filter-row{flex-direction:column}
  .pph-search{min-width:100%}
  .pph-grid{grid-template-columns:repeat(2,1fr)}
  .pph-card-img{height:90px}
  .pph-card-avatar{width:60px;height:60px}
}
</style>

<script is:inline>
(function(){
  var roleTabs = document.querySelectorAll('.pph-role-pill');
  var teamSel = document.getElementById('teamFilter');
  var sortSel = document.getElementById('sortFilter');
  var search = document.getElementById('playerSearch');
  var countEl = document.getElementById('visibleCount');
  var rows = document.querySelectorAll('.pph-card');
  var listEl = document.getElementById('cfgList');
  var loadMoreBtn = document.getElementById('loadMoreBtn');
  var loadMoreWrap = document.getElementById('loadMoreWrap');
  var loadMoreCount = document.getElementById('loadMoreCount');
  var tableLoadMoreBtn = document.getElementById('tableLoadMoreBtn');
  var tableLoadMoreWrap = document.getElementById('tableLoadMoreWrap');

  var BATCH = 48;
  var isFiltering = false;
  var activeRole = 'all';

  // Role pill tab click
  roleTabs.forEach(function(pill){
    pill.addEventListener('click', function(){
      roleTabs.forEach(function(p){ p.classList.remove('active'); });
      pill.classList.add('active');
      activeRole = pill.dataset.role;
      filter();
    });
  });

  function updateLoadMore() {
    if (isFiltering) {
      loadMoreWrap.style.display = 'none';
      return;
    }
    var paginated = document.querySelectorAll('.pph-card.pph-paginated:not(.pph-revealed)');
    if (paginated.length === 0) {
      loadMoreWrap.style.display = 'none';
    } else {
      loadMoreWrap.style.display = 'block';
      loadMoreCount.textContent = '(' + paginated.length + ' remaining)';
    }
  }

  function filter(){
    var role = activeRole;
    var q = search.value.toLowerCase();
    var team = teamSel.value;
    var vis = 0;
    isFiltering = (role !== 'all' || q !== '' || team !== 'all');

    rows.forEach(function(c){
      var mr = role === 'all' || c.dataset.role === role;
      var ms = !q || c.dataset.name.indexOf(q) > -1 || c.dataset.team.indexOf(q) > -1;
      var mt = team === 'all' || c.dataset.team === team;
      var show = mr && ms && mt;

      if (isFiltering) {
        c.classList.toggle('hidden', !show);
        c.style.display = show ? '' : 'none';
      } else {
        var isPaginated = c.classList.contains('pph-paginated') && !c.classList.contains('pph-revealed');
        c.classList.toggle('hidden', !show);
        c.style.display = (show && !isPaginated) ? '' : 'none';
      }
      if(show) vis++;
    });
    countEl.textContent = vis;
    updateLoadMore();
  }

  function sortRows(){
    var val = sortSel.value;
    if (val === 'default') return;
    var arr = Array.from(rows);
    arr.sort(function(a, b){
      if (val === 'edpi-asc') return Number(a.dataset.edpi) - Number(b.dataset.edpi);
      if (val === 'edpi-desc') return Number(b.dataset.edpi) - Number(a.dataset.edpi);
      if (val === 'name-az') return a.dataset.name.localeCompare(b.dataset.name);
      if (val === 'name-za') return b.dataset.name.localeCompare(a.dataset.name);
      return 0;
    });
    arr.forEach(function(r){ listEl.appendChild(r); });
    filter();
  }

  loadMoreBtn.addEventListener('click', function(){
    var hidden = document.querySelectorAll('.pph-card.pph-paginated:not(.pph-revealed)');
    var count = 0;
    hidden.forEach(function(c){
      if (count < BATCH) {
        c.classList.add('pph-revealed');
        if (!c.classList.contains('hidden')) c.style.display = '';
        count++;
      }
    });
    updateLoadMore();
  });

  // Table load more
  tableLoadMoreBtn.addEventListener('click', function(){
    document.querySelectorAll('.pph-trow-hidden').forEach(function(r){ r.classList.remove('pph-trow-hidden'); });
    tableLoadMoreWrap.style.display = 'none';
  });

  // Table search
  var tableSearch = document.getElementById('tableSearch');
  var tableRows = document.querySelectorAll('#tableBody tr');
  tableSearch.addEventListener('input', function(){
    var q = tableSearch.value.toLowerCase();
    if (q) {
      document.querySelectorAll('.pph-trow-hidden').forEach(function(r){ r.classList.remove('pph-trow-hidden'); });
      tableLoadMoreWrap.style.display = 'none';
    }
    tableRows.forEach(function(row){
      var text = row.textContent.toLowerCase();
      row.style.display = (!q || text.indexOf(q) > -1) ? '' : 'none';
    });
    if (!q) {
      tableRows.forEach(function(row, i){
        if (i >= 50) row.classList.add('pph-trow-hidden');
        row.style.display = '';
      });
      tableLoadMoreWrap.style.display = 'block';
    }
  });

  teamSel.addEventListener('change', filter);
  sortSel.addEventListener('change', sortRows);
  search.addEventListener('input', filter);

  // Initial state
  updateLoadMore();
})();
</script>
