---
import Base from '../../layouts/Base.astro';
import ExploreMore from '../../components/ExploreMore.astro';
import { PRO_PLAYERS, getAverageEdpi, getEdpiDistribution, getEdpiPercentile, getGearImageUrl, type ProPlayer } from '../../lib/pro-players';
import { breadcrumbSchema, faqSchema } from '../../lib/weapons';
import { getSkinBySlug, RARITY_COLORS } from '../../lib/skins';

export function getStaticPaths() {
  return PRO_PLAYERS.map(p => ({
    params: { slug: p.slug },
    props: { player: p },
  }));
}

const { player } = Astro.props as { player: ProPlayer };
const avgEdpi = getAverageEdpi();
const cm360 = Math.round((2.54 * 360) / (player.edpi * 0.022));
const edpiDist = getEdpiDistribution();
const edpiPercentile = getEdpiPercentile(player.edpi);
const edpiPctLabel = edpiPercentile < 50 ? `lower than ${100 - edpiPercentile}%` : `higher than ${edpiPercentile}%`;
const maxBucketPct = Math.max(...edpiDist.buckets.map(x => x.pct));
const edpiHistBars = edpiDist.buckets.map(b => ({
  pct: b.pct,
  height: Math.max(4, Math.round((b.pct / (maxBucketPct || 1)) * 48)),
  active: player.edpi >= b.min && player.edpi <= b.max,
  label: b.max >= 1600 ? '1600+' : b.min < 400 ? '<400' : `${b.min}`,
}));

// Find similar players (same role or close eDPI)
const similar = PRO_PLAYERS
  .filter(p => p.slug !== player.slug)
  .map(p => ({ ...p, diff: Math.abs(p.edpi - player.edpi) }))
  .sort((a, b) => {
    if (a.role === player.role && b.role !== player.role) return -1;
    if (b.role === player.role && a.role !== player.role) return 1;
    return a.diff - b.diff;
  })
  .slice(0, 6);

// Teammates — exclude non-team entries like Free Agent, Retired, Inactive, etc.
const NON_TEAMS = ['free agent', 'retired', 'inactive', 'no team', 'none', 'benched', 'n/a', ''];
const isRealTeam = !NON_TEAMS.includes(player.team.toLowerCase().trim());
const teammates = isRealTeam
  ? PRO_PLAYERS.filter(p => p.team === player.team && p.slug !== player.slug)
  : [];

const title = `${player.name} Settings, Crosshair, Team & Stats | CSGOLuck Wiki`;
const description = `${player.name}${player.realName ? ` (${player.realName})` : ''} CS2 settings: ${player.dpi} DPI, ${player.sens} sensitivity (${player.edpi} eDPI), ${player.res} ${player.stretch}, ${player.mouse}. Full crosshair code, gear, and config.`;

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Pro Players', url: '/pro-players/' },
  { name: `${player.name} Settings`, url: `/player/${player.slug}/` },
];

// Build intro text
const sensDesc = player.edpi < 600 ? 'a low' : player.edpi < 900 ? 'a medium' : 'a high';
const sensComparison = player.edpi < avgEdpi ? `below the pro average of ${avgEdpi}` : player.edpi > avgEdpi ? `above the pro average of ${avgEdpi}` : `right at the pro average of ${avgEdpi}`;
const teamText = isRealTeam ? ` currently playing for ${player.team}` : '';
const introText = `${player.name} is a professional CS2 ${player.role.toLowerCase()}${teamText} from ${player.country}. ${player.name} plays with ${sensDesc} sensitivity setup at ${player.edpi} eDPI (${player.dpi} DPI × ${player.sens} sens), which is ${sensComparison}. ${player.name} uses ${player.res} resolution (${player.aspect} ${player.stretch}) on a ${player.monitor || 'gaming monitor'}, paired with a ${player.mouse || 'gaming mouse'}.`;

// Crosshair color map for preview
const xhairColorMap: Record<string, string> = {
  'Green': '#00ff00', 'Red': '#ff0000', 'Yellow': '#ffff00', 'Blue': '#2020ff',
  'Cyan': '#00ffff', 'White': '#ffffff', 'Pink': '#ff69b4', 'Orange': '#ff8c00',
  'Custom': '#00ff00', '': '#00ff00',
};
const xhairColor = xhairColorMap[player.crosshairColor] || '#00ff00';

// Build autoexec config
const configLines = [
  `// ${player.name}'s CS2 Config — Generated by CSGOLuck Wiki`,
  `// https://wiki.csgoluck.com/pro-players/${player.slug}/`,
  '',
  '// Sensitivity',
  `sensitivity "${player.sens}"`,
  `zoom_sensitivity_ratio_mouse "${player.zoomSens}"`,
  '',
  '// Crosshair',
  `cl_crosshairstyle "4"`,
  `cl_crosshairsize "${player.crosshairSize}"`,
  `cl_crosshairgap "${player.crosshairGap}"`,
  `cl_crosshairthickness "${player.crosshairThickness}"`,
  `cl_crosshairdot "${player.crosshairDot ? 1 : 0}"`,
  `cl_crosshair_drawoutline "${player.crosshairOutline ? 1 : 0}"`,
  '',
  '// Viewmodel',
  `viewmodel_fov "${player.vmFov}"`,
  `viewmodel_offset_x "${player.vmX}"`,
  `viewmodel_offset_y "${player.vmY}"`,
  `viewmodel_offset_z "${player.vmZ}"`,
];

if (player.launchOptions) {
  configLines.push('', `// Launch Options: ${player.launchOptions}`);
}

const configText = configLines.join('\n');

// Console commands one-liner
const allCmds = `sensitivity ${player.sens}; zoom_sensitivity_ratio_mouse ${player.zoomSens}; cl_crosshairstyle 4; cl_crosshairsize ${player.crosshairSize}; cl_crosshairgap ${player.crosshairGap}; cl_crosshairthickness ${player.crosshairThickness}; cl_crosshairdot ${player.crosshairDot ? 1 : 0}; cl_crosshair_drawoutline ${player.crosshairOutline ? 1 : 0}; viewmodel_fov ${player.vmFov}; viewmodel_offset_x ${player.vmX}; viewmodel_offset_y ${player.vmY}; viewmodel_offset_z ${player.vmZ}`;

// Resolve loadout skin slugs to full skin objects
const loadoutSlots = ['knife', 'gloves', 'rifle', 'pistol', 'awp'] as const;
const loadoutLabels: Record<string, string> = { knife: 'Knife', gloves: 'Gloves', rifle: 'Rifle', pistol: 'Pistol', awp: 'AWP' };
const resolvedLoadout = loadoutSlots
  .filter(slot => player.loadout?.[slot])
  .map(slot => {
    const skinSlug = player.loadout![slot]!;
    const skin = getSkinBySlug(skinSlug);
    return {
      slot,
      label: loadoutLabels[slot],
      slug: skinSlug,
      skin,
      name: skin ? `${skin.weapon} | ${skin.name}` : skinSlug.replace(/-/g, ' ').replace(/\b\w/g, c => c.toUpperCase()),
      image: skin?.image || null,
      rarity: skin?.rarity || null,
      rarityColor: skin?.rarityColor || (skin?.rarity ? RARITY_COLORS[skin.rarity] : null),
    };
  });
const hasLoadout = resolvedLoadout.length > 0;

// Check which extended sections have data
const hasVideoSettings = player.videoSettings && Object.keys(player.videoSettings).length > 0;
const hasBobSettings = player.bobSettings && Object.keys(player.bobSettings).length > 0;
const hasRadarSettings = player.radarSettings && Object.keys(player.radarSettings).length > 0;
const hasHudSettings = player.hudSettings && Object.keys(player.hudSettings).length > 0;
const hasMonitorSettings = player.monitorSettings && Object.keys(player.monitorSettings).length > 0;
const hasCrosshairSettings = player.crosshairSettings && Object.keys(player.crosshairSettings).length > 0;

// Sidebar sections
const sections: { id: string; label: string }[] = [
  { id: 'upcoming', label: 'Upcoming Matches' },
  { id: 'sensitivity', label: 'Mouse & Sensitivity' },
  { id: 'crosshair', label: 'Crosshair' },
  { id: 'video', label: 'Video & Display' },
  { id: 'viewmodel', label: 'Viewmodel' },
];
if (hasRadarSettings || hasHudSettings) sections.push({ id: 'gamehud', label: 'Radar & HUD' });
if (hasMonitorSettings) sections.push({ id: 'monitorsettings', label: 'Monitor Settings' });
sections.push({ id: 'gear', label: 'Gear & Peripherals' });
if (player.gpu) sections.push({ id: 'pcspecs', label: 'PC Specs' });
if (hasLoadout) sections.push({ id: 'loadout', label: 'Weapon Skins' });
sections.push({ id: 'config', label: 'Config & Download' });
if (player.launchOptions) sections.push({ id: 'launch', label: 'Launch Options' });
sections.push({ id: 'livestats', label: 'Performance Stats' });
sections.push({ id: 'matchhistory', label: 'Match History' });
if (teammates.length > 0) sections.push({ id: 'teammates', label: 'Teammates' });
sections.push({ id: 'similar', label: 'Similar Players' });
sections.push({ id: 'faq', label: 'FAQ' });

const faqs = [
  { question: `What sensitivity does ${player.name} use in CS2?`, answer: `${player.name} uses ${player.dpi} DPI with ${player.sens} in-game sensitivity, resulting in ${player.edpi} eDPI. This translates to approximately ${cm360} cm per 360-degree turn. ${player.edpi < avgEdpi ? `This is below the pro average of ${avgEdpi} eDPI, suggesting a preference for precision over speed.` : player.edpi > avgEdpi ? `This is above the pro average of ${avgEdpi} eDPI, suggesting a preference for faster target acquisition.` : `This is right at the pro average of ${avgEdpi} eDPI.`}` },
  { question: `What mouse does ${player.name} use?`, answer: `${player.name} currently uses the ${player.mouse} at ${player.dpi} DPI with a ${player.pollingRate}Hz polling rate, paired with a ${player.mousepad} mousepad.` },
  { question: `What resolution does ${player.name} play on?`, answer: `${player.name} plays on ${player.res} (${player.aspect}) with ${player.stretch} display mode at ${player.refreshRate}Hz on a ${player.monitor}.` },
  { question: `What is ${player.name}'s crosshair code?`, answer: player.crosshairCode ? `${player.name}'s crosshair code is ${player.crosshairCode}. To apply it, open CS2, go to Settings → Crosshair → Share or Import, and paste the code.` : `${player.name}'s crosshair code is not currently available. Check back later as we regularly update player settings.` },
];
---

<Base {title} {description} currentNav="/pro-players/" ogImage={player.image || undefined}>
<Fragment slot="head">
<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema(breadcrumbs))} />
<script type="application/ld+json" set:html={JSON.stringify(faqSchema(faqs))} />
<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Person",
  "name": player.realName || player.name,
  "alternateName": player.name,
  "url": `https://wiki.csgoluck.com/pro-players/${player.slug}/`,
  ...(player.image ? { "image": player.image } : {}),
  "jobTitle": `Professional CS2 ${player.role}`,
  ...(isRealTeam ? { "memberOf": { "@type": "SportsTeam", "name": player.team } } : {}),
  ...(player.country && player.country !== 'Unknown' ? { "nationality": player.country } : {}),
  ...(player.birthday ? { "birthDate": (() => { try { return new Date(player.birthday).toISOString().split('T')[0]; } catch { return undefined; } })() } : {}),
  "knowsAbout": "Counter-Strike 2",
})} />
</Fragment>

<nav class="breadcrumb"><a href="/">Home</a> <span>/</span> <a href="/pro-players/">Players</a> <span>/</span> <span>{player.name}</span></nav>

<!-- Hero: Two-column (player image + team left, name + stats table right) -->
<section class="pp-hero">
  <div class="pp-hero-left">
    <div class="pp-hero-img-wrap">
      {player.image && <img class="pp-hero-img" src={player.image} alt={player.name} width="120" height="120" loading="eager" onerror="this.style.display='none'" />}
      <span class="pp-hero-flag">{player.flag}</span>
    </div>
    <div class="pp-hero-badge">
      {isRealTeam && <a href={`/pro-teams/${player.team.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '')}/`} class="pp-hero-team-link">
        <span class="pp-hero-team-logo" id="heroTeamLogo"></span>
        <span class="pp-hero-team">{player.team}</span>
      </a>}
      {!isRealTeam && <span class="pp-hero-team">{player.team}</span>}
      <span class="pp-hero-role" data-r={player.role.toLowerCase().replace(/\s/g,'-')}>{player.role}</span>
    </div>
  </div>
  <div class="pp-hero-right">
    <h1 class="pp-hero-name">{player.name} <span class="pp-hero-name-sub">Settings, Crosshair & Stats</span></h1>
    <div class="pp-hero-meta">
      <span class="pp-hero-country">{player.country}</span>
      {player.age && <span class="pp-hero-age">Age {player.age}</span>}
      {player.realName && <span class="pp-hero-realname">{player.realName}</span>}
    </div>
    <table class="pp-hero-table">
      <tbody>
        <tr><td class="pp-hero-tl">eDPI</td><td class="pp-hero-tv pp-hero-tv-accent">{player.edpi}</td><td class="pp-hero-tl">Resolution</td><td class="pp-hero-tv">{player.res} {player.aspect}</td></tr>
        <tr><td class="pp-hero-tl">DPI</td><td class="pp-hero-tv">{player.dpi}</td><td class="pp-hero-tl">Scaling</td><td class="pp-hero-tv">{player.stretch}</td></tr>
        <tr><td class="pp-hero-tl">Sensitivity</td><td class="pp-hero-tv">{player.sens}</td><td class="pp-hero-tl">Refresh Rate</td><td class="pp-hero-tv">{player.refreshRate}Hz</td></tr>
        <tr><td class="pp-hero-tl">cm/360</td><td class="pp-hero-tv">{cm360}cm</td><td class="pp-hero-tl">Mouse</td><td class="pp-hero-tv">{player.mouse}</td></tr>
      </tbody>
    </table>
    <button class="pp-share-btn" id="shareBtn" title="Share settings">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12v8a2 2 0 002 2h12a2 2 0 002-2v-8"/><polyline points="16 6 12 2 8 6"/><line x1="12" y1="2" x2="12" y2="15"/></svg>
      Share Settings
    </button>
  </div>
</section>

<!-- Bio -->
<section class="pp-bio">
  <p>{introText} Calculate your own effective sensitivity using the <a href="/edpi-calculator/">eDPI Calculator</a>, or use the <a href="/sensitivity-converter/">Sensitivity Converter</a> to match {player.name}'s setup from another game.</p>
  {player.bio && <p class="pp-bio-extra">{player.bio}</p>}
  {isRealTeam && <p class="pp-bio-extra">See all <a href={`/pro-teams/${player.team.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '')}/`}>{player.team} team settings</a> for a full roster comparison, or browse the <a href="/pro-gaming-gear/">Pro Gaming Gear</a> hub to find gear used by top players.</p>}
</section>

<!-- Two-column layout: sticky sidebar nav + main content -->
<div class="pp-layout">
<nav class="pp-sidebar" id="ppSidebar">
  <ul class="pp-sidebar-list">
    {sections.map(s => (
      <li><a href={`#${s.id}`} class="pp-sidebar-link" data-section={s.id}>{s.label}</a></li>
    ))}
  </ul>
</nav>

<div class="pp-main">

<!-- Upcoming Matches (loaded client-side) -->
<section class="pp-section pp-match-history" id="upcoming">
  <h2 class="pp-section-title">Upcoming Matches</h2>
  <p class="pp-match-history-sub">Scheduled matches and tournaments for this player's team.</p>
  <div id="upcomingMatchesContent">
    <div class="pp-mh-loading"><div class="pp-mh-spinner"></div> Loading upcoming matches…</div>
  </div>
</section>

  <!-- MOUSE & SENSITIVITY -->
  <section class="pp-section" id="sensitivity">
    <h2 class="pp-section-title">Mouse & Sensitivity</h2>
    <div class="pp-kv-grid">
      <div class="pp-kv"><span class="pp-kv-key">Mouse DPI</span><span class="pp-kv-val">{player.dpi}</span></div>
      <div class="pp-kv"><span class="pp-kv-key">Game Sensitivity</span><span class="pp-kv-val">{player.sens}</span></div>
      <div class="pp-kv pp-kv-accent"><span class="pp-kv-key">eDPI</span><span class="pp-kv-val">{player.edpi}</span></div>
      <div class="pp-kv"><span class="pp-kv-key">Zoom Sensitivity</span><span class="pp-kv-val">{player.zoomSens}</span></div>
      <div class="pp-kv"><span class="pp-kv-key">Polling Rate</span><span class="pp-kv-val">{player.pollingRate}Hz</span></div>
      <div class="pp-kv"><span class="pp-kv-key">cm/360</span><span class="pp-kv-val">{cm360}cm</span></div>
    </div>
    <div class="pp-edpi-meter">
      <div class="pp-edpi-track">
        <div class="pp-edpi-pin" style={`left:${Math.min(100, Math.max(0, ((player.edpi - 400) / (1700 - 400)) * 100))}%`}>
          <span>{player.edpi}</span>
        </div>
        <div class="pp-edpi-avg" style={`left:${((avgEdpi - 400) / (1700 - 400)) * 100}%`}>
          <span>Avg {avgEdpi}</span>
        </div>
      </div>
      <div class="pp-edpi-labels"><span>Low</span><span>Medium</span><span>High</span></div>
    </div>
    <div class="pp-edpi-dist">
      <div class="pp-edpi-dist-header">
        <span class="pp-edpi-dist-title">Pro eDPI Distribution</span>
        <span class="pp-edpi-dist-pctl">{player.name}: {edpiPctLabel} of pros</span>
      </div>
      <div class="pp-edpi-hist">
        {edpiHistBars.map(b => (
          <div class={`pp-edpi-hist-col ${b.active ? 'active' : ''}`}>
            <span class="pp-edpi-hist-pct">{b.pct}%</span>
            <div class="pp-edpi-hist-bar" style={`height:${b.height}px`}></div>
            <span class="pp-edpi-hist-label">{b.label}</span>
          </div>
        ))}
      </div>
    </div>
    <h3 class="pp-sub">Mouse & Mousepad</h3>
    <div class="pp-kv-grid">
      <div class="pp-kv"><span class="pp-kv-key">Mouse</span><span class="pp-kv-val">{player.mouse}</span></div>
      <div class="pp-kv"><span class="pp-kv-key">Mousepad</span><span class="pp-kv-val">{player.mousepad}</span></div>
    </div>
  </section>

  <!-- CROSSHAIR -->
  <section class="pp-section" id="crosshair">
    <h2 class="pp-section-title">Crosshair</h2>
    <div class="pp-xhair-preview" id="xhairPreview">
      <div class="pp-xhair-render" id="xhairRender"></div>
      <span class="pp-xhair-label">{player.name}'s Crosshair</span>
    </div>
    <a href="/crosshair-generator/" class="pp-xhair-link">Open in Crosshair Generator &rarr;</a>

    <div class="pp-code-box">
      <code id="xhairCode">{player.crosshairCode || 'Not available'}</code>
      {player.crosshairCode && <button class="pp-copy-btn" id="copyXhair">Copy Crosshair</button>}
    </div>

    <div class="pp-kv-grid">
      <div class="pp-kv"><span class="pp-kv-key">Style</span><span class="pp-kv-val">{hasCrosshairSettings ? player.crosshairSettings!.style || player.crosshairStyle : player.crosshairStyle}</span></div>
      <div class="pp-kv"><span class="pp-kv-key">Color</span><span class="pp-kv-val">{hasCrosshairSettings ? player.crosshairSettings!.color || player.crosshairColor || 'N/A' : player.crosshairColor || 'N/A'}</span></div>
      <div class="pp-kv"><span class="pp-kv-key">Size</span><span class="pp-kv-val">{hasCrosshairSettings ? player.crosshairSettings!.size || player.crosshairSize : player.crosshairSize}</span></div>
      <div class="pp-kv"><span class="pp-kv-key">Thickness</span><span class="pp-kv-val">{hasCrosshairSettings ? player.crosshairSettings!.thickness || player.crosshairThickness : player.crosshairThickness}</span></div>
      <div class="pp-kv"><span class="pp-kv-key">Gap</span><span class="pp-kv-val">{hasCrosshairSettings ? player.crosshairSettings!.gap ?? player.crosshairGap : player.crosshairGap}</span></div>
      <div class="pp-kv"><span class="pp-kv-key">Dot</span><span class="pp-kv-val">{hasCrosshairSettings ? player.crosshairSettings!.dot || (player.crosshairDot ? 'Yes' : 'No') : (player.crosshairDot ? 'Yes' : 'No')}</span></div>
      <div class="pp-kv"><span class="pp-kv-key">Outline</span><span class="pp-kv-val">{hasCrosshairSettings ? player.crosshairSettings!.outline || (player.crosshairOutline ? 'Yes' : 'No') : (player.crosshairOutline ? 'Yes' : 'No')}</span></div>
    </div>
    {hasCrosshairSettings && (
    <details class="pp-advanced">
      <summary>Advanced Crosshair Settings</summary>
      <div class="pp-kv-grid">
        {player.crosshairSettings!.followRecoil && <div class="pp-kv"><span class="pp-kv-key">Follow Recoil</span><span class="pp-kv-val">{player.crosshairSettings!.followRecoil}</span></div>}
        {player.crosshairSettings!.tStyle && <div class="pp-kv"><span class="pp-kv-key">T-Style</span><span class="pp-kv-val">{player.crosshairSettings!.tStyle}</span></div>}
        {player.crosshairSettings!.red !== undefined && <div class="pp-kv"><span class="pp-kv-key">Red</span><span class="pp-kv-val">{player.crosshairSettings!.red}</span></div>}
        {player.crosshairSettings!.green !== undefined && <div class="pp-kv"><span class="pp-kv-key">Green</span><span class="pp-kv-val">{player.crosshairSettings!.green}</span></div>}
        {player.crosshairSettings!.blue !== undefined && <div class="pp-kv"><span class="pp-kv-key">Blue</span><span class="pp-kv-val">{player.crosshairSettings!.blue}</span></div>}
        {player.crosshairSettings!.useAlpha && <div class="pp-kv"><span class="pp-kv-key">Use Alpha</span><span class="pp-kv-val">{player.crosshairSettings!.useAlpha}</span></div>}
        {player.crosshairSettings!.alphaValue && <div class="pp-kv"><span class="pp-kv-key">Alpha</span><span class="pp-kv-val">{player.crosshairSettings!.alphaValue}</span></div>}
        {player.crosshairSettings!.outlineThickness && <div class="pp-kv"><span class="pp-kv-key">Outline Thickness</span><span class="pp-kv-val">{player.crosshairSettings!.outlineThickness}</span></div>}
        {player.crosshairSettings!.deployedWeaponGap && <div class="pp-kv"><span class="pp-kv-key">Deployed Weapon Gap</span><span class="pp-kv-val">{player.crosshairSettings!.deployedWeaponGap}</span></div>}
        {player.crosshairSettings!.splitDistance && <div class="pp-kv"><span class="pp-kv-key">Split Distance</span><span class="pp-kv-val">{player.crosshairSettings!.splitDistance}</span></div>}
        {player.crosshairSettings!.fixedGap && <div class="pp-kv"><span class="pp-kv-key">Fixed Gap</span><span class="pp-kv-val">{player.crosshairSettings!.fixedGap}</span></div>}
        {player.crosshairSettings!.innerSplitAlpha && <div class="pp-kv"><span class="pp-kv-key">Inner Split Alpha</span><span class="pp-kv-val">{player.crosshairSettings!.innerSplitAlpha}</span></div>}
        {player.crosshairSettings!.outerSplitAlpha && <div class="pp-kv"><span class="pp-kv-key">Outer Split Alpha</span><span class="pp-kv-val">{player.crosshairSettings!.outerSplitAlpha}</span></div>}
        {player.crosshairSettings!.splitSizeRatio && <div class="pp-kv"><span class="pp-kv-key">Split Size Ratio</span><span class="pp-kv-val">{player.crosshairSettings!.splitSizeRatio}</span></div>}
        {player.crosshairSettings!.sniperWidth && <div class="pp-kv"><span class="pp-kv-key">Sniper Width</span><span class="pp-kv-val">{player.crosshairSettings!.sniperWidth}</span></div>}
      </div>
    </details>
    )}
  </section>

  <!-- VIDEO & DISPLAY -->
  <section class="pp-section" id="video">
    <h2 class="pp-section-title">Video & Display</h2>
    <div class="pp-kv-grid">
      <div class="pp-kv pp-kv-accent"><span class="pp-kv-key">Resolution</span><span class="pp-kv-val">{player.res}</span></div>
      <div class="pp-kv"><span class="pp-kv-key">Aspect Ratio</span><span class="pp-kv-val">{player.aspect}</span></div>
      <div class="pp-kv"><span class="pp-kv-key">Scaling Mode</span><span class="pp-kv-val">{player.stretch}</span></div>
      <div class="pp-kv"><span class="pp-kv-key">Refresh Rate</span><span class="pp-kv-val">{player.refreshRate}Hz</span></div>
      <div class="pp-kv"><span class="pp-kv-key">Monitor</span><span class="pp-kv-val">{player.monitor}</span></div>
      {player.videoSettings?.displayMode && <div class="pp-kv"><span class="pp-kv-key">Display Mode</span><span class="pp-kv-val">{player.videoSettings.displayMode}</span></div>}
      {player.videoSettings?.brightness && <div class="pp-kv"><span class="pp-kv-key">Brightness</span><span class="pp-kv-val">{player.videoSettings.brightness}</span></div>}
      {player.videoSettings?.boostPlayerContrast && <div class="pp-kv"><span class="pp-kv-key">Boost Player Contrast</span><span class="pp-kv-val">{player.videoSettings.boostPlayerContrast}</span></div>}
      {player.videoSettings?.vsync && <div class="pp-kv"><span class="pp-kv-key">V-Sync</span><span class="pp-kv-val">{player.videoSettings.vsync}</span></div>}
      {player.videoSettings?.nvidiaReflex && <div class="pp-kv"><span class="pp-kv-key">NVIDIA Reflex</span><span class="pp-kv-val">{player.videoSettings.nvidiaReflex}</span></div>}
      {player.videoSettings?.nvidiaGSync && <div class="pp-kv"><span class="pp-kv-key">NVIDIA G-Sync</span><span class="pp-kv-val">{player.videoSettings.nvidiaGSync}</span></div>}
      {player.videoSettings?.maxFPS && <div class="pp-kv"><span class="pp-kv-key">Max FPS</span><span class="pp-kv-val">{player.videoSettings.maxFPS}</span></div>}
    </div>
    {hasVideoSettings && (
    <>
    <h3 class="pp-sub">Advanced Video</h3>
    <div class="pp-kv-grid">
      {player.videoSettings!.msaa && <div class="pp-kv"><span class="pp-kv-key">Anti-Aliasing</span><span class="pp-kv-val">{player.videoSettings!.msaa}</span></div>}
      {player.videoSettings!.globalShadowQuality && <div class="pp-kv"><span class="pp-kv-key">Shadow Quality</span><span class="pp-kv-val">{player.videoSettings!.globalShadowQuality}</span></div>}
      {player.videoSettings!.dynamicShadows && <div class="pp-kv"><span class="pp-kv-key">Dynamic Shadows</span><span class="pp-kv-val">{player.videoSettings!.dynamicShadows}</span></div>}
      {player.videoSettings!.modelTextureDetail && <div class="pp-kv"><span class="pp-kv-key">Texture Detail</span><span class="pp-kv-val">{player.videoSettings!.modelTextureDetail}</span></div>}
      {player.videoSettings!.textureFilteringMode && <div class="pp-kv"><span class="pp-kv-key">Texture Filtering</span><span class="pp-kv-val">{player.videoSettings!.textureFilteringMode}</span></div>}
      {player.videoSettings!.shaderDetail && <div class="pp-kv"><span class="pp-kv-key">Shader Detail</span><span class="pp-kv-val">{player.videoSettings!.shaderDetail}</span></div>}
      {player.videoSettings!.particleDetail && <div class="pp-kv"><span class="pp-kv-key">Particle Detail</span><span class="pp-kv-val">{player.videoSettings!.particleDetail}</span></div>}
      {player.videoSettings!.ambientOcclusion && <div class="pp-kv"><span class="pp-kv-key">Ambient Occlusion</span><span class="pp-kv-val">{player.videoSettings!.ambientOcclusion}</span></div>}
      {player.videoSettings!.hdr && <div class="pp-kv"><span class="pp-kv-key">HDR</span><span class="pp-kv-val">{player.videoSettings!.hdr}</span></div>}
      {player.videoSettings!.fidelityFX && <div class="pp-kv"><span class="pp-kv-key">FidelityFX</span><span class="pp-kv-val">{player.videoSettings!.fidelityFX}</span></div>}
    </div>
    </>
    )}

    <!-- Viewmodel -->
    <h3 class="pp-sub" id="viewmodel">Viewmodel{hasBobSettings ? ' & Bob' : ''}</h3>
    <div class="pp-kv-grid">
      <div class="pp-kv"><span class="pp-kv-key">viewmodel_fov</span><span class="pp-kv-val">{player.vmFov}</span></div>
      <div class="pp-kv"><span class="pp-kv-key">viewmodel_offset_x</span><span class="pp-kv-val">{player.vmX}</span></div>
      <div class="pp-kv"><span class="pp-kv-key">viewmodel_offset_y</span><span class="pp-kv-val">{player.vmY}</span></div>
      <div class="pp-kv"><span class="pp-kv-key">viewmodel_offset_z</span><span class="pp-kv-val">{player.vmZ}</span></div>
      {player.vmPresetpos && <div class="pp-kv"><span class="pp-kv-key">viewmodel_presetpos</span><span class="pp-kv-val">{player.vmPresetpos}</span></div>}
    </div>
    <div class="pp-cmd-row">
      <code id="vmCmds">viewmodel_fov {player.vmFov}; viewmodel_offset_x {player.vmX}; viewmodel_offset_y {player.vmY}; viewmodel_offset_z {player.vmZ}</code>
      <button class="pp-copy-btn pp-copy-sm" id="copyVm">Copy</button>
    </div>
    {hasBobSettings && (
    <>
    <h3 class="pp-sub">Weapon Bob</h3>
    <div class="pp-kv-grid">
      {player.bobSettings!.lowerAmt && <div class="pp-kv"><span class="pp-kv-key">cl_bob_lower_amt</span><span class="pp-kv-val">{player.bobSettings!.lowerAmt}</span></div>}
      {player.bobSettings!.amtLat && <div class="pp-kv"><span class="pp-kv-key">cl_bobamt_lat</span><span class="pp-kv-val">{player.bobSettings!.amtLat}</span></div>}
      {player.bobSettings!.amtVert && <div class="pp-kv"><span class="pp-kv-key">cl_bobamt_vert</span><span class="pp-kv-val">{player.bobSettings!.amtVert}</span></div>}
      {player.bobSettings!.cycle && <div class="pp-kv"><span class="pp-kv-key">cl_bobcycle</span><span class="pp-kv-val">{player.bobSettings!.cycle}</span></div>}
    </div>
    </>
    )}

    <!-- Radar & HUD -->
    {(hasRadarSettings || hasHudSettings) && (
    <>
    <h3 class="pp-sub" id="gamehud">Radar & HUD</h3>
    <div class="pp-kv-grid">
      {hasRadarSettings && (
      <>
        {player.radarSettings!.centersPlayer && <div class="pp-kv"><span class="pp-kv-key">Centers Player</span><span class="pp-kv-val">{player.radarSettings!.centersPlayer}</span></div>}
        {player.radarSettings!.rotating && <div class="pp-kv"><span class="pp-kv-key">Rotating</span><span class="pp-kv-val">{player.radarSettings!.rotating}</span></div>}
        {player.radarSettings!.toggleShape && <div class="pp-kv"><span class="pp-kv-key">Toggle Shape</span><span class="pp-kv-val">{player.radarSettings!.toggleShape}</span></div>}
        {player.radarSettings!.hudSize && <div class="pp-kv"><span class="pp-kv-key">Radar HUD Size</span><span class="pp-kv-val">{player.radarSettings!.hudSize}</span></div>}
        {player.radarSettings!.mapZoom && <div class="pp-kv"><span class="pp-kv-key">Radar Map Zoom</span><span class="pp-kv-val">{player.radarSettings!.mapZoom}</span></div>}
      </>
      )}
      {hasHudSettings && (
      <>
        {player.hudSettings!.scale && <div class="pp-kv"><span class="pp-kv-key">HUD Scale</span><span class="pp-kv-val">{player.hudSettings!.scale}</span></div>}
        {player.hudSettings!.color && <div class="pp-kv"><span class="pp-kv-key">HUD Color</span><span class="pp-kv-val">{player.hudSettings!.color}</span></div>}
      </>
      )}
    </div>
    </>
    )}

    <!-- Monitor Settings -->
    {hasMonitorSettings && (
    <>
    <h3 class="pp-sub" id="monitorsettings">Monitor Settings</h3>
    <div class="pp-kv-grid">
      {player.monitorSettings!.dyac && <div class="pp-kv"><span class="pp-kv-key">DyAc</span><span class="pp-kv-val">{player.monitorSettings!.dyac}</span></div>}
      {player.monitorSettings!.blackEqualizer && <div class="pp-kv"><span class="pp-kv-key">Black eQualizer</span><span class="pp-kv-val">{player.monitorSettings!.blackEqualizer}</span></div>}
      {player.monitorSettings!.colorVibrance && <div class="pp-kv"><span class="pp-kv-key">Color Vibrance</span><span class="pp-kv-val">{player.monitorSettings!.colorVibrance}</span></div>}
      {player.monitorSettings!.lowBlueLight && <div class="pp-kv"><span class="pp-kv-key">Low Blue Light</span><span class="pp-kv-val">{player.monitorSettings!.lowBlueLight}</span></div>}
      {player.monitorSettings!.pictureMode && <div class="pp-kv"><span class="pp-kv-key">Picture Mode</span><span class="pp-kv-val">{player.monitorSettings!.pictureMode}</span></div>}
      {player.monitorSettings!.contrast && <div class="pp-kv"><span class="pp-kv-key">Contrast</span><span class="pp-kv-val">{player.monitorSettings!.contrast}</span></div>}
      {player.monitorSettings!.sharpness && <div class="pp-kv"><span class="pp-kv-key">Sharpness</span><span class="pp-kv-val">{player.monitorSettings!.sharpness}</span></div>}
      {player.monitorSettings!.gamma && <div class="pp-kv"><span class="pp-kv-key">Gamma</span><span class="pp-kv-val">{player.monitorSettings!.gamma}</span></div>}
      {player.monitorSettings!.colorTemperature && <div class="pp-kv"><span class="pp-kv-key">Color Temperature</span><span class="pp-kv-val">{player.monitorSettings!.colorTemperature}</span></div>}
      {player.monitorSettings!.ama && <div class="pp-kv"><span class="pp-kv-key">AMA</span><span class="pp-kv-val">{player.monitorSettings!.ama}</span></div>}
    </div>
    </>
    )}
  </section>

  <!-- GEAR & PERIPHERALS -->
  <section class="pp-section" id="gear">
    <h2 class="pp-section-title">Gear & Peripherals</h2>
    <div class="pp-gear-list">
      {[
        { key: 'mouse' as const, label: 'Mouse', value: player.mouse },
        { key: 'monitor' as const, label: 'Monitor', value: player.monitor },
        { key: 'keyboard' as const, label: 'Keyboard', value: player.keyboard },
        { key: 'headset' as const, label: 'Headset', value: player.headset },
        { key: 'mousepad' as const, label: 'Mousepad', value: player.mousepad },
      ].map(g => {
        const gearSlug = `${g.key}-${g.value.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '')}`;
        return (
        <a href={`/pro-gaming-gear/${gearSlug}/`} class="pp-gear-item">
          {getGearImageUrl(g.value) && <img class="pp-gear-img" src={getGearImageUrl(g.value)} alt={g.value} width="36" height="36" loading="lazy" onerror="this.style.display='none'" />}
          <span class="pp-gear-label">{g.label}</span>
          <span class="pp-gear-value">{g.value}</span>
        </a>
        );
      })}
    </div>

    {/* PC Specs */}
    {player.gpu && (
    <>
    <h3 class="pp-sub" id="pcspecs">PC Specs</h3>
    <div class="pp-gear-list">
      <div class="pp-gear-item"><span class="pp-gear-label">GPU</span><span class="pp-gear-value">{player.gpu}</span></div>
    </div>
    </>
    )}

    {/* Loadout */}
    {hasLoadout && (
    <>
    <h3 class="pp-sub" id="loadout">{player.name}'s Weapon Skins</h3>
    <div class="pp-loadout-grid">
      {resolvedLoadout.map(item => (
        <a href={item.skin ? `/cs2-skins/${item.slug}/` : '#'} class={`pp-loadout-card${item.skin ? '' : ' pp-loadout-nolink'}`} style={item.rarityColor ? `border-color:${item.rarityColor}` : ''}>
          {item.image ? (
            <img class="pp-loadout-img" src={item.image} alt={item.name} width="160" height="120" loading="lazy" onerror="this.style.display='none'" />
          ) : (
            <div class="pp-loadout-placeholder"><span>{item.label}</span></div>
          )}
          <div class="pp-loadout-info">
            <span class="pp-loadout-slot">{item.label}</span>
            <span class="pp-loadout-name">{item.name}</span>
            {item.rarity && <span class="pp-loadout-rarity" style={`color:${item.rarityColor}`}>{item.rarity}</span>}
          </div>
        </a>
      ))}
    </div>
    </>
    )}
  </section>

  <!-- CONFIG & DOWNLOAD -->
  <section class="pp-section" id="config">
    <h2 class="pp-section-title">Config & Download</h2>
    <p class="pp-config-desc">Grab {player.name}'s full CS2 config as an autoexec file, or copy console commands directly.</p>
    <div class="pp-config-actions">
      <button class="pp-config-btn pp-config-dl" id="downloadConfig">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
        Download autoexec.cfg
      </button>
      <button class="pp-config-btn pp-config-cp" id="copyAllCmds">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
        Copy All Commands
      </button>
    </div>
    <div class="pp-config-preview">
      <div class="pp-config-bar">
        <span>autoexec.cfg</span>
        <button class="pp-copy-btn pp-copy-sm" id="copyConfig">Copy</button>
      </div>
      <pre id="configPreview">{configText}</pre>
    </div>

    {/* Launch Options */}
    {player.launchOptions && (
    <>
    <h3 class="pp-sub" id="launch">Launch Options</h3>
    <div class="pp-cmd-row">
      <code id="launchOpts">{player.launchOptions}</code>
      <button class="pp-copy-btn pp-copy-sm" id="copyLaunch">Copy</button>
    </div>
    </>
    )}
  </section>

<!-- PandaScore Live Performance Stats (loaded client-side) -->
<section class="pp-section pp-live-stats" id="livestats">
  <h2 class="pp-section-title">Performance Stats</h2>
  <p class="pp-live-stats-sub">Live stats from professional matches, powered by PandaScore.</p>
  <div id="liveStatsContent">
    <div class="pp-ls-loading"><div class="pp-ls-spinner"></div> Loading performance data…</div>
  </div>
</section>

<!-- Match History (loaded client-side) -->
<section class="pp-section pp-match-history" id="matchhistory">
  <h2 class="pp-section-title">Recent Matches</h2>
  <p class="pp-match-history-sub">Recent match results for this player's team.</p>
  <div id="matchHistoryContent">
    <div class="pp-mh-loading"><div class="pp-mh-spinner"></div> Loading match history…</div>
  </div>
</section>

</div><!-- /pp-main -->
</div><!-- /pp-layout -->

<!-- Team Info: Sidebar-style box -->
{isRealTeam && teammates.length > 0 && (
<section class="pp-team-box" id="teammates">
  <div class="pp-team-header">{player.team}</div>
  <div class="pp-team-roster">
    {teammates.map(t => (
      <a href={`/pro-players/${t.slug}/`} class="pp-team-member">
        <span class="pp-team-member-name">{t.flag} {t.name}</span>
        <span class="pp-team-member-edpi">{t.edpi} eDPI</span>
      </a>
    ))}
  </div>
</section>
)}

<!-- Similar Players: Horizontal scrolling strip -->
<section class="pp-section" id="similar">
  <h2 class="pp-section-title">Similar Configs</h2>
  <div class="pp-similar-strip">
    {similar.map(s => (
      <a href={`/pro-players/${s.slug}/`} class="pp-similar-card">
        {s.image && <img class="pp-similar-img" src={s.image} alt={s.name} width="40" height="40" loading="lazy" onerror="this.style.display='none'" />}
        <span class="pp-similar-name">{s.flag} {s.name}</span>
        <span class="pp-similar-detail">{s.team}</span>
        <span class="pp-similar-edpi">{s.edpi} eDPI</span>
      </a>
    ))}
  </div>

  <!-- Quick Compare Table -->
  <div class="pp-compare">
    <h3 class="pp-compare-title">Settings Comparison</h3>
    <div class="pp-compare-scroll">
      <table class="pp-compare-table">
        <thead>
          <tr>
            <th class="pp-compare-label">Setting</th>
            <th class="pp-compare-player pp-compare-current">{player.name}</th>
            {similar.slice(0, 4).map(s => (
              <th class="pp-compare-player"><a href={`/pro-players/${s.slug}/`}>{s.name}</a></th>
            ))}
          </tr>
        </thead>
        <tbody>
          <tr>
            <td class="pp-compare-label">eDPI</td>
            <td class="pp-compare-current">{player.edpi}</td>
            {similar.slice(0, 4).map(s => <td>{s.edpi}</td>)}
          </tr>
          <tr>
            <td class="pp-compare-label">DPI</td>
            <td class="pp-compare-current">{player.dpi}</td>
            {similar.slice(0, 4).map(s => <td>{s.dpi}</td>)}
          </tr>
          <tr>
            <td class="pp-compare-label">Sensitivity</td>
            <td class="pp-compare-current">{player.sens}</td>
            {similar.slice(0, 4).map(s => <td>{s.sens}</td>)}
          </tr>
          <tr>
            <td class="pp-compare-label">Resolution</td>
            <td class="pp-compare-current">{player.res}</td>
            {similar.slice(0, 4).map(s => <td>{s.res}</td>)}
          </tr>
          <tr>
            <td class="pp-compare-label">Aspect</td>
            <td class="pp-compare-current">{player.aspect}</td>
            {similar.slice(0, 4).map(s => <td>{s.aspect}</td>)}
          </tr>
          <tr>
            <td class="pp-compare-label">Scaling</td>
            <td class="pp-compare-current">{player.stretch}</td>
            {similar.slice(0, 4).map(s => <td>{s.stretch}</td>)}
          </tr>
          <tr>
            <td class="pp-compare-label">Mouse</td>
            <td class="pp-compare-current">{player.mouse}</td>
            {similar.slice(0, 4).map(s => <td>{s.mouse}</td>)}
          </tr>
          <tr>
            <td class="pp-compare-label">Refresh Rate</td>
            <td class="pp-compare-current">{player.refreshRate}Hz</td>
            {similar.slice(0, 4).map(s => <td>{s.refreshRate}Hz</td>)}
          </tr>
        </tbody>
      </table>
    </div>
  </div>
</section>

<!-- FAQ: <details> accordion -->
<section class="pp-section" id="faq">
  <h2 class="pp-section-title">Frequently Asked Questions</h2>
  {faqs.map(f => (
    <details class="pp-faq">
      <summary class="pp-faq-q">{f.question}</summary>
      <p class="pp-faq-a">{f.answer}</p>
    </details>
  ))}
</section>

<!-- Internal Links -->
<div class="internal-links">
  <strong>Related:</strong>
  <a href="/pro-players/">All Configs</a>
  <a href="/pro-teams/">Pro Teams</a>
  {isRealTeam && <a href={`/pro-teams/${player.team.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '')}/`}>{player.team} Settings</a>}
  <a href="/pro-gaming-gear/">Pro Gaming Gear</a>
  <a href="/crosshair-codes/">Crosshair Codes</a>
  <a href="/crosshair-generator/">Crosshair Generator</a>
  <a href="/sensitivity-converter/">Sensitivity Converter</a>
  <a href="/edpi-calculator/">eDPI Calculator</a>
  <a href="/cm360-calculator/">cm/360 Calculator</a>
  <a href="/resolution-calculator/">Resolution Calculator</a>
  <a href="/loadout-builder/">Loadout Builder</a>
  <a href="/autoexec-generator/">Autoexec Generator</a>
  <a href="/bind-generator/">Bind Generator</a>
  <a href="/cs2-weapons/">Weapon Database</a>
  <a href="/cs2-skins/">Skin Database</a>
  <a href="/cs2-maps/">Map Callouts</a>
  <a href="/cs2-guides/crosshair-guide/">Crosshair Guide</a>
  <a href="/cs2-guides/sensitivity-guide/">Sensitivity Guide</a>
  <a href="/cs2-guides/config-guide/">Config Guide</a>
  <a href="/cs2-tools/">All Tools</a>
</div>

