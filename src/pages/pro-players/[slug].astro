<style>
/* ── Hero: Two-column layout ─────────────────────────────────────────────── */
.pp-hero{display:flex;gap:1.5rem;align-items:flex-start;padding:1.25rem 0;margin-bottom:1.5rem;border-bottom:1px solid var(--border)}
.pp-hero-left{display:flex;flex-direction:column;align-items:center;gap:.6rem;flex-shrink:0}
.pp-hero-img-wrap{position:relative;display:inline-block}
.pp-hero-img{width:120px;height:120px;border-radius:4px;object-fit:cover;border:2px solid var(--border);background:var(--bg3)}
.pp-hero-flag{position:absolute;bottom:-4px;right:-4px;font-size:1.3rem;line-height:1;filter:drop-shadow(0 1px 3px rgba(0,0,0,.5))}
.pp-hero-badge{display:flex;flex-direction:column;align-items:center;gap:.3rem}
.pp-hero-team-link{display:flex;align-items:center;gap:.35rem;text-decoration:none;color:var(--accent);transition:opacity .15s}
.pp-hero-team-link:hover{opacity:.8}
.pp-hero-team-logo{display:inline-block;width:18px;height:18px;flex-shrink:0;overflow:hidden}
.pp-hero-team-logo img{width:18px;height:18px;max-width:18px;max-height:18px;object-fit:contain;display:block}
.pp-hero-team{color:var(--accent);font-weight:700;font-size:.85rem;text-align:center}
.pp-hero-role{font-size:.62rem;font-weight:700;padding:.15rem .5rem;border-radius:4px;text-transform:uppercase;letter-spacing:.04em;background:var(--bg3);color:var(--text2);border:1px solid var(--border)}
.pp-hero-role[data-r="awper"]{background:rgba(239,83,80,.12);color:var(--red);border-color:var(--red)}
.pp-hero-role[data-r="rifler"]{background:rgba(66,165,245,.12);color:var(--blue);border-color:var(--blue)}
.pp-hero-role[data-r="igl"]{background:rgba(171,71,188,.12);color:var(--purple);border-color:var(--purple)}
.pp-hero-role[data-r="entry-fragger"]{background:rgba(46,204,113,.12);color:var(--accent);border-color:var(--accent)}
.pp-hero-role[data-r="support"]{background:rgba(76,175,80,.12);color:var(--green);border-color:var(--green)}

.pp-hero-right{flex:1;min-width:0}
.pp-hero-name{font-size:1.8rem;font-weight:800;margin:0 0 .3rem;letter-spacing:-.02em}
.pp-hero-name-sub{font-size:.85rem;font-weight:500;color:var(--text2);letter-spacing:0;display:block;margin-top:.1rem}
.pp-hero-meta{display:flex;gap:.6rem;flex-wrap:wrap;align-items:center;margin-bottom:.75rem}
.pp-hero-country,.pp-hero-age,.pp-hero-realname{color:var(--text2);font-size:.82rem}
.pp-hero-realname{font-style:italic}
.pp-share-btn{display:inline-flex;align-items:center;gap:.35rem;margin-top:.5rem;padding:.35rem .7rem;background:var(--bg3);border:1px solid var(--border);border-radius:4px;color:var(--text2);font-size:.72rem;font-weight:600;cursor:pointer;font-family:inherit;transition:all .15s}
.pp-share-btn:hover{border-color:var(--accent);color:var(--accent)}
.pp-share-btn.shared{border-color:var(--accent);color:var(--accent);background:rgba(46,204,113,.08)}

.pp-hero-table{width:100%;border-collapse:collapse;font-size:.82rem}
.pp-hero-table td{padding:.35rem .5rem;border-bottom:1px solid var(--border)}
.pp-hero-tl{color:var(--text2);font-weight:600;width:25%}
.pp-hero-tv{color:var(--text);font-weight:700;width:25%}
.pp-hero-tv-accent{color:var(--accent)}

/* ── Bio ─────────────────────────────────────────────────────────────────── */
.pp-bio{margin-bottom:1.5rem;line-height:1.65}
.pp-bio p{color:var(--text2);font-size:.88rem;margin:0}
.pp-bio-extra{margin-top:.6rem;color:var(--text);font-style:italic;border-left:3px solid var(--accent);padding-left:.75rem}

/* ── Two-Column Layout: Sticky Sidebar + Main ───────────────────────────── */
.pp-layout{display:flex;gap:1.5rem;align-items:flex-start;margin-bottom:2.5rem}
.pp-sidebar{position:sticky;top:70px;width:200px;flex-shrink:0;align-self:flex-start}
.pp-sidebar-list{list-style:none;margin:0;padding:0;display:flex;flex-direction:column;gap:1px;background:var(--bg2);border:1px solid var(--border);border-radius:4px;overflow:hidden}
.pp-sidebar-list li{margin:0}
.pp-sidebar-link{display:block;padding:.5rem .75rem;font-size:.78rem;font-weight:600;color:var(--text2);text-decoration:none;border-left:3px solid transparent;transition:all .15s}
.pp-sidebar-link:hover{color:var(--text);background:var(--bg3);border-left-color:var(--accent)}
.pp-sidebar-link.active{color:var(--accent);background:var(--bg3);border-left-color:var(--accent)}
.pp-main{flex:1;min-width:0}

/* ── Section blocks ─────────────────────────────────────────────────────── */
.pp-section{margin-bottom:2rem;scroll-margin-top:70px;background:var(--bg2);border:1px solid var(--border);border-radius:4px;padding:1.5rem}
.pp-section-title{font-size:1.1rem;margin:0 0 .75rem;font-weight:700}
.pp-sub{font-size:.92rem;font-weight:700;color:var(--text);margin:1.25rem 0 .5rem;padding-top:1rem;border-top:1px solid var(--border);scroll-margin-top:80px}

/* ── Key-Value Grid (settings rows) ──────────────────────────────────────── */
.pp-kv-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:.3rem}
.pp-kv{font-size:.85rem;color:var(--text);padding:.4rem .6rem;background:var(--bg);border:1px solid var(--border);border-left:3px solid transparent;border-radius:4px;display:flex;justify-content:space-between;align-items:center}
.pp-kv:hover{border-left-color:var(--accent)}
.pp-kv-key{color:var(--text2);font-weight:600;font-size:.8rem}
.pp-kv-val{font-weight:700}
.pp-kv-accent{border-left:3px solid var(--accent)}
.pp-kv-accent .pp-kv-val{color:var(--accent)}

/* ── eDPI Meter ──────────────────────────────────────────────────────────── */
.pp-edpi-meter{margin:1rem 0}
.pp-edpi-track{position:relative;height:22px;background:linear-gradient(90deg,var(--green),#f1c40f,var(--red));border-radius:4px;opacity:.25}
.pp-edpi-pin{position:absolute;top:-7px;transform:translateX(-50%);z-index:2}
.pp-edpi-pin span{background:var(--accent);color:#000;font-size:.66rem;font-weight:800;padding:.12rem .4rem;border-radius:4px;display:block;white-space:nowrap}
.pp-edpi-avg{position:absolute;bottom:-7px;transform:translateX(-50%);z-index:1}
.pp-edpi-avg span{font-size:.56rem;color:var(--text2);font-weight:600;white-space:nowrap}
.pp-edpi-labels{display:flex;justify-content:space-between;margin-top:.4rem;font-size:.65rem;color:var(--text2)}

/* ── eDPI Distribution Histogram ─────────────────────────────────────────── */
.pp-edpi-dist{margin-top:1rem;padding:.8rem;background:var(--bg);border:1px solid var(--border);border-radius:4px}
.pp-edpi-dist-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:.6rem;flex-wrap:wrap;gap:.3rem}
.pp-edpi-dist-title{font-size:.72rem;font-weight:700;color:var(--text)}
.pp-edpi-dist-pctl{font-size:.68rem;color:var(--accent);font-weight:600}
.pp-edpi-hist{display:flex;align-items:flex-end;gap:2px;justify-content:space-between}
.pp-edpi-hist-col{display:flex;flex-direction:column;align-items:center;flex:1;min-width:0}
