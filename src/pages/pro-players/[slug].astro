.pp-gear-item:hover{background:var(--bg3)}
.pp-gear-img{width:36px;height:36px;object-fit:contain;border-radius:4px;flex-shrink:0}
.pp-gear-label{color:var(--text2);font-weight:600;font-size:.78rem;min-width:70px}
.pp-gear-value{color:var(--text);font-weight:700;flex:1}

/* ── Loadout ─────────────────────────────────────────────────────────────── */
.pp-loadout-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(170px,1fr));gap:.65rem}
.pp-loadout-card{background:var(--bg);border:2px solid var(--border);border-radius:4px;overflow:hidden;text-decoration:none;transition:border-color .15s}
.pp-loadout-card:hover{border-color:var(--accent)}
.pp-loadout-card.pp-loadout-nolink{pointer-events:none}
.pp-loadout-img{width:100%;height:95px;object-fit:contain;background:var(--bg3);padding:.5rem;display:block}
.pp-loadout-placeholder{width:100%;height:95px;display:flex;align-items:center;justify-content:center;background:var(--bg3);color:var(--text2);font-size:.82rem;font-weight:600}
.pp-loadout-info{padding:.45rem .65rem}
.pp-loadout-slot{display:block;font-size:.6rem;text-transform:uppercase;font-weight:700;color:var(--text2);letter-spacing:.04em;margin-bottom:.1rem}
.pp-loadout-name{display:block;font-size:.82rem;font-weight:700;color:var(--text);line-height:1.3}
.pp-loadout-rarity{display:block;font-size:.68rem;font-weight:600;margin-top:.12rem}

