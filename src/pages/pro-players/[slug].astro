.pp-edpi-hist-col.active .pp-edpi-hist-pct{color:var(--accent);font-weight:700}
.pp-edpi-hist-col.active .pp-edpi-hist-label{color:var(--accent);font-weight:700}
.pp-edpi-hist-label{font-size:.52rem;color:var(--text2);margin-top:2px;white-space:nowrap}

/* ── Crosshair Preview ──────────────────────────────────────────────────── */
.pp-xhair-preview{width:100%;max-width:360px;height:170px;background:linear-gradient(135deg,#2a2a2a 0%,#1a1a1a 50%,#2a2a2a 100%);border-radius:4px;position:relative;overflow:hidden;border:1px solid var(--border);margin-bottom:.4rem}
.pp-xhair-preview::before{content:'';position:absolute;inset:0;background:radial-gradient(circle at center,transparent 0%,rgba(0,0,0,.4) 100%)}
.pp-xhair-render{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);z-index:1}
.pp-xhair-label{position:absolute;bottom:.4rem;left:.6rem;font-size:.62rem;color:rgba(255,255,255,.35);z-index:1}
.pp-xhair-link{font-size:.78rem;color:var(--accent);text-decoration:none;font-weight:600;display:inline-block;margin-bottom:1rem}
.pp-xhair-link:hover{text-decoration:underline}

/* ── Code Box ────────────────────────────────────────────────────────────── */
.pp-code-box{display:flex;gap:.6rem;align-items:center;background:var(--bg);border:2px solid var(--accent);border-radius:4px;padding:.55rem .75rem;margin-bottom:1rem;font-family:monospace}
.pp-code-box code{flex:1;font-size:.8rem;color:var(--accent);word-break:break-all}
.pp-copy-btn{background:linear-gradient(135deg,#2ecc71,#27ae60);color:#fff;border:none;padding:.4rem .85rem;border-radius:4px;font-weight:700;font-size:.8rem;cursor:pointer;white-space:nowrap;font-family:inherit;box-shadow:0 2px 8px rgba(46,204,113,.2);transition:all .2s ease}
.pp-copy-btn:hover{transform:translateY(-1px);box-shadow:0 3px 12px rgba(46,204,113,.35)}
.pp-copy-btn.copied{background:linear-gradient(135deg,#4caf50,#388e3c);color:#fff;box-shadow:0 2px 8px rgba(76,175,80,.3)}
.pp-copy-sm{padding:.28rem .6rem;font-size:.75rem}

/* ── Command Row ─────────────────────────────────────────────────────────── */
.pp-cmd-row{display:flex;gap:.6rem;align-items:center;background:var(--bg);border:1px solid var(--border);border-radius:4px;padding:.4rem .6rem;margin-top:.5rem}
.pp-cmd-row code{flex:1;font-size:.78rem;color:var(--text);word-break:break-all}

/* ── Advanced Toggle ─────────────────────────────────────────────────────── */
.pp-advanced{margin-top:.75rem;border-top:1px solid var(--border);padding-top:.75rem}
.pp-advanced summary{cursor:pointer;color:var(--accent);font-size:.82rem;font-weight:600;padding:.3rem 0;user-select:none}
