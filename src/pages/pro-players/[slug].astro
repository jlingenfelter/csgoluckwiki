.pp-config-cp{background:var(--bg3);color:var(--text);border:1px solid var(--border)}
.pp-config-cp.copied{background:var(--green);color:#fff;border-color:var(--green)}
.pp-config-preview{background:var(--bg);border:1px solid var(--border);border-radius:4px;overflow:hidden}
.pp-config-bar{display:flex;justify-content:space-between;align-items:center;padding:.35rem .6rem;background:var(--bg3);border-bottom:1px solid var(--border)}
.pp-config-bar span{font-size:.7rem;color:var(--text2);font-weight:600}
.pp-config-preview pre{padding:.6rem;margin:0;font-size:.72rem;color:var(--text2);line-height:1.6;overflow-x:auto;max-height:200px;overflow-y:auto}

/* ── Team Box: Sidebar-style ─────────────────────────────────────────────── */
.pp-team-box{margin-bottom:2rem;background:var(--bg2);border:1px solid var(--border);border-radius:4px;overflow:hidden;max-width:400px}
.pp-team-header{padding:.65rem 1rem;background:var(--bg3);font-weight:700;font-size:.9rem;color:var(--accent);border-bottom:2px solid var(--accent)}
