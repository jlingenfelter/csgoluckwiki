.pp-team-member:last-child{border-bottom:none}
.pp-team-member:hover{border-left-color:var(--accent);background:var(--bg3)}
.pp-team-member-name{font-weight:700;font-size:.85rem;color:var(--text)}
.pp-team-member-edpi{font-size:.78rem;color:var(--text2)}

/* (section styles defined above in layout block) */

/* ── Similar Players: Horizontal scrolling strip ─────────────────────────── */
.pp-similar-strip{display:flex;gap:.5rem;overflow-x:auto;padding-bottom:.5rem;-webkit-overflow-scrolling:touch}
.pp-similar-card{display:flex;flex-direction:column;align-items:center;gap:.25rem;padding:.6rem .85rem;background:var(--bg2);border:1px solid var(--border);border-radius:4px;text-decoration:none;white-space:nowrap;flex-shrink:0;min-width:110px;transition:border-color .15s}
.pp-similar-card:hover{border-color:var(--accent)}
.pp-similar-img{width:40px;height:40px;border-radius:4px;object-fit:cover;border:1px solid var(--border);background:var(--bg3)}
.pp-similar-name{font-weight:700;font-size:.78rem;color:var(--text)}
.pp-similar-detail{font-size:.65rem;color:var(--text2)}
.pp-similar-edpi{font-size:.72rem;color:var(--accent);font-weight:700}

/* ── Compare Table ────────────────────────────────────────────────────────── */
.pp-compare{margin-top:1.2rem}
.pp-compare-title{font-size:.82rem;font-weight:700;color:var(--text);margin-bottom:.6rem}
.pp-compare-scroll{overflow-x:auto;-webkit-overflow-scrolling:touch;padding-bottom:.3rem}
.pp-compare-table{width:100%;border-collapse:collapse;font-size:.75rem;min-width:500px}
.pp-compare-table th,.pp-compare-table td{padding:.4rem .5rem;border-bottom:1px solid var(--border);text-align:center;white-space:nowrap}
.pp-compare-table th{font-weight:700;font-size:.7rem;color:var(--text2);background:var(--bg)}
.pp-compare-table th a{color:var(--accent);text-decoration:none;font-weight:700}
.pp-compare-table th a:hover{text-decoration:underline}
.pp-compare-label{text-align:left!important;color:var(--text2);font-weight:600;width:100px;font-size:.72rem}
.pp-compare-current{color:var(--accent)!important;font-weight:700!important;background:rgba(46,204,113,.04)}

/* ── Live Performance Stats ── */
.pp-live-stats-sub{font-size:.82rem;color:var(--text2);margin:0 0 1rem}

/* ── FAQ: <details> accordion ────────────────────────────────────────────── */
.pp-faq{background:var(--bg2);border:1px solid var(--border);border-radius:4px;margin-bottom:.35rem;overflow:hidden}
.pp-faq-q{padding:.65rem 1rem;font-size:.88rem;font-weight:700;color:var(--text);cursor:pointer;user-select:none;list-style:none;display:flex;justify-content:space-between;align-items:center}
.pp-faq-q::-webkit-details-marker{display:none}
.pp-faq-q::after{content:'+';font-size:1.1rem;color:var(--accent);font-weight:700;flex-shrink:0;margin-left:.5rem}
.pp-faq[open] .pp-faq-q::after{content:'\2212'}
.pp-faq[open] .pp-faq-q{border-bottom:1px solid var(--border)}
.pp-faq-a{padding:.65rem 1rem;font-size:.82rem;color:var(--text2);line-height:1.65;margin:0}

/* ── Responsive ──────────────────────────────────────────────────────────── */
@media(max-width:768px){
  .pp-hero{flex-direction:column;align-items:flex-start;gap:.75rem}
  .pp-hero-left{flex-direction:row;align-items:center;gap:.75rem}
