  .pp-sidebar{display:none}
  .pp-layout{flex-direction:column}
  .pp-kv-grid{grid-template-columns:1fr}
  .pp-config-actions{flex-direction:column}
  .pp-config-btn{justify-content:center}
  .pp-code-box{flex-direction:column;align-items:stretch}
  .pp-loadout-grid{grid-template-columns:1fr 1fr}
  .pp-team-box{max-width:100%}
}
