  var text = shareName + "'s CS2 Settings" +
    (shareTeam ? ' (' + shareTeam + ')' : '') +
    '\n\n' +
    shareEdpi + ' eDPI (' + shareDpi + ' DPI × ' + shareSens + ' sens)\n' +
    shareRes + ' ' + shareAspect + ' ' + shareStretch + '\n' +
    shareMouse + '\n\n' +
    'Full settings: https://wiki.csgoluck.com/pro-players/' + shareSlug + '/';

  btn.addEventListener('click', function() {
    if (navigator.share) {
      navigator.share({ title: shareName + "'s CS2 Settings", text: text, url: 'https://wiki.csgoluck.com/pro-players/' + shareSlug + '/' }).catch(function(){});
    } else if (navigator.clipboard) {
      navigator.clipboard.writeText(text).then(function() {
        btn.classList.add('shared');
        btn.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg> Copied!';
        setTimeout(function() {
          btn.classList.remove('shared');
          btn.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12v8a2 2 0 002 2h12a2 2 0 002-2v-8"/><polyline points="16 6 12 2 8 6"/><line x1="12" y1="2" x2="12" y2="15"/></svg> Share Settings';
        }, 2000);
      });
    }
  });
})();
</script>

<script is:inline define:vars={{ playerSlug: player.slug, playerDisplayName: player.name, playerTeam: player.team || '', playerCountry: player.country || '' }}>
(function(){
  // Share player-stats data globally so match history can use lastGames as fallback
  window.__playerStatsData = null;
  var container = document.getElementById('liveStatsContent');
  if (!container) return;

  var statsUrl = '/api/player-stats?slug=' + encodeURIComponent(playerSlug) + '&name=' + encodeURIComponent(playerDisplayName);
  if (playerTeam) statsUrl += '&team=' + encodeURIComponent(playerTeam);
  if (playerCountry) statsUrl += '&country=' + encodeURIComponent(playerCountry);
  fetch(statsUrl)
    .then(function(res) {
      if (!res.ok) throw new Error('HTTP ' + res.status);
      return res.json();
    })
    .then(function(data) {
      if (data.error) throw new Error(data.error);
      // Store globally for match history fallback
      window.__playerStatsData = data;

      var s = data.stats || {};
      var avg = s.averages || {};
      var tot = s.totals || {};
      var pr = s.perRound || {};
      var games = data.lastGames || [];

      // Format helpers
      function fmt(v, dec) { return v != null ? Number(v).toFixed(dec || 1) : '—'; }
      function fmtK(v) { return v != null ? (v >= 1000 ? (v/1000).toFixed(1) + 'k' : v) : '—'; }
      function fmtPct(v) { return v != null ? (v > 1 ? fmt(v, 1) : fmt(v * 100, 1)) + '%' : '—'; }

      var html = '';

      // Main stat cards
      html += '<div class="pp-ls-grid">';
      html += '<div class="pp-ls-stat pp-ls-primary"><span class="pp-ls-stat-val">' + fmt(avg.rating) + '</span><span class="pp-ls-stat-lbl">HLTV Rating</span></div>';
      html += '<div class="pp-ls-stat pp-ls-primary"><span class="pp-ls-stat-val">' + fmt(avg.adr) + '</span><span class="pp-ls-stat-lbl">ADR</span></div>';
      html += '<div class="pp-ls-stat pp-ls-primary"><span class="pp-ls-stat-val">' + fmtPct(avg.kast) + '</span><span class="pp-ls-stat-lbl">KAST%</span></div>';
      html += '<div class="pp-ls-stat"><span class="pp-ls-stat-val">' + fmt(avg.kills) + '</span><span class="pp-ls-stat-lbl">Avg Kills</span></div>';
      html += '<div class="pp-ls-stat"><span class="pp-ls-stat-val">' + fmt(avg.deaths) + '</span><span class="pp-ls-stat-lbl">Avg Deaths</span></div>';
      html += '<div class="pp-ls-stat"><span class="pp-ls-stat-val">' + fmt(avg.assists) + '</span><span class="pp-ls-stat-lbl">Avg Assists</span></div>';
      html += '<div class="pp-ls-stat"><span class="pp-ls-stat-val">' + fmt(avg.headshots) + '</span><span class="pp-ls-stat-lbl">Avg HS</span></div>';
      html += '<div class="pp-ls-stat"><span class="pp-ls-stat-val">' + fmt(avg.firstKillsDiff, 1) + '</span><span class="pp-ls-stat-lbl">FK Diff</span></div>';
      html += '</div>';

      // Career totals
      if (tot.kills || tot.matchesPlayed) {
        html += '<div class="pp-ls-totals">';
        html += '<div class="pp-ls-total"><span class="pp-ls-total-val">' + fmtK(tot.kills) + '</span><span class="pp-ls-total-lbl">Total Kills</span></div>';
        html += '<div class="pp-ls-total"><span class="pp-ls-total-val">' + fmtK(tot.deaths) + '</span><span class="pp-ls-total-lbl">Total Deaths</span></div>';
        html += '<div class="pp-ls-total"><span class="pp-ls-total-val">' + fmtK(tot.assists) + '</span><span class="pp-ls-total-lbl">Total Assists</span></div>';
        html += '<div class="pp-ls-total"><span class="pp-ls-total-val">' + fmtK(tot.headshots) + '</span><span class="pp-ls-total-lbl">Total HS</span></div>';
        html += '<div class="pp-ls-total"><span class="pp-ls-total-val">' + (tot.matchesPlayed || '—') + '</span><span class="pp-ls-total-lbl">Matches</span></div>';
        html += '<div class="pp-ls-total"><span class="pp-ls-total-val">' + (tot.matchesWon || '—') + '</span><span class="pp-ls-total-lbl">Wins</span></div>';
        html += '</div>';
      }

      // Per-round stats
      if (pr.kills) {
        html += '<div class="pp-ls-totals">';
        html += '<div class="pp-ls-total"><span class="pp-ls-total-val">' + fmt(pr.kills, 2) + '</span><span class="pp-ls-total-lbl">Kills/Round</span></div>';
        html += '<div class="pp-ls-total"><span class="pp-ls-total-val">' + fmt(pr.deaths, 2) + '</span><span class="pp-ls-total-lbl">Deaths/Round</span></div>';
        html += '<div class="pp-ls-total"><span class="pp-ls-total-val">' + fmt(pr.headshots, 2) + '</span><span class="pp-ls-total-lbl">HS/Round</span></div>';
        html += '</div>';
      }

      // Recent games
      if (games.length > 0) {
        html += '<div class="pp-ls-recent"><h3>Recent Games</h3><div class="pp-ls-games">';
        games.forEach(function(g) {
          var oppImg = g.opponent && g.opponent.image ? '<img src="' + g.opponent.image + '" alt="" style="width:20px;height:20px;object-fit:contain" />' : '';
          var oppName = g.opponent ? g.opponent.name : 'Unknown';
          html += '<div class="pp-ls-game">';
          html += '<div class="pp-ls-game-opp">' + oppImg + '<span>' + oppName + '</span></div>';
          html += '<div class="pp-ls-game-stats">';
          html += '<div class="pp-ls-game-stat"><span class="pp-ls-game-stat-val">' + (g.kills || '—') + '</span><span class="pp-ls-game-stat-lbl">K</span></div>';
          html += '<div class="pp-ls-game-stat"><span class="pp-ls-game-stat-val">' + (g.deaths || '—') + '</span><span class="pp-ls-game-stat-lbl">D</span></div>';
          html += '<div class="pp-ls-game-stat"><span class="pp-ls-game-stat-val">' + (g.assists || '—') + '</span><span class="pp-ls-game-stat-lbl">A</span></div>';
          html += '<div class="pp-ls-game-stat"><span class="pp-ls-game-stat-val">' + fmt(g.adr) + '</span><span class="pp-ls-game-stat-lbl">ADR</span></div>';
          html += '<div class="pp-ls-game-stat"><span class="pp-ls-game-stat-val pp-ls-game-rating">' + fmt(g.rating) + '</span><span class="pp-ls-game-stat-lbl">Rating</span></div>';
          html += '</div></div>';
        });
        html += '</div></div>';
      }

      // Form Chart — last 5 games
      if (games.length > 0) {
        var formGames = games.slice(0, 5);
        html += '<div class="pp-ls-form"><h3>Current Form</h3><div class="pp-ls-form-row">';
        formGames.forEach(function(g) {
          var rating = g.rating != null ? Number(g.rating) : null;
          var isWin = rating !== null && rating >= 1.0;
          var cls = isWin ? 'pp-ls-form-dot pp-ls-form-w' : 'pp-ls-form-dot pp-ls-form-l';
          var label = isWin ? 'W' : 'L';
          html += '<div class="' + cls + '"><span class="pp-ls-form-letter">' + label + '</span><span class="pp-ls-form-rating">' + fmt(rating) + '</span></div>';
        });
        html += '</div></div>';
      }

      container.innerHTML = html;
    })
    .catch(function(err) {
      console.warn('PandaScore stats not available for ' + playerDisplayName + ':', err.message);
      container.innerHTML = '<div class="pp-ls-error">Performance stats not available for this player. Stats are tracked for players with recent professional match data.</div>';
    });
})();
</script>

<script is:inline define:vars={{ playerSlug: player.slug, playerIGN: player.name, playerTeamMH: player.team || '', playerCountryMH: player.country || '' }}>
(function(){
  var container = document.getElementById('matchHistoryContent');
  if (!container) return;

  var mhUrl = '/api/player-matches?slug=' + encodeURIComponent(playerSlug) + '&name=' + encodeURIComponent(playerIGN);
  if (playerTeamMH) mhUrl += '&team=' + encodeURIComponent(playerTeamMH);
  if (playerCountryMH) mhUrl += '&country=' + encodeURIComponent(playerCountryMH);
  fetch(mhUrl)
    .then(function(res) {
      if (!res.ok) throw new Error('HTTP ' + res.status);
      return res.json();
    })
    .then(function(data) {
      if (data.error) throw new Error(data.error);

      var matches = (data.matches || []).slice(0, 10);
      var upcoming = (data.upcoming || []).slice(0, 10);
      var currentTeam = data.currentTeam;
      var currentTeamId = currentTeam ? currentTeam.id : null;

      // Load team logo into hero
      if (currentTeam && currentTeam.image) {
        var logoEl = document.getElementById('heroTeamLogo');
        if (logoEl) {
          logoEl.innerHTML = '<img src="' + currentTeam.image + '" alt="' + (currentTeam.name || '') + '" width="18" height="18" style="width:18px;height:18px;max-width:18px;max-height:18px;object-fit:contain" onerror="this.style.display=\'none\'" />';
        }
      }

      // --- Render upcoming matches ---
      var upContainer = document.getElementById('upcomingMatchesContent');
      if (upContainer) {
        if (upcoming.length === 0) {
          upContainer.innerHTML = '<div class="pp-mh-empty">No upcoming matches scheduled.</div>';
        } else {
          var uh = '<div class="pp-mh-list">';
          upcoming.forEach(function(m) {
            var date = m.beginAt ? new Date(m.beginAt) : null;
            var dateStr = date ? date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) : 'TBD';
            var timeStr = date ? date.toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' }) : '';

            var opponent = null;
            if (m.opponents && m.opponents.length === 2) {
              m.opponents.forEach(function(o) {
                if (o.id !== currentTeamId) opponent = o;
              });
            }
            if (!opponent && m.opponents && m.opponents.length > 0) {
              opponent = m.opponents.find(function(o) { return o.id !== currentTeamId; }) || m.opponents[0];
            }

            var oppImg = opponent && opponent.image ? '<img src="' + opponent.image + '" alt="" class="pp-mh-opp-img" />' : '';
            var oppName = opponent ? (opponent.acronym || opponent.name) : 'TBD';
            var tournamentName = m.tournament ? m.tournament.name : (m.league ? m.league.name : '');
            var matchType = m.matchType === 'best_of' ? 'BO' + m.numberOfGames : '';

            uh += '<a href="/match-detail/?id=' + m.id + '" class="pp-mh-row">';
            uh += '<span class="pp-mh-date">' + dateStr + (timeStr ? '<br><span style="font-size:.7rem;color:var(--text3)">' + timeStr + '</span>' : '') + '</span>';
            uh += '<span class="pp-mh-vs">vs</span>';
            uh += '<span class="pp-mh-opponent">' + oppImg + '<span>' + oppName + '</span></span>';
            uh += '<span class="pp-mh-score"><span class="pp-mh-badge pp-mh-upcoming">' + (matchType || '—') + '</span></span>';
            uh += '<span class="pp-mh-tournament">' + tournamentName + '</span>';
            uh += '</a>';
          });
          uh += '</div>';
          upContainer.innerHTML = uh;
        }
      }

      // --- Render recent matches ---
      if (matches.length === 0) {
        container.innerHTML = '<div class="pp-mh-empty">No recent match data available.</div>';
        return;
      }

      var html = '<div class="pp-mh-list">';
      matches.forEach(function(m) {
        var date = m.beginAt ? new Date(m.beginAt) : null;
        var dateStr = date ? date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) : '—';

        // Find opponent
        var opponent = null;
        var ownTeam = null;
        if (m.opponents && m.opponents.length === 2) {
          m.opponents.forEach(function(o) {
            if (o.id === currentTeamId) { ownTeam = o; } else { opponent = o; }
          });
        }
        if (!opponent && m.opponents && m.opponents.length === 2) {
          opponent = m.opponents[1];
          ownTeam = m.opponents[0];
        }

        // Score
        var ownScore = '—';
        var oppScore = '—';
        var isWin = false;
        if (m.results && m.results.length === 2 && ownTeam) {
          m.results.forEach(function(r) {
            if (r.team_id === ownTeam.id) { ownScore = r.score; }
            else { oppScore = r.score; }
          });
        }
        if (m.winnerId && ownTeam) {
          isWin = m.winnerId === ownTeam.id;
        }

        var resultClass = isWin ? 'pp-mh-badge pp-mh-win' : 'pp-mh-badge pp-mh-loss';
        var resultLabel = isWin ? 'W' : 'L';
        var oppImg = opponent && opponent.image ? '<img src="' + opponent.image + '" alt="" class="pp-mh-opp-img" />' : '';
        var oppName = opponent ? (opponent.acronym || opponent.name) : 'TBD';
        var tournamentName = m.tournament ? m.tournament.name : (m.league ? m.league.name : '');

        html += '<a href="/match-detail/?id=' + m.id + '" class="pp-mh-row">';
        html += '<span class="pp-mh-date">' + dateStr + '</span>';
        html += '<span class="pp-mh-vs">vs</span>';
        html += '<span class="pp-mh-opponent">' + oppImg + '<span>' + oppName + '</span></span>';
        html += '<span class="pp-mh-score"><span class="' + resultClass + '">' + resultLabel + '</span> ' + ownScore + '–' + oppScore + '</span>';
        html += '<span class="pp-mh-tournament">' + tournamentName + '</span>';
        html += '</a>';
      });
      html += '</div>';

      container.innerHTML = html;
    })
    .catch(function(err) {
      console.warn('Match history not available via player-matches:', err.message);
      // Fallback: use lastGames from player-stats if available
      var statsData = window.__playerStatsData;
      if (statsData && statsData.lastGames && statsData.lastGames.length > 0) {
        var games = statsData.lastGames;
        var html = '<div class="pp-mh-list">';
        games.forEach(function(g) {
          var oppImg = g.opponent && g.opponent.image ? '<img src="' + g.opponent.image + '" alt="" class="pp-mh-opp-img" />' : '';
          var oppName = g.opponent ? g.opponent.name : 'Unknown';
          var rating = g.rating != null ? Number(g.rating) : null;
          var isWin = rating !== null && rating >= 1.0;
          var resultClass = isWin ? 'pp-mh-badge pp-mh-win' : 'pp-mh-badge pp-mh-loss';
          var resultLabel = isWin ? 'W' : 'L';

          html += '<div class="pp-mh-row" style="cursor:default">';
          html += '<span class="pp-mh-date">' + (g.kills || 0) + '/' + (g.deaths || 0) + '/' + (g.assists || 0) + '</span>';
          html += '<span class="pp-mh-vs">vs</span>';
          html += '<span class="pp-mh-opponent">' + oppImg + '<span>' + oppName + '</span></span>';
          html += '<span class="pp-mh-score"><span class="' + resultClass + '">' + resultLabel + '</span> ' + (g.rating != null ? Number(g.rating).toFixed(2) : '—') + ' rating</span>';
          html += '<span class="pp-mh-tournament" style="font-size:.72rem;color:var(--text3)">' + (g.adr != null ? Number(g.adr).toFixed(1) + ' ADR' : '') + '</span>';
          html += '</div>';
        });
        html += '</div>';
        container.innerHTML = html;
      } else {
        // Wait briefly for player-stats to finish, then retry
        setTimeout(function() {
          var retryData = window.__playerStatsData;
          if (retryData && retryData.lastGames && retryData.lastGames.length > 0) {
            var gms = retryData.lastGames;
            var h = '<div class="pp-mh-list">';
            gms.forEach(function(g) {
              var oi = g.opponent && g.opponent.image ? '<img src="' + g.opponent.image + '" alt="" class="pp-mh-opp-img" />' : '';
              var on = g.opponent ? g.opponent.name : 'Unknown';
              var r = g.rating != null ? Number(g.rating) : null;
              var w = r !== null && r >= 1.0;
              h += '<div class="pp-mh-row" style="cursor:default">';
              h += '<span class="pp-mh-date">' + (g.kills||0) + '/' + (g.deaths||0) + '/' + (g.assists||0) + '</span>';
              h += '<span class="pp-mh-vs">vs</span>';
              h += '<span class="pp-mh-opponent">' + oi + '<span>' + on + '</span></span>';
              h += '<span class="pp-mh-score"><span class="' + (w?'pp-mh-badge pp-mh-win':'pp-mh-badge pp-mh-loss') + '">' + (w?'W':'L') + '</span> ' + (r!=null?r.toFixed(2):'—') + ' rating</span>';
              h += '<span class="pp-mh-tournament" style="font-size:.72rem;color:var(--text3)">' + (g.adr!=null?Number(g.adr).toFixed(1)+' ADR':'') + '</span>';
              h += '</div>';
            });
            h += '</div>';
            container.innerHTML = h;
          } else {
            container.innerHTML = '<div class="pp-mh-empty">Match history not available for this player.</div>';
          }
        }, 2000);
      }
    });
})();
</script>

<script is:inline define:vars={{ xhairColor, crosshairSize: player.crosshairSize, crosshairGap: player.crosshairGap, crosshairThickness: player.crosshairThickness, crosshairDot: player.crosshairDot, crosshairOutline: player.crosshairOutline, configText, allCmds, playerName: player.name }}>
(function(){
  // ── Sidebar scroll spy ──
  var sidebarLinks = document.querySelectorAll('.pp-sidebar-link');
  var sectionEls = [];
  sidebarLinks.forEach(function(link) {
    var id = link.getAttribute('data-section');
    var el = document.getElementById(id);
    if (el) sectionEls.push({ id: id, el: el, link: link });
  });

  function updateActiveLink() {
    var scrollY = window.scrollY + 120;
    var active = null;
    for (var i = sectionEls.length - 1; i >= 0; i--) {
      if (sectionEls[i].el.offsetTop <= scrollY) {
        active = sectionEls[i];
        break;
      }
    }
    sidebarLinks.forEach(function(l) { l.classList.remove('active'); });
    if (active) active.link.classList.add('active');
  }

  window.addEventListener('scroll', updateActiveLink, { passive: true });
  updateActiveLink();

  // Smooth scroll on click
  sidebarLinks.forEach(function(link) {
    link.addEventListener('click', function(e) {
      e.preventDefault();
      var id = link.getAttribute('data-section');
      var target = document.getElementById(id);
      if (target) target.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  });

  // ── Copy buttons ──
  function bindCopy(btnId, codeId) {
    var btn = document.getElementById(btnId);
    var code = document.getElementById(codeId);
    if (!btn || !code) return;
    btn.addEventListener('click', function(){
      navigator.clipboard.writeText(code.textContent.trim()).then(function(){
        var orig = btn.textContent;
        btn.textContent = 'Copied!';
        btn.classList.add('copied');
        setTimeout(function(){ btn.textContent = orig; btn.classList.remove('copied'); }, 1500);
      });
    });
  }
  bindCopy('copyXhair', 'xhairCode');
  bindCopy('copyVm', 'vmCmds');
  bindCopy('copyLaunch', 'launchOpts');
  bindCopy('copyConfig', 'configPreview');

  // ── Copy All Commands ──
  var copyAllBtn = document.getElementById('copyAllCmds');
  if (copyAllBtn) {
    copyAllBtn.addEventListener('click', function(){
      navigator.clipboard.writeText(allCmds).then(function(){
        copyAllBtn.querySelector('svg').style.display = 'none';
        copyAllBtn.classList.add('copied');
        var origText = copyAllBtn.childNodes[copyAllBtn.childNodes.length - 1];
        origText.textContent = ' Copied!';
        setTimeout(function(){
          copyAllBtn.querySelector('svg').style.display = '';
          copyAllBtn.classList.remove('copied');
          origText.textContent = ' Copy All Commands';
        }, 1500);
      });
    });
  }

  // ── Download Config ──
  var dlBtn = document.getElementById('downloadConfig');
  if (dlBtn) {
    dlBtn.addEventListener('click', function(){
      var blob = new Blob([configText], { type: 'text/plain' });
      var url = URL.createObjectURL(blob);
      var a = document.createElement('a');
      a.href = url;
      a.download = playerName.toLowerCase().replace(/[^a-z0-9]/g, '_') + '_autoexec.cfg';
      document.body.appendChild(a);
      a.click();
      document.body.removeChild(a);
      URL.revokeObjectURL(url);
    });
  }

  // ── Crosshair Preview Render ──
  var ch = document.getElementById('xhairRender');
  if (ch) {
    var s = crosshairSize;
    var g = crosshairGap;
    var t = Math.max(crosshairThickness, 0.5);
    var gapPx = Math.round((g + 5) * 3);
    var thickPx = Math.max(Math.round(t * 2), 1);
    var armLen = s * 6;
    var shadow = crosshairOutline ? '0 0 0 1px rgba(0,0,0,0.8)' : 'none';

    var arms = [
      { x: -gapPx - armLen, y: -thickPx / 2, w: armLen, h: thickPx },
      { x: gapPx, y: -thickPx / 2, w: armLen, h: thickPx },
      { x: -thickPx / 2, y: -gapPx - armLen, w: thickPx, h: armLen },
      { x: -thickPx / 2, y: gapPx, w: thickPx, h: armLen },
    ];
    arms.forEach(function(arm) {
      var d = document.createElement('div');
      d.style.cssText = 'position:absolute;left:50%;top:50%;background:' + xhairColor + ';box-shadow:' + shadow + ';transform:translate(' + arm.x + 'px,' + arm.y + 'px);width:' + arm.w + 'px;height:' + arm.h + 'px;';
      ch.appendChild(d);
    });
    if (crosshairDot) {
      var dotEl = document.createElement('div');
      var dotSize = Math.max(thickPx + 2, 3);
      dotEl.style.cssText = 'position:absolute;left:50%;top:50%;background:' + xhairColor + ';width:' + dotSize + 'px;height:' + dotSize + 'px;transform:translate(-50%,-50%);box-shadow:' + shadow;
      ch.appendChild(dotEl);
    }
  }
})();
</script>
