---
import Base from '../layouts/Base.astro';
import ExploreMore from '../components/ExploreMore.astro';
import { faqSchema, breadcrumbSchema, toolAppSchema } from '../lib/weapons';

const title = 'CS2 Recoil Patterns';
const description = 'Master CS2 weapon recoil patterns. View spray patterns for rifles, SMGs, and pistols with detailed descriptions.';

const weapons = [
  {
    name: 'AK-47',
    category: 'Rifle',
    recoilDesc: 'Moderate upward climb with slight rightward drift. Requires counter-strafing and crosshair placement.',
    sprayTips: 'First 5 shots are predictable, then becomes erratic. Use burst fire or single fire.',
    difficulty: 'Hard'
  },
  {
    name: 'M4A4',
    category: 'Rifle',
    recoilDesc: 'Very predictable with consistent upward pattern. Slight left-to-right movement.',
    sprayTips: 'Easy to control. Can spray full magazine with practice. Mirror AK-47 for opposite spray.',
    difficulty: 'Easy'
  },
  {
    name: 'M4A1-S',
    category: 'Rifle',
    recoilDesc: 'Even more controlled than M4A4. Very vertical with minimal horizontal deviation.',
    sprayTips: 'Best precision weapon. Pull down consistently for spray control.',
    difficulty: 'Easy'
  },
  {
    name: 'Galil AR',
    category: 'Rifle',
    recoilDesc: 'Moderate recoil with slight upward pull and right drift.',
    sprayTips: 'Pull down and left for control. Good eco weapon.',
    difficulty: 'Medium'
  },
  {
    name: 'Famas',
    category: 'Rifle',
    recoilDesc: 'Tight spray pattern but requires perfect counter-strafing.',
    sprayTips: 'Best used in semi-auto or short bursts. Very mobile weapon.',
    difficulty: 'Medium'
  },
  {
    name: 'AWP',
    category: 'Sniper',
    recoilDesc: 'No spray pattern - one shot, one kill. High recoil between shots.',
    sprayTips: 'Pre-aim and relocate. Crosshair placement is everything.',
    difficulty: 'Medium'
  },
  {
    name: 'UMP-45',
    category: 'SMG',
    recoilDesc: 'Moderate upward recoil with slight rightward drift.',
    sprayTips: 'Good at close range. Vertical pull for spray control.',
    difficulty: 'Easy'
  },
  {
    name: 'MP9',
    category: 'SMG',
    recoilDesc: 'Very manageable, mostly vertical with minimal spread.',
    sprayTips: 'Fast fire rate makes it predictable. Good for eco rounds.',
    difficulty: 'Easy'
  },
  {
    name: 'Deagle',
    category: 'Pistol',
    recoilDesc: 'Extremely high recoil. Requires spacing between shots.',
    sprayTips: 'Single fire only. Tap fire with crosshair placement.',
    difficulty: 'Hard'
  },
  {
    name: 'P250',
    category: 'Pistol',
    recoilDesc: 'Moderate recoil. Decent accuracy for a pistol.',
    sprayTips: 'Eco weapon. Use in bursts at medium range.',
    difficulty: 'Medium'
  }
];

const faq = [
  {
    question: 'What is recoil in CS2?',
    answer: 'Recoil is the upward/downward movement of your crosshair when firing a weapon. Different weapons have different recoil patterns that must be learned and controlled.'
  },
  {
    question: 'How do I control spray recoil?',
    answer: 'Spray control involves pulling your mouse in the opposite direction of the recoil pattern. Practice in aim maps to develop muscle memory.'
  },
  {
    question: 'What is counter-strafing?',
    answer: 'Counter-strafing is pressing the opposite movement key while moving to instantly stop. Combined with recoil control, it\'s essential for accurate spraying.'
  },
  {
    question: 'Is spray control necessary?',
    answer: 'For professional play, yes. For casual play, burst firing and tapping are often more effective than trying to control full sprays.'
  }
];

const schemaData = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faq.map(item => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer
    }
  }))
};
---

<Base title={title} description={description} currentNav="/cs2-tools/">
  <script type="application/ld+json" set:html={JSON.stringify(toolAppSchema({ name: 'CS2 Recoil Patterns', url: 'https://wiki.csgoluck.com/recoil-patterns/', description }))}></script>
  <script type="application/ld+json" set:html={JSON.stringify(schemaData)} />

  <nav class="breadcrumb"><a href="/">Home</a> <span>/</span> <a href="/cs2-tools/">Tools</a> <span>/</span> <span>Recoil Patterns</span></nav>

  <div class="rcp-hero">
    <h1 class="rcp-title">CS2 Recoil Patterns</h1>
    <p class="rcp-desc">Master <a href="/cs2-weapons/" style="color:var(--accent)">weapon</a> recoil and spray control for rifles, SMGs, and pistols. Practice hands-on with the <a href="/spray-trainer/" style="color:var(--accent)">spray trainer</a>.</p>
  </div>

  <div class="rcp-grid">
    {weapons.map(weapon => (
      <div class="rcp-card">
        <div class="rcp-card-header">
          <h2 class="rcp-weapon-name">{weapon.name}</h2>
          <span class="rcp-category">{weapon.category}</span>
        </div>
        <div class="rcp-difficulty">
          <span class="rcp-diff-label">Difficulty</span>
          <span class={`rcp-diff-badge rcp-diff-${weapon.difficulty.toLowerCase()}`}>{weapon.difficulty}</span>
        </div>
        <div class="rcp-sections">
          <div class="rcp-section">
            <h4 class="rcp-section-head">Recoil Pattern</h4>
            <p class="rcp-section-text">{weapon.recoilDesc}</p>
          </div>
          <div class="rcp-section">
            <h4 class="rcp-section-head">Spray Tips</h4>
            <p class="rcp-section-text">{weapon.sprayTips}</p>
          </div>
        </div>
      </div>
    ))}
  </div>

  <div class="rcp-two-col">
    <div class="rcp-info-block">
      <h2 class="rcp-block-title">Recoil Control Techniques</h2>
      <div class="rcp-technique-list">
        <div class="rcp-technique">
          <h3 class="rcp-tech-name">Tap Firing</h3>
          <p class="rcp-tech-desc">Single shot then release. Most accurate method. Used for long-range engagements.</p>
        </div>
        <div class="rcp-technique">
          <h3 class="rcp-tech-name">Burst Firing</h3>
          <p class="rcp-tech-desc">3-4 shots in quick succession. Balance between fire rate and accuracy. Ideal for medium range.</p>
        </div>
        <div class="rcp-technique">
          <h3 class="rcp-tech-name">Spray Control</h3>
          <p class="rcp-tech-desc">Hold down fire and counter the recoil pattern. Requires practice and muscle memory. Best at close range.</p>
        </div>
        <div class="rcp-technique">
          <h3 class="rcp-tech-name">Counter-Strafing</h3>
          <p class="rcp-tech-desc">Press opposite movement key to stop instantly while maintaining accuracy. Essential for advanced play.</p>
        </div>
      </div>
    </div>

    <div class="rcp-info-block">
      <h2 class="rcp-block-title">Practice Tips</h2>
      <ul class="rcp-tips-list">
        <li>Use aim maps in community servers to practice spray control without pressure</li>
        <li>Record demos and review your spray patterns to identify inconsistencies</li>
        <li>Practice with one weapon at a time to build muscle memory</li>
        <li>Start with burst firing before attempting full spray control</li>
        <li>Focus on crosshair placement first, spray control second</li>
        <li>Play death match to get comfortable with recoil in real matches</li>
        <li>Most importantly: counter-strafe to stabilize before spraying</li>
      </ul>
    </div>
  </div>

  <section class="rcp-faq">
    <h2 class="rcp-block-title">Frequently Asked Questions</h2>
    {faq.map(item => (
      <details class="rcp-faq-item">
        <summary class="rcp-faq-q">{item.question}</summary>
        <p class="rcp-faq-a">{item.answer}</p>
      </details>
    ))}
  </section>

  <div class="rcp-info-block" style="margin-bottom:2rem">
    <h2 class="rcp-block-title">Related Tools</h2>
    <div class="rcp-link-list">
      <a href="/weapon-compare/" class="rcp-link">Weapon Compare</a>
      <a href="/damage-calculator/" class="rcp-link">Damage Calculator</a>
      <a href="/spray-trainer/" class="rcp-link">Spray Trainer</a>
      <a href="/sensitivity-converter/" class="rcp-link">Sensitivity Converter</a>
      <a href="/crosshair-generator/" class="rcp-link">Crosshair Generator</a>
      <a href="/economy-calculator/" class="rcp-link">Economy Calculator</a>
      <a href="/cs2-weapons/" class="rcp-link">Weapon Database</a>
      <a href="/pro-players/" class="rcp-link">Pro Player Settings</a>
      <a href="/cs2-tools/" class="rcp-link">All Tools</a>
      <a href="/cs2-guides/beginners-guide/" class="rcp-link">Beginner's Guide</a>
      <a href="/cs2-maps/" class="rcp-link">Map Database</a>
      <a href="/edpi-calculator/" class="rcp-link">eDPI Calculator</a>
      <a href="/cs2-guides/advanced-mechanics-guide/" class="rcp-link">Advanced Mechanics Guide</a>
    </div>
  </div>

  <ExploreMore context="weapons" />
</Base>

<style>
  .rcp-hero{padding:1.5rem 0;margin-bottom:1.5rem}
  .rcp-title{font-size:2rem;font-weight:800;margin:0 0 .5rem;color:var(--text)}
  .rcp-desc{color:var(--text2);font-size:.95rem;margin:0;max-width:600px;line-height:1.6}

  .rcp-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(340px,1fr));gap:1rem;margin-bottom:2rem}
  .rcp-card{background:var(--bg2);border:1px solid var(--border);border-left:3px solid transparent;border-radius:4px;padding:1.25rem;transition:border-left-color .15s}
  .rcp-card:hover{border-left-color:var(--accent)}
  .rcp-card-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:.75rem}
  .rcp-weapon-name{font-size:1.2rem;font-weight:700;color:var(--text);margin:0}
  .rcp-category{background:var(--bg3);color:var(--text2);padding:.2rem .6rem;border-radius:4px;font-size:.75rem;font-weight:600;text-transform:uppercase;letter-spacing:.04em}

  .rcp-difficulty{display:flex;align-items:center;gap:.75rem;margin-bottom:1rem}
  .rcp-diff-label{font-size:.8rem;color:var(--text2);font-weight:600;text-transform:uppercase;letter-spacing:.04em}
  .rcp-diff-badge{padding:.25rem .65rem;border-radius:4px;font-size:.8rem;font-weight:600;text-transform:uppercase;letter-spacing:.04em}
  .rcp-diff-easy{background:rgba(92,184,92,.15);color:var(--green)}
  .rcp-diff-medium{background:rgba(232,201,110,.15);color:var(--gold)}
  .rcp-diff-hard{background:rgba(224,112,112,.15);color:var(--red)}

  .rcp-sections{display:flex;flex-direction:column;gap:.75rem}
  .rcp-section{border-top:1px solid var(--border);padding-top:.75rem}
  .rcp-section:first-child{border-top:none;padding-top:0}
  .rcp-section-head{color:var(--accent);font-size:.85rem;font-weight:600;text-transform:uppercase;letter-spacing:.04em;margin:0 0 .35rem}
  .rcp-section-text{color:var(--text2);margin:0;line-height:1.6;font-size:.88rem}

  .rcp-two-col{display:grid;grid-template-columns:1fr 1fr;gap:1.5rem;margin-bottom:2rem}
  .rcp-info-block{background:var(--bg2);border:1px solid var(--border);border-radius:4px;padding:1.5rem}
  .rcp-block-title{font-size:1.1rem;font-weight:700;color:var(--text);margin:0 0 1rem}

  .rcp-technique-list{display:flex;flex-direction:column;gap:.6rem}
  .rcp-technique{background:var(--bg);border-left:3px solid var(--accent);border-radius:4px;padding:1rem}
  .rcp-tech-name{color:var(--accent);font-size:.95rem;margin:0 0 .35rem;font-weight:700}
  .rcp-tech-desc{color:var(--text2);margin:0;line-height:1.6;font-size:.88rem}

  .rcp-tips-list{list-style:none;padding:0;margin:0}
  .rcp-tips-list li{padding:.6rem 0 .6rem 1.5rem;position:relative;color:var(--text2);border-bottom:1px solid var(--border);line-height:1.6;font-size:.88rem}
  .rcp-tips-list li:last-child{border-bottom:none}
  .rcp-tips-list li::before{content:'';position:absolute;left:.4rem;top:.95rem;width:6px;height:6px;background:var(--accent);border-radius:50%}

  .rcp-link-list{display:flex;flex-direction:column;gap:.4rem}
  .rcp-link{display:block;padding:.5rem .75rem;background:var(--bg3);border:1px solid var(--border);border-left:3px solid transparent;border-radius:4px;color:var(--accent);text-decoration:none;font-size:.85rem;transition:border-left-color .15s}
  .rcp-link:hover{border-left-color:var(--accent)}

  .rcp-faq{margin-bottom:2rem}
  .rcp-faq-item{background:var(--bg2);border:1px solid var(--border);border-radius:4px;margin-bottom:.5rem;overflow:hidden}
  .rcp-faq-q{padding:.8rem 1rem;cursor:pointer;font-weight:600;font-size:.9rem;color:var(--text);list-style:none;display:flex;align-items:center;justify-content:space-between}
  .rcp-faq-q::-webkit-details-marker{display:none}
  .rcp-faq-q::after{content:'+';font-size:1.1rem;color:var(--accent);font-weight:700}
  .rcp-faq-item[open] .rcp-faq-q::after{content:'-'}
  .rcp-faq-item[open]{border-left:3px solid var(--accent)}
  .rcp-faq-a{padding:0 1rem .8rem;margin:0;font-size:.88rem;color:var(--text2);line-height:1.6}

  @media(max-width:768px){
    .rcp-grid{grid-template-columns:1fr}
    .rcp-two-col{grid-template-columns:1fr}
  }
</style>
