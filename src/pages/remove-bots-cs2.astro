      .rbc-toc-mobile-link:hover{color:var(--accent);border-color:var(--accent)}
      .rbc-header h1{font-size:1.7rem}
      .rbc-section-header{margin:0 -1rem 1rem;padding:.6rem 1rem}
      .rbc-resources-grid{grid-template-columns:repeat(2,1fr)}
    }
