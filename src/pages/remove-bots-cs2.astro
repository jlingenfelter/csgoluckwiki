    code{background:var(--bg3);padding:.15rem .4rem;border-radius:3px;font-size:.88rem;color:var(--accent)}
    .rbc-list{list-style:none;padding:0;margin:.75rem 0 1.5rem}
    .rbc-list li{padding:.4rem 0 .4rem 1.6rem;position:relative;color:var(--text2);line-height:1.65}
    .rbc-list li::before{content:'';position:absolute;left:.25rem;top:.75rem;width:6px;height:6px;background:var(--accent);border-radius:1px}
    .rbc-list li strong{color:var(--text)}
