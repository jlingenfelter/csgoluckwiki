      .rbc-wrap{padding:0 1rem 1.5rem}
      .rbc-resources-grid{grid-template-columns:1fr}
      .rbc-header h1{font-size:1.5rem}
    }
  </style>
  <AuthorBox updated="2026-03-04" />
</Base>
