---
import Base from '../layouts/Base.astro';
import ExploreMore from '../components/ExploreMore.astro';
import { breadcrumbSchema, faqSchema } from '../lib/weapons';

const title = 'CS2 Resolution & Aspect Ratio Calculator — Stretched vs Black Bars | CSGOLuck Wiki';
const description = 'Calculate the best CS2 resolution for your monitor. Compare 4:3 stretched, 16:9, and 16:10 aspect ratios. See FOV differences, pros and cons, and what the pros use.';
const crumbs = [{ name: 'Home', url: '/' }, { name: 'Resolution Calculator', url: '/resolution-calculator/' }];
const faqs = [
  { question: 'Is 4:3 stretched better than 16:9 in CS2?', answer: '4:3 stretched makes player models appear wider, which some players find easier to aim at. However, you lose peripheral vision (reduced horizontal FOV). Most pros use 4:3 stretched, but it is personal preference — 16:9 gives you more information on screen.' },
  { question: 'What resolution do most CS2 pros use?', answer: 'The most popular pro resolution is 1280x960 (4:3 stretched), followed by 1024x768 and 1920x1080 (native 16:9). About 60% of professional players use some form of 4:3 resolution.' },
  { question: 'Does resolution affect FPS in CS2?', answer: 'Yes. Lower resolutions render fewer pixels, which can significantly boost FPS. Switching from 1920x1080 to 1280x960 can increase FPS by 30-50% depending on your GPU. This is why many players on older hardware prefer lower resolutions.' },
  { question: 'What is the difference between stretched and black bars?', answer: 'Both use a 4:3 resolution. Stretched fills your entire screen by stretching the image horizontally — models look wider but distorted. Black bars keep the native aspect ratio with unused black space on the sides — models look normal but your usable screen area is smaller.' },
  { question: 'How do I set up stretched resolution in CS2?', answer: 'Set your in-game resolution to a 4:3 option (like 1280x960), then in your GPU control panel (NVIDIA Control Panel or AMD Radeon Settings) set the display scaling mode to "Full-screen" instead of "Aspect ratio". This forces the image to stretch across your entire monitor.' },
];

const RESOLUTIONS = [
  { w: 1920, h: 1080, ratio: '16:9', label: '1080p', common: true },
  { w: 2560, h: 1440, ratio: '16:9', label: '1440p', common: true },
  { w: 3840, h: 2160, ratio: '16:9', label: '4K', common: false },
  { w: 1280, h: 960, ratio: '4:3', label: 'Pro Standard', common: true },
  { w: 1024, h: 768, ratio: '4:3', label: 'Classic Low', common: true },
  { w: 1280, h: 1024, ratio: '5:4', label: '5:4', common: false },
  { w: 1680, h: 1050, ratio: '16:10', label: 'WSXGA+', common: false },
  { w: 1440, h: 1080, ratio: '4:3', label: '4:3 HD', common: true },
  { w: 1600, h: 900, ratio: '16:9', label: '900p', common: false },
  { w: 1280, h: 800, ratio: '16:10', label: 'WXGA', common: false },
  { w: 1920, h: 1200, ratio: '16:10', label: 'WUXGA', common: false },
  { w: 800, h: 600, ratio: '4:3', label: 'Lowest', common: false },
];

const PRO_RESOLUTIONS = [
  { player: 's1mple', res: '1280x960', ratio: '4:3', mode: 'Stretched' },
  { player: 'ZywOo', res: '1280x960', ratio: '4:3', mode: 'Stretched' },
  { player: 'NiKo', res: '1280x960', ratio: '4:3', mode: 'Stretched' },
  { player: 'm0NESY', res: '1280x960', ratio: '4:3', mode: 'Stretched' },
  { player: 'donk', res: '1280x960', ratio: '4:3', mode: 'Stretched' },
  { player: 'device', res: '1024x768', ratio: '4:3', mode: 'Stretched' },
  { player: 'ropz', res: '1920x1080', ratio: '16:9', mode: 'Native' },
  { player: 'Twistzz', res: '1280x960', ratio: '4:3', mode: 'Stretched' },
  { player: 'b1t', res: '1280x960', ratio: '4:3', mode: 'Stretched' },
  { player: 'electronic', res: '1280x960', ratio: '4:3', mode: 'Stretched' },
  { player: 'rain', res: '1920x1080', ratio: '16:9', mode: 'Native' },
  { player: 'broky', res: '1024x768', ratio: '4:3', mode: 'Black Bars' },
  { player: 'EliGE', res: '1280x960', ratio: '4:3', mode: 'Stretched' },
  { player: 'NAF', res: '1920x1080', ratio: '16:9', mode: 'Native' },
  { player: 'FalleN', res: '1024x768', ratio: '4:3', mode: 'Stretched' },
  { player: 'Stewie2k', res: '1280x960', ratio: '4:3', mode: 'Black Bars' },
  { player: 'coldzera', res: '1024x768', ratio: '4:3', mode: 'Stretched' },
  { player: 'Aleksib', res: '1920x1080', ratio: '16:9', mode: 'Native' },
  { player: 'apEX', res: '1280x960', ratio: '4:3', mode: 'Stretched' },
  { player: 'Magisk', res: '1920x1080', ratio: '16:9', mode: 'Native' },
];

const toolSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": title,
  "description": description,
  "applicationCategory": "UtilityApplication",
  "operatingSystem": "Web",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
  "author": { "@type": "Organization", "name": "CSGOLuck Wiki", "url": "https://wiki.csgoluck.com" }
});
---

<Base title={title} description={description}>
  <script type="application/ld+json" set:html={toolSchema}></script>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema(crumbs))}></script>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema(faqs))}></script>

  <nav class="breadcrumb"><a href="/">Home</a> <span>/</span> <a href="/cs2-tools/">Tools</a> <span>/</span> <span>Resolution Calculator</span></nav>

  <div class="rsc-hero">
    <h1 class="rsc-title">CS2 Resolution & Aspect Ratio Calculator</h1>
    <p class="rsc-desc">Find the perfect resolution for your CS2 setup. Compare aspect ratios, understand FOV differences, and see what resolution the pros use.</p>
  </div>

  <!-- Calculator -->
  <section class="rsc-section">
    <h2 class="rsc-section-title">Resolution Comparison Tool</h2>
    <p class="rsc-subtitle">Select or enter two resolutions to compare FOV, pixel count, and aspect ratio differences.</p>

    <div class="rsc-compare-grid">
      <div class="rsc-input-box">
        <h3 class="rsc-box-title">Resolution A</h3>
        <div class="rsc-field"><label class="rsc-label">Width</label><input type="number" id="resA-w" value="1920" min="640" max="7680" class="rsc-input" /></div>
        <div class="rsc-field"><label class="rsc-label">Height</label><input type="number" id="resA-h" value="1080" min="480" max="4320" class="rsc-input" /></div>
        <div class="rsc-presets" id="presetsA">
          {RESOLUTIONS.filter(r => r.common).map(r => (
            <button class="rsc-preset-btn" data-w={r.w} data-h={r.h} data-target="A">{r.w}x{r.h}</button>
          ))}
        </div>
      </div>
      <div class="rsc-vs">VS</div>
      <div class="rsc-input-box">
        <h3 class="rsc-box-title">Resolution B</h3>
        <div class="rsc-field"><label class="rsc-label">Width</label><input type="number" id="resB-w" value="1280" min="640" max="7680" class="rsc-input" /></div>
        <div class="rsc-field"><label class="rsc-label">Height</label><input type="number" id="resB-h" value="960" min="480" max="4320" class="rsc-input" /></div>
        <div class="rsc-presets" id="presetsB">
          {RESOLUTIONS.filter(r => r.common).map(r => (
            <button class="rsc-preset-btn" data-w={r.w} data-h={r.h} data-target="B">{r.w}x{r.h}</button>
          ))}
        </div>
      </div>
    </div>

    <div class="rsc-options-row">
      <div class="rsc-field"><label class="rsc-label">Monitor Size (inches)</label><input type="number" id="monitor-size" value="24" min="13" max="49" class="rsc-input" /></div>
      <div class="rsc-field">
        <label class="rsc-label">Display Mode</label>
        <select id="display-mode" class="rsc-select">
          <option value="stretched">Stretched</option>
          <option value="blackbars">Black Bars</option>
          <option value="native">Native</option>
        </select>
      </div>
    </div>

    <button class="rsc-calc-btn" id="calc-btn">Compare Resolutions</button>

    <div id="rc-results" style="display:none">
      <div class="rsc-results-grid">
        <div class="rsc-result-col">
          <div class="rsc-result-header" id="rc-labelA">1920x1080</div>
          <div class="rsc-result-stats" id="rc-statsA"></div>
        </div>
        <div class="rsc-result-col">
          <div class="rsc-result-header" id="rc-labelB">1280x960</div>
          <div class="rsc-result-stats" id="rc-statsB"></div>
        </div>
      </div>
      <div class="rsc-verdict" id="rc-verdict"></div>
    </div>
  </section>

  <!-- Aspect Ratio Guide -->
  <section class="rsc-section">
    <h2 class="rsc-section-title">Aspect Ratio Comparison</h2>
    <div class="rsc-ratio-grid">
      <div class="rsc-ratio-card">
        <div class="rsc-ratio-visual rsc-169"></div>
        <h3>16:9 (Native)</h3>
        <div class="rsc-ratio-tag">Widest FOV</div>
        <p>Full horizontal field of view. See everything on screen. Models appear at their normal width. Best for spotting enemies at the edge of your vision.</p>
        <div class="rsc-pros"><strong>Pros:</strong> Maximum information, natural proportions, no distortion</div>
        <div class="rsc-cons"><strong>Cons:</strong> Models are thinner, may feel "harder to hit" for some players</div>
      </div>
      <div class="rsc-ratio-card">
        <div class="rsc-ratio-visual rsc-1610"></div>
        <h3>16:10</h3>
        <div class="rsc-ratio-tag">Middle Ground</div>
        <p>Slight reduction in horizontal FOV. A compromise between 16:9 and 4:3. Rarely used competitively but comfortable for some players.</p>
        <div class="rsc-pros"><strong>Pros:</strong> Minor FPS boost, slight model widening, still decent FOV</div>
        <div class="rsc-cons"><strong>Cons:</strong> Not as dramatic as 4:3, not as wide as 16:9 -- worst of both worlds for some</div>
      </div>
      <div class="rsc-ratio-card rsc-popular">
        <div class="rsc-ratio-visual rsc-43"></div>
        <h3>4:3 Stretched</h3>
        <div class="rsc-ratio-tag">Most Popular (Pros)</div>
        <p>Image is stretched to fill the screen. Player models appear ~25% wider, making them subjectively easier to hit. Significant FPS boost. Used by ~60% of professional players.</p>
        <div class="rsc-pros"><strong>Pros:</strong> Wider models, higher FPS, faster perceived movement</div>
        <div class="rsc-cons"><strong>Cons:</strong> Reduced FOV, distorted image, lose peripheral vision</div>
      </div>
      <div class="rsc-ratio-card">
        <div class="rsc-ratio-visual rsc-43bb"></div>
        <h3>4:3 Black Bars</h3>
        <div class="rsc-ratio-tag">Focused View</div>
        <p>4:3 resolution with black bars on the sides. Models retain their original proportions. Smaller viewable area helps some players focus on the center of the screen.</p>
        <div class="rsc-pros"><strong>Pros:</strong> Normal proportions, FPS boost, less visual clutter</div>
        <div class="rsc-cons"><strong>Cons:</strong> Reduced FOV, wasted screen space, feels claustrophobic</div>
      </div>
    </div>
  </section>

  <!-- FOV Chart -->
  <section class="rsc-section">
    <h2 class="rsc-section-title">Horizontal FOV by Aspect Ratio</h2>
    <p class="rsc-subtitle">CS2's base vertical FOV is 73.74 degrees. Horizontal FOV scales with aspect ratio.</p>
    <div class="rsc-fov-bars">
      <div class="rsc-fov-row">
        <span class="rsc-fov-label">16:9</span>
        <div class="rsc-fov-track"><div class="rsc-fov-fill" style="width:100%;background:var(--green)"></div></div>
        <span class="rsc-fov-val">106.26</span>
      </div>
      <div class="rsc-fov-row">
        <span class="rsc-fov-label">16:10</span>
        <div class="rsc-fov-track"><div class="rsc-fov-fill" style="width:93%;background:var(--blue)"></div></div>
        <span class="rsc-fov-val">100.39</span>
      </div>
      <div class="rsc-fov-row">
        <span class="rsc-fov-label">4:3</span>
        <div class="rsc-fov-track"><div class="rsc-fov-fill" style="width:84%;background:var(--accent)"></div></div>
        <span class="rsc-fov-val">90.00</span>
      </div>
      <div class="rsc-fov-row">
        <span class="rsc-fov-label">5:4</span>
        <div class="rsc-fov-track"><div class="rsc-fov-fill" style="width:81%;background:var(--purple)"></div></div>
        <span class="rsc-fov-val">86.07</span>
      </div>
    </div>
  </section>

  <!-- Pro Settings Table -->
  <section class="rsc-section">
    <h2 class="rsc-section-title">What Resolution Do Pros Use?</h2>
    <p class="rsc-subtitle">Resolution settings from top CS2 professional players. Note: players frequently change settings.</p>
    <div class="rsc-table-wrap">
      <table class="rsc-table">
        <thead>
          <tr><th>Player</th><th>Resolution</th><th>Aspect Ratio</th><th>Display Mode</th></tr>
        </thead>
        <tbody>
          {PRO_RESOLUTIONS.map(p => (
            <tr>
              <td><strong>{p.player}</strong></td>
              <td>{p.res}</td>
              <td><span class={`rsc-tag ${p.ratio === '4:3' ? 'rsc-tag-43' : p.ratio === '16:9' ? 'rsc-tag-169' : 'rsc-tag-other'}`}>{p.ratio}</span></td>
              <td>{p.mode}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <!-- Distribution -->
  <section class="rsc-section">
    <h2 class="rsc-section-title">Pro Resolution Distribution</h2>
    <div class="rsc-dist-bars">
      <div class="rsc-dist-row">
        <span class="rsc-dist-label">4:3 Stretched</span>
        <div class="rsc-fov-track"><div class="rsc-fov-fill" style="width:55%;background:var(--accent)"></div></div>
        <span class="rsc-fov-val">~55%</span>
      </div>
      <div class="rsc-dist-row">
        <span class="rsc-dist-label">16:9 Native</span>
        <div class="rsc-fov-track"><div class="rsc-fov-fill" style="width:25%;background:var(--green)"></div></div>
        <span class="rsc-fov-val">~25%</span>
      </div>
      <div class="rsc-dist-row">
        <span class="rsc-dist-label">4:3 Black Bars</span>
        <div class="rsc-fov-track"><div class="rsc-fov-fill" style="width:12%;background:var(--blue)"></div></div>
        <span class="rsc-fov-val">~12%</span>
      </div>
      <div class="rsc-dist-row">
        <span class="rsc-dist-label">16:10</span>
        <div class="rsc-fov-track"><div class="rsc-fov-fill" style="width:5%;background:var(--purple)"></div></div>
        <span class="rsc-fov-val">~5%</span>
      </div>
      <div class="rsc-dist-row">
        <span class="rsc-dist-label">Other</span>
        <div class="rsc-fov-track"><div class="rsc-fov-fill" style="width:3%;background:var(--text2)"></div></div>
        <span class="rsc-fov-val">~3%</span>
      </div>
    </div>
  </section>

  <!-- Setup Guide -->
  <section class="rsc-guide">
    <h2 class="rsc-section-title">How to Set Up Stretched Resolution</h2>
    <div class="rsc-steps">
      <div class="rsc-step">
        <span class="rsc-step-num">1</span>
        <div>
          <h3>Set CS2 Resolution</h3>
          <p>Open CS2 Settings, go to Video, then Resolution. Select your desired 4:3 resolution (e.g., 1280x960). Set display mode to Fullscreen.</p>
        </div>
      </div>
      <div class="rsc-step">
        <span class="rsc-step-num">2</span>
        <div>
          <h3>Configure GPU Scaling (NVIDIA)</h3>
          <p>Open NVIDIA Control Panel, go to Display, then Adjust desktop size and position. Select "Full-screen" under scaling mode, then Apply.</p>
        </div>
      </div>
      <div class="rsc-step">
        <span class="rsc-step-num">3</span>
        <div>
          <h3>Configure GPU Scaling (AMD)</h3>
          <p>Open AMD Radeon Settings, go to Display, enable GPU Scaling, set Scaling Mode to Full Panel, then Apply.</p>
        </div>
      </div>
      <div class="rsc-step">
        <span class="rsc-step-num">4</span>
        <div>
          <h3>Verify In-Game</h3>
          <p>Launch CS2 and verify the image fills your screen. If you see black bars, the GPU scaling setting is not applied correctly. Try toggling fullscreen/windowed and back.</p>
        </div>
      </div>
    </div>
  </section>

  <div class="rsc-links">
    <span class="rsc-links-label">Related Tools:</span>
    <a href="/sensitivity-converter/">Sensitivity Converter</a>
    <a href="/edpi-calculator/">eDPI Calculator</a>
    <a href="/cm360-calculator/">cm/360 Calculator</a>
    <a href="/crosshair-generator/">Crosshair Generator</a>
    <a href="/crosshair-codes/">Crosshair Codes</a>
    <a href="/launch-options/">Launch Options</a>
    <a href="/autoexec-generator/">Autoexec Generator</a>
    <a href="/pro-players/">Pro Player Settings</a>
    <a href="/cs2-tools/">All Tools</a>
  </div>

  <section class="rsc-section">
    <h2 class="rsc-section-title">Frequently Asked Questions</h2>
    {faqs.map(f => (
      <details class="rsc-faq-item">
        <summary class="rsc-faq-q">{f.question}</summary>
        <div class="rsc-faq-a">{f.answer}</div>
      </details>
    ))}
  </section>

  <ExploreMore context="tools" />
</Base>

<script is:inline>
(function(){
  function gcd(a,b){return b===0?a:gcd(b,a%b);}
  function getAspectRatio(w,h){var d=gcd(w,h);return(w/d)+':'+(h/d);}
  function getHFov(w,h){var vfov=73.74*Math.PI/180;var aspect=w/h;return Math.round(2*Math.atan(Math.tan(vfov/2)*aspect)*180/Math.PI*100)/100;}
  function getPixelCount(w,h){return(w*h/1000000).toFixed(2);}

  // Preset buttons
  document.querySelectorAll('.rsc-presets .rsc-preset-btn').forEach(function(btn){
    btn.addEventListener('click',function(){
      var t=btn.dataset.target;
      document.getElementById('res'+t+'-w').value=btn.dataset.w;
      document.getElementById('res'+t+'-h').value=btn.dataset.h;
    });
  });

  document.getElementById('calc-btn').addEventListener('click',function(){
    var aw=parseInt(document.getElementById('resA-w').value)||1920;
    var ah=parseInt(document.getElementById('resA-h').value)||1080;
    var bw=parseInt(document.getElementById('resB-w').value)||1280;
    var bh=parseInt(document.getElementById('resB-h').value)||960;

    var resDiv=document.getElementById('rc-results');
    resDiv.style.display='block';

    document.getElementById('rc-labelA').textContent=aw+'x'+ah;
    document.getElementById('rc-labelB').textContent=bw+'x'+bh;

    var hfovA=getHFov(aw,ah);
    var hfovB=getHFov(bw,bh);
    var pixA=getPixelCount(aw,ah);
    var pixB=getPixelCount(bw,bh);
    var arA=getAspectRatio(aw,ah);
    var arB=getAspectRatio(bw,bh);
    var fpsBoost=Math.round((1-(bw*bh)/(aw*ah))*100);

    function statHtml(label,val){return '<div class="rsc-stat-item"><span class="rsc-stat-l">'+label+'</span><span class="rsc-stat-v">'+val+'</span></div>';}

    document.getElementById('rc-statsA').innerHTML=
      statHtml('Aspect Ratio',arA)+
      statHtml('Horizontal FOV',hfovA+'deg')+
      statHtml('Total Pixels',pixA+'MP')+
      statHtml('Resolution',aw+'x'+ah);

    document.getElementById('rc-statsB').innerHTML=
      statHtml('Aspect Ratio',arB)+
      statHtml('Horizontal FOV',hfovB+'deg')+
      statHtml('Total Pixels',pixB+'MP')+
      statHtml('Resolution',bw+'x'+bh);

    var fovDiff=Math.abs(hfovA-hfovB).toFixed(1);
    var wider=hfovA>hfovB?'A':'B';
    var verdict='<strong>FOV Difference:</strong> '+fovDiff+' degrees -- Resolution '+(wider==='A'?aw+'x'+ah:bw+'x'+bh)+' has wider field of view.<br>';
    if(fpsBoost>0)verdict+='<strong>FPS Estimate:</strong> Switching from '+aw+'x'+ah+' to '+bw+'x'+bh+' could give ~'+fpsBoost+'% FPS boost.<br>';
    else if(fpsBoost<0)verdict+='<strong>FPS Estimate:</strong> '+bw+'x'+bh+' renders '+Math.abs(fpsBoost)+'% more pixels -- expect lower FPS.<br>';
    document.getElementById('rc-verdict').innerHTML=verdict;
  });

  // Auto-calculate on load
  document.getElementById('calc-btn').click();
})();
</script>

<style>
  /* Hero */
  .rsc-hero{margin-bottom:1.5rem}
  .rsc-title{font-size:1.8rem;font-weight:800;margin:0 0 .5rem}
  .rsc-desc{color:var(--text2);font-size:.95rem;margin:0;line-height:1.6;max-width:700px}

  /* Sections */
  .rsc-section{background:var(--bg2);border:1px solid var(--border);border-radius:4px;padding:1.5rem;margin-bottom:1.5rem}
  .rsc-section-title{font-size:1.15rem;font-weight:700;margin:0 0 .75rem}
  .rsc-subtitle{color:var(--text2);font-size:.88rem;margin:0 0 1rem;line-height:1.5}

  /* Compare grid */
  .rsc-compare-grid{display:grid;grid-template-columns:1fr auto 1fr;gap:1rem;align-items:start}
  .rsc-input-box{background:var(--bg3);border:1px solid var(--border);border-radius:4px;padding:1.25rem}
  .rsc-box-title{margin:0 0 .75rem;font-size:1rem;font-weight:700}
  .rsc-vs{display:flex;align-items:center;font-size:1.5rem;font-weight:900;color:var(--accent);padding-top:2rem}

  /* Fields */
  .rsc-field{display:flex;align-items:center;gap:.75rem;margin-bottom:.6rem}
  .rsc-label{font-size:.85rem;color:var(--text2);min-width:70px;font-weight:600}
  .rsc-input{background:var(--bg3);border:1px solid var(--border);border-radius:4px;padding:.45rem .6rem;color:var(--text);font-size:.9rem;width:100%}
  .rsc-input:focus{outline:none;border-color:var(--accent)}
  .rsc-select{background:var(--bg3);border:1px solid var(--border);border-radius:4px;padding:.45rem .6rem;color:var(--text);font-size:.9rem;width:100%}
  .rsc-select:focus{outline:none;border-color:var(--accent)}

  /* Options row */
  .rsc-options-row{display:flex;gap:1.5rem;margin-top:1rem;justify-content:center;flex-wrap:wrap}
  .rsc-options-row .rsc-field{margin-bottom:0}

  /* Presets */
  .rsc-presets{display:flex;gap:.4rem;flex-wrap:wrap;margin-top:.75rem}
  .rsc-preset-btn{background:var(--bg2);border:1px solid var(--border);border-radius:4px;padding:.3rem .6rem;color:var(--text2);font-size:.78rem;cursor:pointer;transition:border-color .2s,color .2s}
  .rsc-preset-btn:hover{border-color:var(--accent);color:var(--accent)}

  /* Calc button */
