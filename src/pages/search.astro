---
import Base from '../layouts/Base.astro';
import { SKINS, getLowestPrice, RARITY_COLORS, RARITY_BG } from '../lib/skins';
import { WEAPONS, faqSchema, breadcrumbSchema } from '../lib/weapons';

// Prepare minimal search data for client-side filtering
const searchData = SKINS.map(skin => ({
  slug: skin.slug,
  weapon: skin.weapon,
  name: skin.name,
  rarity: skin.rarity,
  category: skin.category,
  image: skin.image,
  price: getLowestPrice(skin),
}));

const title = 'Search | CSDB.gg';
const description = 'Search for CS2 skins and weapons. Find the latest weapon stats, skin prices, and more.';

const faq = [
  {
    question: 'How do I find a specific skin?',
    answer: 'Use the search bar and type the weapon name or skin name. Results include pricing info from multiple markets.'
  },
  {
    question: 'What does rarity mean?',
    answer: 'Rarity determines how common a skin is. Covert (red) is rarest, followed by Classified (pink), Restricted (purple), Mil-Spec (blue), Industrial (light blue), and Consumer (white).'
  },
  {
    question: 'Are prices up to date?',
    answer: 'Prices are updated regularly from major skin markets. Check individual market listings for real-time pricing.'
  }
];

const schemaData = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faq.map(item => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer
    }
  }))
};

// Define filter options
const categories = ['All', 'Rifle', 'Pistol', 'SMG', 'Heavy', 'Knife', 'Glove'];
const rarities = ['All', 'Covert', 'Classified', 'Restricted', 'Mil-Spec', 'Industrial', 'Consumer'];
---

<Base title={title} description={description}>
  <div class="search-container">
    <h1>Search CSDB</h1>
    <p class="subtitle">Find CS2 skins and weapons</p>

    <div class="search-box-section">
      <input
        type="text"
        placeholder="Search skins, weapons..."
        class="search-input"
        id="searchInput"
        autofocus
      />
      <button type="button" class="search-btn" id="clearBtn">Clear</button>
    </div>

    <!-- Filter Chips -->
    <div class="filters-section">
      <div class="filter-group">
        <h3>Category</h3>
        <div class="filter-chips">
          {categories.map(cat => (
            <button
              class="filter-chip"
              data-filter="category"
              data-value={cat === 'All' ? '' : cat}
              data-active={cat === 'All' ? 'true' : 'false'}
            >
              {cat}
            </button>
          ))}
        </div>
      </div>

      <div class="filter-group">
        <h3>Rarity</h3>
        <div class="filter-chips">
          {rarities.map(rarity => (
            <button
              class="filter-chip"
              data-filter="rarity"
              data-value={rarity === 'All' ? '' : rarity}
              data-active={rarity === 'All' ? 'true' : 'false'}
            >
              {rarity}
            </button>
          ))}
        </div>
      </div>
    </div>

    <!-- Results or Empty State -->
    <div id="resultsContainer" class="results-container hidden">
      <div class="results-header">
        <h2 id="resultsTitle">Results</h2>
        <p id="resultsCount" class="results-count"></p>
      </div>
      <div id="resultsGrid" class="skins-grid"></div>
    </div>

    <div id="emptyState" class="empty-state">
      <div class="empty-content">
        <h2>Start Searching</h2>
        <p>Search for your favorite CS2 skins or weapons above.</p>

        <div class="quick-links">
          <h3>Popular Searches</h3>
          <div class="links-grid">
            <a href="javascript:void(0)" class="quick-link" data-search="Dragon Lore">Dragon Lore</a>
            <a href="javascript:void(0)" class="quick-link" data-search="AK-47">AK-47</a>
            <a href="javascript:void(0)" class="quick-link" data-search="M4A4">M4A4</a>
            <a href="javascript:void(0)" class="quick-link" data-search="AWP">AWP</a>
          </div>
        </div>
      </div>
    </div>

    <div class="faq-section">
      <h2>Frequently Asked Questions</h2>
      {faq.map(item => (
        <div class="faq-item">
          <h3>{item.question}</h3>
          <p>{item.answer}</p>
        </div>
      ))}
    </div>

    <div class="links-section">
      <h2>Related Tools</h2>
      <ul>
        <li><a href="/damage-calculator">Damage Calculator</a></li>
        <li><a href="/weapon-compare">Weapon Compare</a></li>
        <li><a href="/recoil-patterns">Recoil Patterns</a></li>
        <li><a href="/economy-calculator">Economy Calculator</a></li>
      </ul>
    </div>
  </div>

  <script type="application/ld+json" set:html={JSON.stringify(schemaData)} />
</Base>

<style is:inline>
  * {
    box-sizing: border-box;
  }

  :root {
    --bg: #121218;
    --bg2: #1a1a24;
    --bg3: #232330;
    --text: #dcdce6;
    --text2: #8e8ea3;
    --accent: #d4956e;
    --border: #2d2d3c;
  }

  .search-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem;
    color: var(--text);
  }

  h1 {
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
    color: var(--text);
  }

  .subtitle {
    color: var(--text2);
    font-size: 1.1rem;
    margin-bottom: 2rem;
  }

  .search-box-section {
    display: flex;
    gap: 0.75rem;
    margin-bottom: 2rem;
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1.5rem;
  }

  .search-input {
    flex: 1;
    padding: 0.75rem 1rem;
    background: var(--bg3);
    border: 1px solid var(--border);
    border-radius: 6px;
    color: var(--text);
    font-size: 1rem;
    min-width: 0;
    transition: border-color 0.2s;
  }

  .search-input:hover {
    border-color: var(--accent);
  }

  .search-input:focus {
    outline: none;
    border-color: var(--accent);
  }

  .search-input::placeholder {
    color: var(--text2);
  }

  .search-btn {
    padding: 0.75rem 2rem;
    background: #4ade80;
    border: none;
    border-radius: 6px;
    color: #000;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
  }

  .search-btn:hover {
    background: #22c55e;
    transform: translateY(-2px);
  }

  .search-btn:active {
    transform: translateY(0);
  }

  .filters-section {
    margin-bottom: 2rem;
    padding: 1.5rem;
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 12px;
  }

  .filter-group {
    margin-bottom: 1.5rem;
  }

  .filter-group:last-child {
    margin-bottom: 0;
  }

  .filter-group h3 {
    font-size: 0.95rem;
    color: var(--text2);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.75rem;
  }

  .filter-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .filter-chip {
    padding: 0.5rem 1rem;
    background: var(--bg3);
    border: 1px solid var(--border);
    border-radius: 20px;
    color: var(--text2);
    cursor: pointer;
    font-size: 0.9rem;
    transition: all 0.2s;
  }

  .filter-chip:hover {
    border-color: var(--accent);
    color: var(--text);
  }

  .filter-chip[data-active="true"] {
    background: var(--accent);
    color: #000;
    border-color: var(--accent);
  }

  .results-container {
    margin-bottom: 3rem;
  }

  .results-container.hidden {
    display: none;
  }

  .results-header {
    margin-bottom: 1.5rem;
  }

  #resultsTitle {
    font-size: 1.5rem;
    color: var(--text);
    margin-bottom: 0.5rem;
  }

  .results-count {
    color: var(--text2);
    font-size: 0.95rem;
  }

  .skins-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 1.5rem;
  }

  .skin-card {
    display: flex;
    flex-direction: column;
    background: var(--bg2);
    border: 2px solid var(--border);
    border-radius: 8px;
    overflow: hidden;
    transition: all 0.3s;
    text-decoration: none;
    color: inherit;
  }

  .skin-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 16px rgba(0, 0, 0, 0.3);
  }

  .skin-card[data-rarity="Covert"] {
    border-color: #eb4b4b;
  }

  .skin-card[data-rarity="Covert"]:hover {
    border-color: #eb4b4b;
    box-shadow: 0 0 16px rgba(235, 75, 75, 0.3);
  }

  .skin-card[data-rarity="Classified"] {
    border-color: #d32ce6;
  }

  .skin-card[data-rarity="Classified"]:hover {
    border-color: #d32ce6;
    box-shadow: 0 0 16px rgba(211, 44, 230, 0.3);
  }

  .skin-card[data-rarity="Restricted"] {
    border-color: #8847ff;
  }

  .skin-card[data-rarity="Restricted"]:hover {
    border-color: #8847ff;
    box-shadow: 0 0 16px rgba(136, 71, 255, 0.3);
  }

  .skin-card[data-rarity="Mil-Spec"] {
    border-color: #4b69ff;
  }

  .skin-card[data-rarity="Mil-Spec"]:hover {
    border-color: #4b69ff;
    box-shadow: 0 0 16px rgba(75, 105, 255, 0.3);
  }

  .skin-card[data-rarity="Industrial"] {
    border-color: #5e98d9;
  }

  .skin-card[data-rarity="Industrial"]:hover {
    border-color: #5e98d9;
    box-shadow: 0 0 16px rgba(94, 152, 217, 0.3);
  }

  .skin-card[data-rarity="Consumer"] {
    border-color: #b0c3d9;
  }

  .skin-card[data-rarity="Consumer"]:hover {
    border-color: #b0c3d9;
    box-shadow: 0 0 16px rgba(176, 195, 217, 0.3);
  }

  .skin-image {
    width: 100%;
    height: 150px;
    background: linear-gradient(135deg, var(--bg3), var(--bg));
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text2);
    font-size: 0.85rem;
  }

  .skin-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .skin-info {
    padding: 1rem;
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .skin-name {
    color: var(--text);
    margin: 0 0 0.25rem 0;
    font-size: 0.95rem;
    font-weight: 600;
  }

  .weapon-name {
    color: var(--text2);
    font-size: 0.85rem;
    margin: 0 0 0.75rem 0;
  }

  .rarity-badge {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    border-radius: 4px;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.75rem;
    align-self: flex-start;
  }

  .price-info {
    margin-top: auto;
    color: #4ade80;
    font-weight: 600;
    font-size: 1rem;
  }

  .empty-state {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 3rem;
    text-align: center;
  }

  .empty-content h2 {
    color: var(--text);
    font-size: 1.8rem;
    margin-bottom: 0.5rem;
  }

  .empty-content > p {
    color: var(--text2);
    font-size: 1.1rem;
    margin-bottom: 2rem;
  }

  .quick-links {
    margin-top: 2rem;
  }

  .quick-links h3 {
    color: var(--text2);
    font-size: 0.95rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 1rem;
  }

  .links-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: 1rem;
  }

  .quick-link {
    display: block;
    padding: 0.75rem 1rem;
    background: var(--bg3);
    border: 1px solid var(--border);
    border-radius: 6px;
    color: var(--accent);
    text-decoration: none;
    transition: all 0.2s;
    cursor: pointer;
  }

  .quick-link:hover {
    background: var(--accent);
    color: #000;
  }

  .faq-section {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 2rem;
    margin-bottom: 2rem;
  }

  .faq-section h2 {
    color: var(--text);
    font-size: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .faq-item {
    margin-bottom: 1.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--border);
  }

  .faq-item:last-child {
    border-bottom: none;
  }

  .faq-item h3 {
    color: var(--text);
    margin-bottom: 0.5rem;
  }

  .faq-item p {
    color: var(--text2);
    line-height: 1.6;
  }

  .links-section {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 2rem;
  }

  .links-section h2 {
    color: var(--text);
    font-size: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .links-section ul {
    list-style: none;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1rem;
  }

  .links-section a {
    display: block;
    padding: 0.75rem 1rem;
    background: var(--bg3);
    border: 1px solid var(--border);
    border-radius: 6px;
    color: var(--accent);
    text-decoration: none;
    transition: all 0.2s;
  }

  .links-section a:hover {
    background: var(--accent);
    color: #000;
  }
</style>

<script define:vars={{ searchData, RARITY_COLORS, RARITY_BG }}>
  let currentFilters = {
    category: '',
    rarity: '',
    query: ''
  };

  let debounceTimer;

  const searchInput = document.getElementById('searchInput');
  const clearBtn = document.getElementById('clearBtn');
  const filterChips = document.querySelectorAll('.filter-chip');
  const resultsContainer = document.getElementById('resultsContainer');
  const emptyState = document.getElementById('emptyState');
  const resultsGrid = document.getElementById('resultsGrid');
  const resultsTitle = document.getElementById('resultsTitle');
  const resultsCount = document.getElementById('resultsCount');
  const quickLinks = document.querySelectorAll('.quick-link[data-search]');

  function filterSkins() {
    const filtered = searchData.filter(skin => {
      const matchesQuery = !currentFilters.query ||
        skin.name.toLowerCase().includes(currentFilters.query.toLowerCase()) ||
        skin.weapon.toLowerCase().includes(currentFilters.query.toLowerCase());

      const matchesCategory = !currentFilters.category || skin.category === currentFilters.category;
      const matchesRarity = !currentFilters.rarity || skin.rarity === currentFilters.rarity;

      return matchesQuery && matchesCategory && matchesRarity;
    });

    return filtered;
  }

  function renderResults() {
    const results = filterSkins();

    if (results.length === 0 && !currentFilters.query && !currentFilters.category && !currentFilters.rarity) {
      resultsContainer.classList.add('hidden');
      emptyState.style.display = 'block';
      return;
    }

    emptyState.style.display = 'none';
    resultsContainer.classList.remove('hidden');

    let title = 'Results';
    if (currentFilters.query) {
      title = `Results for "${currentFilters.query}"`;
    }
    resultsTitle.textContent = title;
    resultsCount.textContent = `${results.length} ${results.length === 1 ? 'skin' : 'skins'} found`;

    resultsGrid.innerHTML = results.map(skin => `
      <a href="/skin/${skin.slug}/" class="skin-card" data-rarity="${skin.rarity}">
        <div class="skin-image">
          ${skin.image ? `<img src="${skin.image}" alt="${skin.name}">` : 'No image'}
        </div>
        <div class="skin-info">
          <div class="skin-name">${skin.name}</div>
          <div class="weapon-name">${skin.weapon}</div>
          <div class="rarity-badge" style="background-color: ${RARITY_BG[skin.rarity]}; color: ${RARITY_COLORS[skin.rarity]};">
            ${skin.rarity}
          </div>
          <div class="price-info">
            ${skin.price > 0 ? `$${skin.price.toFixed(2)}` : 'N/A'}
          </div>
        </div>
      </a>
    `).join('');
  }

  searchInput.addEventListener('input', (e) => {
    currentFilters.query = e.target.value;
    clearTimeout(debounceTimer);
    debounceTimer = setTimeout(renderResults, 200);
  });

  clearBtn.addEventListener('click', () => {
    searchInput.value = '';
    currentFilters.query = '';
    currentFilters.category = '';
    currentFilters.rarity = '';
    filterChips.forEach(chip => {
      chip.dataset.active = chip.dataset.value === '' ? 'true' : 'false';
    });
    renderResults();
  });

  filterChips.forEach(chip => {
    chip.addEventListener('click', () => {
      const filterType = chip.dataset.filter;

      if (filterType === 'category') {
        document.querySelectorAll('[data-filter="category"]').forEach(c => {
          c.dataset.active = 'false';
        });
        currentFilters.category = chip.dataset.value;
      } else if (filterType === 'rarity') {
        document.querySelectorAll('[data-filter="rarity"]').forEach(c => {
          c.dataset.active = 'false';
        });
        currentFilters.rarity = chip.dataset.value;
      }

      chip.dataset.active = 'true';
      renderResults();
    });
  });

  quickLinks.forEach(link => {
    link.addEventListener('click', (e) => {
      e.preventDefault();
      searchInput.value = link.dataset.search;
      currentFilters.query = link.dataset.search;
      renderResults();
      searchInput.focus();
    });
  });

  renderResults();
</script>
