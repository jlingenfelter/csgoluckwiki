---
import Base from '../layouts/Base.astro';
import { SKINS, getLowestPrice, RARITY_COLORS, RARITY_BG } from '../lib/skins';
import { WEAPONS, faqSchema, breadcrumbSchema } from '../lib/weapons';

// Prepare minimal search data for client-side filtering
const searchData = SKINS.map(skin => ({
  slug: skin.slug,
  weapon: skin.weapon,
  name: skin.name,
  rarity: skin.rarity,
  category: skin.category,
  image: skin.image,
  price: getLowestPrice(skin),
}));

const title = 'Search CSGOLuck Wiki — Find Skins, Weapons & More';
const description = 'Search the CSGOLuck Wiki database for CS2 skins, weapons, and market data. Instant results with pricing, rarity filters, and direct links to full details.';

const faq = [
  {
    question: 'How do I find a specific skin on CSGOLuck Wiki?',
    answer: 'Type the weapon name or skin name into the search bar above. Results show pricing from multiple markets and you can filter by category or rarity to narrow things down.'
  },
  {
    question: 'What do the rarity colors mean?',
    answer: 'Rarity indicates how rare a skin is. Covert (red) is the rarest drop tier, followed by Classified (pink), Restricted (purple), Mil-Spec (blue), Industrial (light blue), and Consumer (white). Higher rarity generally means higher value.'
  },
  {
    question: 'How current are the prices shown?',
    answer: 'CSGOLuck Wiki pulls pricing data from 14+ marketplaces through PriceEmpire and refreshes regularly. For exact real-time prices, click through to the individual skin page for full market breakdowns.'
  }
];

const schemaData = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faq.map(item => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer
    }
  }))
};

// Define filter options
const categories = ['All', 'Rifle', 'Pistol', 'SMG', 'Heavy', 'Knife', 'Glove'];
const rarities = ['All', 'Covert', 'Classified', 'Restricted', 'Mil-Spec', 'Industrial', 'Consumer'];
---

<Base title={title} description={description}>
  <section class="sr-hero">
    <h1>Search the Wiki</h1>
    <p class="sr-hero-desc">Find any CS2 skin, weapon, or item in our database</p>
  </section>

  <!-- Watchlist (populated via JS from localStorage) -->
  <section class="sr-watchlist" id="watchlistSection" style="display:none">
    <div class="sr-watchlist-header">
      <h2 class="sr-watchlist-title">Your Watchlist</h2>
    </div>
    <div class="sr-watchlist-grid" id="watchlistGrid"></div>
  </section>

  <div class="sr-search-bar">
    <input
      type="text"
      placeholder="Try 'Dragon Lore', 'AK-47', 'Butterfly Knife'..."
      class="sr-input"
      id="searchInput"
      autofocus
    />
    <button type="button" class="sr-clear-btn" id="clearBtn">Clear</button>
  </div>

  <!-- Filter Chips -->
  <div class="sr-filters">
    <div class="sr-filter-group">
      <h3 class="sr-filter-label">Category</h3>
      <div class="sr-chips">
        {categories.map(cat => (
          <button
            class="sr-chip"
            data-filter="category"
            data-value={cat === 'All' ? '' : cat}
            data-active={cat === 'All' ? 'true' : 'false'}
          >
            {cat}
          </button>
        ))}
      </div>
    </div>

    <div class="sr-filter-group">
      <h3 class="sr-filter-label">Rarity</h3>
      <div class="sr-chips">
        {rarities.map(rarity => (
          <button
            class="sr-chip"
            data-filter="rarity"
            data-value={rarity === 'All' ? '' : rarity}
            data-active={rarity === 'All' ? 'true' : 'false'}
          >
            {rarity}
          </button>
        ))}
      </div>
    </div>
  </div>

  <!-- Results or Empty State -->
  <div id="resultsContainer" class="sr-results sr-hidden">
    <div class="sr-results-header">
      <h2 id="resultsTitle" class="sr-results-title">Results</h2>
      <p id="resultsCount" class="sr-results-count"></p>
    </div>
    <div id="resultsGrid" class="sr-results-grid"></div>
  </div>

  <div id="emptyState" class="sr-empty">
    <div class="sr-empty-inner">
      <h2>What Are You Looking For?</h2>
      <p>Type a skin name, weapon, or keyword above to search the CSGOLuck Wiki database.</p>

      <div class="sr-quick">
        <h3 class="sr-quick-heading">Popular Searches</h3>
        <div class="sr-quick-list">
          <a href="javascript:void(0)" class="sr-quick-link" data-search="Dragon Lore">Dragon Lore</a>
          <a href="javascript:void(0)" class="sr-quick-link" data-search="AK-47">AK-47</a>
          <a href="javascript:void(0)" class="sr-quick-link" data-search="M4A4">M4A4</a>
          <a href="javascript:void(0)" class="sr-quick-link" data-search="AWP">AWP</a>
        </div>
      </div>
    </div>
  </div>

  <section class="sr-faq">
    <h2>Frequently Asked Questions</h2>
    {faq.map(item => (
      <details class="sr-faq-item">
        <summary>{item.question}</summary>
        <p>{item.answer}</p>
      </details>
    ))}
  </section>

  <section class="sr-links">
    <h2>Related Tools</h2>
    <div class="sr-links-list">
      <a href="/damage-calculator/" class="sr-links-row">Damage Calculator</a>
      <a href="/weapon-compare/" class="sr-links-row">Weapon Compare</a>
      <a href="/recoil-patterns/" class="sr-links-row">Recoil Patterns</a>
      <a href="/economy-calculator/" class="sr-links-row">Economy Calculator</a>
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify(schemaData)} />
</Base>

<style>
/* ── Hero ── */
.sr-hero{background:var(--bg2);border:1px solid var(--border);border-radius:4px;padding:2rem;margin-bottom:1.5rem}
.sr-hero h1{font-family:'Montserrat',sans-serif;font-size:2rem;font-weight:800;margin:0 0 .4rem;color:var(--text)}
.sr-hero-desc{color:var(--text2);font-size:.95rem;margin:0}

/* ── Search Bar ── */
.sr-search-bar{display:flex;gap:.65rem;background:var(--bg2);border:1px solid var(--border);border-radius:4px;padding:1rem 1.25rem;margin-bottom:1.25rem}
.sr-input{flex:1;padding:.6rem .85rem;background:var(--bg3);border:1px solid var(--border);border-radius:4px;color:var(--text);font-size:.95rem;font-family:'Montserrat',sans-serif;min-width:0;transition:border-color .15s}
.sr-input:hover,.sr-input:focus{border-color:var(--accent);outline:none}
.sr-input::placeholder{color:var(--text2)}
.sr-clear-btn{padding:.6rem 1.5rem;background:var(--accent);border:none;border-radius:4px;color:#000;font-weight:700;cursor:pointer;font-family:'Montserrat',sans-serif;transition:opacity .15s}
.sr-clear-btn:hover{opacity:.85}

/* ── Filters ── */
.sr-filters{background:var(--bg2);border:1px solid var(--border);border-radius:4px;padding:1.25rem;margin-bottom:1.5rem}
.sr-filter-group{margin-bottom:1rem}
.sr-filter-group:last-child{margin-bottom:0}
.sr-filter-label{font-size:.8rem;color:var(--text2);text-transform:uppercase;letter-spacing:.05em;font-weight:600;margin:0 0 .5rem}
.sr-chips{display:flex;flex-wrap:wrap;gap:.4rem}
.sr-chip{padding:.4rem .75rem;background:var(--bg3);border:1px solid var(--border);border-radius:4px;color:var(--text2);cursor:pointer;font-size:.82rem;font-weight:600;font-family:'Montserrat',sans-serif;transition:border-color .15s,color .15s}
.sr-chip:hover{border-color:var(--accent);color:var(--text)}
.sr-chip[data-active="true"]{background:var(--accent);color:#000;border-color:var(--accent)}

/* ── Results ── */
.sr-results{margin-bottom:2rem}
.sr-hidden{display:none}
.sr-results-header{margin-bottom:1rem}
.sr-results-title{font-family:'Montserrat',sans-serif;font-size:1.2rem;font-weight:700;color:var(--text);margin:0 0 .3rem}
.sr-results-count{color:var(--text2);font-size:.85rem;margin:0}
.sr-results-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:1rem}

/* ── Empty State ── */
.sr-empty{background:var(--bg2);border:1px solid var(--border);border-radius:4px;padding:2.5rem 2rem}
.sr-empty-inner h2{font-family:'Montserrat',sans-serif;color:var(--text);font-size:1.4rem;margin:0 0 .4rem}
.sr-empty-inner>p{color:var(--text2);font-size:1rem;margin:0 0 1.5rem}
.sr-quick{margin-top:1.5rem}
.sr-quick-heading{font-size:.82rem;color:var(--text2);text-transform:uppercase;letter-spacing:.05em;font-weight:600;margin:0 0 .65rem}
.sr-quick-list{display:flex;gap:.5rem;flex-wrap:wrap}
.sr-quick-link{display:inline-block;padding:.5rem .85rem;background:var(--bg3);border:1px solid var(--border);border-left:3px solid transparent;border-radius:4px;color:var(--accent);text-decoration:none;font-size:.88rem;font-weight:600;cursor:pointer;transition:border-color .15s,background .15s}
.sr-quick-link:hover{border-left-color:var(--accent);background:var(--bg)}

/* ── FAQ ── */
.sr-faq{margin-bottom:1.5rem}
.sr-faq h2{font-family:'Montserrat',sans-serif;font-size:1.15rem;font-weight:700;color:var(--text);margin:0 0 .75rem}
.sr-faq-item{background:var(--bg2);border:1px solid var(--border);border-radius:4px;margin-bottom:.35rem;overflow:hidden}
.sr-faq-item summary{padding:.75rem 2.5rem .75rem 1rem;font-weight:700;font-size:.9rem;color:var(--text);cursor:pointer;list-style:none;position:relative;transition:background .15s}
.sr-faq-item summary::after{content:'+';position:absolute;right:1.25rem;top:50%;transform:translateY(-50%);font-size:1.2rem;color:var(--accent);font-weight:700}
.sr-faq-item[open] summary::after{content:'\2212'}
.sr-faq-item summary:hover{background:var(--bg3)}
.sr-faq-item summary::-webkit-details-marker{display:none}
.sr-faq-item p{padding:0 1rem .85rem 1rem;margin:0;color:var(--text2);font-size:.88rem;line-height:1.6}

/* ── Related Links ── */
.sr-links{margin-bottom:2rem}
.sr-links h2{font-family:'Montserrat',sans-serif;font-size:1.15rem;font-weight:700;color:var(--text);margin:0 0 .65rem}
.sr-links-list{display:flex;flex-direction:column;gap:2px}
.sr-links-row{display:block;padding:.55rem .85rem;background:var(--bg2);border:1px solid var(--border);border-left:3px solid transparent;border-radius:4px;color:var(--accent);text-decoration:none;font-size:.88rem;font-weight:600;transition:border-color .15s,background .15s}
.sr-links-row:hover{border-left-color:var(--accent);background:var(--bg3)}

/* ── Watchlist ── */
.sr-watchlist{background:var(--bg2);border:1px solid var(--border);border-radius:4px;padding:1.25rem;margin-bottom:1.25rem}
.sr-watchlist-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:.85rem}
.sr-watchlist-title{font-family:'Montserrat',sans-serif;font-size:1.05rem;font-weight:700;color:var(--text);margin:0}
.sr-watchlist-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:.75rem}
.sr-wl-card{position:relative;display:flex;flex-direction:column;background:var(--bg3);border:1px solid var(--border);border-radius:4px;overflow:hidden;text-decoration:none;color:inherit;transition:border-color .15s,background .15s}
.sr-wl-card:hover{border-color:var(--accent)}
.sr-wl-card-img{width:100%;height:100px;display:flex;align-items:center;justify-content:center;background:var(--bg);overflow:hidden}
.sr-wl-card-img img{max-width:90%;max-height:80px;object-fit:contain}
.sr-wl-card-info{padding:.55rem .65rem;flex:1;display:flex;flex-direction:column;gap:.1rem}
.sr-wl-card-weapon{font-size:.7rem;color:var(--text2)}
.sr-wl-card-name{font-size:.82rem;font-weight:700;color:var(--text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.sr-wl-card-price{font-size:.85rem;font-weight:700;color:var(--accent);margin-top:.2rem}
.sr-wl-remove{position:absolute;top:4px;right:4px;width:22px;height:22px;border-radius:50%;background:rgba(0,0,0,.6);border:none;color:#fff;font-size:.75rem;font-weight:700;cursor:pointer;display:flex;align-items:center;justify-content:center;opacity:0;transition:opacity .15s,background .15s;line-height:1}
.sr-wl-card:hover .sr-wl-remove{opacity:1}
.sr-wl-remove:hover{background:rgba(231,76,60,.8)}

/* ── Responsive ── */
@media(max-width:768px){
  .sr-hero h1{font-size:1.5rem}
  .sr-search-bar{flex-direction:column}
  .sr-results-grid{grid-template-columns:repeat(auto-fill,minmax(160px,1fr))}
  .sr-watchlist-grid{grid-template-columns:repeat(auto-fill,minmax(150px,1fr))}
}
</style>

<script define:vars={{ searchData, RARITY_COLORS, RARITY_BG }}>
  let currentFilters = {
    category: '',
    rarity: '',
    query: ''
  };

  let debounceTimer;

  const searchInput = document.getElementById('searchInput');
  const clearBtn = document.getElementById('clearBtn');
  const filterChips = document.querySelectorAll('.sr-chip');
  const resultsContainer = document.getElementById('resultsContainer');
  const emptyState = document.getElementById('emptyState');
  const resultsGrid = document.getElementById('resultsGrid');
  const resultsTitle = document.getElementById('resultsTitle');
  const resultsCount = document.getElementById('resultsCount');
  const quickLinks = document.querySelectorAll('.sr-quick-link[data-search]');

  function filterSkins() {
    const filtered = searchData.filter(skin => {
      const matchesQuery = !currentFilters.query ||
        skin.name.toLowerCase().includes(currentFilters.query.toLowerCase()) ||
        skin.weapon.toLowerCase().includes(currentFilters.query.toLowerCase());

      const matchesCategory = !currentFilters.category || skin.category === currentFilters.category;
      const matchesRarity = !currentFilters.rarity || skin.rarity === currentFilters.rarity;

      return matchesQuery && matchesCategory && matchesRarity;
    });

    return filtered;
  }

  function renderResults() {
    const results = filterSkins();

    if (results.length === 0 && !currentFilters.query && !currentFilters.category && !currentFilters.rarity) {
      resultsContainer.classList.add('sr-hidden');
      emptyState.style.display = 'block';
      return;
    }

    emptyState.style.display = 'none';
    resultsContainer.classList.remove('sr-hidden');

    let title = 'Results';
    if (currentFilters.query) {
      title = `Results for "${currentFilters.query}"`;
    }
    resultsTitle.textContent = title;
    resultsCount.textContent = `${results.length} ${results.length === 1 ? 'skin' : 'skins'} found`;

    resultsGrid.innerHTML = results.map(skin => `
      <a href="/cs2-skins/${skin.slug}/" class="sr-skin-card" data-rarity="${skin.rarity}">
        <div class="sr-skin-img">
          ${skin.image ? `<img src="${skin.image}" alt="${skin.name}">` : 'No image'}
        </div>
        <div class="sr-skin-info">
          <div class="sr-skin-name">${skin.name}</div>
          <div class="sr-skin-weapon">${skin.weapon}</div>
          <div class="sr-skin-rarity" style="background-color: ${RARITY_BG[skin.rarity]}; color: ${RARITY_COLORS[skin.rarity]};">
            ${skin.rarity}
          </div>
          <div class="sr-skin-price">
            ${skin.price > 0 ? `$${skin.price.toFixed(2)}` : 'N/A'}
          </div>
        </div>
      </a>
    `).join('');
  }

  searchInput.addEventListener('input', (e) => {
    currentFilters.query = e.target.value;
    clearTimeout(debounceTimer);
    debounceTimer = setTimeout(renderResults, 200);
  });

  clearBtn.addEventListener('click', () => {
    searchInput.value = '';
    currentFilters.query = '';
    currentFilters.category = '';
    currentFilters.rarity = '';
    filterChips.forEach(chip => {
      chip.dataset.active = chip.dataset.value === '' ? 'true' : 'false';
    });
    renderResults();
  });

  filterChips.forEach(chip => {
    chip.addEventListener('click', () => {
      const filterType = chip.dataset.filter;

      if (filterType === 'category') {
        document.querySelectorAll('[data-filter="category"]').forEach(c => {
          c.dataset.active = 'false';
        });
        currentFilters.category = chip.dataset.value;
      } else if (filterType === 'rarity') {
        document.querySelectorAll('[data-filter="rarity"]').forEach(c => {
          c.dataset.active = 'false';
        });
        currentFilters.rarity = chip.dataset.value;
      }

      chip.dataset.active = 'true';
      renderResults();
    });
  });

  quickLinks.forEach(link => {
    link.addEventListener('click', (e) => {
      e.preventDefault();
      searchInput.value = link.dataset.search;
      currentFilters.query = link.dataset.search;
      renderResults();
      searchInput.focus();
    });
  });

  renderResults();
</script>

<script>
// ── Watchlist on Search Page ─────────────────────────────
document.addEventListener('DOMContentLoaded', () => {
  const STORAGE_KEY = 'csgoluck_favorites';
  const section = document.getElementById('watchlistSection');
  const grid = document.getElementById('watchlistGrid');
  if (!section || !grid) return;

  function getFavorites() {
    try { return JSON.parse(localStorage.getItem(STORAGE_KEY)) || []; }
    catch { return []; }
  }

  function saveFavorites(favs) {
    localStorage.setItem(STORAGE_KEY, JSON.stringify(favs));
  }

  function renderWatchlist() {
    const favs = getFavorites();
    if (favs.length === 0) {
      section.style.display = 'none';
      return;
    }
    section.style.display = '';
    grid.innerHTML = favs.map(f => `
      <div class="sr-wl-card">
        <button class="sr-wl-remove" data-slug="${f.slug}" title="Remove from watchlist">&times;</button>
        <a href="/cs2-skins/${f.slug}/" style="text-decoration:none;color:inherit;display:flex;flex-direction:column;flex:1">
          <div class="sr-wl-card-img">
            ${f.image ? `<img src="${f.image}" alt="${f.weapon} | ${f.name}" loading="lazy" />` : ''}
          </div>
          <div class="sr-wl-card-info">
            <div class="sr-wl-card-weapon">${f.weapon}</div>
            <div class="sr-wl-card-name">${f.name}</div>
            ${f.price > 0 ? `<div class="sr-wl-card-price">$${parseFloat(f.price).toFixed(2)}</div>` : ''}
          </div>
        </a>
      </div>
    `).join('');

    // Attach remove handlers
    grid.querySelectorAll('.sr-wl-remove').forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        const slug = btn.dataset.slug;
        let favs = getFavorites();
        favs = favs.filter(f => f.slug !== slug);
        saveFavorites(favs);
        renderWatchlist();
      });
    });
  }

  renderWatchlist();
});
</script>

<style is:inline>
/* Skin card styles need to be global since they're rendered via JS innerHTML */
.sr-skin-card{display:flex;flex-direction:column;background:var(--bg2);border:1px solid var(--border);border-left:3px solid transparent;border-radius:4px;overflow:hidden;transition:border-color .15s,background .15s;text-decoration:none;color:inherit}
.sr-skin-card:hover{border-left-color:var(--accent);background:var(--bg3)}
.sr-skin-card[data-rarity="Covert"]{border-color:var(--border);border-left-color:transparent}.sr-skin-card[data-rarity="Covert"]:hover{border-left-color:#2ecc71}
.sr-skin-card[data-rarity="Classified"]{border-color:var(--border);border-left-color:transparent}.sr-skin-card[data-rarity="Classified"]:hover{border-left-color:#d32ce6}
.sr-skin-card[data-rarity="Restricted"]{border-color:var(--border);border-left-color:transparent}.sr-skin-card[data-rarity="Restricted"]:hover{border-left-color:#8847ff}
.sr-skin-card[data-rarity="Mil-Spec"]{border-color:var(--border);border-left-color:transparent}.sr-skin-card[data-rarity="Mil-Spec"]:hover{border-left-color:#4b69ff}
.sr-skin-card[data-rarity="Industrial"]{border-color:var(--border);border-left-color:transparent}.sr-skin-card[data-rarity="Industrial"]:hover{border-left-color:#5e98d9}
.sr-skin-card[data-rarity="Consumer"]{border-color:var(--border);border-left-color:transparent}.sr-skin-card[data-rarity="Consumer"]:hover{border-left-color:#b0c3d9}
.sr-skin-img{width:100%;height:140px;background:var(--bg3);display:flex;align-items:center;justify-content:center;color:var(--text2);font-size:.82rem}
.sr-skin-img img{width:100%;height:100%;object-fit:cover}
.sr-skin-info{padding:.85rem;flex:1;display:flex;flex-direction:column}
.sr-skin-name{color:var(--text);margin:0 0 .15rem;font-size:.9rem;font-weight:700}
.sr-skin-weapon{color:var(--text2);font-size:.8rem;margin:0 0 .5rem}
.sr-skin-rarity{display:inline-block;padding:.15rem .5rem;border-radius:4px;font-size:.7rem;font-weight:700;text-transform:uppercase;letter-spacing:.04em;margin-bottom:.5rem;align-self:flex-start}
.sr-skin-price{margin-top:auto;color:var(--accent);font-weight:700;font-size:.95rem}
</style>
