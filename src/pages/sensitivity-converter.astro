---
import Base from '../layouts/Base.astro';
import ExploreMore from '../components/ExploreMore.astro';
import { faqSchema, breadcrumbSchema } from '../lib/weapons';

const title = 'Sensitivity Converter';
const description = 'Convert mouse sensitivity between CS2, Valorant, Apex Legends, and other popular games.';

const games = [
  { name: 'CS2', fov: 90, formula: 'standard' },
  { name: 'Valorant', fov: 103, formula: 'valorant' },
  { name: 'Apex Legends', fov: 110, formula: 'apex' },
  { name: 'Overwatch 2', fov: 103, formula: 'overwatch' },
  { name: 'Call of Duty', fov: 85, formula: 'standard' },
  { name: 'Quake', fov: 90, formula: 'standard' },
];

const faq = [
  {
    question: 'Why do I need to convert sensitivity?',
    answer: 'Different games use different FOV (field of view) calculations and sensitivity scaling. Converting ensures your crosshair moves the same distance in different games.'
  },
  {
    question: 'What is 3.09 sens in CS2?',
    answer: 'This is a common professional player sensitivity. It provides a good balance between precision aiming and flick shots.'
  },
  {
    question: 'What does DPI affect?',
    answer: 'DPI (dots per inch) is your mouse hardware setting. Lower DPI with higher sens or higher DPI with lower sens can give the same effective sensitivity.'
  }
];

const schemaData = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faq.map(item => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer
    }
  }))
};

const toolSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": title,
  "description": description,
  "applicationCategory": "UtilityApplication",
  "operatingSystem": "Web",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
  "author": { "@type": "Organization", "name": "CSDB.gg", "url": "https://csdb.gg" }
});
---

<Base title={title} description={description}>
  <div class="calc-container">
    <h1>Sensitivity Converter</h1>
    <p class="subtitle">Convert sensitivity between CS2 and other games</p>

    <div class="calc-section">
      <div class="calc-row">
        <div class="input-group">
          <label for="dpi">DPI</label>
          <input type="number" id="dpi" min="100" value="800" class="input-field">
          <small>Your mouse DPI setting</small>
        </div>

        <div class="input-group">
          <label for="sourceGame">From Game</label>
          <select id="sourceGame" class="input-field">
            {games.map(g => <option value={g.name}>{g.name}</option>)}
          </select>
        </div>

        <div class="input-group">
          <label for="sourceSens">Sensitivity</label>
          <input type="number" id="sourceSens" min="0.1" max="10" step="0.01" value="1.5" class="input-field">
        </div>
      </div>

      <div class="calc-row">
        <div class="input-group">
          <label for="targetGame">To Game</label>
          <select id="targetGame" class="input-field">
            {games.map(g => g.name !== 'CS2' ? <option value={g.name}>{g.name}</option> : null)}
          </select>
        </div>

        <div class="result-box highlight">
          <h3>Converted Sensitivity</h3>
          <p class="sensitivity-value" id="convertedSens">1.5</p>
        </div>

        <div class="result-box">
          <h3>Effective eDPI</h3>
          <p class="sensitivity-value" id="edpi">1200</p>
        </div>
      </div>

      <div class="conversion-table">
        <h3>Conversion Table</h3>
        <table id="conversionTable">
          <thead>
            <tr>
              <th>Game</th>
              <th>FOV</th>
              <th>Sensitivity</th>
              <th>eDPI</th>
            </tr>
          </thead>
          <tbody id="tableBody">
          </tbody>
        </table>
      </div>
    </div>

    <div class="info-section">
      <h2>Understanding Sensitivity</h2>
      <ul>
        <li><strong>Sensitivity:</strong> In-game sensitivity multiplier (1.0 - 10.0 range typically)</li>
        <li><strong>DPI:</strong> Dots per inch - your mouse hardware setting (100-3200 common)</li>
        <li><strong>eDPI:</strong> Effective DPI = DPI × Sensitivity. This determines your actual mouse speed</li>
        <li><strong>FOV:</strong> Field of View affects perceived movement and aiming feel</li>
      </ul>
    </div>

    <div class="pro-settings">
      <h2>Popular Pro Settings</h2>
      <div class="settings-grid">
        <div class="setting-card">
          <h4>Typical CS2 Pros</h4>
          <p><strong>DPI:</strong> 400-1600</p>
          <p><strong>Sensitivity:</strong> 1.0-2.0</p>
          <p><strong>eDPI:</strong> 800-2000</p>
        </div>
        <div class="setting-card">
          <h4>Typical Valorant Pros</h4>
          <p><strong>DPI:</strong> 400-1200</p>
          <p><strong>Sensitivity:</strong> 0.4-0.8</p>
          <p><strong>eDPI:</strong> 240-800</p>
        </div>
      </div>
    </div>

    <div class="faq-section">
      <h2>Frequently Asked Questions</h2>
      {faq.map(item => (
        <div class="faq-item">
          <h3>{item.question}</h3>
          <p>{item.answer}</p>
        </div>
      ))}
    </div>

    <div class="links-section">
      <h2>Related Tools</h2>
      <ul>
        <li><a href="/edpi-calculator/">eDPI Calculator</a></li>
        <li><a href="/cm360-calculator/">cm/360 Calculator</a></li>
        <li><a href="/resolution-calculator/">Resolution Calculator</a></li>
        <li><a href="/crosshair-generator/">Crosshair Generator</a></li>
        <li><a href="/crosshair-codes/">Crosshair Codes</a></li>
        <li><a href="/damage-calculator/">Damage Calculator</a></li>
        <li><a href="/recoil-patterns/">Recoil Patterns</a></li>
        <li><a href="/weapon-compare/">Weapon Compare</a></li>
        <li><a href="/pro-players/">Pro Player Settings</a></li>
        <li><a href="/tools/">All Tools</a></li>
      </ul>
    </div>
  </div>

  <script type="application/ld+json" set:html={toolSchema}></script>
  <script type="application/ld+json" set:html={JSON.stringify(schemaData)} />

  <ExploreMore context="tools" />
</Base>

<style is:inline>
  .calc-container {
    max-width: 900px;
    margin: 0 auto;
    padding: 2rem;
    color: var(--text);
  }

  h1 {
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
    color: var(--accent);
  }

  .subtitle {
    color: var(--text2);
    font-size: 1.1rem;
    margin-bottom: 2rem;
  }

  .calc-section {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 2rem;
    margin-bottom: 2rem;
  }

  .calc-row {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1.5rem;
    margin-bottom: 2rem;
  }

  .input-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  label {
    font-weight: 600;
    color: var(--text2);
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  small {
    color: var(--text2);
    font-size: 0.8rem;
  }

  .input-field, select {
    padding: 0.75rem;
    background: var(--bg3);
    border: 1px solid var(--border);
    border-radius: 6px;
    color: var(--text);
    font-size: 1rem;
  }

  .input-field:hover, select:hover {
    border-color: var(--accent);
  }

  .input-field:focus, select:focus {
    outline: none;
    border-color: var(--accent);
    box-shadow: 0 0 0 3px rgba(212, 149, 110, 0.1);
  }

  .result-box {
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1.5rem;
    text-align: center;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .result-box.highlight {
    border-color: var(--accent);
    background: rgba(212, 149, 110, 0.1);
  }

  .result-box h3 {
    color: var(--text2);
    font-size: 0.9rem;
    margin: 0 0 0.75rem 0;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .sensitivity-value {
    font-size: 2rem;
    font-weight: 700;
    color: var(--accent);
    margin: 0;
  }

  .conversion-table {
    margin-top: 2rem;
    overflow-x: auto;
  }

  .conversion-table h3 {
    color: var(--accent);
    margin-bottom: 1rem;
  }

  table {
    width: 100%;
    border-collapse: collapse;
    background: var(--bg);
    border-radius: 8px;
    overflow: hidden;
  }

  th, td {
    padding: 1rem;
    text-align: left;
    border-bottom: 1px solid var(--border);
  }

  th {
    background: var(--bg3);
    color: var(--text2);
    font-weight: 600;
    text-transform: uppercase;
    font-size: 0.85rem;
    letter-spacing: 0.05em;
  }

  td {
    color: var(--text2);
  }

  tr:last-child td {
    border-bottom: none;
  }

  .info-section {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 2rem;
    margin-bottom: 2rem;
  }

  .info-section h2 {
    color: var(--accent);
    font-size: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .info-section ul {
    list-style: none;
    padding: 0;
  }

  .info-section li {
    padding: 0.75rem 0;
    border-bottom: 1px solid var(--border);
    color: var(--text2);
  }

  .info-section li:last-child {
    border-bottom: none;
  }

  .pro-settings {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 2rem;
    margin-bottom: 2rem;
  }

  .pro-settings h2 {
    color: var(--accent);
    font-size: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .settings-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1.5rem;
  }

  .setting-card {
    background: var(--bg3);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1.5rem;
  }

  .setting-card h4 {
    color: var(--accent);
    margin-bottom: 1rem;
  }

  .setting-card p {
    color: var(--text2);
    margin: 0.5rem 0;
    line-height: 1.5;
  }

  .faq-section {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 2rem;
    margin-bottom: 2rem;
  }

  .faq-section h2 {
    color: var(--accent);
    font-size: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .faq-item {
    margin-bottom: 1.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--border);
  }

  .faq-item:last-child {
    border-bottom: none;
  }

  .faq-item h3 {
    color: var(--accent);
    margin-bottom: 0.5rem;
  }

  .faq-item p {
    color: var(--text2);
    line-height: 1.6;
  }

  .links-section {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 2rem;
  }

  .links-section h2 {
    color: var(--accent);
    font-size: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .links-section ul {
    list-style: none;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1rem;
  }

  .links-section a {
    display: block;
    padding: 0.75rem 1rem;
    background: var(--bg3);
    border: 1px solid var(--border);
    border-radius: 6px;
    color: var(--accent);
    text-decoration: none;
    transition: all 0.2s;
  }

  .links-section a:hover {
    background: var(--accent);
    color: white;
  }
</style>

<script>
  const games = [
    { name: 'CS2', fov: 90 },
    { name: 'Valorant', fov: 103 },
    { name: 'Apex Legends', fov: 110 },
    { name: 'Overwatch 2', fov: 103 },
    { name: 'Call of Duty', fov: 85 },
    { name: 'Quake', fov: 90 },
  ];

  const dpiInput = document.getElementById('dpi');
  const sourceGameSelect = document.getElementById('sourceGame');
  const sourceSensInput = document.getElementById('sourceSens');
  const targetGameSelect = document.getElementById('targetGame');
  const convertedSensEl = document.getElementById('convertedSens');
  const edpiEl = document.getElementById('edpi');
  const tableBody = document.getElementById('tableBody');

  function getGameFov(gameName) {
    return games.find(g => g.name === gameName)?.fov || 90;
  }

  function convertSensitivity() {
    const dpi = parseInt(dpiInput.value) || 800;
    const sourceSens = parseFloat(sourceSensInput.value) || 1;
    const sourceGame = sourceGameSelect.value;
    const targetGame = targetGameSelect.value;

    const sourceFov = getGameFov(sourceGame);
    const targetFov = getGameFov(targetGame);

    // FOV conversion: higher FOV = lower sensitivity needed for same feel
    const fovRatio = Math.tan((sourceFov / 2) * Math.PI / 180) / Math.tan((targetFov / 2) * Math.PI / 180);
    const convertedSens = (sourceSens * fovRatio).toFixed(2);
    const edpi = (dpi * parseFloat(convertedSens)).toFixed(0);

    convertedSensEl.textContent = convertedSens;
    edpiEl.textContent = edpi;

    updateConversionTable(sourceSens, dpi);
  }

  function updateConversionTable(baseSens, dpi) {
    const sourceFov = getGameFov(sourceGameSelect.value);
    tableBody.innerHTML = '';

    games.forEach(game => {
      const fovRatio = Math.tan((sourceFov / 2) * Math.PI / 180) / Math.tan((game.fov / 2) * Math.PI / 180);
      const convertedSens = (baseSens * fovRatio).toFixed(2);
      const edpi = (dpi * parseFloat(convertedSens)).toFixed(0);

      const row = document.createElement('tr');
      row.innerHTML = `
        <td>${game.name}</td>
        <td>${game.fov}</td>
        <td>${convertedSens}</td>
        <td>${edpi}</td>
      `;
      tableBody.appendChild(row);
    });
  }

  dpiInput.addEventListener('input', convertSensitivity);
  sourceSensInput.addEventListener('input', convertSensitivity);
  sourceGameSelect.addEventListener('change', convertSensitivity);
  targetGameSelect.addEventListener('change', convertSensitivity);

  convertSensitivity();
</script>
