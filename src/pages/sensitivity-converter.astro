---
import Base from '../layouts/Base.astro';
import ExploreMore from '../components/ExploreMore.astro';
import { faqSchema, breadcrumbSchema } from '../lib/weapons';

const title = 'CS2 Sensitivity Converter — Convert Between Games | CSGOLuck Wiki';
const description = 'Convert mouse sensitivity between CS2, Valorant, Apex Legends, and other popular games.';

const games = [
  { name: 'CS2', fov: 90, formula: 'standard' },
  { name: 'Valorant', fov: 103, formula: 'valorant' },
  { name: 'Apex Legends', fov: 110, formula: 'apex' },
  { name: 'Overwatch 2', fov: 103, formula: 'overwatch' },
  { name: 'Call of Duty', fov: 85, formula: 'standard' },
  { name: 'Quake', fov: 90, formula: 'standard' },
];

const faq = [
  {
    question: 'Why do I need to convert sensitivity?',
    answer: 'Different games use different FOV (field of view) calculations and sensitivity scaling. Converting ensures your crosshair moves the same distance in different games.'
  },
  {
    question: 'What is 3.09 sens in CS2?',
    answer: 'This is a common professional player sensitivity. It provides a good balance between precision aiming and flick shots.'
  },
  {
    question: 'What does DPI affect?',
    answer: 'DPI (dots per inch) is your mouse hardware setting. Lower DPI with higher sens or higher DPI with lower sens can give the same effective sensitivity.'
  }
];

const schemaData = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faq.map(item => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer
    }
  }))
};

const toolSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": title,
  "description": description,
  "applicationCategory": "UtilityApplication",
  "operatingSystem": "Web",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
  "author": { "@type": "Organization", "name": "CSGOLuck Wiki", "url": "https://wiki.csgoluck.com" }
});
---

<Base title={title} description={description} currentNav="/cs2-tools/">
  <script type="application/ld+json" set:html={toolSchema}></script>
  <script type="application/ld+json" set:html={JSON.stringify(schemaData)} />

  <nav class="breadcrumb"><a href="/">Home</a> <span>/</span> <a href="/cs2-tools/">Tools</a> <span>/</span> <span>Sensitivity Converter</span></nav>

  <div class="snc-hero">
    <h1 class="snc-title">Sensitivity Converter</h1>
    <p class="snc-desc">Convert mouse sensitivity between CS2, Valorant, Apex Legends, and other popular FPS games. Use the <a href="/edpi-calculator/" style="color:var(--accent)">eDPI calculator</a> to see how <a href="/pro-players/" style="color:var(--accent)">pro players</a> compare.</p>
  </div>

  <div class="snc-panel">
    <div class="snc-grid">
      <div class="snc-field">
        <label class="snc-label" for="dpi">DPI</label>
        <input type="number" id="dpi" min="100" value="800" class="snc-input">
        <small class="snc-hint">Your mouse DPI setting</small>
      </div>

      <div class="snc-field">
        <label class="snc-label" for="sourceGame">From Game</label>
        <select id="sourceGame" class="snc-input">
          {games.map(g => <option value={g.name}>{g.name}</option>)}
        </select>
      </div>

      <div class="snc-field">
        <label class="snc-label" for="sourceSens">Sensitivity</label>
        <input type="number" id="sourceSens" min="0.1" max="10" step="0.01" value="1.5" class="snc-input">
      </div>

      <div class="snc-field">
        <label class="snc-label" for="targetGame">To Game</label>
        <select id="targetGame" class="snc-input">
          {games.map(g => g.name !== 'CS2' ? <option value={g.name}>{g.name}</option> : null)}
        </select>
      </div>
    </div>

    <div class="snc-result-row">
      <div class="snc-result-item snc-result-highlight">
        <span class="snc-result-label">Converted Sensitivity</span>
        <span class="snc-result-value" id="convertedSens">1.5</span>
      </div>
      <div class="snc-result-item">
        <span class="snc-result-label">Effective eDPI</span>
        <span class="snc-result-value" id="edpi">1200</span>
      </div>
    </div>

    <div class="snc-table-wrap">
      <h3 class="snc-table-title">Conversion Table</h3>
      <table class="snc-table">
        <thead>
          <tr>
            <th>Game</th>
            <th>FOV</th>
            <th>Sensitivity</th>
            <th>eDPI</th>
          </tr>
        </thead>
        <tbody id="tableBody">
        </tbody>
      </table>
    </div>
  </div>

  <div class="snc-two-col">
    <div class="snc-info-block">
      <h2 class="snc-section-title">Understanding Sensitivity</h2>
      <ul class="snc-info-list">
        <li><strong>Sensitivity:</strong> In-game sensitivity multiplier (1.0 - 10.0 range typically)</li>
        <li><strong>DPI:</strong> Dots per inch - your mouse hardware setting (100-3200 common)</li>
        <li><strong>eDPI:</strong> Effective DPI = DPI x Sensitivity. This determines your actual mouse speed</li>
        <li><strong>FOV:</strong> Field of View affects perceived movement and aiming feel</li>
      </ul>
    </div>

    <div class="snc-info-block">
      <h2 class="snc-section-title">Popular Pro Settings</h2>
      <div class="snc-pro-grid">
        <div class="snc-pro-card">
          <h4 class="snc-pro-name">Typical CS2 Pros</h4>
          <p><strong>DPI:</strong> 400-1600</p>
          <p><strong>Sensitivity:</strong> 1.0-2.0</p>
          <p><strong>eDPI:</strong> 800-2000</p>
        </div>
        <div class="snc-pro-card">
          <h4 class="snc-pro-name">Typical Valorant Pros</h4>
          <p><strong>DPI:</strong> 400-1200</p>
          <p><strong>Sensitivity:</strong> 0.4-0.8</p>
          <p><strong>eDPI:</strong> 240-800</p>
        </div>
      </div>
    </div>
  </div>

  <section class="snc-faq">
    <h2 class="snc-section-title">Frequently Asked Questions</h2>
    {faq.map(item => (
      <details class="snc-faq-item">
        <summary class="snc-faq-q">{item.question}</summary>
        <p class="snc-faq-a">{item.answer}</p>
      </details>
    ))}
  </section>

  <div class="snc-info-block" style="margin-bottom:2rem">
    <h2 class="snc-section-title">Related Tools</h2>
    <div class="snc-link-list">
      <a href="/edpi-calculator/" class="snc-link">eDPI Calculator</a>
      <a href="/cm360-calculator/" class="snc-link">cm/360 Calculator</a>
      <a href="/resolution-calculator/" class="snc-link">Resolution Calculator</a>
      <a href="/crosshair-generator/" class="snc-link">Crosshair Generator</a>
      <a href="/crosshair-codes/" class="snc-link">Crosshair Codes</a>
      <a href="/damage-calculator/" class="snc-link">Damage Calculator</a>
      <a href="/recoil-patterns/" class="snc-link">Recoil Patterns</a>
      <a href="/weapon-compare/" class="snc-link">Weapon Compare</a>
      <a href="/pro-players/" class="snc-link">Pro Player Settings</a>
      <a href="/cs2-tools/" class="snc-link">All Tools</a>
      <a href="/cs2-guides/mouse-settings-guide/" class="snc-link">Mouse Settings Guide</a>
      <a href="/cs2-guides/crosshair-guide/" class="snc-link">Crosshair Guide</a>
      <a href="/cs2-commands/" class="snc-link">Console Commands</a>
    </div>
  </div>

  <ExploreMore context="tools" />
</Base>

<style>
  .snc-hero{padding:1.5rem 0;margin-bottom:1.5rem}
  .snc-title{font-size:2rem;font-weight:800;margin:0 0 .5rem;color:var(--text)}
  .snc-desc{color:var(--text2);font-size:.95rem;margin:0;max-width:600px;line-height:1.6}

  .snc-panel{background:var(--bg2);border:1px solid var(--border);border-radius:4px;padding:1.5rem;margin-bottom:2rem}
  .snc-grid{display:grid;grid-template-columns:1fr 1fr;gap:1.25rem;margin-bottom:1.5rem}
  .snc-field{display:flex;flex-direction:column;gap:.4rem}
  .snc-label{font-weight:600;color:var(--text2);font-size:.85rem;text-transform:uppercase;letter-spacing:.04em}
  .snc-hint{color:var(--text2);font-size:.78rem}

  .snc-input{padding:.6rem;background:var(--bg3);border:1px solid var(--border);border-radius:4px;color:var(--text);font-size:.95rem;font-family:inherit}
  .snc-input:focus{outline:none;border-color:var(--accent)}

  .snc-result-row{display:grid;grid-template-columns:1fr 1fr;gap:.75rem;margin-bottom:1.5rem}
  .snc-result-item{background:var(--bg);border:1px solid var(--border);border-radius:4px;padding:1.25rem;text-align:center}
  .snc-result-highlight{border-left:3px solid var(--accent);background:rgba(46,204,113,.06)}
  .snc-result-label{display:block;font-size:.78rem;font-weight:600;color:var(--text2);text-transform:uppercase;letter-spacing:.04em;margin-bottom:.5rem}
  .snc-result-value{display:block;font-size:2rem;font-weight:800;color:var(--accent)}

  .snc-table-wrap{overflow-x:auto}
  .snc-table-title{font-size:1rem;font-weight:700;color:var(--text);margin:0 0 .75rem}
  .snc-table{width:100%;border-collapse:collapse;background:var(--bg);border-radius:4px;overflow:hidden}
  .snc-table th,.snc-table td{padding:.75rem 1rem;text-align:left;border-bottom:1px solid var(--border)}
  .snc-table th{background:var(--bg3);color:var(--text2);font-weight:600;text-transform:uppercase;font-size:.8rem;letter-spacing:.04em}
  .snc-table td{color:var(--text2);font-size:.9rem}
  .snc-table tr:last-child td{border-bottom:none}

  .snc-two-col{display:grid;grid-template-columns:1fr 1fr;gap:1.5rem;margin-bottom:2rem}
  .snc-info-block{background:var(--bg2);border:1px solid var(--border);border-radius:4px;padding:1.5rem}
  .snc-section-title{font-size:1.1rem;font-weight:700;color:var(--text);margin:0 0 1rem}
  .snc-info-list{list-style:none;padding:0;margin:0}
  .snc-info-list li{padding:.6rem 0;border-bottom:1px solid var(--border);color:var(--text2);font-size:.88rem;line-height:1.5}
  .snc-info-list li:last-child{border-bottom:none}
  .snc-info-list strong{color:var(--text)}

  .snc-pro-grid{display:flex;flex-direction:column;gap:.75rem}
  .snc-pro-card{background:var(--bg3);border:1px solid var(--border);border-radius:4px;padding:1rem}
  .snc-pro-name{color:var(--accent);font-size:.95rem;margin:0 0 .5rem}
  .snc-pro-card p{color:var(--text2);margin:.3rem 0;font-size:.88rem;line-height:1.5}
  .snc-pro-card strong{color:var(--text)}

  .snc-link-list{display:flex;flex-direction:column;gap:.4rem}
  .snc-link{display:block;padding:.5rem .75rem;background:var(--bg3);border:1px solid var(--border);border-left:3px solid transparent;border-radius:4px;color:var(--accent);text-decoration:none;font-size:.85rem;transition:border-left-color .15s}
  .snc-link:hover{border-left-color:var(--accent)}

  .snc-faq{margin-bottom:2rem}
  .snc-faq-item{background:var(--bg2);border:1px solid var(--border);border-radius:4px;margin-bottom:.5rem;overflow:hidden}
  .snc-faq-q{padding:.8rem 1rem;cursor:pointer;font-weight:600;font-size:.9rem;color:var(--text);list-style:none;display:flex;align-items:center;justify-content:space-between}
  .snc-faq-q::-webkit-details-marker{display:none}
  .snc-faq-q::after{content:'+';font-size:1.1rem;color:var(--accent);font-weight:700}
  .snc-faq-item[open] .snc-faq-q::after{content:'-'}
  .snc-faq-item[open]{border-left:3px solid var(--accent)}
  .snc-faq-a{padding:0 1rem .8rem;margin:0;font-size:.88rem;color:var(--text2);line-height:1.6}

  @media(max-width:768px){
    .snc-grid{grid-template-columns:1fr}
    .snc-two-col{grid-template-columns:1fr}
    .snc-result-row{grid-template-columns:1fr}
  }
</style>

<script>
  const games = [
    { name: 'CS2', fov: 90 },
    { name: 'Valorant', fov: 103 },
    { name: 'Apex Legends', fov: 110 },
    { name: 'Overwatch 2', fov: 103 },
    { name: 'Call of Duty', fov: 85 },
    { name: 'Quake', fov: 90 },
  ];

  const dpiInput = document.getElementById('dpi');
  const sourceGameSelect = document.getElementById('sourceGame');
  const sourceSensInput = document.getElementById('sourceSens');
  const targetGameSelect = document.getElementById('targetGame');
  const convertedSensEl = document.getElementById('convertedSens');
  const edpiEl = document.getElementById('edpi');
  const tableBody = document.getElementById('tableBody');

  function getGameFov(gameName) {
    return games.find(g => g.name === gameName)?.fov || 90;
  }

  function convertSensitivity() {
    const dpi = parseInt(dpiInput.value) || 800;
    const sourceSens = parseFloat(sourceSensInput.value) || 1;
    const sourceGame = sourceGameSelect.value;
    const targetGame = targetGameSelect.value;

    const sourceFov = getGameFov(sourceGame);
    const targetFov = getGameFov(targetGame);

    // FOV conversion: higher FOV = lower sensitivity needed for same feel
    const fovRatio = Math.tan((sourceFov / 2) * Math.PI / 180) / Math.tan((targetFov / 2) * Math.PI / 180);
    const convertedSens = (sourceSens * fovRatio).toFixed(2);
    const edpi = (dpi * parseFloat(convertedSens)).toFixed(0);

    convertedSensEl.textContent = convertedSens;
    edpiEl.textContent = edpi;

    updateConversionTable(sourceSens, dpi);
  }

  function updateConversionTable(baseSens, dpi) {
    const sourceFov = getGameFov(sourceGameSelect.value);
    tableBody.innerHTML = '';

    games.forEach(game => {
      const fovRatio = Math.tan((sourceFov / 2) * Math.PI / 180) / Math.tan((game.fov / 2) * Math.PI / 180);
      const convertedSens = (baseSens * fovRatio).toFixed(2);
      const edpi = (dpi * parseFloat(convertedSens)).toFixed(0);

      const row = document.createElement('tr');
      row.innerHTML = `
        <td>${game.name}</td>
        <td>${game.fov}</td>
        <td>${convertedSens}</td>
        <td>${edpi}</td>
      `;
      tableBody.appendChild(row);
    });
  }

  dpiInput.addEventListener('input', convertSensitivity);
  sourceSensInput.addEventListener('input', convertSensitivity);
  sourceGameSelect.addEventListener('change', convertSensitivity);
  targetGameSelect.addEventListener('change', convertSensitivity);

  convertSensitivity();
</script>
