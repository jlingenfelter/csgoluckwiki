---
import Base from '../layouts/Base.astro';
import ExploreMore from '../components/ExploreMore.astro';
import { SKINS, getLowestPrice, getHighestPrice, RARITY_COLORS, RARITY_BG } from '../lib/skins';
import { faqSchema, breadcrumbSchema, toolAppSchema } from '../lib/weapons';

const title = 'CS2 Skin Comparison Tool — Compare Prices Side by Side | CSGOLuck Wiki';
const description = 'Compare CS2 skins side-by-side. View prices per wear condition, marketplace prices, float ranges, and StatTrak availability. Find the best deal.';

// Pass full skin data including prices, floats, variants for client-side comparison
const skinDataForClient = SKINS.map(s => ({
  slug: s.slug,
  weapon: s.weapon,
  name: s.name,
  rarity: s.rarity,
  rarityColor: s.rarityColor || null,
  collection: s.collection || null,
  image: s.image || null,
  statTrak: s.statTrak,
  souvenir: s.souvenir,
  minFloat: s.minFloat,
  maxFloat: s.maxFloat,
  prices: s.prices || [],
}));

const faqs = [
  {
    question: 'Why compare skins before buying?',
    answer: 'Comparing skins helps you understand price differences across wear conditions and marketplaces. You can spot better deals, see value differences between similar skins, and make informed purchasing decisions.'
  },
  {
    question: 'How do marketplace prices differ?',
    answer: 'Different marketplaces (Steam, CSGOFloat, OPSkins, etc.) charge different fees and have varying supply. Prices can differ by 5-20% between platforms. Always compare before buying to save money.'
  },
  {
    question: 'What is float range?',
    answer: 'Float range indicates wear progression. Factory New (0.00-0.07) looks pristine, while Battle-Scarred (0.45-1.0) shows heavy wear. Identical float values can look different per skin due to texture patterns.'
  },
  {
    question: 'Should I buy StatTrak or standard?',
    answer: 'StatTrak skins cost 2-5x more than standard versions but track your kills. Choose StatTrak for favorite weapons, standard for budget-conscious collecting. Both have identical appearance.'
  },
  {
    question: 'How do I find the cheapest version?',
    answer: 'Our comparison tool shows prices across wear conditions and marketplaces. The cheapest option is usually Battle-Scarred on smaller markets, but check condition-specific prices for Factory New deals.'
  },
  {
    question: 'Can I compare different wear conditions of the same skin?',
    answer: 'Yes! Select the same skin in different wear conditions. Our tool shows exact pricing per wear state, making it easy to see if paying more for better condition is worth it for your budget.'
  }
];

const crumbs = [
  { name: 'Home', url: '/' },
  { name: 'Skins', url: '/cs2-skins/' },
  { name: 'Skin Comparison', url: '/skin-compare/' }
];
---

<Base title={title} description={description} currentNav="/cs2-skins/">
<script type="application/ld+json" set:html={JSON.stringify(faqSchema(faqs))}></script>
<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema(crumbs))}></script>
<script type="application/ld+json" set:html={JSON.stringify(toolAppSchema({ name: 'CS2 Skin Comparison Tool', url: 'https://wiki.csgoluck.com/skin-compare/', description }))}></script>

<nav class="breadcrumb"><a href="/">Home</a> <span>/</span> <a href="/cs2-skins/">Skins</a> <span>/</span> <span>Skin Comparison</span></nav>

<div class="skc-hero">
  <h1 class="skc-title">CS2 Skin Comparison Tool</h1>
  <p class="skc-desc">Compare CS2 skins side-by-side. View prices across wear conditions and marketplaces to find the best deals.</p>
</div>

<!-- Comparison Section -->
<section class="skc-panel">
  <div class="skc-selector-grid">
    <div class="skc-selector">
      <h3 class="skc-selector-title">Skin A</h3>
      <div class="skc-search-wrap">
        <input type="text" id="skinASearch" class="skc-search" placeholder="Search skins..." autocomplete="off" />
        <div class="skc-dropdown" id="skinADropdown" style="display:none;"></div>
      </div>
      <div class="skc-selected" id="skinAInfo"></div>
    </div>
    <div class="skc-vs">VS</div>
    <div class="skc-selector">
      <h3 class="skc-selector-title">Skin B</h3>
      <div class="skc-search-wrap">
        <input type="text" id="skinBSearch" class="skc-search" placeholder="Search skins..." autocomplete="off" />
        <div class="skc-dropdown" id="skinBDropdown" style="display:none;"></div>
      </div>
      <div class="skc-selected" id="skinBInfo"></div>
    </div>
  </div>

  <!-- Comparison Results -->
  <div class="skc-results" id="comparisonResults" style="display:none;">
    <h2 class="skc-section-title">Comparison Results</h2>

    <div class="skc-info-grid">
      <div class="skc-info-box">
        <h4 class="skc-box-label">Skin A</h4>
        <div class="skc-info-rows" id="skinABasic"></div>
      </div>
      <div class="skc-info-box">
        <h4 class="skc-box-label">Skin B</h4>
        <div class="skc-info-rows" id="skinBBasic"></div>
      </div>
    </div>

    <h3 class="skc-sub-title">Price by Wear Condition</h3>
    <div class="skc-table-wrap">
      <table class="skc-table">
        <thead>
          <tr><th>Wear Condition</th><th>Skin A</th><th>Difference</th><th>Skin B</th></tr>
        </thead>
        <tbody id="wearComparison"></tbody>
      </table>
    </div>

    <h3 class="skc-sub-title">Float Range & Availability</h3>
    <div class="skc-info-grid">
      <div class="skc-info-box">
        <h4 class="skc-box-label">Skin A Float</h4>
        <div class="skc-info-rows" id="skinAFloat"></div>
      </div>
      <div class="skc-info-box">
        <h4 class="skc-box-label">Skin B Float</h4>
        <div class="skc-info-rows" id="skinBFloat"></div>
      </div>
    </div>

    <h3 class="skc-sub-title">Special Variants</h3>
    <div class="skc-info-grid">
      <div class="skc-info-box">
        <h4 class="skc-box-label">Skin A Variants</h4>
        <div class="skc-info-rows" id="skinAVariants"></div>
      </div>
      <div class="skc-info-box">
        <h4 class="skc-box-label">Skin B Variants</h4>
        <div class="skc-info-rows" id="skinBVariants"></div>
      </div>
    </div>

    <div class="skc-rec" id="recommendation"></div>
  </div>

  <div class="skc-empty" id="emptyState">
    <p>Select two skins to compare their prices and specifications.</p>
    <p class="skc-empty-hint">Start typing in either search box above to find skins.</p>
  </div>
</section>

<!-- Recent Comparisons History -->
<section class="skc-history" id="comparisonHistory" style="display:none;">
  <div class="skc-history-header">
    <h2 class="skc-section-title">Recent Comparisons</h2>
    <button class="skc-clear-btn" id="clearHistoryBtn">Clear History</button>
  </div>
  <div class="skc-history-list" id="historyList"></div>
</section>

<div class="skc-links">
  <span class="skc-links-label">Related Resources:</span>
  <a href="/cs2-skins/">Skin Database</a>
  <a href="/market-trends/">Market Trends</a>
  <a href="/price-tracker/">Price Tracker</a>
  <a href="/float-checker/">Float Checker</a>
  <a href="/tradeup-calculator/">Trade-Up Calculator</a>
  <a href="/case-simulator/">Case Simulator</a>
  <a href="/cs2-cases/">Cases & Collections</a>
  <a href="/inventory-lookup/">Inventory Lookup</a>
  <a href="/loadout-builder/">Loadout Builder</a>
  <a href="/cs2-weapons/">Weapon Database</a>
  <a href="/cs2-guides/float-guide/">Float Guide</a>
  <a href="/cs2-guides/trading-guide/">Trading Guide</a>
  <a href="/cs2-guides/skins-investing-guide/">Investing Guide</a>
  <a href="/cs2-tools/">All Tools</a>
</div>

<section class="skc-section">
  <h2 class="skc-section-title">Frequently Asked Questions</h2>
  {faqs.map(f => (
    <details class="skc-faq-item">
      <summary class="skc-faq-q">{f.question}</summary>
      <div class="skc-faq-a">{f.answer}</div>
    </details>
  ))}
</section>

<style>
  /* Hero */
  .skc-hero{margin-bottom:1.5rem}
  .skc-title{font-size:1.8rem;font-weight:800;margin:0 0 .5rem}
  .skc-desc{color:var(--text2);font-size:.95rem;margin:0;line-height:1.6;max-width:700px}

  /* Panel & Sections */
  .skc-panel,.skc-section{background:var(--bg2);border:1px solid var(--border);border-radius:4px;padding:1.5rem;margin-bottom:1.5rem}
  .skc-section-title{font-size:1.15rem;font-weight:700;margin:0 0 1rem}
  .skc-sub-title{font-size:1rem;font-weight:700;margin:1.5rem 0 .75rem}

  /* Selector grid */
  .skc-selector-grid{display:grid;grid-template-columns:1fr auto 1fr;gap:1.25rem;align-items:start;margin-bottom:1.5rem}
  .skc-selector{display:flex;flex-direction:column;gap:.75rem}
  .skc-selector-title{margin:0;font-size:1rem;font-weight:700}
  .skc-vs{display:flex;align-items:center;justify-content:center;font-weight:900;color:var(--accent);font-size:1.3rem;padding-top:1.5rem}

  /* Search */
  .skc-search-wrap{position:relative}
  .skc-search{width:100%;background:var(--bg3);color:var(--text);border:1px solid var(--border);padding:.6rem .8rem;border-radius:4px;font-size:.9rem;font-family:inherit;box-sizing:border-box}
  .skc-search:focus{outline:none;border-color:var(--accent)}
  .skc-search::placeholder{color:var(--text2)}

  /* Dropdown */
  .skc-dropdown{position:absolute;top:100%;left:0;right:0;background:var(--bg2);border:1px solid var(--border);border-top:none;border-radius:0 0 4px 4px;max-height:320px;overflow-y:auto;z-index:100}
  .skc-dd-item{padding:.6rem .8rem;cursor:pointer;border-bottom:1px solid var(--border);transition:border-left .2s}
  .skc-dd-item:hover{background:var(--bg3);border-left:3px solid var(--accent)}
  .skc-dd-item:last-child{border-bottom:none}
  .skc-dd-weapon{font-size:.72rem;color:var(--text2);text-transform:uppercase;letter-spacing:.03em}
  .skc-dd-name{font-weight:700;margin:.2rem 0;font-size:.9rem}
  .skc-dd-rarity{font-size:.72rem;font-weight:600}

  /* Selected skin */
  .skc-selected{background:var(--bg3);border:1px solid var(--border);border-radius:4px;padding:1rem;min-height:70px;display:flex;flex-direction:column;justify-content:center;align-items:center;text-align:center}
  .skc-selected.skc-empty{color:var(--text2);font-size:.88rem}
  .skc-selected.skc-filled{border-color:var(--accent);border-left:3px solid var(--accent)}
  .skc-sel-weapon{font-size:.72rem;color:var(--text2);text-transform:uppercase;letter-spacing:.03em;margin-bottom:.2rem}
  .skc-sel-name{font-weight:800;font-size:1rem;color:var(--text);margin-bottom:.2rem}
  .skc-sel-rarity{font-size:.72rem;font-weight:700;text-transform:uppercase;letter-spacing:.03em}

  /* Results */
  .skc-results{animation:skcFadeIn .3s ease}
  @keyframes skcFadeIn{from{opacity:0}to{opacity:1}}

  /* Info grid */
  .skc-info-grid{display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:1rem}
  .skc-info-box{background:var(--bg3);border:1px solid var(--border);border-radius:4px;padding:1.25rem}
  .skc-box-label{margin:0 0 .75rem;font-size:.85rem;font-weight:700;color:var(--accent);text-transform:uppercase;letter-spacing:.03em}
  .skc-info-rows{display:flex;flex-direction:column;gap:0}
  .skc-row{display:flex;justify-content:space-between;align-items:center;padding:.4rem 0;border-bottom:1px solid var(--border)}
  .skc-row:last-child{border-bottom:none}
  .skc-row-label{color:var(--text2);font-size:.85rem;font-weight:500}
  .skc-row-value{color:var(--text);font-weight:700;font-size:.9rem}

  /* Table */
  .skc-table-wrap{overflow-x:auto;margin-bottom:1rem}
  .skc-table{width:100%;border-collapse:collapse;font-size:.88rem}
  .skc-table th{text-align:left;padding:.6rem .75rem;border-bottom:2px solid var(--border);color:var(--text2);font-weight:700;font-size:.8rem;text-transform:uppercase;letter-spacing:.03em}
  .skc-table td{padding:.55rem .75rem;border-bottom:1px solid var(--border)}
  .skc-table tbody tr:hover{background:var(--bg3)}
  .skc-price{font-weight:700;color:var(--text)}
  .skc-cheaper{color:var(--green)}
  .skc-higher{color:var(--red)}
  .skc-price-diff{text-align:center;font-weight:600;color:var(--accent)}

  /* Recommendation */
  .skc-rec{background:var(--bg3);border:1px solid var(--border);border-left:3px solid var(--accent);border-radius:4px;padding:1.25rem;margin-top:1.5rem}
  .skc-rec h3{margin:0 0 .5rem;font-size:1rem}
  .skc-rec p{margin:.4rem 0;color:var(--text2);font-size:.88rem;line-height:1.6}
  .skc-rec-item{display:flex;align-items:center;gap:.6rem;margin:.4rem 0;font-size:.88rem}
  .skc-rec-icon{font-size:1rem;color:var(--accent)}

  /* Empty */
  .skc-empty{text-align:center;padding:2.5rem 1rem;color:var(--text2)}
  .skc-empty p{margin:.75rem 0;font-size:.95rem}
  .skc-empty-hint{font-size:.88rem;color:var(--text2)}

  /* Links */
  .skc-links{display:flex;flex-wrap:wrap;gap:.5rem;align-items:center;margin-bottom:1.5rem;padding:1rem;background:var(--bg2);border:1px solid var(--border);border-radius:4px}
  .skc-links-label{font-weight:700;font-size:.85rem;color:var(--text2);margin-right:.25rem}
  .skc-links a{color:var(--accent);font-size:.85rem;text-decoration:none;padding:.25rem .5rem;border-radius:4px;border:1px solid var(--border);transition:border-color .2s}
  .skc-links a:hover{border-color:var(--accent)}

  /* FAQ */
  .skc-faq-item{background:var(--bg3);border:1px solid var(--border);border-radius:4px;margin-bottom:.5rem;overflow:hidden}
  .skc-faq-q{padding:.8rem 1rem;cursor:pointer;font-weight:600;font-size:.9rem;color:var(--text);list-style:none;display:flex;align-items:center;justify-content:space-between}
  .skc-faq-q::-webkit-details-marker{display:none}
  .skc-faq-q::after{content:'+';font-size:1.1rem;color:var(--accent);font-weight:700}
  .skc-faq-item[open] .skc-faq-q::after{content:'-'}
  .skc-faq-item[open]{border-left:3px solid var(--accent)}
  .skc-faq-a{padding:0 1rem .8rem;font-size:.88rem;color:var(--text2);line-height:1.6}

  /* History */
  .skc-history{background:var(--bg2);border:1px solid var(--border);border-radius:4px;padding:1.5rem;margin-bottom:1.5rem}
  .skc-history-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:1rem}
  .skc-history-header .skc-section-title{margin:0}
  .skc-clear-btn{background:var(--bg3);border:1px solid var(--border);color:var(--text2);padding:.35rem .8rem;border-radius:4px;font-size:.78rem;font-weight:600;cursor:pointer;font-family:inherit;transition:all .15s}
  .skc-clear-btn:hover{color:var(--red);border-color:var(--red)}
  .skc-history-list{display:flex;flex-direction:column;gap:4px}
  .skc-history-row{display:flex;align-items:center;gap:.75rem;padding:.65rem 1rem;background:var(--bg3);border:1px solid var(--border);border-left:3px solid transparent;border-radius:4px;transition:border-left-color .15s,background .15s;text-decoration:none;color:inherit;cursor:pointer}
  .skc-history-row:hover{border-left-color:var(--accent);background:var(--bg)}
  .skc-history-skins{font-weight:700;font-size:.9rem;color:var(--text);flex:1}
  .skc-history-vs{color:var(--accent);font-weight:800;font-size:.78rem;margin:0 .3rem}
  .skc-history-date{font-size:.75rem;color:var(--text2);white-space:nowrap}
  .skc-history-arrow{color:var(--text2);font-size:.82rem;margin-left:auto}

  @media(max-width:768px){
    .skc-selector-grid{grid-template-columns:1fr;gap:.5rem}
    .skc-vs{padding:0}
    .skc-info-grid{grid-template-columns:1fr}
    .skc-title{font-size:1.4rem}
    .skc-history-row{flex-wrap:wrap;gap:.4rem}
    .skc-history-arrow{display:none}
  }
</style>

<script is:inline define:vars={{ skinDataForClient }}>
  // Client-side skin search and comparison logic
  const allSkins = skinDataForClient;
  let selectedSkinA = null;
  let selectedSkinB = null;

  function getSkinBySlug(slug) {
    return allSkins.find(s => s.slug === slug);
  }

  function filterSkins(query) {
    const q = query.toLowerCase();
    return allSkins.filter(s =>
      s.name.toLowerCase().includes(q) ||
      s.weapon.toLowerCase().includes(q) ||
      (s.collection && s.collection.toLowerCase().includes(q))
    );
  }

  function populateDropdown(inputId, dropdownId, query) {
    const dropdown = document.getElementById(dropdownId);
    if (!query.trim()) {
      dropdown.style.display = 'none';
      return;
    }

    const results = filterSkins(query).slice(0, 8);
    if (results.length === 0) {
      dropdown.innerHTML = '<div style="padding:1rem;text-align:center;color:var(--text2);">No skins found</div>';
      dropdown.style.display = 'block';
      return;
    }

    dropdown.innerHTML = results
      .map(
        skin => `
      <div class="skc-dd-item" onclick="selectSkin('${inputId}', '${skin.slug}')">
        <div class="skc-dd-weapon">${skin.weapon}</div>
        <div class="skc-dd-name">${skin.name}</div>
        <div class="skc-dd-rarity" style="color:var(--text2)">${skin.rarity}${skin.collection ? ' - ' + skin.collection : ''}</div>
      </div>
    `
      )
      .join('');
    dropdown.style.display = 'block';
  }

  window.selectSkin = function(inputId, slug) {
    const skin = getSkinBySlug(slug);
    if (!skin) return;

    if (inputId === 'skinASearch') {
      selectedSkinA = skin;
      document.getElementById('skinASearch').value = skin.weapon + ' | ' + skin.name;
    } else {
      selectedSkinB = skin;
      document.getElementById('skinBSearch').value = skin.weapon + ' | ' + skin.name;
    }

    document.getElementById(inputId.replace('Search', 'Dropdown')).style.display = 'none';
    updateComparison();
  };

  function updateComparison() {
    const resultsDiv = document.getElementById('comparisonResults');
    const emptyStateDiv = document.getElementById('emptyState');

    if (!selectedSkinA || !selectedSkinB) {
      resultsDiv.style.display = 'none';
      emptyStateDiv.style.display = 'block';
      updateSelectedSkinDisplay('A', selectedSkinA);
      updateSelectedSkinDisplay('B', selectedSkinB);
      return;
    }

    emptyStateDiv.style.display = 'none';
    resultsDiv.style.display = 'block';

    updateSelectedSkinDisplay('A', selectedSkinA);
    updateSelectedSkinDisplay('B', selectedSkinB);
    updateBasicInfo('A', selectedSkinA);
    updateBasicInfo('B', selectedSkinB);
    updateFloatInfo('A', selectedSkinA);
    updateFloatInfo('B', selectedSkinB);
    updateVariantsInfo('A', selectedSkinA);
    updateVariantsInfo('B', selectedSkinB);
    updateWearComparison();
    updateRecommendation();
  }

  function updateSelectedSkinDisplay(letter, skin) {
    const div = document.getElementById('skin' + letter + 'Info');
    if (!skin) {
      div.className = 'skc-selected skc-empty';
      div.innerHTML = '<span>Select ' + (letter === 'A' ? 'first' : 'second') + ' skin</span>';
    } else {
      div.className = 'skc-selected skc-filled';
      div.innerHTML = '<div class="skc-sel-weapon">' + skin.weapon + '</div><div class="skc-sel-name">' + skin.name + '</div><div class="skc-sel-rarity">' + skin.rarity + '</div>';
    }
  }

  function updateBasicInfo(letter, skin) {
    const div = document.getElementById('skin' + letter + 'Basic');
    if (!skin) return;
    const lowestPrice = skin.prices && skin.prices.length ? Math.min(...skin.prices.map(p => p.price)) : null;
    const highestPrice = skin.prices && skin.prices.length ? Math.max(...skin.prices.map(p => p.price)) : null;
    var html = '<div class="skc-row"><span class="skc-row-label">Weapon</span><span class="skc-row-value">' + skin.weapon + '</span></div>';
    html += '<div class="skc-row"><span class="skc-row-label">Name</span><span class="skc-row-value">' + skin.name + '</span></div>';
    html += '<div class="skc-row"><span class="skc-row-label">Rarity</span><span class="skc-row-value" style="color:' + (skin.rarityColor || 'var(--accent)') + '">' + skin.rarity + '</span></div>';
    if (lowestPrice != null) {
      html += '<div class="skc-row"><span class="skc-row-label">Price Range</span><span class="skc-row-value">$' + lowestPrice.toFixed(2) + (highestPrice && highestPrice !== lowestPrice ? ' - $' + highestPrice.toFixed(2) : '') + '</span></div>';
    }
    if (skin.collection) {
      html += '<div class="skc-row"><span class="skc-row-label">Collection</span><span class="skc-row-value">' + skin.collection + '</span></div>';
    }
    div.innerHTML = html;
  }

  function updateFloatInfo(letter, skin) {
    const div = document.getElementById('skin' + letter + 'Float');
    if (!skin) return;
    const minF = skin.minFloat != null ? skin.minFloat.toFixed(4) : '0.0000';
    const maxF = skin.maxFloat != null ? skin.maxFloat.toFixed(4) : '1.0000';
    const wears = [];
    if (skin.minFloat <= 0.07) wears.push('FN');
    if (skin.minFloat <= 0.15 && skin.maxFloat >= 0.07) wears.push('MW');
    if (skin.minFloat <= 0.38 && skin.maxFloat >= 0.15) wears.push('FT');
    if (skin.minFloat <= 0.45 && skin.maxFloat >= 0.38) wears.push('WW');
    if (skin.maxFloat >= 0.45) wears.push('BS');
    const wearRange = wears.length ? wears.join(', ') : 'FN to BS';
    div.innerHTML = '<div class="skc-row"><span class="skc-row-label">Min Float</span><span class="skc-row-value">' + minF + '</span></div>' +
      '<div class="skc-row"><span class="skc-row-label">Max Float</span><span class="skc-row-value">' + maxF + '</span></div>' +
      '<div class="skc-row"><span class="skc-row-label">Wear Range</span><span class="skc-row-value">' + wearRange + '</span></div>';
  }

  function updateVariantsInfo(letter, skin) {
    const div = document.getElementById('skin' + letter + 'Variants');
    if (!skin) return;
    div.innerHTML = '<div class="skc-row"><span class="skc-row-label">StatTrak</span><span class="skc-row-value">' + (skin.statTrak ? 'Available' : 'Not Available') + '</span></div>' +
      '<div class="skc-row"><span class="skc-row-label">Souvenir</span><span class="skc-row-value">' + (skin.souvenir ? 'Available' : 'Not Available') + '</span></div>';
  }

  function getPriceForWear(skin, wear) {
    if (!skin || !skin.prices || !skin.prices.length) return null;
    const match = skin.prices.find(p => p.wear === wear);
    return match ? match.price : null;
  }

  function updateWearComparison() {
    const tbody = document.getElementById('wearComparison');
    const wears = ['Factory New', 'Minimal Wear', 'Field-Tested', 'Well-Worn', 'Battle-Scarred'];

    tbody.innerHTML = wears
      .map(wear => {
        const priceA = getPriceForWear(selectedSkinA, wear);
        const priceB = getPriceForWear(selectedSkinB, wear);
        const hasBoth = priceA != null && priceB != null;
        const diff = hasBoth ? Math.abs(priceA - priceB) : 0;
        const aIsCheaper = hasBoth && priceA < priceB;
        const bIsCheaper = hasBoth && priceB < priceA;

        const cellA = priceA != null
          ? '<td class="skc-price ' + (aIsCheaper ? 'skc-cheaper' : bIsCheaper ? 'skc-higher' : '') + '">$' + priceA.toFixed(2) + '</td>'
          : '<td class="skc-price" style="color:var(--text2)">--</td>';
        const cellB = priceB != null
          ? '<td class="skc-price ' + (bIsCheaper ? 'skc-cheaper' : aIsCheaper ? 'skc-higher' : '') + '">$' + priceB.toFixed(2) + '</td>'
          : '<td class="skc-price" style="color:var(--text2)">--</td>';
        const diffCell = hasBoth
          ? '<td class="skc-price-diff">' + (aIsCheaper ? '-' : bIsCheaper ? '+' : '=') + ' $' + diff.toFixed(2) + '</td>'
          : '<td class="skc-price-diff" style="color:var(--text2)">--</td>';

        return '<tr><td>' + wear + '</td>' + cellA + diffCell + cellB + '</tr>';
      })
      .join('');
  }

  function updateRecommendation() {
    const div = document.getElementById('recommendation');
    if (!selectedSkinA || !selectedSkinB) return;

    const wears = ['Factory New', 'Minimal Wear', 'Field-Tested', 'Well-Worn', 'Battle-Scarred'];
    let totalA = 0, countA = 0, totalB = 0, countB = 0;
    let aCheaperCount = 0, bCheaperCount = 0;

    wears.forEach(w => {
      const pA = getPriceForWear(selectedSkinA, w);
      const pB = getPriceForWear(selectedSkinB, w);
      if (pA != null) { totalA += pA; countA++; }
      if (pB != null) { totalB += pB; countB++; }
      if (pA != null && pB != null) {
        if (pA < pB) aCheaperCount++;
        else if (pB < pA) bCheaperCount++;
      }
    });

    const avgA = countA ? totalA / countA : 0;
    const avgB = countB ? totalB / countB : 0;
    const noPrices = countA === 0 && countB === 0;

    if (noPrices) {
      div.innerHTML = '<h3>Recommendation</h3><p>No price data available for these skins. Price data updates when the full skin database is built on Cloudflare.</p>';
      return;
    }

    const cheaper = avgA <= avgB ? selectedSkinA : selectedSkinB;
    const letter = avgA <= avgB ? 'A' : 'B';
    const cheaperWins = avgA <= avgB ? aCheaperCount : bCheaperCount;
    const avgPrice = avgA <= avgB ? avgA : avgB;
    const pctDiff = Math.abs(((avgA - avgB) / Math.max(avgA, avgB)) * 100).toFixed(0);

    div.innerHTML = '<h3>Recommendation</h3>' +
      '<p><strong>Better Value: Skin ' + letter + ' -- ' + cheaper.weapon + ' | ' + cheaper.name + '</strong></p>' +
      '<p>Average price: $' + avgPrice.toFixed(2) + '. Cheaper in ' + cheaperWins + ' out of ' + Math.min(countA, countB) + ' comparable wear conditions.</p>' +
      '<div class="skc-rec-item"><span class="skc-rec-icon">+</span><span><strong>Price advantage:</strong> ' + cheaper.weapon + ' | ' + cheaper.name + ' is ' + pctDiff + '% ' + (avgA <= avgB ? 'cheaper' : 'more expensive') + ' on average</span></div>' +
      '<div class="skc-rec-item"><span class="skc-rec-icon">i</span><span><strong>Compare across markets:</strong> Prices may vary between Steam, Skinport, Buff163, and other platforms</span></div>';
  }

  document.getElementById('skinASearch').addEventListener('input', e => {
    populateDropdown('skinASearch', 'skinADropdown', e.target.value);
  });

  document.getElementById('skinBSearch').addEventListener('input', e => {
    populateDropdown('skinBSearch', 'skinBDropdown', e.target.value);
  });

  document.addEventListener('click', e => {
    if (!e.target.classList.contains('skc-search')) {
      document.getElementById('skinADropdown').style.display = 'none';
      document.getElementById('skinBDropdown').style.display = 'none';
    }
  });

  // --- Comparison History ---
  const HISTORY_KEY = 'csgoluck_comparisons';
  const MAX_HISTORY = 10;

  function getHistory() {
    try {
      const raw = localStorage.getItem(HISTORY_KEY);
      return raw ? JSON.parse(raw) : [];
    } catch (e) {
      return [];
    }
  }

  function saveComparison(skinA, skinB) {
    if (!skinA || !skinB) return;
    var history = getHistory();
    // Remove duplicate if exists (same pair in either order)
    history = history.filter(function(entry) {
      return !(
        (entry.skin1Slug === skinA.slug && entry.skin2Slug === skinB.slug) ||
        (entry.skin1Slug === skinB.slug && entry.skin2Slug === skinA.slug)
      );
    });
    // Add new entry at the start
    history.unshift({
      skin1Slug: skinA.slug,
      skin1Name: skinA.weapon + ' | ' + skinA.name,
      skin2Slug: skinB.slug,
      skin2Name: skinB.weapon + ' | ' + skinB.name,
      date: new Date().toISOString().split('T')[0]
    });
    // Keep only max entries
    if (history.length > MAX_HISTORY) {
      history = history.slice(0, MAX_HISTORY);
    }
    try {
      localStorage.setItem(HISTORY_KEY, JSON.stringify(history));
    } catch (e) {}
    renderHistory();
  }

  function renderHistory() {
    var history = getHistory();
    var section = document.getElementById('comparisonHistory');
    var list = document.getElementById('historyList');

    if (!history.length) {
      section.style.display = 'none';
      return;
    }
    section.style.display = 'block';
    list.innerHTML = history.map(function(entry) {
      return '<div class="skc-history-row" data-skin1="' + entry.skin1Slug + '" data-skin2="' + entry.skin2Slug + '">' +
        '<span class="skc-history-skins">' + entry.skin1Name + '<span class="skc-history-vs"> vs </span>' + entry.skin2Name + '</span>' +
        '<span class="skc-history-date">' + entry.date + '</span>' +
        '<span class="skc-history-arrow">&rarr;</span>' +
        '</div>';
    }).join('');

    // Click handlers for re-comparing
    var rows = list.querySelectorAll('.skc-history-row');
    rows.forEach(function(row) {
      row.addEventListener('click', function() {
        var s1 = row.getAttribute('data-skin1');
        var s2 = row.getAttribute('data-skin2');
        var skinA = getSkinBySlug(s1);
        var skinB = getSkinBySlug(s2);
        if (skinA) {
          selectedSkinA = skinA;
          document.getElementById('skinASearch').value = skinA.weapon + ' | ' + skinA.name;
        }
        if (skinB) {
          selectedSkinB = skinB;
          document.getElementById('skinBSearch').value = skinB.weapon + ' | ' + skinB.name;
        }
        updateComparison();
        // Scroll to top of comparison panel
        document.querySelector('.skc-panel').scrollIntoView({ behavior: 'smooth' });
      });
    });
  }

  function clearHistory() {
    try {
      localStorage.removeItem(HISTORY_KEY);
    } catch (e) {}
    renderHistory();
  }

  document.getElementById('clearHistoryBtn').addEventListener('click', clearHistory);

  // Patch updateComparison to save history when both skins selected
  var _origUpdateComparison = updateComparison;
  updateComparison = function() {
    _origUpdateComparison();
    if (selectedSkinA && selectedSkinB) {
      saveComparison(selectedSkinA, selectedSkinB);
    }
  };

  // Initial render of history
  renderHistory();

  updateComparison();
</script>

