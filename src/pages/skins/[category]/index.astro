---
import Base from '../../../layouts/Base.astro';
import ExploreMore from '../../../components/ExploreMore.astro';
import { SKINS, RARITY_COLORS, RARITY_BG, getLowestPrice, getHighestPrice, getSkinsByCategory, getWeaponsInCategory, getCategoryCount, SKINS_TOTAL, getVolumeLabel, getLiquidityColor, getLiquidityLabel } from '../../../lib/skins';
import { faqSchema, breadcrumbSchema } from '../../../lib/weapons';
import { skinCardImage } from '../../../lib/imageOptimize';

interface CategoryMeta {
  dataCategory: string;
  label: string;
  singular: string;
  description: string;
  icon: string;
  faqs: { question: string; answer: string }[];
}

export function getStaticPaths() {
  return [
    { params: { category: 'rifles' }, props: { dataCategory: 'rifle', label: 'Rifles', singular: 'Rifle', icon: '🔫', description: 'Browse all CS2 rifle skins including the AK-47, M4A4, M4A1-S, AWP and more. Compare prices across wear conditions and find the best deals on rifle skins.', faqs: [{ question: 'What are the most popular CS2 rifle skins?', answer: 'The most sought-after rifle skins include AK-47 Fire Serpent, AWP Dragon Lore, M4A4 Howl (Contraband), AK-47 Asiimov, M4A1-S Hyper Beast, and AWP Asiimov.' },{ question: 'Which rifle skins are the best value in CS2?', answer: 'Great value rifle skins include the AK-47 Redline, M4A1-S Guardian, AWP Redline, and AK-47 Blue Laminate. These offer clean designs at affordable prices.' },{ question: 'Do rifle skins affect gameplay in CS2?', answer: 'No, skins are purely cosmetic in CS2. They do not affect weapon damage, accuracy, recoil, or any gameplay mechanics.' }] } },
    { params: { category: 'pistols' }, props: { dataCategory: 'pistol', label: 'Pistols', singular: 'Pistol', icon: '🔫', description: 'Browse all CS2 pistol skins for the USP-S, Glock-18, Desert Eagle, P250, Five-SeveN and more. Find prices, float ranges and the best marketplace deals.', faqs: [{ question: 'What are the most expensive CS2 pistol skins?', answer: 'The most expensive pistol skins include the Desert Eagle Blaze, USP-S Kill Confirmed, Glock-18 Fade, and Desert Eagle Hand Cannon.' },{ question: 'Which pistol should I buy skins for first?', answer: 'The USP-S and Glock-18 are the most commonly used pistols since they are default starting weapons. The Desert Eagle is also very popular.' }] } },
    { params: { category: 'smgs' }, props: { dataCategory: 'smg', label: 'SMGs', singular: 'SMG', icon: '🔧', description: 'Browse all CS2 SMG skins including MP9, MAC-10, MP7, UMP-45 and P90. Compare prices and find affordable anti-eco round weapon skins.', faqs: [{ question: 'Which SMG skins are most popular in CS2?', answer: 'Popular SMG skins include MP9 Hypnotic, MAC-10 Neon Rider, UMP-45 Primus, and P90 Asiimov. SMG skins tend to be more affordable than rifle or knife skins.' }] } },
    { params: { category: 'heavy' }, props: { dataCategory: 'heavy', label: 'Heavy Weapons', singular: 'Heavy', icon: '🛡️', description: 'Browse all CS2 heavy weapon skins including Nova, XM1014, MAG-7, Sawed-Off, M249 and Negev. Find shotgun and machine gun skins with prices.', faqs: [{ question: 'What are the best shotgun skins in CS2?', answer: 'Popular shotgun skins include the Nova Hyper Beast, XM1014 Tranquility, MAG-7 Heat, and Sawed-Off The Kraken.' }] } },
    { params: { category: 'knives' }, props: { dataCategory: 'knife', label: 'Knives', singular: 'Knife', icon: '🔪', description: 'Browse all CS2 knife skins including Karambit, Butterfly Knife, M9 Bayonet, Bayonet, Flip Knife and more. Compare knife prices across finishes and wear conditions.', faqs: [{ question: 'What is the most expensive CS2 knife?', answer: 'The most expensive CS2 knives include the Karambit Case Hardened (Blue Gem patterns), Butterfly Knife Doppler (Sapphire/Ruby), and M9 Bayonet Crimson Web Factory New. Prices can reach tens of thousands of dollars.' },{ question: 'Which CS2 knife type is most popular?', answer: 'The Butterfly Knife, Karambit, and M9 Bayonet are consistently the most popular knife types due to their unique animations and visual appeal.' },{ question: 'How many knife types are there in CS2?', answer: 'CS2 features over 20 knife types including Karambit, Butterfly, M9 Bayonet, Bayonet, Flip Knife, Gut Knife, Huntsman, Falchion, Shadow Daggers, Bowie, Ursus, Navaja, Stiletto, Talon, Classic, Nomad, Paracord, Survival, Skeleton, and Kukri.' },{ question: 'What knife finishes are available in CS2?', answer: 'Common knife finishes include Doppler (Ruby, Sapphire, Black Pearl, Phase 1-4), Fade, Marble Fade, Tiger Tooth, Crimson Web, Slaughter, Case Hardened, Night, Ultraviolet, Damascus Steel, Rust Coat, and many more.' }] } },
    { params: { category: 'gloves' }, props: { dataCategory: 'glove', label: 'Gloves', singular: 'Glove', icon: '🧤', description: 'Browse all CS2 glove skins including Sport Gloves, Moto Gloves, Specialist Gloves, Driver Gloves, Hand Wraps and more. Find glove prices and matching combos.', faqs: [{ question: 'What are the most popular CS2 gloves?', answer: 'The most popular gloves include Sport Gloves Pandora\'s Box, Specialist Gloves Fade, Sport Gloves Vice, Moto Gloves Spearmint, and Driver Gloves King Snake.' },{ question: 'How do gloves work in CS2?', answer: 'Gloves are cosmetic items that change the appearance of your character\'s hands in-game. They can be equipped alongside knife skins for a coordinated loadout.' },{ question: 'What gloves go well with which knives?', answer: 'Popular combos include Sport Gloves Vice + Butterfly Doppler Ruby, Specialist Gloves Fade + Karambit Fade, Moto Gloves Spearmint + Butterfly Emerald. Use our Loadout Builder to plan.' }] } },
    { params: { category: 'other' }, props: { dataCategory: 'other', label: 'Other Skins', singular: 'Other', icon: '📦', description: 'Browse other CS2 skins and cosmetic items not in the standard weapon categories.', faqs: [{ question: 'What other cosmetic items exist in CS2?', answer: 'Beyond weapon skins, CS2 features stickers, agents (character models), music kits, graffiti, and patches.' }] } },
  ];
}

// Category lookup for the related section
const ALL_CATEGORIES: Record<string, { dataCategory: string; label: string; icon: string }> = {
  rifles: { dataCategory: 'rifle', label: 'Rifles', icon: '🔫' },
  pistols: { dataCategory: 'pistol', label: 'Pistols', icon: '🔫' },
  smgs: { dataCategory: 'smg', label: 'SMGs', icon: '🔧' },
  heavy: { dataCategory: 'heavy', label: 'Heavy Weapons', icon: '🛡️' },
  knives: { dataCategory: 'knife', label: 'Knives', icon: '🔪' },
  gloves: { dataCategory: 'glove', label: 'Gloves', icon: '🧤' },
  other: { dataCategory: 'other', label: 'Other Skins', icon: '📦' },
};

const { category } = Astro.params;
const { dataCategory, label, singular, description, icon, faqs } = Astro.props as CategoryMeta;

const categorySkins = getSkinsByCategory(dataCategory).sort((a, b) => getHighestPrice(b) - getHighestPrice(a));
const weapons = getWeaponsInCategory(dataCategory);
const totalCount = categorySkins.length;

const title = `CS2 ${label} Skins — Browse All ${label} with Prices | CSDB.gg`;
const crumbs = [
  { name: 'Home', url: '/' },
  { name: 'Skins', url: '/skins/' },
  { name: label, url: `/skins/${category}/` },
];
---
<Base title={title} description={description} currentNav="/skins/">
<script type="application/ld+json" set:html={JSON.stringify(faqSchema(faqs))}></script>
<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema(crumbs))}></script>

<nav class="breadcrumb"><a href="/">Home</a> / <a href="/skins/">Skins</a> / <span>{label}</span></nav>

<div class="sc-header">
  <h1>{icon} CS2 {label} Skins</h1>
  <p>{description}</p>
  <div class="sc-stats">
    <div class="sc-stat"><span class="sc-stat-val">{totalCount}</span><span class="sc-stat-lbl">Total Skins</span></div>
    <div class="sc-stat"><span class="sc-stat-val">{weapons.length}</span><span class="sc-stat-lbl">{label === 'Knives' ? 'Knife Types' : label === 'Gloves' ? 'Glove Types' : 'Weapons'}</span></div>
  </div>
</div>

<!-- Weapon Sub-Filter -->
{weapons.length > 1 && (
<section class="sc-filter-section">
  <div class="sc-filter-label">Filter by {label === 'Knives' ? 'Knife Type' : label === 'Gloves' ? 'Glove Type' : 'Weapon'}</div>
  <div class="sc-wep-grid">
    <button class="sc-wep-btn active" data-weapon="all">
      <span class="sc-wep-name">All {label}</span>
      <span class="sc-wep-count">{totalCount}</span>
    </button>
    {weapons.map(w => (
      <button class="sc-wep-btn" data-weapon={w.weaponSlug}>
        <span class="sc-wep-name">{w.weapon}</span>
        <span class="sc-wep-count">{w.count}</span>
      </button>
    ))}
  </div>
</section>
)}

<!-- Sort Controls -->
<div class="sc-controls">
  <div class="sc-count" id="skin-count">Showing {totalCount} skins</div>
  <div class="sc-sort">
    <label for="sort-select">Sort by:</label>
    <select id="sort-select">
      <option value="price-desc">Price: High to Low</option>
      <option value="price-asc">Price: Low to High</option>
      <option value="name-asc">Name: A-Z</option>
      <option value="name-desc">Name: Z-A</option>
    </select>
  </div>
</div>

<!-- Skin Grid -->
<div class="skin-grid" id="skin-grid">
{categorySkins.map((skin, i) => {
  const low = getLowestPrice(skin);
  const high = getHighestPrice(skin);
  const rarityColor = RARITY_COLORS[skin.rarity] || '#fff';
  const rarityBg = RARITY_BG[skin.rarity] || 'rgba(255,255,255,0.05)';
  return (
    <a href={`/skin/${skin.slug}/`} class={`skin-card${i >= 48 ? ' sc-paginated' : ''}`} data-weapon={skin.weaponSlug} data-rarity={skin.rarity} data-price={high} data-name={skin.name} style={`--rarity-color:${rarityColor};--rarity-bg:${rarityBg}`}>
      <div class="skin-card-header">
        <span class="skin-weapon-name">{skin.weapon}</span>
        <span class="skin-name">{skin.name}</span>
      </div>
      <div class="skin-card-badges">
        <span class="rarity-pill" style={`background:${rarityColor};color:#000`}>{skin.rarity}</span>
        {skin.statTrak && <span class="stattrak-pill">StatTrak</span>}
        {skin.souvenir && <span class="souvenir-pill">Souvenir</span>}
      </div>
      {((skin.volume7d && skin.volume7d > 0) || (skin.liquidity && skin.liquidity > 0)) && (
        <div class="skin-card-trend">
          {skin.volume7d && skin.volume7d > 0 && <span class="trend-badge trend-volume" title="7-day Steam volume">{getVolumeLabel(skin.volume7d)} vol</span>}
          {skin.liquidity && skin.liquidity > 0 && <span class="trend-badge trend-liquidity" style={`color:${getLiquidityColor(skin.liquidity)}`} title={`Liquidity: ${getLiquidityLabel(skin.liquidity)}`}>{getLiquidityLabel(skin.liquidity)}</span>}
        </div>
      )}
      <div class="skin-card-image" style={`background:${rarityBg}`}>
        {skin.image
          ? <img src={skinCardImage(skin.image)} alt={`${skin.weapon} | ${skin.name}`} loading="lazy" width="400" height="300" style="max-width:90%;max-height:120px;object-fit:contain" />
          : <div class="skin-placeholder">{skin.weapon.substring(0, 2)}</div>
        }
      </div>
      <div class="skin-card-prices">
        <span class="skin-price-range">${low.toFixed(2)}{low !== high ? ` – $${high.toFixed(2)}` : ''}</span>
        {skin.collection && <span class="skin-collection">{skin.collection}</span>}
      </div>
      <div class="skin-card-wears">
        <table class="skin-wear-table">
          {skin.prices.map(p => (
            <tr><td class="wear-name">{p.wear}</td><td class="wear-price">${p.price.toFixed(2)}</td></tr>
          ))}
        </table>
      </div>
      <div class="skin-card-footer">
        <span class="skin-wears">{skin.prices.length} wear{skin.prices.length !== 1 ? 's' : ''} &bull; Float {skin.minFloat.toFixed(2)} &ndash; {skin.maxFloat.toFixed(2)}</span>
      </div>
    </a>
  );
})}
</div>

{totalCount > 48 && (
<div class="sc-loadmore-wrap">
  <button class="sc-loadmore-btn" id="load-more-btn">Load More Skins</button>
</div>
)}

<!-- Related Categories -->
<section class="sc-related">
  <h2>Browse Other Skin Categories</h2>
  <div class="sc-related-grid">
    {Object.entries(ALL_CATEGORIES).filter(([slug]) => slug !== category).map(([slug, meta]) => {
      const count = getCategoryCount(meta.dataCategory);
      return (
        <a href={`/skins/${slug}/`} class="sc-related-card">
          <span class="sc-related-icon">{meta.icon}</span>
          <h3>{meta.label}</h3>
          <span class="sc-related-count">{count} skins</span>
        </a>
      );
    })}
  </div>
</section>

<div class="internal-links">
  <strong>Related Pages:</strong>
  <a href="/skins/">All Skins</a>
  <a href="/skin-compare/">Compare Skins</a>
  <a href="/price-tracker/">Price Tracker</a>
  <a href="/market-trends/">Market Trends</a>
  <a href="/float-checker/">Float Checker</a>
  <a href="/tradeup-calculator/">Trade-Up Calculator</a>
  <a href="/cases/">Cases & Collections</a>
  <a href="/inventory-lookup/">Inventory Lookup</a>
  <a href="/loadout-builder/">Loadout Builder</a>
</div>

<h2>Frequently Asked Questions</h2>
<dl class="faq">{faqs.map(f => (<Fragment><dt>{f.question}</dt><dd>{f.answer}</dd></Fragment>))}</dl>

<ExploreMore context="skins" />
</Base>

<style is:inline>
/* Category Page Header */
.sc-header{text-align:center;margin-bottom:2rem;padding-bottom:1.5rem;border-bottom:1px solid var(--border)}
.sc-header h1{margin:0 0 .5rem;font-size:2.2rem}
.sc-header p{max-width:640px;margin:0 auto .75rem;color:var(--text2);line-height:1.6}
.sc-stats{display:flex;justify-content:center;gap:2rem;margin-top:1rem}
.sc-stat{display:flex;flex-direction:column;align-items:center;gap:.1rem}
.sc-stat-val{font-size:1.8rem;font-weight:800;color:var(--accent)}
.sc-stat-lbl{font-size:.78rem;color:var(--text2);text-transform:uppercase;letter-spacing:.05em}

/* Filter Section */
.sc-filter-section{margin-bottom:1.5rem}
.sc-filter-label{font-size:.82rem;color:var(--text2);margin-bottom:.75rem;font-weight:700;text-transform:uppercase;letter-spacing:.05em}
.sc-wep-grid{display:flex;gap:.5rem;flex-wrap:wrap;padding:.5rem;background:var(--bg2);border:1px solid var(--border);border-radius:8px}
.sc-wep-btn{display:flex;flex-direction:column;align-items:center;gap:.1rem;background:var(--bg3);border:1px solid var(--border);border-radius:6px;padding:.5rem .8rem;cursor:pointer;font-family:inherit;color:var(--text2);transition:all .2s;min-width:80px}
.sc-wep-btn:hover{border-color:var(--accent);color:var(--text)}
.sc-wep-btn.active{border-color:var(--accent);background:rgba(212,149,110,.1);color:var(--accent)}
.sc-wep-name{font-size:.82rem;font-weight:600;white-space:nowrap}
.sc-wep-count{font-size:.7rem;color:var(--accent);font-weight:700}

/* Controls Bar */
.sc-controls{display:flex;justify-content:space-between;align-items:center;margin-bottom:1rem;flex-wrap:wrap;gap:.5rem}
.sc-count{font-size:.88rem;color:var(--text2);font-weight:600}
.sc-sort{display:flex;align-items:center;gap:.5rem}
.sc-sort label{font-size:.82rem;color:var(--text2);font-weight:600}
.sc-sort select{background:var(--bg3);color:var(--text);border:1px solid var(--border);padding:.4rem .7rem;border-radius:6px;font-size:.85rem;font-family:inherit;cursor:pointer}
.sc-sort select:focus{outline:none;border-color:var(--accent)}

/* Load More */
.sc-loadmore-wrap{text-align:center;margin:2rem 0}
.sc-loadmore-btn{background:var(--accent);color:var(--bg);border:none;padding:.7rem 2.5rem;border-radius:8px;font-weight:700;font-size:.95rem;cursor:pointer;font-family:inherit;transition:all .2s}
.sc-loadmore-btn:hover{background:var(--accent2);transform:translateY(-1px);box-shadow:0 4px 12px rgba(212,149,110,.3)}
.sc-paginated{display:none}
.sc-paginated.sc-revealed{display:flex}

/* Related Categories */
.sc-related{margin:3rem 0;padding:2rem;background:var(--bg2);border:1px solid var(--border);border-radius:12px}
.sc-related h2{margin:0 0 1rem;text-align:center}
.sc-related-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(150px,1fr));gap:.75rem}
.sc-related-card{display:flex;flex-direction:column;align-items:center;gap:.3rem;background:var(--bg3);border:1px solid var(--border);border-radius:8px;padding:1rem;text-decoration:none;color:inherit;transition:all .2s}
.sc-related-card:hover{border-color:var(--accent);transform:translateY(-2px)}
.sc-related-icon{font-size:1.8rem}
.sc-related-card h3{margin:0;font-size:.9rem;color:var(--text)}
.sc-related-count{font-size:.75rem;color:var(--accent);font-weight:600}

/* Skin Grid (reuse from main skins page) */
.skin-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:1rem;margin:1.5rem 0}
@media(max-width:1100px){.skin-grid{grid-template-columns:repeat(3,1fr)}}
@media(max-width:768px){.skin-grid{grid-template-columns:repeat(2,1fr)}}
@media(max-width:480px){.skin-grid{grid-template-columns:1fr}}

.skin-card{display:flex;flex-direction:column;background:var(--bg2);border:1px solid var(--border);border-radius:10px;overflow:hidden;text-decoration:none;color:inherit;transition:border-color .2s,transform .2s,box-shadow .2s}
.skin-card:hover{border-color:var(--rarity-color,var(--accent));transform:translateY(-3px);box-shadow:0 8px 24px rgba(0,0,0,.4)}

.skin-card-header{padding:.9rem 1rem .4rem;text-align:center}
.skin-weapon-name{display:block;font-size:.78rem;color:var(--text2);letter-spacing:.03em}
.skin-name{display:block;font-size:1.1rem;font-weight:800;color:var(--text);margin-top:.15rem}

.skin-card-badges{display:flex;flex-direction:column;align-items:center;gap:.35rem;padding:0 .75rem .5rem}
.rarity-pill{display:inline-block;padding:.2rem .75rem;border-radius:3px;font-size:.72rem;font-weight:700;text-transform:uppercase;letter-spacing:.04em;width:100%;text-align:center}
.stattrak-pill{display:inline-block;padding:.2rem .75rem;border-radius:3px;font-size:.72rem;font-weight:600;background:#cf6d1e;color:#000;width:100%;text-align:center}
.souvenir-pill{display:inline-block;padding:.2rem .75rem;border-radius:3px;font-size:.72rem;font-weight:600;background:#ffd740;color:#000;width:100%;text-align:center}

.skin-card-trend{display:flex;gap:.35rem;justify-content:center;padding:0 .75rem .25rem;flex-wrap:wrap}
.trend-badge{font-size:.68rem;font-weight:600;padding:.15rem .5rem;border-radius:3px;background:var(--bg3);letter-spacing:.02em}
.trend-volume{color:#81c784}

.skin-card-image{display:flex;align-items:center;justify-content:center;min-height:130px;padding:.75rem;position:relative}
.skin-placeholder{font-size:2.5rem;font-weight:900;color:var(--rarity-color,var(--text2));opacity:.25}

.skin-card-prices{padding:.6rem 1rem .3rem;text-align:center}
.skin-price-range{display:block;font-size:1.05rem;font-weight:700;color:var(--text)}
.skin-collection{display:block;font-size:.72rem;color:var(--text2);margin-top:.25rem}

.skin-card-wears{padding:.3rem .75rem .5rem}
.skin-wear-table{width:100%;border-collapse:collapse;font-size:.82rem}
.skin-wear-table td{padding:.25rem .4rem;border-bottom:1px solid var(--border)}
.wear-name{color:var(--text2)}
.wear-price{text-align:right;font-weight:700;color:var(--text)}

.skin-card-footer{padding:.5rem .75rem;background:var(--bg3);text-align:center;border-top:1px solid var(--border);margin-top:auto}
.skin-wears{font-size:.75rem;font-weight:600;color:var(--accent)}
</style>

<script is:inline>
(function(){
  var wepBtns = document.querySelectorAll('.sc-wep-btn[data-weapon]');
  var cards = document.querySelectorAll('.skin-card[data-weapon]');
  var countEl = document.getElementById('skin-count');
  var loadBtn = document.getElementById('load-more-btn');
  var sortSelect = document.getElementById('sort-select');
  var grid = document.getElementById('skin-grid');
  var activeWep = 'all';
  var revealedCount = 48;
  var isFiltering = false;

  function updateDisplay() {
    var visible = 0;
    cards.forEach(function(c) {
      var wepMatch = activeWep === 'all' || c.dataset.weapon === activeWep;
      if (wepMatch) {
        visible++;
        if (isFiltering) {
          c.style.display = '';
          c.classList.add('sc-revealed');
        } else {
          // Respect pagination
          if (c.classList.contains('sc-paginated') && !c.classList.contains('sc-revealed')) {
            c.style.display = '';
          } else {
            c.style.display = '';
          }
        }
      } else {
        c.style.display = 'none';
      }
    });
    if (countEl) countEl.textContent = 'Showing ' + visible + ' skin' + (visible !== 1 ? 's' : '');
    if (loadBtn) {
      loadBtn.style.display = isFiltering ? 'none' : '';
      // Check if all cards are revealed
      var hidden = document.querySelectorAll('.sc-paginated:not(.sc-revealed)');
      if (hidden.length === 0) loadBtn.style.display = 'none';
    }
  }

  // Weapon filter
  wepBtns.forEach(function(btn) {
    btn.addEventListener('click', function() {
      wepBtns.forEach(function(b) { b.classList.remove('active'); });
      btn.classList.add('active');
      activeWep = btn.dataset.weapon;
      isFiltering = activeWep !== 'all';
      updateDisplay();
    });
  });

  // Load More
  if (loadBtn) {
    loadBtn.addEventListener('click', function() {
      var hidden = document.querySelectorAll('.sc-paginated:not(.sc-revealed)');
      var count = 0;
      hidden.forEach(function(c) {
        if (count < 48) { c.classList.add('sc-revealed'); count++; }
      });
      revealedCount += count;
      var remaining = document.querySelectorAll('.sc-paginated:not(.sc-revealed)');
      if (remaining.length === 0) loadBtn.style.display = 'none';
      updateDisplay();
    });
  }

  // Sort
  if (sortSelect) {
    sortSelect.addEventListener('change', function() {
      var cardsArr = Array.from(cards);
      var val = sortSelect.value;
      cardsArr.sort(function(a, b) {
        if (val === 'price-desc') return (parseFloat(b.dataset.price) || 0) - (parseFloat(a.dataset.price) || 0);
        if (val === 'price-asc') return (parseFloat(a.dataset.price) || 0) - (parseFloat(b.dataset.price) || 0);
        if (val === 'name-asc') return (a.dataset.name || '').localeCompare(b.dataset.name || '');
        if (val === 'name-desc') return (b.dataset.name || '').localeCompare(a.dataset.name || '');
        return 0;
      });
      cardsArr.forEach(function(c) { grid.appendChild(c); });
    });
  }
})();
</script>
