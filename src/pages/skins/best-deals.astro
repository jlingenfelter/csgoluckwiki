---
import Base from '../../layouts/Base.astro';
import ExploreMore from '../../components/ExploreMore.astro';
import { SKINS, RARITY_COLORS, MARKETPLACES, getUniqueCategories, getWeaponsInCategory } from '../../lib/skins';
import { breadcrumbSchema, faqSchema } from '../../lib/weapons';
import { skinCardImage } from '../../lib/imageOptimize';

const title = 'CS2 Skin Best Deals — Find Discounted Skins | CSDB.gg';
const description = 'Find the best CS2 skin deals across 14+ marketplaces. Compare prices to find skins selling below market value. Updated daily with live price data.';

const weaponGroups = [
  { cat: 'rifle', label: 'Rifles', weapons: getWeaponsInCategory('rifle') },
  { cat: 'pistol', label: 'Pistols', weapons: getWeaponsInCategory('pistol') },
  { cat: 'smg', label: 'SMGs', weapons: getWeaponsInCategory('smg') },
  { cat: 'heavy', label: 'Heavy', weapons: getWeaponsInCategory('heavy') },
  { cat: 'knife', label: 'Knives', weapons: getWeaponsInCategory('knife') },
  { cat: 'glove', label: 'Gloves', weapons: getWeaponsInCategory('glove') },
].filter(g => g.weapons.length > 0);

// Build deal data: for each skin + wear, find the best deal vs steam
type Deal = {
  s: string; // slug
  n: string; // name
  w: string; // weaponSlug
  c: string; // category
  r: string; // rarity
  rc: string; // rarityColor
  i: string; // image
  wear: string; // wear condition
  steam: number; // steam price
  best: number; // best third-party price
  bestMarket: string; // marketplace name
  discount: number; // discount percentage
};

const deals: Deal[] = [];
for (const skin of SKINS) {
  if (skin.phase) continue;
  for (const wp of skin.prices) {
    if (!wp.providers) continue;
    const steam = wp.providers['steam'];
    if (!steam || steam <= 0) continue;

    let bestPrice = Infinity;
    let bestKey = '';
    for (const [key, price] of Object.entries(wp.providers)) {
      if (key === 'steam' || key.includes('_buy') || !price || price <= 0) continue;
      if (price < bestPrice) {
        bestPrice = price;
        bestKey = key;
      }
    }

    if (bestPrice < steam && bestPrice < Infinity) {
      const discount = Math.round(((steam - bestPrice) / steam) * 100);
      if (discount >= 5) { // Only show deals with 5%+ discount
        deals.push({
          s: skin.slug,
          n: `${skin.weapon} | ${skin.name}`,
          w: skin.weaponSlug,
          c: skin.category,
          r: skin.rarity,
          rc: RARITY_COLORS[skin.rarity] || '#444',
          i: skin.image ? skinCardImage(skin.image) : '',
          wear: wp.wear,
          steam: steam,
          best: bestPrice,
          bestMarket: MARKETPLACES[bestKey]?.name || bestKey,
          discount: discount,
        });
      }
    }
  }
}

// Sort by discount descending and take top 500
const topDeals = deals.sort((a, b) => b.discount - a.discount).slice(0, 500);

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Skins', url: '/skins/' },
  { name: 'Best Deals', url: '/skins/best-deals/' },
];

const faqs = [
  { question: 'How are CS2 skin deals calculated?', answer: 'We compare the Steam Community Market price against prices from 14+ third-party marketplaces including Skinport, CSFloat, Buff163, and more. The discount percentage shows how much cheaper the skin is on the best marketplace vs Steam.' },
  { question: 'How often are skin deals updated?', answer: 'Skin prices are fetched daily from PriceEmpire, which aggregates live pricing data from all major CS2 skin marketplaces. Deals may change as prices fluctuate.' },
  { question: 'Are these deals safe to buy?', answer: 'We only show prices from established, reputable CS2 skin marketplaces. However, always verify prices directly on the marketplace before purchasing. CSDB.gg is an information resource and does not facilitate transactions.' },
];
---

<Base title={title} description={description} currentNav="/skins/">
<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema(breadcrumbs))} />
<script type="application/ld+json" set:html={JSON.stringify(faqSchema(faqs))} />

<nav class="breadcrumb">
  <a href="/">Home</a> / <a href="/skins/">Skins</a> / <span>Best Deals</span>
</nav>

<div class="bd-header">
  <h1>CS2 Skin Best Deals</h1>
  <p>Find skins selling below Steam Market price on third-party marketplaces. {topDeals.length} deals found across {Object.keys(MARKETPLACES).length}+ marketplaces.</p>
</div>

<div class="bd-controls">
  <div class="bd-control-row">
    <select id="bd-category" class="bd-select">
      <option value="">All Categories</option>
      {weaponGroups.map(g => (
        <option value={g.cat}>{g.label}</option>
      ))}
    </select>
    <select id="bd-budget" class="bd-select">
      <option value="">Any Budget</option>
      <option value="5">Under $5</option>
      <option value="10">Under $10</option>
      <option value="25">Under $25</option>
      <option value="50">Under $50</option>
      <option value="100">Under $100</option>
      <option value="250">Under $250</option>
    </select>
    <select id="bd-sort" class="bd-select">
      <option value="discount">Biggest Discount</option>
      <option value="price-asc">Price: Low → High</option>
      <option value="price-desc">Price: High → Low</option>
      <option value="savings">Biggest Savings ($)</option>
    </select>
  </div>
</div>

<div class="bd-results-header">
  <span id="bd-count">{topDeals.length}</span> deals found
</div>

<div id="bd-grid" class="bd-grid">
  {topDeals.map(d => (
    <a href={`/skin/${d.s}/`} class="bd-card" data-cat={d.c} data-best={d.best} data-discount={d.discount} data-savings={(d.steam - d.best).toFixed(2)} style={`border-color:${d.rc}`}>
      {d.i && <img src={d.i} alt={d.n} width="160" height="120" loading="lazy" class="bd-card-img" />}
      <div class="bd-card-info">
        <strong>{d.n}</strong>
        <span class="bd-card-wear">{d.wear}</span>
        <div class="bd-card-prices">
          <span class="bd-card-steam">${d.steam.toFixed(2)}</span>
          <span class="bd-card-best">${d.best.toFixed(2)}</span>
        </div>
        <div class="bd-card-deal">
          <span class="bd-card-discount">-{d.discount}%</span>
          <span class="bd-card-market">on {d.bestMarket}</span>
        </div>
      </div>
    </a>
  ))}
</div>

<section class="bd-faq">
  <h2>Frequently Asked Questions</h2>
  <dl class="faq">
    {faqs.map(f => (
      <Fragment>
        <dt>{f.question}</dt>
        <dd>{f.answer}</dd>
      </Fragment>
    ))}
  </dl>
</section>

<ExploreMore context="skins" />
</Base>

<script>
const cards = document.querySelectorAll('.bd-card');
const catSelect = document.getElementById('bd-category') as HTMLSelectElement;
const budgetSelect = document.getElementById('bd-budget') as HTMLSelectElement;
const sortSelect = document.getElementById('bd-sort') as HTMLSelectElement;
const countEl = document.getElementById('bd-count');
const grid = document.getElementById('bd-grid');

function applyFilters() {
  const cat = catSelect.value;
  const budget = parseFloat(budgetSelect.value) || Infinity;
  const sort = sortSelect.value;

  const arr = [...cards];
  let visible = 0;

  arr.forEach(card => {
    const el = card as HTMLElement;
    const cCat = el.dataset.cat;
    const cBest = parseFloat(el.dataset.best || '0');
    const show = (!cat || cCat === cat) && cBest <= budget;
    el.style.display = show ? '' : 'none';
    if (show) visible++;
  });

  // Sort visible cards
  const sorted = arr.filter(c => (c as HTMLElement).style.display !== 'none');
  sorted.sort((a, b) => {
    const ae = a as HTMLElement, be = b as HTMLElement;
    if (sort === 'discount') return parseFloat(be.dataset.discount||'0') - parseFloat(ae.dataset.discount||'0');
    if (sort === 'price-asc') return parseFloat(ae.dataset.best||'0') - parseFloat(be.dataset.best||'0');
    if (sort === 'price-desc') return parseFloat(be.dataset.best||'0') - parseFloat(ae.dataset.best||'0');
    if (sort === 'savings') return parseFloat(be.dataset.savings||'0') - parseFloat(ae.dataset.savings||'0');
    return 0;
  });

  sorted.forEach(c => grid?.appendChild(c));
  if (countEl) countEl.textContent = String(visible);
}

[catSelect, budgetSelect, sortSelect].forEach(el => el.addEventListener('change', applyFilters));
</script>

<style>
  .bd-header{margin-bottom:1.5rem}
  .bd-header h1{margin:0 0 .5rem;font-size:2rem}
  .bd-header p{color:var(--text2);margin:0}
  .bd-controls{margin-bottom:1rem}
  .bd-control-row{display:flex;gap:.75rem;flex-wrap:wrap}
  .bd-select{background:var(--bg2);border:1px solid var(--border);border-radius:6px;padding:.5rem .75rem;color:var(--text);font-size:.85rem;cursor:pointer}
  .bd-results-header{font-size:.9rem;color:var(--text2);margin-bottom:1rem}
  .bd-results-header span{font-weight:700;color:var(--accent)}
  .bd-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:.75rem;margin-bottom:2rem}
  .bd-card{background:var(--bg2);border:1px solid var(--border);border-radius:10px;padding:.75rem;text-decoration:none;color:inherit;display:flex;flex-direction:column;align-items:center;text-align:center;transition:border-color .2s,transform .2s}
  .bd-card:hover{transform:translateY(-2px);border-color:var(--accent)}
  .bd-card-img{width:100%;max-width:160px;height:auto;object-fit:contain;margin-bottom:.5rem}
  .bd-card-info{display:flex;flex-direction:column;gap:.2rem;width:100%}
  .bd-card-info strong{font-size:.85rem}
  .bd-card-wear{font-size:.7rem;color:var(--text2)}
  .bd-card-prices{display:flex;justify-content:center;gap:.75rem;align-items:center;margin-top:.25rem}
  .bd-card-steam{text-decoration:line-through;color:var(--text2);font-size:.8rem}
  .bd-card-best{color:var(--accent);font-weight:700;font-size:.95rem}
  .bd-card-deal{display:flex;justify-content:center;gap:.5rem;align-items:center;margin-top:.2rem}
  .bd-card-discount{background:rgba(76,175,80,0.2);color:#4caf50;font-weight:700;font-size:.8rem;padding:.1rem .4rem;border-radius:4px}
  .bd-card-market{font-size:.7rem;color:var(--text2)}
  .bd-faq{margin-bottom:2rem}
  .bd-faq h2{margin:0 0 1rem}
  @media(max-width:768px){
    .bd-grid{grid-template-columns:repeat(auto-fill,minmax(160px,1fr))}
    .bd-control-row{flex-direction:column}
    .bd-select{width:100%}
  }
</style>
