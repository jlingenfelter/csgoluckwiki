---
import Base from '../../../layouts/Base.astro';
import ExploreMore from '../../../components/ExploreMore.astro';
import { WEAPONS, breadcrumbSchema, faqSchema } from '../../../lib/weapons';
import { getSkinsByWeapon, RARITY_COLORS, getLowestPrice, getHighestPrice } from '../../../lib/skins';
import { skinCardImage } from '../../../lib/imageOptimize';

export function getStaticPaths() {
  return WEAPONS.filter(w => getSkinsByWeapon(w.slug).length > 0).map(w => ({
    params: { weapon: w.slug },
    props: { weapon: w },
  }));
}

const { weapon } = Astro.props;
const allSkins = getSkinsByWeapon(weapon.slug).filter(s => !s.phase);
const skinsWithPrice = allSkins.map(s => ({ ...s, low: getLowestPrice(s), high: getHighestPrice(s) }));

const budget = skinsWithPrice.filter(s => s.low > 0 && s.low <= 10).sort((a, b) => b.low - a.low);
const mid = skinsWithPrice.filter(s => s.low > 10 && s.low <= 50).sort((a, b) => b.low - a.low);
const premium = skinsWithPrice.filter(s => s.low > 50 && s.low <= 200).sort((a, b) => b.low - a.low);
const luxury = skinsWithPrice.filter(s => s.low > 200).sort((a, b) => b.low - a.low);

const title = `Best ${weapon.name} Skins in CS2 — Top Picks by Price | CSDB.gg`;
const description = `Discover the best ${weapon.name} skins in Counter-Strike 2. Browse ${allSkins.length} skins sorted by price tier — from budget picks under $10 to premium collector items. Compare prices across marketplaces.`;

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Skins', url: '/skins/' },
  { name: `${weapon.name} Skins`, url: `/weapon/${weapon.slug}/` },
  { name: `Best ${weapon.name} Skins`, url: `/skins/best/${weapon.slug}/` },
];

const faqs = [
  { question: `What is the best ${weapon.name} skin in CS2?`, answer: `The best ${weapon.name} skin depends on your budget. ${luxury.length > 0 ? `For collectors, ${luxury[0].weapon} | ${luxury[0].name} (from $${luxury[0].low.toFixed(2)}) is a top pick.` : ''} ${mid.length > 0 ? `For mid-range budgets, ${mid[0].weapon} | ${mid[0].name} (from $${mid[0].low.toFixed(2)}) offers great value.` : ''} ${budget.length > 0 ? `On a budget, ${budget[0].weapon} | ${budget[0].name} (from $${budget[0].low.toFixed(2)}) is popular.` : ''}` },
  { question: `How many ${weapon.name} skins are there in CS2?`, answer: `There are currently ${allSkins.length} ${weapon.name} skins in Counter-Strike 2, available across multiple rarity tiers and wear conditions.` },
  { question: `What is the cheapest ${weapon.name} skin?`, answer: budget.length > 0 ? `The most affordable ${weapon.name} skins start under $10. ${budget[budget.length - 1].weapon} | ${budget[budget.length - 1].name} starts from $${budget[budget.length - 1].low.toFixed(2)}.` : `Check current market prices on the individual skin pages for the latest pricing.` },
  { question: `What is the most expensive ${weapon.name} skin?`, answer: luxury.length > 0 ? `The most expensive ${weapon.name} skins include ${luxury.slice(0, 3).map(s => `${s.weapon} | ${s.name} (from $${s.low.toFixed(2)})`).join(', ')}.` : premium.length > 0 ? `Premium ${weapon.name} skins include ${premium.slice(0, 3).map(s => `${s.weapon} | ${s.name} (from $${s.low.toFixed(2)})`).join(', ')}.` : `Check the listings above for current pricing across all marketplaces.` },
];
---

<Base title={title} description={description} currentNav="/skins/">
<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema(breadcrumbs))} />
<script type="application/ld+json" set:html={JSON.stringify(faqSchema(faqs))} />

<nav class="breadcrumb">
  <a href="/">Home</a> / <a href="/skins/">Skins</a> / <a href={`/weapon/${weapon.slug}/`}>{weapon.name}</a> / <span>Best Skins</span>
</nav>

<div class="bs-header">
  <h1>Best {weapon.name} Skins in CS2</h1>
  <p>{description}</p>
  <div class="bs-stats">
    <span class="bs-stat">{allSkins.length} total skins</span>
    <span class="bs-stat">{budget.length} under $10</span>
    <span class="bs-stat">{mid.length} $10–$50</span>
    <span class="bs-stat">{premium.length + luxury.length} $50+</span>
  </div>
</div>

{luxury.length > 0 && (
  <section class="bs-tier">
    <h2>Luxury Skins ($200+)</h2>
    <p class="bs-tier-desc">Premium collector items and investment-grade skins.</p>
    <div class="bs-grid">
      {luxury.map(s => (
        <a href={`/skin/${s.slug}/`} class="bs-card" style={`border-color:${RARITY_COLORS[s.rarity] || '#444'}`}>
          {s.image && <img src={skinCardImage(s.image)} alt={`${s.weapon} | ${s.name}`} width="160" height="120" loading="lazy" class="bs-img" />}
          <div class="bs-info">
            <strong>{s.name}</strong>
            <span class="bs-rarity" style={`color:${RARITY_COLORS[s.rarity] || '#fff'}`}>{s.rarity}</span>
            <span class="bs-price">From ${s.low.toFixed(2)}</span>
          </div>
        </a>
      ))}
    </div>
  </section>
)}

{premium.length > 0 && (
  <section class="bs-tier">
    <h2>Premium Skins ($50–$200)</h2>
    <p class="bs-tier-desc">High-quality skins that stand out in-game without breaking the bank.</p>
    <div class="bs-grid">
      {premium.map(s => (
        <a href={`/skin/${s.slug}/`} class="bs-card" style={`border-color:${RARITY_COLORS[s.rarity] || '#444'}`}>
          {s.image && <img src={skinCardImage(s.image)} alt={`${s.weapon} | ${s.name}`} width="160" height="120" loading="lazy" class="bs-img" />}
          <div class="bs-info">
            <strong>{s.name}</strong>
            <span class="bs-rarity" style={`color:${RARITY_COLORS[s.rarity] || '#fff'}`}>{s.rarity}</span>
            <span class="bs-price">From ${s.low.toFixed(2)}</span>
          </div>
        </a>
      ))}
    </div>
  </section>
)}

{mid.length > 0 && (
  <section class="bs-tier">
    <h2>Mid-Range Skins ($10–$50)</h2>
    <p class="bs-tier-desc">Great designs at accessible price points for competitive players.</p>
    <div class="bs-grid">
      {mid.map(s => (
        <a href={`/skin/${s.slug}/`} class="bs-card" style={`border-color:${RARITY_COLORS[s.rarity] || '#444'}`}>
          {s.image && <img src={skinCardImage(s.image)} alt={`${s.weapon} | ${s.name}`} width="160" height="120" loading="lazy" class="bs-img" />}
          <div class="bs-info">
            <strong>{s.name}</strong>
            <span class="bs-rarity" style={`color:${RARITY_COLORS[s.rarity] || '#fff'}`}>{s.rarity}</span>
            <span class="bs-price">From ${s.low.toFixed(2)}</span>
          </div>
        </a>
      ))}
    </div>
  </section>
)}

{budget.length > 0 && (
  <section class="bs-tier">
    <h2>Budget Skins (Under $10)</h2>
    <p class="bs-tier-desc">Affordable skins that look great without the investment.</p>
    <div class="bs-grid">
      {budget.map(s => (
        <a href={`/skin/${s.slug}/`} class="bs-card" style={`border-color:${RARITY_COLORS[s.rarity] || '#444'}`}>
          {s.image && <img src={skinCardImage(s.image)} alt={`${s.weapon} | ${s.name}`} width="160" height="120" loading="lazy" class="bs-img" />}
          <div class="bs-info">
            <strong>{s.name}</strong>
            <span class="bs-rarity" style={`color:${RARITY_COLORS[s.rarity] || '#fff'}`}>{s.rarity}</span>
            <span class="bs-price">From ${s.low.toFixed(2)}</span>
          </div>
        </a>
      ))}
    </div>
  </section>
)}

<section class="bs-faq">
  <h2>Frequently Asked Questions</h2>
  <dl class="faq">
    {faqs.map(f => (
      <Fragment>
        <dt>{f.question}</dt>
        <dd>{f.answer}</dd>
      </Fragment>
    ))}
  </dl>
</section>

<ExploreMore context="skins" />
</Base>

<style>
  .bs-header{margin-bottom:2rem}
  .bs-header h1{margin:0 0 .75rem;font-size:2rem}
  .bs-header p{color:var(--text2);line-height:1.7;margin:0 0 1rem}
  .bs-stats{display:flex;gap:1rem;flex-wrap:wrap}
  .bs-stat{background:var(--bg2);border:1px solid var(--border);border-radius:6px;padding:.4rem .8rem;font-size:.82rem;color:var(--accent);font-weight:600}
  .bs-tier{margin-bottom:2.5rem}
  .bs-tier h2{margin:0 0 .4rem}
  .bs-tier-desc{color:var(--text2);font-size:.9rem;margin:0 0 1rem}
  .bs-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:.75rem}
  .bs-card{background:var(--bg2);border:1px solid var(--border);border-radius:10px;padding:.75rem;text-decoration:none;color:inherit;transition:border-color .2s,transform .2s;display:flex;flex-direction:column;align-items:center;text-align:center}
  .bs-card:hover{transform:translateY(-2px);border-color:var(--accent)}
  .bs-img{width:100%;max-width:160px;height:auto;object-fit:contain;margin-bottom:.5rem}
  .bs-info{display:flex;flex-direction:column;gap:.2rem}
  .bs-info strong{font-size:.9rem}
  .bs-rarity{font-size:.75rem;font-weight:600}
  .bs-price{font-size:.85rem;color:var(--accent);font-weight:700}
  .bs-faq{margin-bottom:2rem}
  .bs-faq h2{margin:0 0 1rem}
  @media(max-width:768px){
    .bs-grid{grid-template-columns:repeat(auto-fill,minmax(150px,1fr))}
    .bs-stats{flex-direction:column;gap:.5rem}
  }
</style>
