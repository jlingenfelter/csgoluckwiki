---
import Base from '../../layouts/Base.astro';
import ExploreMore from '../../components/ExploreMore.astro';
import { SKINS, RARITY_COLORS, getLowestPrice, getHighestPrice, getUniqueCategories, getWeaponsInCategory, SKINS_TOTAL } from '../../lib/skins';
import { breadcrumbSchema, faqSchema } from '../../lib/weapons';
import { skinCardImage } from '../../lib/imageOptimize';

const title = 'CS2 Skin Finder — Search & Filter All Skins | CSDB.gg';
const description = `Find the perfect CS2 skin. Filter ${SKINS_TOTAL} skins by weapon, rarity, price range, wear condition, StatTrak availability, and more.`;

const weaponGroups = [
  { cat: 'rifle', label: 'Rifles', weapons: getWeaponsInCategory('rifle') },
  { cat: 'pistol', label: 'Pistols', weapons: getWeaponsInCategory('pistol') },
  { cat: 'smg', label: 'SMGs', weapons: getWeaponsInCategory('smg') },
  { cat: 'heavy', label: 'Heavy', weapons: getWeaponsInCategory('heavy') },
  { cat: 'knife', label: 'Knives', weapons: getWeaponsInCategory('knife') },
  { cat: 'glove', label: 'Gloves', weapons: getWeaponsInCategory('glove') },
].filter(g => g.weapons.length > 0);

const rarities = Object.keys(RARITY_COLORS);

// Prepare lightweight skin data for client-side filtering
const skinData = SKINS.filter(s => !s.phase).map(s => ({
  s: s.slug,
  n: `${s.weapon} | ${s.name}`,
  w: s.weaponSlug,
  c: s.category,
  r: s.rarity,
  st: s.statTrak,
  sv: s.souvenir,
  p: getLowestPrice(s),
  ph: getHighestPrice(s),
  i: s.image ? skinCardImage(s.image) : '',
  rc: RARITY_COLORS[s.rarity] || '#444',
}));

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Skins', url: '/skins/' },
  { name: 'Skin Finder', url: '/skins/finder/' },
];

const faqs = [
  { question: 'How do I find the perfect CS2 skin?', answer: 'Use our Skin Finder to filter skins by weapon type, rarity tier, price range, and wear condition. You can narrow results to find skins that match your budget and style preferences.' },
  { question: 'What is the cheapest CS2 skin?', answer: 'Many Consumer and Industrial grade skins are available for under $0.10. Use the price filter to find skins within any budget range.' },
  { question: 'Can I filter CS2 skins by StatTrak?', answer: 'Yes! Toggle the StatTrak filter to show only skins that have StatTrak variants available, which track your kills in-game.' },
];
---

<Base title={title} description={description} currentNav="/skins/">
<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema(breadcrumbs))} />
<script type="application/ld+json" set:html={JSON.stringify(faqSchema(faqs))} />

<nav class="breadcrumb">
  <a href="/">Home</a> / <a href="/skins/">Skins</a> / <span>Skin Finder</span>
</nav>

<div class="sf-header">
  <h1>CS2 Skin Finder</h1>
  <p>Search and filter {SKINS_TOTAL} CS2 skins to find the perfect one for your loadout.</p>
</div>

<div class="sf-layout">
  <aside class="sf-filters">
    <div class="sf-filter-group">
      <label class="sf-label">Search</label>
      <input type="text" id="sf-search" class="sf-input" placeholder="Search by name..." />
    </div>

    <div class="sf-filter-group">
      <label class="sf-label">Category</label>
      <select id="sf-category" class="sf-select">
        <option value="">All Categories</option>
        {weaponGroups.map(g => (
          <option value={g.cat}>{g.label}</option>
        ))}
      </select>
    </div>

    <div class="sf-filter-group">
      <label class="sf-label">Weapon</label>
      <select id="sf-weapon" class="sf-select">
        <option value="">All Weapons</option>
        {weaponGroups.map(g => (
          <optgroup label={g.label}>
            {g.weapons.map(w => (
              <option value={w.weaponSlug}>{w.weapon} ({w.count})</option>
            ))}
          </optgroup>
        ))}
      </select>
    </div>

    <div class="sf-filter-group">
      <label class="sf-label">Rarity</label>
      <div class="sf-rarity-grid">
        {rarities.map(r => (
          <label class="sf-rarity-chip" style={`border-color:${RARITY_COLORS[r]}`}>
            <input type="checkbox" value={r} class="sf-rarity-cb" />
            <span style={`color:${RARITY_COLORS[r]}`}>{r}</span>
          </label>
        ))}
      </div>
    </div>

    <div class="sf-filter-group">
      <label class="sf-label">Price Range (USD)</label>
      <div class="sf-price-row">
        <input type="number" id="sf-price-min" class="sf-input sf-price-input" placeholder="Min" min="0" step="0.01" />
        <span>—</span>
        <input type="number" id="sf-price-max" class="sf-input sf-price-input" placeholder="Max" min="0" step="0.01" />
      </div>
    </div>

    <div class="sf-filter-group">
      <label class="sf-toggle-row">
        <input type="checkbox" id="sf-stattrak" />
        <span>StatTrak Only</span>
      </label>
      <label class="sf-toggle-row">
        <input type="checkbox" id="sf-souvenir" />
        <span>Souvenir Only</span>
      </label>
    </div>

    <div class="sf-filter-group">
      <label class="sf-label">Sort By</label>
      <select id="sf-sort" class="sf-select">
        <option value="price-asc">Price: Low → High</option>
        <option value="price-desc">Price: High → Low</option>
        <option value="name-asc">Name: A → Z</option>
        <option value="name-desc">Name: Z → A</option>
      </select>
    </div>

    <button id="sf-reset" class="sf-reset-btn">Reset Filters</button>
  </aside>

  <div class="sf-results">
    <div class="sf-results-header">
      <span id="sf-count">0</span> skins found
    </div>
    <div id="sf-grid" class="sf-grid"></div>
    <button id="sf-load-more" class="sf-load-more" style="display:none">Load More</button>
  </div>
</div>

<section class="sf-faq">
  <h2>Frequently Asked Questions</h2>
  <dl class="faq">
    {faqs.map(f => (
      <Fragment>
        <dt>{f.question}</dt>
        <dd>{f.answer}</dd>
      </Fragment>
    ))}
  </dl>
</section>

<ExploreMore context="skins" />
</Base>

<script define:vars={{ skinData }}>
const SKINS = skinData;
const PAGE_SIZE = 48;
let filtered = [];
let showing = 0;

const grid = document.getElementById('sf-grid');
const countEl = document.getElementById('sf-count');
const loadMore = document.getElementById('sf-load-more');
const searchInput = document.getElementById('sf-search');
const catSelect = document.getElementById('sf-category');
const weaponSelect = document.getElementById('sf-weapon');
const rarityCbs = document.querySelectorAll('.sf-rarity-cb');
const priceMin = document.getElementById('sf-price-min');
const priceMax = document.getElementById('sf-price-max');
const stCheck = document.getElementById('sf-stattrak');
const svCheck = document.getElementById('sf-souvenir');
const sortSelect = document.getElementById('sf-sort');
const resetBtn = document.getElementById('sf-reset');

function applyFilters() {
  const q = searchInput.value.toLowerCase().trim();
  const cat = catSelect.value;
  const wpn = weaponSelect.value;
  const checkedRarities = [...rarityCbs].filter(c => c.checked).map(c => c.value);
  const pMin = parseFloat(priceMin.value) || 0;
  const pMax = parseFloat(priceMax.value) || Infinity;
  const stOnly = stCheck.checked;
  const svOnly = svCheck.checked;

  filtered = SKINS.filter(s => {
    if (q && !s.n.toLowerCase().includes(q)) return false;
    if (cat && s.c !== cat) return false;
    if (wpn && s.w !== wpn) return false;
    if (checkedRarities.length > 0 && !checkedRarities.includes(s.r)) return false;
    if (s.p < pMin || s.p > pMax) return false;
    if (stOnly && !s.st) return false;
    if (svOnly && !s.sv) return false;
    return true;
  });

  const sort = sortSelect.value;
  if (sort === 'price-asc') filtered.sort((a, b) => a.p - b.p);
  else if (sort === 'price-desc') filtered.sort((a, b) => b.p - a.p);
  else if (sort === 'name-asc') filtered.sort((a, b) => a.n.localeCompare(b.n));
  else if (sort === 'name-desc') filtered.sort((a, b) => b.n.localeCompare(a.n));

  showing = 0;
  grid.innerHTML = '';
  countEl.textContent = filtered.length;
  renderMore();
}

function renderMore() {
  const batch = filtered.slice(showing, showing + PAGE_SIZE);
  for (const s of batch) {
    const card = document.createElement('a');
    card.href = `/skin/${s.s}/`;
    card.className = 'sf-card';
    card.style.borderColor = s.rc;
    card.innerHTML = `
      ${s.i ? `<img src="${s.i}" alt="${s.n}" width="160" height="120" loading="lazy" class="sf-card-img" />` : '<div class="sf-card-img sf-card-placeholder"></div>'}
      <strong>${s.n}</strong>
      <span class="sf-card-rarity" style="color:${s.rc}">${s.r}</span>
      ${s.p > 0 ? `<span class="sf-card-price">From $${s.p.toFixed(2)}</span>` : '<span class="sf-card-price">No price data</span>'}
    `;
    grid.appendChild(card);
  }
  showing += batch.length;
  loadMore.style.display = showing < filtered.length ? '' : 'none';
}

// Sync category → weapon filter
catSelect.addEventListener('change', () => {
  const cat = catSelect.value;
  const opts = weaponSelect.querySelectorAll('optgroup, option[value]');
  if (!cat) {
    opts.forEach(o => o.style.display = '');
  } else {
    weaponSelect.querySelectorAll('optgroup').forEach(g => {
      g.style.display = g.label.toLowerCase().includes(cat) ? '' : 'none';
    });
  }
  weaponSelect.value = '';
  applyFilters();
});

[searchInput, weaponSelect, sortSelect].forEach(el => el.addEventListener('input', applyFilters));
[stCheck, svCheck].forEach(el => el.addEventListener('change', applyFilters));
rarityCbs.forEach(cb => cb.addEventListener('change', applyFilters));
[priceMin, priceMax].forEach(el => el.addEventListener('change', applyFilters));
loadMore.addEventListener('click', renderMore);

resetBtn.addEventListener('click', () => {
  searchInput.value = '';
  catSelect.value = '';
  weaponSelect.value = '';
  rarityCbs.forEach(cb => cb.checked = false);
  priceMin.value = '';
  priceMax.value = '';
  stCheck.checked = false;
  svCheck.checked = false;
  sortSelect.value = 'price-asc';
  applyFilters();
});

applyFilters();
</script>

<style>
  .sf-header{margin-bottom:2rem}
  .sf-header h1{margin:0 0 .5rem;font-size:2rem}
  .sf-header p{color:var(--text2);margin:0}
  .sf-layout{display:grid;grid-template-columns:260px 1fr;gap:1.5rem;margin-bottom:2rem}
  .sf-filters{background:var(--bg2);border:1px solid var(--border);border-radius:10px;padding:1.25rem;position:sticky;top:80px;max-height:calc(100vh - 100px);overflow-y:auto}
  .sf-filter-group{margin-bottom:1.25rem}
  .sf-label{display:block;font-size:.82rem;font-weight:700;color:var(--text2);text-transform:uppercase;letter-spacing:.03em;margin-bottom:.5rem}
  .sf-input,.sf-select{width:100%;background:var(--bg3);border:1px solid var(--border);border-radius:6px;padding:.5rem .75rem;color:var(--text);font-size:.85rem}
  .sf-select{cursor:pointer}
  .sf-price-row{display:flex;align-items:center;gap:.5rem}
  .sf-price-input{width:50%}
  .sf-rarity-grid{display:flex;flex-wrap:wrap;gap:.4rem}
  .sf-rarity-chip{display:flex;align-items:center;gap:.3rem;border:1px solid;border-radius:6px;padding:.25rem .5rem;font-size:.75rem;cursor:pointer;background:transparent;transition:background .2s}
  .sf-rarity-chip:has(input:checked){background:rgba(255,255,255,0.08)}
  .sf-rarity-chip input{display:none}
  .sf-toggle-row{display:flex;align-items:center;gap:.5rem;font-size:.85rem;cursor:pointer;margin-bottom:.4rem}
  .sf-reset-btn{width:100%;padding:.5rem;background:transparent;border:1px solid var(--border);border-radius:6px;color:var(--text2);font-size:.82rem;cursor:pointer;transition:border-color .2s}
  .sf-reset-btn:hover{border-color:var(--accent);color:var(--accent)}
  .sf-results-header{font-size:.9rem;color:var(--text2);margin-bottom:1rem}
  .sf-results-header span{font-weight:700;color:var(--accent)}
  .sf-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(170px,1fr));gap:.75rem}
  .sf-card{background:var(--bg2);border:1px solid var(--border);border-radius:10px;padding:.75rem;text-decoration:none;color:inherit;display:flex;flex-direction:column;align-items:center;text-align:center;transition:border-color .2s,transform .2s}
  .sf-card:hover{transform:translateY(-2px);border-color:var(--accent)}
  .sf-card-img{width:100%;max-width:160px;height:auto;object-fit:contain;margin-bottom:.5rem}
  .sf-card-placeholder{width:160px;height:120px;background:var(--bg3);border-radius:6px;margin-bottom:.5rem}
  .sf-card strong{font-size:.82rem;margin-bottom:.2rem}
  .sf-card-rarity{font-size:.7rem;font-weight:600}
  .sf-card-price{font-size:.82rem;color:var(--accent);font-weight:700;margin-top:.2rem}
  .sf-load-more{display:block;width:100%;padding:.75rem;margin-top:1rem;background:var(--bg2);border:1px solid var(--border);border-radius:8px;color:var(--accent);font-weight:600;cursor:pointer;transition:border-color .2s}
  .sf-load-more:hover{border-color:var(--accent)}
  .sf-faq{margin-bottom:2rem}
  .sf-faq h2{margin:0 0 1rem}
  @media(max-width:768px){
    .sf-layout{grid-template-columns:1fr}
    .sf-filters{position:static;max-height:none}
    .sf-grid{grid-template-columns:repeat(auto-fill,minmax(140px,1fr))}
  }
</style>
