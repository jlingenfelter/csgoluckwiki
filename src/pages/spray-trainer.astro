---
import Base from '../layouts/Base.astro';
import ExploreMore from '../components/ExploreMore.astro';
import { breadcrumbSchema, faqSchema, toolAppSchema } from '../lib/weapons';

const title = 'CS2 Spray Pattern Trainer — Practice Recoil Control | CSGOLuck Wiki';
const description = 'Interactive spray pattern trainer for Counter-Strike 2. Learn and practice recoil control for AK-47, M4A4, M4A1-S, Galil AR, FAMAS, SG 553, and AUG. Master your spray patterns with real-time feedback and difficulty settings.';

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Tools', url: '/cs2-tools/' },
  { name: 'Spray Trainer', url: '/spray-trainer/' },
];

const faqData = [
  { q: 'How long does it take to master spray patterns?', a: 'Most players need 50-100 hours of dedicated practice to develop solid spray control. Muscle memory takes time to develop, but consistent practice shows results within weeks.' },
  { q: 'Should I practice on all weapons or just the AK-47?', a: 'Start with the AK-47 if you play T-side, or M4A4 if you play CT-side. Once you master one, learning other weapons is easier since the fundamentals transfer.' },
  { q: 'Is spray control or single-tap accuracy more important?', a: 'Single-tap accuracy at long range is more important than spraying. Learn to tap first, spray second. Spraying is primarily for close-to-mid range fights.' },
  { q: 'Why is the AK-47 spray so hard?', a: 'The AK-47 spray is unpredictable because it moves left and right inconsistently. This by design — it\'s harder to learn but rewards consistent practice.' },
  { q: 'Can I use a spray pattern crosshair code to help?', a: 'Yes! Many players use spray pattern crosshair codes that overlay the pattern. However, relying too much on visual aids can slow down learning. Balance visual learning with pattern practice.' },
  { q: 'What is counter-strafing and why is it important?', a: 'Counter-strafing is pressing the opposite movement key to stop moving. It resets your velocity quickly, allowing you to take accurate shots without waiting. Essential for peeking angles.' },
  { q: 'Should I spray or burst fire at range?', a: 'At range, single-tap and short bursts are more accurate than spraying. Reserve full sprays for close-to-mid range where you\'re confident in your pattern.' },
  { q: 'How do I know if I\'m improving?', a: 'Track your accuracy percentage and score over time. Improving accuracy and hitting more targets consistently indicates better spray control. Recording demos and reviewing them helps identify weak areas.' },
];
---

<Base title={title} description={description} currentNav="/cs2-weapons/">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema(breadcrumbs))} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema(faqData))} />
    <script type="application/ld+json" set:html={JSON.stringify(toolAppSchema({ name: 'CS2 Spray Pattern Trainer', url: 'https://wiki.csgoluck.com/spray-trainer/', description }))} />
  </Fragment>

  <nav class="breadcrumb"><a href="/">Home</a> <span>/</span> <a href="/cs2-tools/">Tools</a> <span>/</span> <span>Spray Trainer</span></nav>

  <div class="spt-hero">
    <h1 class="spt-title">CS2 Spray Pattern Trainer</h1>
    <p class="spt-desc">Master recoil control by practicing <a href="/cs2-weapons/" style="color:var(--accent)">weapon</a> spray patterns. Study the <a href="/recoil-patterns/" style="color:var(--accent)">recoil pattern charts</a> first, then click to match targets perfectly.</p>
  </div>

  <div class="spt-layout">
    <div class="spt-controls">
      <div class="spt-field">
        <label class="spt-label" for="weapon-select">Select Weapon</label>
        <select id="weapon-select" class="spt-select">
          <option value="ak-47">AK-47 (T-Side)</option>
          <option value="m4a4">M4A4 (CT-Side)</option>
          <option value="m4a1-s">M4A1-S (CT-Side)</option>
          <option value="galil-ar">Galil AR (T-Side)</option>
          <option value="famas">FAMAS (CT-Side)</option>
          <option value="sg-553">SG 553 (T-Side)</option>
          <option value="aug">AUG (CT-Side)</option>
        </select>
      </div>
      <div class="spt-field">
        <label class="spt-label" for="mode-select">Mode</label>
        <select id="mode-select" class="spt-select">
          <option value="practice">Practice Mode (Track Targets)</option>
          <option value="learn">Learn Mode (Show Pattern)</option>
        </select>
      </div>
      <div class="spt-field">
        <label class="spt-label" for="speed-select">Difficulty</label>
        <select id="speed-select" class="spt-select">
          <option value="slow">Slow (50% speed)</option>
          <option value="medium" selected>Medium (100% speed)</option>
          <option value="fast">Fast (150% speed)</option>
        </select>
      </div>
      <div class="spt-field spt-field-row">
        <input type="checkbox" id="show-pattern" class="spt-checkbox">
        <label class="spt-label" for="show-pattern">Show Ideal Pattern Overlay</label>
      </div>
      <button id="start-btn" class="spt-start-btn">Start Practice</button>
      <button id="reset-btn" class="spt-reset-btn">Reset Stats</button>
    </div>

    <div class="spt-canvas-wrap">
      <canvas id="spray-canvas" width="600" height="400"></canvas>
      <div class="spt-canvas-hint" id="canvas-hint">Click on targets following the spray pattern</div>
    </div>
  </div>

  <div class="spt-stats">
    <div class="spt-stat">
      <span class="spt-stat-label">Accuracy</span>
      <span class="spt-stat-value" id="stat-accuracy">0%</span>
    </div>
    <div class="spt-stat">
      <span class="spt-stat-label">Score</span>
      <span class="spt-stat-value" id="stat-score">0</span>
    </div>
    <div class="spt-stat">
      <span class="spt-stat-label">Hits</span>
      <span class="spt-stat-value" id="stat-hits">0/0</span>
    </div>
    <div class="spt-stat">
      <span class="spt-stat-label">Elapsed Time</span>
      <span class="spt-stat-value" id="stat-time">0s</span>
    </div>
  </div>

  <div class="spt-two-col">
    <div class="spt-info-block">
      <h2 class="spt-section-title">Spray Control Tips</h2>
      <ul class="spt-tip-list">
        <li><strong>Learn First 10 Bullets:</strong> The first 10 bullets of any spray are the most important. Master these before attempting full sprays.</li>
        <li><strong>Pull Down Initially:</strong> Most weapons require pulling your crosshair down initially.</li>
        <li><strong>Muscle Memory:</strong> Practice the same weapon repeatedly until the spray pattern becomes muscle memory.</li>
        <li><strong>Distance Matters:</strong> Spray patterns behave differently at different ranges.</li>
        <li><strong>Counter-Strafe for Accuracy:</strong> Stop moving briefly before spraying for better accuracy.</li>
        <li><strong>Spray Transfers:</strong> Practice moving your spray from one target to another smoothly.</li>
        <li><strong>Short Bursts:</strong> 3-4 bullet bursts are more efficient than full sprays at range.</li>
        <li><strong>One-Tap at Range:</strong> Take time between shots rather than spraying at long distance.</li>
      </ul>
    </div>

    <div class="spt-info-block">
      <h2 class="spt-section-title">Weapon Spray Details</h2>
      <div class="spt-weapon-list">
        <div class="spt-weapon-item">
          <h4 class="spt-weapon-name">AK-47 (T-Side)</h4>
          <p class="spt-weapon-meta">Hard | 36 DMG | 600 RPM</p>
          <p class="spt-weapon-desc">Iconic T-side rifle with high damage but challenging recoil. Spray goes up, then left, then right in an inverted-T shape.</p>
        </div>
        <div class="spt-weapon-item">
          <h4 class="spt-weapon-name">M4A4 (CT-Side)</h4>
          <p class="spt-weapon-meta">Medium | 33 DMG | 666 RPM | 30 rounds</p>
          <p class="spt-weapon-desc">Standard CT rifle with a more forgiving and tighter spray pattern than the AK-47.</p>
        </div>
        <div class="spt-weapon-item">
          <h4 class="spt-weapon-name">M4A1-S (CT-Side)</h4>
          <p class="spt-weapon-meta">Medium | 38 DMG | 600 RPM | 20 rounds</p>
          <p class="spt-weapon-desc">Silenced alternative. Lower fire rate makes spray slightly easier but only 20 rounds demands precision.</p>
        </div>
      </div>
    </div>
  </div>

  <section class="spt-faq">
    <h2 class="spt-section-title">Frequently Asked Questions</h2>
    {faqData.map(item => (
      <details class="spt-faq-item">
        <summary class="spt-faq-q">{item.q}</summary>
        <p class="spt-faq-a">{item.a}</p>
      </details>
    ))}
  </section>

  <div class="spt-info-block" style="margin-bottom:2rem">
    <h2 class="spt-section-title">Related Tools</h2>
    <div class="spt-link-list">
      <a href="/recoil-patterns/" class="spt-link">Recoil Pattern Charts</a>
      <a href="/damage-calculator/" class="spt-link">Damage Calculator</a>
      <a href="/cs2-weapons/" class="spt-link">Weapon Database</a>
      <a href="/weapon-compare/" class="spt-link">Compare Weapons</a>
      <a href="/sensitivity-converter/" class="spt-link">Sensitivity Converter</a>
      <a href="/crosshair-generator/" class="spt-link">Crosshair Generator</a>
      <a href="/pro-players/" class="spt-link">Pro Player Settings</a>
      <a href="/cs2-tools/" class="spt-link">All Tools</a>
      <a href="/cs2-guides/advanced-mechanics-guide/" class="spt-link">Advanced Mechanics Guide</a>
      <a href="/edpi-calculator/" class="spt-link">eDPI Calculator</a>
      <a href="/economy-calculator/" class="spt-link">Economy Calculator</a>
      <a href="/cs2-maps/" class="spt-link">Map Database</a>
      <a href="/cs2-guides/beginners-guide/" class="spt-link">Beginner's Guide</a>
    </div>
  </div>

  <ExploreMore context="tools" />
</Base>

<style>
  .spt-hero{padding:1.5rem 0;margin-bottom:1.5rem}
  .spt-title{font-size:2rem;font-weight:800;margin:0 0 .5rem;color:var(--text)}
  .spt-desc{color:var(--text2);font-size:.95rem;margin:0;max-width:600px;line-height:1.6}

  .spt-layout{display:grid;grid-template-columns:260px minmax(0,1fr);gap:1.5rem;margin-bottom:1.5rem}
  .spt-controls{background:var(--bg2);border:1px solid var(--border);border-radius:4px;padding:1.25rem;display:flex;flex-direction:column;gap:.75rem}
  .spt-field{display:flex;flex-direction:column;gap:.35rem}
  .spt-field-row{flex-direction:row;align-items:center;gap:.6rem}
  .spt-label{font-weight:600;color:var(--text2);font-size:.82rem;text-transform:uppercase;letter-spacing:.04em}
  .spt-select{background:var(--bg3);color:var(--text);border:1px solid var(--border);padding:.5rem .6rem;border-radius:4px;font-size:.88rem;font-family:inherit}
  .spt-select:focus{outline:none;border-color:var(--accent)}
  .spt-checkbox{width:18px;height:18px;accent-color:var(--accent)}

  .spt-start-btn{padding:.65rem 1rem;background:var(--accent);color:#000;border:none;border-radius:4px;font-weight:700;cursor:pointer;font-size:.9rem;font-family:inherit;transition:opacity .15s}
  .spt-start-btn:hover{opacity:.9}
  .spt-start-btn.spt-active{background:#ef5350}
  .spt-reset-btn{padding:.55rem 1rem;background:var(--bg3);border:1px solid var(--border);color:var(--text2);border-radius:4px;font-size:.85rem;cursor:pointer;font-family:inherit;transition:all .15s}
  .spt-reset-btn:hover{border-color:var(--accent);color:var(--text)}

  .spt-canvas-wrap{position:relative;background:var(--bg);border:2px solid var(--border);border-radius:4px;overflow:hidden}
  .spt-canvas-wrap canvas{display:block;width:100%;max-width:600px;background:linear-gradient(135deg,#0a0a0e 0%,#12121a 100%)}
  .spt-canvas-hint{position:absolute;bottom:8px;left:8px;font-size:.82rem;color:var(--text2);background:rgba(0,0,0,.7);padding:.4rem .75rem;border-radius:4px}

  .spt-stats{display:grid;grid-template-columns:repeat(4,1fr);gap:.75rem;margin-bottom:2rem}
  .spt-stat{background:var(--bg2);border:1px solid var(--border);border-radius:4px;padding:.85rem;text-align:center}
  .spt-stat-label{display:block;font-size:.78rem;color:var(--text2);font-weight:600;text-transform:uppercase;letter-spacing:.04em;margin-bottom:.35rem}
  .spt-stat-value{display:block;font-size:1.6rem;font-weight:800;color:var(--accent)}

  .spt-two-col{display:grid;grid-template-columns:1fr 1fr;gap:1.5rem;margin-bottom:2rem}
  .spt-info-block{background:var(--bg2);border:1px solid var(--border);border-radius:4px;padding:1.5rem}
  .spt-section-title{font-size:1.1rem;font-weight:700;color:var(--text);margin:0 0 1rem}

  .spt-tip-list{list-style:none;padding:0;margin:0}
  .spt-tip-list li{padding:.55rem 0;border-bottom:1px solid var(--border);color:var(--text2);font-size:.85rem;line-height:1.5}
  .spt-tip-list li:last-child{border-bottom:none}
  .spt-tip-list strong{color:var(--text)}

  .spt-weapon-list{display:flex;flex-direction:column;gap:.6rem}
  .spt-weapon-item{background:var(--bg3);border:1px solid var(--border);border-left:3px solid var(--accent);border-radius:4px;padding:1rem}
  .spt-weapon-name{color:var(--accent);font-size:.92rem;margin:0 0 .2rem}
  .spt-weapon-meta{color:var(--text2);font-size:.78rem;margin:0 0 .35rem;font-weight:600}
  .spt-weapon-desc{color:var(--text2);margin:0;font-size:.85rem;line-height:1.5}

  .spt-link-list{display:flex;flex-direction:column;gap:.4rem}
  .spt-link{display:block;padding:.5rem .75rem;background:var(--bg3);border:1px solid var(--border);border-left:3px solid transparent;border-radius:4px;color:var(--accent);text-decoration:none;font-size:.85rem;transition:border-left-color .15s}
  .spt-link:hover{border-left-color:var(--accent)}

  .spt-faq{margin-bottom:2rem}
  .spt-faq-item{background:var(--bg2);border:1px solid var(--border);border-radius:4px;margin-bottom:.5rem;overflow:hidden}
  .spt-faq-q{padding:.8rem 1rem;cursor:pointer;font-weight:600;font-size:.9rem;color:var(--text);list-style:none;display:flex;align-items:center;justify-content:space-between}
  .spt-faq-q::-webkit-details-marker{display:none}
  .spt-faq-q::after{content:'+';font-size:1.1rem;color:var(--accent);font-weight:700}
  .spt-faq-item[open] .spt-faq-q::after{content:'-'}
  .spt-faq-item[open]{border-left:3px solid var(--accent)}
  .spt-faq-a{padding:0 1rem .8rem;margin:0;font-size:.88rem;color:var(--text2);line-height:1.6}

  @media(max-width:968px){
    .spt-layout{grid-template-columns:1fr}
    .spt-controls{order:2}
    .spt-canvas-wrap{order:1}
    .spt-two-col{grid-template-columns:1fr}
  }
  @media(max-width:600px){
    .spt-stats{grid-template-columns:repeat(2,1fr)}
  }
</style>

<script is:inline>
  class SprayTrainer {
    constructor() {
      this.canvas = document.getElementById('spray-canvas');
      this.ctx = this.canvas.getContext('2d');
      this.isRunning = false;
      this.mode = 'practice';
      this.currentWeapon = 'ak-47';
      this.difficulty = 'medium';
      this.showPattern = false;
      this.sprayPatterns = {
        'ak-47': [
          {x:300,y:150},{x:300,y:170},{x:299,y:190},{x:298,y:210},
          {x:297,y:230},{x:290,y:250},{x:280,y:265},{x:270,y:275},
          {x:260,y:282},{x:250,y:285},{x:240,y:283},{x:230,y:278},
          {x:225,y:270},{x:223,y:260},{x:225,y:250},{x:230,y:242},
          {x:240,y:238},{x:255,y:235},{x:270,y:237},{x:285,y:242},
          {x:300,y:250},{x:315,y:258},{x:330,y:262},{x:345,y:260},
          {x:355,y:255},{x:360,y:248},{x:358,y:240},{x:350,y:235},
          {x:340,y:232},{x:328,y:234}
        ],
        'm4a4': [
          {x:300,y:150},{x:300,y:170},{x:300,y:190},{x:300,y:210},
          {x:300,y:230},{x:300,y:250},{x:298,y:270},{x:295,y:285},
          {x:292,y:298},{x:290,y:305},{x:292,y:310},{x:295,y:312},
          {x:300,y:310},{x:305,y:305},{x:310,y:298},{x:312,y:290},
          {x:310,y:282},{x:305,y:276},{x:298,y:272},{x:290,y:270},
          {x:283,y:272},{x:278,y:278},{x:275,y:286},{x:274,y:294},
          {x:276,y:302},{x:280,y:308},{x:286,y:312},{x:294,y:314},
          {x:302,y:312},{x:308,y:308}
        ],
        'm4a1-s': [
          {x:300,y:150},{x:300,y:170},{x:300,y:190},{x:300,y:210},
          {x:300,y:230},{x:299,y:250},{x:298,y:268},{x:296,y:282},
          {x:294,y:292},{x:292,y:298},{x:294,y:302},{x:298,y:300},
          {x:304,y:295},{x:308,y:288},{x:310,y:280},{x:308,y:274},
          {x:304,y:270},{x:298,y:268},{x:292,y:270},{x:288,y:275}
        ],
        'galil-ar': [
          {x:300,y:150},{x:300,y:170},{x:300,y:190},{x:299,y:210},
          {x:298,y:230},{x:297,y:250},{x:295,y:268},{x:293,y:283},
          {x:291,y:295},{x:289,y:303},{x:291,y:310},{x:295,y:312},
          {x:300,y:310},{x:305,y:305},{x:310,y:298},{x:312,y:290},
          {x:310,y:283},{x:306,y:278},{x:300,y:276},{x:294,y:278},
          {x:290,y:283},{x:288,y:290},{x:288,y:298},{x:290,y:305},
          {x:294,y:310},{x:300,y:312},{x:306,y:310},{x:310,y:305},
          {x:312,y:298},{x:310,y:292},{x:306,y:288},{x:300,y:286},
          {x:294,y:288},{x:290,y:292},{x:288,y:298}
        ],
        'famas': [
          {x:300,y:150},{x:300,y:170},{x:300,y:190},{x:299,y:210},
          {x:297,y:230},{x:295,y:250},{x:290,y:268},{x:285,y:283},
          {x:280,y:295},{x:280,y:305},{x:285,y:310},{x:292,y:310},
          {x:300,y:308},{x:308,y:304},{x:314,y:298},{x:316,y:290},
          {x:314,y:282},{x:308,y:276},{x:300,y:274},{x:292,y:276},
          {x:286,y:282},{x:284,y:290},{x:286,y:298},{x:292,y:304},
          {x:300,y:306}
        ],
        'sg-553': [
          {x:300,y:150},{x:298,y:170},{x:296,y:190},{x:294,y:210},
          {x:292,y:230},{x:290,y:250},{x:288,y:268},{x:286,y:283},
          {x:284,y:295},{x:282,y:305},{x:280,y:312},{x:282,y:315},
          {x:286,y:315},{x:292,y:312},{x:298,y:308},{x:304,y:302},
          {x:310,y:296},{x:314,y:290},{x:316,y:284},{x:314,y:278},
          {x:310,y:274},{x:304,y:272},{x:298,y:274},{x:292,y:278},
          {x:288,y:284},{x:286,y:292},{x:288,y:300},{x:292,y:306},
          {x:298,y:310},{x:304,y:310}
        ],
        'aug': [
          {x:300,y:150},{x:300,y:170},{x:300,y:190},{x:299,y:210},
          {x:298,y:230},{x:297,y:250},{x:296,y:268},{x:295,y:283},
          {x:294,y:295},{x:293,y:305},{x:295,y:312},{x:298,y:310},
          {x:302,y:305},{x:306,y:298},{x:308,y:290},{x:306,y:282},
          {x:302,y:276},{x:296,y:274},{x:290,y:276},{x:286,y:282},
          {x:284,y:290},{x:286,y:298},{x:290,y:304},{x:296,y:308},
          {x:302,y:308},{x:306,y:304},{x:308,y:298},{x:306,y:292},
          {x:302,y:288},{x:298,y:288}
        ]
      };

      this.stats = {
        hits: 0,
        total: 0,
        score: 0,
        startTime: 0,
        accuracy: 0
      };

      this.speedMultipliers = { slow: 0.5, medium: 1, fast: 1.5 };
      this.targets = [];
      this.patternIndex = 0;
      this.animationFrameId = null;

      this.setupEventListeners();
    }

    setupEventListeners() {
      document.getElementById('start-btn').addEventListener('click', () => this.togglePractice());
      document.getElementById('reset-btn').addEventListener('click', () => this.resetStats());
      document.getElementById('weapon-select').addEventListener('change', (e) => {
        this.currentWeapon = e.target.value;
        this.patternIndex = 0;
        if (this.isRunning) { this.targets = []; }
      });
      document.getElementById('mode-select').addEventListener('change', (e) => this.mode = e.target.value);
      document.getElementById('speed-select').addEventListener('change', (e) => this.difficulty = e.target.value);
      document.getElementById('show-pattern').addEventListener('change', (e) => this.showPattern = e.target.checked);
      this.canvas.addEventListener('click', (e) => this.handleCanvasClick(e));

      this.resizeCanvas();
      window.addEventListener('resize', () => this.resizeCanvas());
    }

    resizeCanvas() {
      const container = this.canvas.parentElement;
      const w = Math.min(600, container.clientWidth);
      const h = Math.round(w * (400 / 600));
      this.canvas.width = 600;
      this.canvas.height = 400;
      this.canvas.style.width = w + 'px';
      this.canvas.style.height = h + 'px';
      this.scaleX = 600 / w;
      this.scaleY = 400 / h;
    }

    togglePractice() {
      this.isRunning = !this.isRunning;
      const btn = document.getElementById('start-btn');

      if (this.isRunning) {
        btn.textContent = 'Stop Practice';
        btn.classList.add('spt-active');
        this.stats.startTime = Date.now();
        this.patternIndex = 0;
        this.targets = [];
        this.animate();
      } else {
        btn.textContent = 'Start Practice';
        btn.classList.remove('spt-active');
        cancelAnimationFrame(this.animationFrameId);
      }
    }

    resetStats() {
      this.stats = {
        hits: 0,
        total: 0,
        score: 0,
        startTime: this.isRunning ? Date.now() : 0,
        accuracy: 0
      };
      this.patternIndex = 0;
      this.targets = [];
      this.updateStats();
    }

    animate() {
      this.draw();
      const speedMult = this.speedMultipliers[this.difficulty];
      const pattern = this.sprayPatterns[this.currentWeapon];

      if (this.mode === 'practice' && this.isRunning && this.patternIndex < pattern.length) {
        const targetPos = pattern[this.patternIndex];
        if (this.targets.length === 0 || this.targets[this.targets.length - 1].clicked) {
          this.targets.push({
            x: targetPos.x,
            y: targetPos.y,
            index: this.patternIndex,
            clicked: false,
            created: Date.now()
          });
          this.stats.total++;
        }

        const timeSinceCreation = (Date.now() - this.targets[this.targets.length - 1].created) / 1000;
        if (timeSinceCreation > (3 / speedMult)) {
          if (!this.targets[this.targets.length - 1].clicked) {
            this.patternIndex++;
          }
        }
      }

      if (this.mode === 'learn' && this.isRunning) {
        const pattern = this.sprayPatterns[this.currentWeapon];
        const currentStep = (Date.now() - this.stats.startTime) / 200 * speedMult;
        this.patternIndex = Math.min(Math.floor(currentStep), pattern.length - 1);
      }

      this.updateStats();
      this.animationFrameId = requestAnimationFrame(() => this.animate());
    }

    draw() {
      this.ctx.fillStyle = '#0e0e12';
      this.ctx.fillRect(0, 0, this.canvas.width, this.canvas.height);

      const pattern = this.sprayPatterns[this.currentWeapon];

      if (this.showPattern) {
        this.drawPatternOverlay(pattern);
      }

      if (this.mode === 'practice') {
        this.drawTargets();
      } else {
        this.drawLearnMode(pattern);
      }

      this.drawCrosshair();
    }

    drawPatternOverlay(pattern) {
      this.ctx.strokeStyle = 'rgba(46, 204, 113, 0.3)';
      this.ctx.lineWidth = 2;
      this.ctx.beginPath();

      for (let i = 0; i < pattern.length; i++) {
        if (i === 0) {
          this.ctx.moveTo(pattern[i].x, pattern[i].y);
        } else {
          this.ctx.lineTo(pattern[i].x, pattern[i].y);
        }
      }
      this.ctx.stroke();

      this.ctx.fillStyle = 'rgba(46, 204, 113, 0.2)';
      for (let i = 0; i < pattern.length; i++) {
        this.ctx.beginPath();
        this.ctx.arc(pattern[i].x, pattern[i].y, 4, 0, Math.PI * 2);
        this.ctx.fill();
      }
    }

    drawTargets() {
      for (const target of this.targets) {
        if (target.clicked) {
          this.ctx.fillStyle = '#4caf50';
          this.ctx.globalAlpha = 0.8;
        } else {
          this.ctx.fillStyle = '#ef5350';
          this.ctx.globalAlpha = 1;
        }

        this.ctx.beginPath();
        this.ctx.arc(target.x, target.y, 15, 0, Math.PI * 2);
        this.ctx.fill();

        this.ctx.globalAlpha = 1;
        this.ctx.strokeStyle = target.clicked ? '#4caf50' : '#ef5350';
        this.ctx.lineWidth = 2;
        this.ctx.beginPath();
        this.ctx.arc(target.x, target.y, 20, 0, Math.PI * 2);
        this.ctx.stroke();

        this.ctx.fillStyle = '#fff';
        this.ctx.font = 'bold 12px monospace';
        this.ctx.textAlign = 'center';
        this.ctx.textBaseline = 'middle';
        this.ctx.fillText(target.index + 1, target.x, target.y);
      }
    }

    drawLearnMode(pattern) {
      const activeIndex = this.patternIndex;

      this.ctx.strokeStyle = 'rgba(46, 204, 113, 0.5)';
      this.ctx.lineWidth = 2;
      this.ctx.beginPath();

      for (let i = 0; i <= activeIndex && i < pattern.length; i++) {
        if (i === 0) {
          this.ctx.moveTo(pattern[i].x, pattern[i].y);
        } else {
          this.ctx.lineTo(pattern[i].x, pattern[i].y);
        }
      }
      this.ctx.stroke();

      for (let i = 0; i <= activeIndex && i < pattern.length; i++) {
        if (i === activeIndex) {
          this.ctx.fillStyle = '#2ecc71';
        } else {
          this.ctx.fillStyle = 'rgba(46, 204, 113, 0.5)';
        }

        this.ctx.beginPath();
        this.ctx.arc(pattern[i].x, pattern[i].y, i === activeIndex ? 10 : 6, 0, Math.PI * 2);
        this.ctx.fill();
      }

      this.ctx.fillStyle = '#2ecc71';
      this.ctx.font = 'bold 14px monospace';
      this.ctx.textAlign = 'center';
      this.ctx.textBaseline = 'top';
      this.ctx.fillText(`Bullet ${activeIndex + 1}`, 50, 20);
    }

    drawCrosshair() {
      this.ctx.strokeStyle = '#42a5f5';
      this.ctx.lineWidth = 2;
      const cx = this.canvas.width / 2;
      const cy = this.canvas.height / 2;
      const size = 20;

      this.ctx.beginPath();
      this.ctx.moveTo(cx - size, cy);
      this.ctx.lineTo(cx + size, cy);
      this.ctx.stroke();

      this.ctx.beginPath();
      this.ctx.moveTo(cx, cy - size);
      this.ctx.lineTo(cx, cy + size);
      this.ctx.stroke();

      this.ctx.beginPath();
      this.ctx.arc(cx, cy, 4, 0, Math.PI * 2);
      this.ctx.strokeStyle = '#42a5f5';
      this.ctx.stroke();
    }

    handleCanvasClick(e) {
      if (!this.isRunning || this.mode !== 'practice') return;

      const rect = this.canvas.getBoundingClientRect();
      const x = (e.clientX - rect.left) * (this.scaleX || 1);
      const y = (e.clientY - rect.top) * (this.scaleY || 1);

      for (let i = this.targets.length - 1; i >= 0; i--) {
        const target = this.targets[i];
        if (target.clicked) continue;

        const dx = x - target.x;
        const dy = y - target.y;
        const dist = Math.sqrt(dx * dx + dy * dy);

        if (dist < 20) {
          target.clicked = true;
          this.stats.hits++;
          this.stats.score += Math.max(10, 50 - Math.floor(dist / 2));
          break;
        }
      }
    }

    updateStats() {
      const accuracy = this.stats.total > 0 ? Math.round((this.stats.hits / this.stats.total) * 100) : 0;
      const elapsed = this.isRunning ? Math.floor((Date.now() - this.stats.startTime) / 1000) : 0;

      document.getElementById('stat-accuracy').textContent = accuracy + '%';
      document.getElementById('stat-score').textContent = this.stats.score;
      document.getElementById('stat-hits').textContent = `${this.stats.hits}/${this.stats.total}`;
      document.getElementById('stat-time').textContent = elapsed + 's';
    }
  }

  document.addEventListener('DOMContentLoaded', () => {
    new SprayTrainer();
  });
</script>
