---
import Base from '../../layouts/Base.astro';
import ExploreMore from '../../components/ExploreMore.astro';
import { STICKERS, getStickerBySlug, getStickersByTournament, getStickersByTeam, getStickersByCollection, getStickersByType, getVariantColor, getVariantBg, VARIANT_COLORS } from '../../lib/stickers';
import { breadcrumbSchema, faqSchema } from '../../lib/weapons';

export function getStaticPaths() {
  return STICKERS.map(s => ({
    params: { slug: s.slug },
    props: { sticker: s },
  }));
}

const { sticker } = Astro.props;

// ── Variant styling ─────────────────────────────────────────────────────────
const variantColor = getVariantColor(sticker.variant);
const variantBg = getVariantBg(sticker.variant);

// ── Marketplace display names ───────────────────────────────────────────────
const MARKETPLACE_NAMES: Record<string, string> = {
  'buff163': 'Buff163',
  'buff163_buy': 'Buff163 Buy',
  'steam': 'Steam Market',
  'skinport': 'Skinport',
  'csmoney': 'CS.Money',
  'csmoney2': 'CS.Money 2.0',
  'dmarket': 'DMarket',
  'bitskins': 'BitSkins',
  'csfloat': 'CSFloat',
  'waxpeer': 'Waxpeer',
  'tradeit': 'Tradeit.gg',
  'skinbaron': 'SkinBaron',
  'gamerpay': 'GamerPay',
  'lootfarm': 'Loot.Farm',
  'shadowpay': 'ShadowPay',
  'skinswap': 'SkinSwap',
  'lis-skins': 'LIS-SKINS',
  'youpin': 'Youpin (UU)',
  'swap_gg': 'Swap.gg',
  'mannco': 'Mannco.store',
  'csdeals': 'CS.Deals',
  'c5game': 'C5Game',
  'igxe': 'IGXE',
  'haloskins': 'HaloSkins',
  'lootbear': 'LootBear',
  'skinbid': 'SkinBid',
};

const MARKETPLACE_DOMAINS: Record<string, string> = {
  'buff163': 'buff.163.com',
  'buff163_buy': 'buff.163.com',
  'steam': 'store.steampowered.com',
  'skinport': 'skinport.com',
  'csmoney': 'cs.money',
  'csmoney2': 'cs.money',
  'dmarket': 'dmarket.com',
  'bitskins': 'bitskins.com',
  'csfloat': 'csfloat.com',
  'waxpeer': 'waxpeer.com',
  'tradeit': 'tradeit.gg',
  'skinbaron': 'skinbaron.de',
  'gamerpay': 'gamerpay.gg',
  'lootfarm': 'loot.farm',
  'shadowpay': 'shadowpay.com',
  'skinswap': 'skinswap.com',
  'lis-skins': 'lis-skins.com',
  'youpin': 'youpin898.com',
  'swap_gg': 'swap.gg',
  'mannco': 'mannco.store',
  'csdeals': 'cs.deals',
  'c5game': 'c5game.com',
  'igxe': 'igxe.cn',
  'haloskins': 'haloskins.com',
  'lootbear': 'lootbear.com',
  'skinbid': 'skinbid.com',
};

function getMarketplaceName(key: string): string {
  return MARKETPLACE_NAMES[key] || key;
}

function getMarketplaceDomain(key: string): string {
  return MARKETPLACE_DOMAINS[key] || '';
}

// ── Blocked providers ───────────────────────────────────────────────────────
const BLOCKED_PROVIDERS = new Set(['csgoempire', 'csgoroll']);

// ── Provider prices, sorted cheapest-first ──────────────────────────────────
const providerEntries = sticker.providers
  ? Object.entries(sticker.providers)
      .filter(([k, v]) => v > 0 && !BLOCKED_PROVIDERS.has(k))
      .sort((a, b) => a[1] - b[1])
  : [];
const providerCount = providerEntries.length;
const bestPrice = providerEntries.length > 0 ? providerEntries[0][1] : (sticker.price > 0 ? sticker.price : 0);
const bestProvider = providerEntries.length > 0 ? providerEntries[0][0] : '';

// ── Deep-link URL builder ───────────────────────────────────────────────────
const searchTerm = `Sticker | ${sticker.name}`.replace(/\s+/g, '+');

function getMarketplaceUrl(key: string): string {
  switch (key) {
    case 'steam':
      return `https://steamcommunity.com/market/search?appid=730&q=${searchTerm}`;
    case 'skinport':
      return `https://skinport.com/market?search=${searchTerm}`;
    case 'csmoney':
    case 'csmoney2':
      return `https://cs.money/market/buy/?search=${searchTerm}`;
    case 'dmarket':
      return `https://dmarket.com/ingame-items/item-list/csgo-skins?title=${searchTerm}`;
    case 'tradeit':
      return `https://tradeit.gg/csgo/store?search=${searchTerm}`;
    case 'shadowpay':
      return `https://shadowpay.com/csgo-items?search=${searchTerm}`;
    case 'skinbaron':
      return `https://skinbaron.de/en/csgo?str=${searchTerm}`;
    case 'waxpeer':
      return `https://waxpeer.com/`;
    case 'buff163':
    case 'buff163_buy':
      return `https://buff.163.com/market/csgo#tab=selling&page_num=1&search=${searchTerm}`;
    case 'skinswap':
      return `https://skinswap.com/market/cs2?search=${searchTerm}`;
    case 'csfloat':
      return `https://csfloat.com/`;
    case 'bitskins':
      return `https://bitskins.com/market/cs2`;
    case 'gamerpay':
      return `https://gamerpay.gg/`;
    case 'lootfarm':
      return `https://loot.farm/`;
    default:
      return '#';
  }
}

// ── Related stickers ────────────────────────────────────────────────────────
let relatedStickers: typeof STICKERS = [];
let relatedLabel = '';

if (sticker.tournament) {
  relatedStickers = getStickersByTournament(sticker.tournament)
    .filter(s => s.slug !== sticker.slug)
    .slice(0, 12);
  relatedLabel = `More ${sticker.tournament} Stickers`;
} else if (sticker.team) {
  relatedStickers = getStickersByTeam(sticker.team)
    .filter(s => s.slug !== sticker.slug)
    .slice(0, 12);
  relatedLabel = `More ${sticker.team} Stickers`;
} else {
  // Community or other — show stickers from same collection or same type
  if (sticker.collection) {
    relatedStickers = getStickersByCollection(sticker.collection)
      .filter(s => s.slug !== sticker.slug)
      .slice(0, 12);
    relatedLabel = `More from ${sticker.collection}`;
  }
  if (relatedStickers.length === 0) {
    relatedStickers = getStickersByType(sticker.type)
      .filter(s => s.slug !== sticker.slug && s.price > 0)
      .slice(0, 12);
    relatedLabel = `More ${sticker.type === 'tournament' ? 'Tournament' : 'Community'} Stickers`;
  }
}

// ── SEO ─────────────────────────────────────────────────────────────────────
const priceDisplay = bestPrice > 0 ? `$${bestPrice.toFixed(2)}` : 'N/A';
const tournamentInfo = sticker.tournament ? ` From ${sticker.tournament}.` : '';
const title = `${sticker.name} Sticker — Price & Marketplace Data | CSDB.gg`;
const description = `Buy ${sticker.name} sticker. Compare prices across ${providerCount > 0 ? providerCount : 'multiple'} marketplaces. Current price: ${priceDisplay}.${tournamentInfo}`;

// ── Breadcrumbs ─────────────────────────────────────────────────────────────
const crumbs = [
  { name: 'Home', url: 'https://csdb.gg/' },
  { name: 'Skins', url: 'https://csdb.gg/skins/' },
  { name: 'Stickers', url: 'https://csdb.gg/stickers/' },
  { name: sticker.name, url: `https://csdb.gg/sticker/${sticker.slug}/` },
];

// ── Product Schema ──────────────────────────────────────────────────────────
const productSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Product",
  "name": `Sticker | ${sticker.name}`,
  "image": sticker.image || undefined,
  "description": `${sticker.name} is a ${sticker.variant} variant ${sticker.type} sticker in Counter-Strike 2.${sticker.tournament ? ` From ${sticker.tournament}.` : ''}${sticker.team ? ` ${sticker.team} team sticker.` : ''}`,
  "brand": { "@type": "Brand", "name": "Counter-Strike 2" },
  "category": "CS2 Stickers",
  "sku": sticker.slug,
  ...(bestPrice > 0 ? {
    "offers": {
      "@type": "Offer",
      "priceCurrency": "USD",
      "price": bestPrice.toFixed(2),
      "availability": "https://schema.org/InStock",
    },
  } : {}),
});

// ── FAQs ────────────────────────────────────────────────────────────────────
const faqs = [
  {
    q: `How much does the ${sticker.name} sticker cost?`,
    a: bestPrice > 0
      ? `The ${sticker.name} sticker is currently priced from ${priceDisplay} across ${providerCount > 0 ? providerCount : 'multiple'} marketplaces. Prices vary by marketplace, so compare above for the best deal.`
      : `The ${sticker.name} sticker pricing varies by marketplace. Check current listings on Buff163, Skinport, or Steam Market for up-to-date pricing.`,
  },
  {
    q: `What variant is the ${sticker.name} sticker?`,
    a: `The ${sticker.name} sticker is a ${sticker.variant} variant.${sticker.variant === 'Gold' ? ' Gold stickers are the rarest and most valuable variant.' : sticker.variant === 'Holo' ? ' Holo stickers have a holographic rainbow effect and are rarer than Paper.' : sticker.variant === 'Foil' ? ' Foil stickers have a metallic reflective finish.' : sticker.variant === 'Glitter' ? ' Glitter stickers have a sparkle effect and are quite rare.' : ' Paper stickers are the most common variant.'}`,
  },
  {
    q: `Where can I buy the ${sticker.name} sticker?`,
    a: bestProvider
      ? `The cheapest listing for the ${sticker.name} sticker is currently on ${getMarketplaceName(bestProvider)} at ${priceDisplay}. You can also compare prices on ${providerCount > 1 ? `${providerCount - 1} other marketplaces` : 'other marketplaces'} above.`
      : `You can buy the ${sticker.name} sticker on marketplaces like Buff163, Skinport, CS.Money, and Steam Market. Compare prices above to find the best deal.`,
  },
  {
    q: `Is the ${sticker.name} sticker a good investment?`,
    a: `${sticker.type === 'tournament' ? 'Tournament stickers can appreciate over time, especially after the associated operation ends.' : 'Community stickers can gain value as they become discontinued.'} The ${sticker.variant} variant ${sticker.variant === 'Gold' || sticker.variant === 'Holo' || sticker.variant === 'Foil' ? 'is a rarer variant which tends to hold value better' : 'is a common variant with more supply'}. Always research market trends before investing.`,
  },
];

// ── Market data helpers ─────────────────────────────────────────────────────
function formatNumber(n: number | null | undefined): string {
  if (n == null) return 'N/A';
  if (n >= 1000) return `${(n / 1000).toFixed(1)}k`;
  return n.toFixed(0);
}

function formatPrice(p: number): string {
  return p >= 1000 ? `$${p.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}` : `$${p.toFixed(2)}`;
}

function getLiquidityLabel(liq: number | null | undefined): { label: string; color: string } {
  if (liq == null) return { label: 'Unknown', color: 'var(--text2)' };
  if (liq >= 0.8) return { label: 'Very High', color: '#4caf50' };
  if (liq >= 0.5) return { label: 'High', color: '#8bc34a' };
  if (liq >= 0.2) return { label: 'Medium', color: '#ff9800' };
  return { label: 'Low', color: '#f44336' };
}

const liquidity = getLiquidityLabel(sticker.liquidity);
const hasMarketData = sticker.liquidity != null || sticker.volume7d != null || sticker.trades7d != null || sticker.listingCount != null;
---

<Base title={title} description={description} currentNav="/skins/" ogImage={sticker.image || undefined}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema(crumbs))} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema(faqs))} />
    <script type="application/ld+json" set:html={productSchema} />
  </Fragment>

  <!-- Breadcrumbs -->
  <nav class="breadcrumb">
    <a href="/">Home</a> <span class="sep">&rsaquo;</span>
    <a href="/skins/">Skins</a> <span class="sep">&rsaquo;</span>
    <a href="/stickers/">Stickers</a> <span class="sep">&rsaquo;</span>
    <span>{sticker.name}</span>
  </nav>

  <!-- Page Header -->
  <div class="sticker-header">
    <h1>{sticker.name}</h1>
    {providerCount > 0 && <span class="offer-count">{providerCount} marketplace{providerCount !== 1 ? 's' : ''}</span>}
  </div>

  <!-- Two-column layout -->
  <div class="sticker-page-grid">
    <!-- LEFT COLUMN: Image + Info -->
    <div class="sticker-left-col">
      <!-- Image Box -->
      <div class="sticker-image-box">
        {sticker.image ? (
          <img
            src={sticker.image}
            alt={`${sticker.name} Sticker`}
            class="sticker-detail-img"
            width="300"
            height="300"
            loading="eager"
          />
        ) : (
          <div class="sticker-placeholder">
            <span>No Image</span>
          </div>
        )}
        <span class="variant-badge" style={`background:${variantBg};color:${variantColor};border-color:${variantColor}`}>
          {sticker.variant}
        </span>
      </div>

      <!-- Sticker Info Card -->
      <div class="info-card">
        <h2>Sticker Details</h2>
        <div class="detail-list">
          <div class="detail-row">
            <span class="detail-label">Type</span>
            <span class="detail-value">{sticker.type === 'tournament' ? 'Tournament' : 'Community'}</span>
          </div>
          <div class="detail-row">
            <span class="detail-label">Variant</span>
            <span class="detail-value" style={`color:${variantColor}`}>{sticker.variant}</span>
          </div>
          {sticker.tournament && (
            <div class="detail-row">
              <span class="detail-label">Tournament</span>
              <span class="detail-value">{sticker.tournament}</span>
            </div>
          )}
          {sticker.team && (
            <div class="detail-row">
              <span class="detail-label">Team</span>
              <span class="detail-value">{sticker.team}</span>
            </div>
          )}
          {sticker.collection && (
            <div class="detail-row">
              <span class="detail-label">Collection</span>
              <span class="detail-value">{sticker.collection}</span>
            </div>
          )}
          {sticker.rarity && (
            <div class="detail-row">
              <span class="detail-label">Rarity</span>
              <span class="detail-value">{sticker.rarity}</span>
            </div>
          )}
        </div>
      </div>

      <!-- Market Data Card -->
      {hasMarketData && (
        <div class="info-card">
          <h2>Market Data</h2>
          <div class="market-stats">
            {sticker.liquidity != null && (
              <div class="market-stat">
                <span class="market-stat-label">Liquidity</span>
                <span class="market-stat-value" style={`color:${liquidity.color}`}>{liquidity.label}</span>
              </div>
            )}
            {sticker.volume7d != null && (
              <div class="market-stat">
                <span class="market-stat-label">7-Day Volume</span>
                <span class="market-stat-value">{formatNumber(sticker.volume7d)}</span>
              </div>
            )}
            {sticker.trades7d != null && (
              <div class="market-stat">
                <span class="market-stat-label">7-Day Trades</span>
                <span class="market-stat-value">{formatNumber(sticker.trades7d)}</span>
              </div>
            )}
            {sticker.listingCount != null && (
              <div class="market-stat">
                <span class="market-stat-label">Active Listings</span>
                <span class="market-stat-value">{formatNumber(sticker.listingCount)}</span>
              </div>
            )}
          </div>
        </div>
      )}
    </div>

    <!-- RIGHT COLUMN: Price + Marketplaces -->
    <div class="sticker-right-col">
      <!-- Best Price Card -->
      <div class="best-price-card">
        <div class="best-price-header">
          <span class="best-price-label">Best Price</span>
          {bestProvider && <span class="best-price-source">on {getMarketplaceName(bestProvider)}</span>}
        </div>
        <div class="best-price-amount">
          {bestPrice > 0 ? formatPrice(bestPrice) : 'Price unavailable'}
        </div>
        {bestProvider && bestPrice > 0 && (
          <a href={getMarketplaceUrl(bestProvider)} target="_blank" rel="noopener noreferrer nofollow" class="buy-btn">
            Buy on {getMarketplaceName(bestProvider)} &rarr;
          </a>
        )}
      </div>

      <!-- Marketplace Comparison Table -->
      {providerEntries.length > 0 && (
        <div class="marketplace-section">
          <div class="mp-section-header">
            <h2>Compare Prices</h2>
            <span class="mp-count">{providerEntries.length} marketplace{providerEntries.length !== 1 ? 's' : ''}</span>
          </div>
          <div class="marketplace-table">
            {providerEntries.map(([pk, pv], idx) => {
              const mpName = getMarketplaceName(pk);
              const mpDomain = getMarketplaceDomain(pk);
              const cheapest = providerEntries[0][1];
              const diff = cheapest > 0 && idx > 0 ? Math.round((pv - cheapest) / cheapest * 100) : 0;
              return (
                <div class={`mp-row ${idx === 0 ? 'mp-row-best' : ''}`}>
                  <div class="mp-left">
                    <span class="mp-icon">
                      {mpDomain
                        ? <img src={`https://www.google.com/s2/favicons?domain=${mpDomain}&sz=32`} alt={mpName} loading="lazy" width="16" height="16" />
                        : <span class="mp-icon-text">{pk.substring(0, 2).toUpperCase()}</span>
                      }
                    </span>
                    <span class="mp-name">{mpName}</span>
                  </div>
                  <div class="mp-right">
                    <span class="mp-price">{formatPrice(pv)}</span>
                    {idx === 0 && <span class="mp-badge mp-badge-best">Best</span>}
                    {diff > 0 && <span class="mp-badge mp-badge-diff">+{diff}%</span>}
                    <a href={getMarketplaceUrl(pk)} target="_blank" rel="noopener noreferrer nofollow" class="mp-buy-link">Buy &rarr;</a>
                  </div>
                </div>
              );
            })}
          </div>
        </div>
      )}

      {providerEntries.length === 0 && (
        <div class="info-card">
          <p class="no-data-msg">No marketplace price data currently available. Check Buff163, Skinport, or Steam Market directly for current listings.</p>
        </div>
      )}
    </div>
  </div>

  <!-- Related Stickers -->
  {relatedStickers.length > 0 && (
    <section class="related-section">
      <h2>{relatedLabel}</h2>
      <div class="related-grid">
        {relatedStickers.map(rs => {
          const rsColor = getVariantColor(rs.variant);
          const rsBg = getVariantBg(rs.variant);
          return (
            <a href={`/sticker/${rs.slug}/`} class="related-card">
              <div class="related-img-wrap">
                {rs.image ? (
                  <img src={rs.image} alt={rs.name} loading="lazy" width="120" height="120" />
                ) : (
                  <div class="related-placeholder">?</div>
                )}
              </div>
              <span class="related-name">{rs.name}</span>
              <span class="related-variant" style={`color:${rsColor}`}>{rs.variant}</span>
              {rs.price > 0 && <span class="related-price">${rs.price.toFixed(2)}</span>}
            </a>
          );
        })}
      </div>
    </section>
  )}

  <!-- FAQ Section -->
  <section class="faq-section">
    <h2>Frequently Asked Questions</h2>
    <dl class="faq">
      {faqs.map((f, i) => (
        <>
          <dt class={i === 0 ? 'first' : ''}>{f.q}</dt>
          <dd>{f.a}</dd>
        </>
      ))}
    </dl>
  </section>

  <!-- Internal Links -->
  <section class="links-section">
    <h2>Related Resources</h2>
    <div class="internal-links">
      <a href="/stickers/">All Stickers</a>
      <a href="/skins/">Skin Database</a>
      <a href="/cases/">Cases & Collections</a>
      <a href="/trading-sites/">Trading Sites</a>
      <a href="/guides/skins-investing-guide/">Investing Guide</a>
      <a href="/price-tracker/">Price Tracker</a>
    </div>
  </section>

  <ExploreMore context="skins" />
</Base>

<style>
  /* ── Breadcrumbs ──────────────────────────────────────────────────────────── */
  .breadcrumb {
    font-size: 0.85rem;
    color: var(--text2);
    margin-bottom: 1.5rem;
  }
  .breadcrumb a {
    color: var(--accent);
    text-decoration: none;
  }
  .breadcrumb a:hover {
    text-decoration: underline;
  }
  .breadcrumb .sep {
    margin: 0 0.35rem;
    color: var(--text2);
  }

  /* ── Page Header ──────────────────────────────────────────────────────────── */
  .sticker-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 2rem;
    flex-wrap: wrap;
  }
  .sticker-header h1 {
    margin: 0;
    font-size: 1.8rem;
    line-height: 1.2;
  }
  .offer-count {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 20px;
    font-size: 0.8rem;
    color: var(--text2);
  }

  /* ── Two-Column Grid ──────────────────────────────────────────────────────── */
  .sticker-page-grid {
    display: grid;
    grid-template-columns: 380px 1fr;
    gap: 2rem;
    align-items: start;
    margin-bottom: 3rem;
  }

  /* ── Left Column ──────────────────────────────────────────────────────────── */
  .sticker-left-col {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  /* ── Image Box ────────────────────────────────────────────────────────────── */
  .sticker-image-box {
    position: relative;
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 300px;
  }
  .sticker-detail-img {
    max-width: 100%;
    height: auto;
    max-height: 300px;
    object-fit: contain;
  }
  .sticker-placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 200px;
    height: 200px;
    background: var(--bg3);
    border-radius: 8px;
    color: var(--text2);
    font-size: 0.9rem;
  }
  .variant-badge {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    padding: 0.3rem 0.75rem;
    border-radius: 6px;
    font-size: 0.75rem;
    font-weight: 700;
    border: 1px solid;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  /* ── Info Card (shared) ───────────────────────────────────────────────────── */
  .info-card {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1.25rem;
  }
  .info-card h2 {
    margin: 0 0 1rem;
    font-size: 1rem;
    color: var(--text);
  }

  /* ── Detail List ──────────────────────────────────────────────────────────── */
  .detail-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .detail-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.6rem 0;
    border-bottom: 1px solid var(--border);
  }
  .detail-row:last-child {
    border-bottom: none;
  }
  .detail-label {
    font-size: 0.85rem;
    color: var(--text2);
  }
  .detail-value {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--text);
  }

  /* ── Market Stats ─────────────────────────────────────────────────────────── */
  .market-stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
  }
  .market-stat {
    background: var(--bg3);
    border-radius: 8px;
    padding: 0.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .market-stat-label {
    font-size: 0.75rem;
    color: var(--text2);
  }
  .market-stat-value {
    font-size: 1rem;
