---
import Base from '../../layouts/Base.astro';
import ExploreMore from '../../components/ExploreMore.astro';
import { getTeams, getAverageEdpi, amazonSearchUrl, type TeamInfo } from '../../lib/pro-players';
import { breadcrumbSchema, faqSchema } from '../../lib/weapons';

export function getStaticPaths() {
  return getTeams().map(t => ({
    params: { slug: t.slug },
    props: { team: t },
  }));
}

const { team } = Astro.props as { team: TeamInfo };
const players = team.players;
const globalAvgEdpi = getAverageEdpi();

// Team-level computed stats
const teamAvgEdpi = Math.round(players.reduce((s, p) => s + p.edpi, 0) / players.length);

// Most common resolution
const resCounts: Record<string, number> = {};
players.forEach(p => resCounts[p.res] = (resCounts[p.res] || 0) + 1);
const mostCommonRes = Object.entries(resCounts).sort((a, b) => b[1] - a[1])[0]?.[0] ?? 'N/A';

// Most common mouse
const mouseCounts: Record<string, number> = {};
players.forEach(p => { if (p.mouse) mouseCounts[p.mouse] = (mouseCounts[p.mouse] || 0) + 1; });
const mostCommonMouse = Object.entries(mouseCounts).sort((a, b) => b[1] - a[1])[0]?.[0] ?? 'N/A';

// Most common aspect ratio
const aspectCounts: Record<string, number> = {};
players.forEach(p => aspectCounts[p.aspect] = (aspectCounts[p.aspect] || 0) + 1);
const mostCommonAspect = Object.entries(aspectCounts).sort((a, b) => b[1] - a[1])[0]?.[0] ?? 'N/A';

// eDPI range
const edpiMin = Math.min(...players.map(p => p.edpi));
const edpiMax = Math.max(...players.map(p => p.edpi));

// DPI range
const dpiValues = [...new Set(players.map(p => p.dpi))].sort((a, b) => a - b);

// Stretched vs native counts
let stretchedCount = 0, barsCount = 0, nativeCount = 0;
players.forEach(p => {
  if (p.stretch === 'Stretched') stretchedCount++;
  else if (p.stretch === 'Black Bars') barsCount++;
  else nativeCount++;
});

// Role breakdown
const roleCounts: Record<string, number> = {};
players.forEach(p => roleCounts[p.role] = (roleCounts[p.role] || 0) + 1);

// Other teams for internal linking
const allTeams = getTeams().filter(t => t.slug !== team.slug);
const relatedTeams = allTeams.slice(0, 8);

const title = `${team.name} CS2 Settings — Crosshair, Sensitivity & Gear | CSDB.gg`;
const description = `Complete ${team.name} CS2 team settings: crosshair codes, sensitivity, resolution, mouse, and gear from ${players.length} players. Copy pro configs instantly.`;

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Pro Players', url: '/pro-players/' },
  { name: 'Teams', url: '/teams/' },
  { name: `${team.name}`, url: `/team/${team.slug}/` },
];

const edpiCompare = teamAvgEdpi < globalAvgEdpi ? 'below' : teamAvgEdpi > globalAvgEdpi ? 'above' : 'at';

const faqs = [
  {
    question: `What sensitivity do ${team.name} players use?`,
    answer: `${team.name} players use an average eDPI of ${teamAvgEdpi}, which is ${edpiCompare} the global pro average of ${globalAvgEdpi}. The team's eDPI ranges from ${edpiMin} to ${edpiMax}. Most players on the roster use ${dpiValues[0] || 400} DPI as their hardware setting.`,
  },
  {
    question: `What resolution does ${team.name} use in CS2?`,
    answer: `The most common resolution on ${team.name} is ${mostCommonRes} (${mostCommonAspect}). ${stretchedCount > 0 ? `${stretchedCount} player${stretchedCount > 1 ? 's' : ''} use stretched mode` : ''}${barsCount > 0 ? `${stretchedCount > 0 ? ', ' : ''}${barsCount} use black bars` : ''}${nativeCount > 0 ? `${stretchedCount > 0 || barsCount > 0 ? ', and ' : ''}${nativeCount} use native resolution` : ''}.`,
  },
  {
    question: `What mouse does ${team.name} use?`,
    answer: `The most popular mouse on ${team.name} is the ${mostCommonMouse}. Each player has their own preferred peripherals, and you can find their exact gear listed on this page with links to purchase.`,
  },
  {
    question: `Should I copy ${team.name}'s settings?`,
    answer: `${team.name}'s settings are a great reference point, especially for understanding what works at the highest level of CS2. However, the best approach is to use their settings as a starting point and adjust based on your own comfort, desk space, and playstyle. Focus on staying within the team's eDPI range (${edpiMin}–${edpiMax}) and give any changes at least 2 weeks of practice.`,
  },
];
---

<Base {title} {description}>
<Fragment slot="head">
<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema(breadcrumbs))} />
<script type="application/ld+json" set:html={JSON.stringify(faqSchema(faqs))} />
</Fragment>

<nav class="breadcrumb">
  <a href="/">Home</a> <span>/</span>
  <a href="/pro-players/">Pro Players</a> <span>/</span>
  <span>Teams</span> <span>/</span>
  <span>{team.name}</span>
</nav>

<!-- Hero Section -->
<section class="tm-hero">
  <h1>{team.name} CS2 Settings</h1>
  <p>Full settings breakdown for {players.length} {team.name} player{players.length !== 1 ? 's' : ''} — crosshair codes, sensitivity, resolution, and gear. Compare configs side by side and copy settings instantly.</p>
  <div class="tm-hero-stats">
    <div class="tm-hstat"><span class="tm-hval">{players.length}</span><span class="tm-hlbl">Players</span></div>
    <div class="tm-hstat"><span class="tm-hval">{teamAvgEdpi}</span><span class="tm-hlbl">Avg eDPI</span></div>
    <div class="tm-hstat"><span class="tm-hval">{mostCommonRes}</span><span class="tm-hlbl">Top Resolution</span></div>
    <div class="tm-hstat"><span class="tm-hval">{mostCommonMouse}</span><span class="tm-hlbl">Top Mouse</span></div>
    <div class="tm-hstat"><span class="tm-hval">{edpiMin}–{edpiMax}</span><span class="tm-hlbl">eDPI Range</span></div>
    <div class="tm-hstat"><span class="tm-hval">{mostCommonAspect}</span><span class="tm-hlbl">Top Aspect Ratio</span></div>
  </div>
</section>

<!-- Player Cards Grid -->
<section class="tm-section">
  <h2>Player Settings</h2>
  <div class="tm-grid">
    {players.map(player => (
      <div class="tm-card">
        <div class="tm-card-top">
          {player.image && <img class="tm-avatar" src={player.image} alt={player.name} width="56" height="56" loading="lazy" onerror="this.style.display='none'" />}
          <div class="tm-card-info">
            <h3 class="tm-name"><a href={`/player/${player.slug}/`}>{player.flag} {player.name}</a></h3>
            <div class="tm-meta">
              <span class="pp-role" data-r={player.role.toLowerCase().replace(/\s/g,'-')}>{player.role}</span>
              {player.country && <span class="tm-country">{player.country}</span>}
            </div>
          </div>
        </div>

        <div class="tm-stats">
          <div class="tm-s"><span class="tm-sv">{player.dpi}</span><span class="tm-sl">DPI</span></div>
          <div class="tm-s"><span class="tm-sv">{player.sens}</span><span class="tm-sl">Sens</span></div>
          <div class="tm-s tm-edpi"><span class="tm-sv">{player.edpi}</span><span class="tm-sl">eDPI</span></div>
          <div class="tm-s"><span class="tm-sv">{player.res}</span><span class="tm-sl">{player.aspect} {player.stretch}</span></div>
        </div>

        {player.crosshairCode && (
          <div class="tm-xhair">
            <code>{player.crosshairCode}</code>
            <button class="tm-copy" data-code={player.crosshairCode}>Copy</button>
          </div>
        )}

        <div class="tm-gear">
          {player.mouse && (
            <div class="tm-gi">
              <span class="tm-gk">Mouse</span>
              <a href={amazonSearchUrl(player.mouse)} target="_blank" rel="nofollow noopener" class="tm-gv tm-glink">{player.mouse}</a>
            </div>
          )}
          {player.keyboard && (
            <div class="tm-gi">
              <span class="tm-gk">Keyboard</span>
              <a href={amazonSearchUrl(player.keyboard)} target="_blank" rel="nofollow noopener" class="tm-gv tm-glink">{player.keyboard}</a>
            </div>
          )}
          {player.headset && (
            <div class="tm-gi">
              <span class="tm-gk">Headset</span>
              <a href={amazonSearchUrl(player.headset)} target="_blank" rel="nofollow noopener" class="tm-gv tm-glink">{player.headset}</a>
            </div>
          )}
          {player.monitor && (
            <div class="tm-gi">
              <span class="tm-gk">Monitor</span>
              <a href={amazonSearchUrl(player.monitor)} target="_blank" rel="nofollow noopener" class="tm-gv tm-glink">{player.monitor}</a>
            </div>
          )}
          {player.mousepad && (
            <div class="tm-gi">
              <span class="tm-gk">Mousepad</span>
              <a href={amazonSearchUrl(player.mousepad)} target="_blank" rel="nofollow noopener" class="tm-gv tm-glink">{player.mousepad}</a>
            </div>
          )}
        </div>

        <div class="tm-edpi-bar">
          <div class="tm-ebar-fill" style={`width:${Math.min(100, Math.round(((player.edpi - 400) / (1700 - 400)) * 100))}%`}></div>
          <span class="tm-ebar-label">{player.edpi} eDPI — {player.edpi < 600 ? 'Low' : player.edpi < 900 ? 'Medium' : 'High'} sens</span>
        </div>

        <a href={`/player/${player.slug}/`} class="tm-view-more">View Full Profile &rarr;</a>
      </div>
    ))}
  </div>
</section>

<!-- Settings Comparison Table -->
<section class="tm-table-section">
  <h2>{team.name} Settings Comparison</h2>
  <p class="tm-table-desc">Side-by-side comparison of all {team.name} players' sensitivity, resolution, crosshair, and gear.</p>
  <div class="tm-table-wrap">
    <table class="tm-table">
      <thead>
        <tr>
          <th>Player</th>
          <th>Role</th>
          <th>DPI</th>
          <th>Sens</th>
          <th>eDPI</th>
          <th>Resolution</th>
          <th>Aspect</th>
          <th>Display</th>
          <th>Refresh</th>
          <th>Mouse</th>
          <th>Mousepad</th>
          <th>Keyboard</th>
          <th>Headset</th>
          <th>Monitor</th>
        </tr>
      </thead>
      <tbody>
        {players.map(p => (
          <tr>
            <td><a href={`/player/${p.slug}/`} class="tm-tlink"><strong>{p.flag} {p.name}</strong></a></td>
            <td><span class="pp-role pp-role-sm" data-r={p.role.toLowerCase().replace(/\s/g,'-')}>{p.role}</span></td>
            <td>{p.dpi}</td>
            <td>{p.sens}</td>
            <td><strong>{p.edpi}</strong></td>
            <td>{p.res}</td>
            <td>{p.aspect}</td>
            <td>{p.stretch}</td>
            <td>{p.refreshRate ? `${p.refreshRate}Hz` : '—'}</td>
            <td>{p.mouse}</td>
            <td>{p.mousepad}</td>
            <td>{p.keyboard}</td>
            <td>{p.headset}</td>
            <td>{p.monitor}</td>
          </tr>
        ))}
      </tbody>
      <tfoot>
        <tr class="tm-tfoot-row">
          <td><strong>Team Avg</strong></td>
          <td>—</td>
          <td>{Math.round(players.reduce((s, p) => s + p.dpi, 0) / players.length)}</td>
          <td>{(players.reduce((s, p) => s + p.sens, 0) / players.length).toFixed(2)}</td>
          <td><strong>{teamAvgEdpi}</strong></td>
          <td>{mostCommonRes}</td>
          <td>{mostCommonAspect}</td>
          <td>—</td>
          <td>—</td>
          <td>{mostCommonMouse}</td>
          <td colspan="4">—</td>
        </tr>
      </tfoot>
    </table>
  </div>
</section>

<!-- Crosshair Codes Section -->
<section class="tm-section">
  <h2>{team.name} Crosshair Codes</h2>
  <p class="tm-table-desc">Copy any {team.name} player's crosshair code and paste it in CS2 settings.</p>
  <div class="tm-xhair-grid">
    {players.filter(p => p.crosshairCode).map(p => (
      <div class="tm-xhair-card">
        <div class="tm-xhair-player">
          <strong>{p.flag} {p.name}</strong>
          <span class="pp-role pp-role-sm" data-r={p.role.toLowerCase().replace(/\s/g,'-')}>{p.role}</span>
        </div>
        <div class="tm-xhair-row">
          <code>{p.crosshairCode}</code>
          <button class="tm-copy" data-code={p.crosshairCode}>Copy</button>
        </div>
      </div>
    ))}
  </div>
</section>

<!-- FAQ -->
<section class="tm-section">
  <h2>Frequently Asked Questions</h2>
  <dl class="faq">
    {faqs.map(f => (
      <>
        <dt>{f.question}</dt>
        <dd>{f.answer}</dd>
      </>
    ))}
  </dl>
</section>

<!-- Internal Links -->
<section class="tm-section">
  <h2>More CS2 Teams</h2>
  <div class="internal-links">
    {relatedTeams.map(t => (
      <a href={`/team/${t.slug}/`}>{t.name} ({t.players.length})</a>
    ))}
    <a href="/pro-players/">All Pro Players</a>
    <a href="/crosshair-codes/">Crosshair Codes</a>
    <a href="/sensitivity-converter/">Sensitivity Converter</a>
    <a href="/edpi-calculator/">eDPI Calculator</a>
  </div>
</section>

<ExploreMore context="general" />

</Base>

<style>
/* Hero */
.tm-hero{background:linear-gradient(135deg,var(--bg2),var(--bg3));border:1px solid var(--border);border-radius:12px;padding:2rem;margin-bottom:2rem}
.tm-hero h1{font-size:2.2rem;margin:0 0 .75rem}
.tm-hero>p{color:var(--text2);font-size:1.05rem;margin:0 0 1.5rem}
.tm-hero-stats{display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:.75rem}
.tm-hstat{background:var(--bg);border:1px solid var(--border);border-radius:8px;padding:1rem;text-align:center}
.tm-hval{display:block;font-size:1.4rem;font-weight:800;color:var(--accent)}
.tm-hlbl{display:block;font-size:.75rem;color:var(--text2);margin-top:.25rem}

/* Sections */
.tm-section{margin-bottom:2.5rem}
.tm-section h2{margin-bottom:1rem}

/* Player Card Grid */
.tm-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(380px,1fr));gap:1.25rem}
.tm-card{background:var(--bg2);border:1px solid var(--border);border-radius:10px;padding:1.25rem;transition:border-color .2s,transform .2s,box-shadow .2s}
.tm-card:hover{border-color:var(--accent);transform:translateY(-2px);box-shadow:0 4px 16px rgba(212,149,110,.1)}
.tm-card-top{display:flex;align-items:flex-start;margin-bottom:1rem;gap:.75rem}
.tm-avatar{width:56px;height:56px;border-radius:50%;object-fit:cover;border:2px solid var(--border);flex-shrink:0;background:var(--bg3)}
.tm-card-info{flex:1;min-width:0}
.tm-name{margin:0;font-size:1.3rem;font-weight:800}
.tm-name a{color:var(--text);text-decoration:none;transition:color .2s}
.tm-name a:hover{color:var(--accent)}
.tm-meta{display:flex;gap:.5rem;align-items:center;margin-top:.3rem}
.tm-country{color:var(--text2);font-size:.82rem}

/* Role badges — reuse existing pp-role styles from Base */
.pp-role{font-size:.72rem;font-weight:700;padding:.2rem .5rem;border-radius:4px;text-transform:uppercase;letter-spacing:.03em;background:var(--bg3);color:var(--text2);border:1px solid var(--border)}
.pp-role[data-r="awper"]{background:rgba(239,83,80,.15);color:var(--red);border-color:var(--red)}
.pp-role[data-r="rifler"]{background:rgba(66,165,245,.15);color:var(--blue);border-color:var(--blue)}
.pp-role[data-r="igl"]{background:rgba(171,71,188,.15);color:var(--purple);border-color:var(--purple)}
.pp-role[data-r="entry-fragger"]{background:rgba(212,149,110,.15);color:var(--accent);border-color:var(--accent)}
.pp-role[data-r="support"]{background:rgba(76,175,80,.15);color:var(--green);border-color:var(--green)}
.pp-role-sm{font-size:.65rem;padding:.15rem .4rem}

/* Stats Row */
.tm-stats{display:grid;grid-template-columns:repeat(4,1fr);gap:.5rem;margin-bottom:1rem}
.tm-s{background:var(--bg);border:1px solid var(--border);border-radius:6px;padding:.5rem;text-align:center}
.tm-s.tm-edpi{border-color:var(--accent)}
.tm-sv{display:block;font-size:1.1rem;font-weight:700;color:var(--text)}
.tm-edpi .tm-sv{color:var(--accent)}
.tm-sl{display:block;font-size:.65rem;color:var(--text2);text-transform:uppercase;margin-top:.15rem}

/* Crosshair row */
.tm-xhair{display:flex;gap:.5rem;background:var(--bg);border:1px solid var(--border);border-radius:6px;padding:.4rem;margin-bottom:1rem;align-items:center}
.tm-xhair code{flex:1;font-size:.75rem;color:var(--text2);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;padding:0 .4rem}
.tm-copy{background:var(--accent);color:#000;border:none;padding:.3rem .6rem;border-radius:4px;font-size:.75rem;font-weight:700;cursor:pointer;white-space:nowrap;font-family:inherit}
.tm-copy:hover{opacity:.9}
.tm-copy.copied{background:var(--green);color:#fff}

/* Gear list */
.tm-gear{display:grid;grid-template-columns:1fr 1fr;gap:.3rem .75rem;margin-bottom:.75rem;font-size:.82rem}
.tm-gi{display:flex;gap:.3rem}
.tm-gk{color:var(--text2);font-weight:600;white-space:nowrap}
.tm-gk::after{content:':'}
.tm-gv{color:var(--text);overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.tm-glink{color:var(--text);text-decoration:none;transition:color .2s}
.tm-glink:hover{color:var(--accent)}

/* eDPI bar */
.tm-edpi-bar{position:relative;background:var(--bg);border:1px solid var(--border);border-radius:4px;height:22px;overflow:hidden;margin-bottom:.75rem}
.tm-ebar-fill{position:absolute;top:0;left:0;height:100%;background:linear-gradient(90deg,var(--green),var(--accent),var(--red));opacity:.25;border-radius:4px}
.tm-ebar-label{position:absolute;top:50%;left:.5rem;transform:translateY(-50%);font-size:.7rem;color:var(--text2);font-weight:600}

/* View more link */
.tm-view-more{display:block;text-align:center;color:var(--accent);font-size:.82rem;font-weight:700;padding-top:.5rem;border-top:1px solid var(--border);text-decoration:none;transition:color .2s}
.tm-view-more:hover{color:var(--accent2)}

/* Comparison Table */
.tm-table-section{margin-bottom:2.5rem}
.tm-table-section h2{margin-bottom:.5rem}
.tm-table-desc{font-size:.92rem;color:var(--text2);margin-bottom:1rem}
.tm-table-wrap{overflow-x:auto;border:1px solid var(--border);border-radius:8px}
.tm-table{width:100%;border-collapse:collapse;background:var(--bg2);font-size:.82rem}
.tm-table thead{background:var(--bg3)}
.tm-table th{padding:.65rem .5rem;text-align:left;font-weight:700;color:var(--text);text-transform:uppercase;font-size:.7rem;letter-spacing:.03em;white-space:nowrap}
.tm-table td{padding:.5rem;border-bottom:1px solid var(--border);color:var(--text2);white-space:nowrap}
.tm-table tbody tr:hover td{background:var(--bg3)}
.tm-table td strong{color:var(--text)}
.tm-tlink{color:var(--accent);text-decoration:none;font-weight:600}
.tm-tlink:hover{text-decoration:underline}
.tm-tfoot-row td{background:var(--bg3);font-weight:600;color:var(--text);border-top:2px solid var(--accent)}

/* Crosshair Codes Grid */
.tm-xhair-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(340px,1fr));gap:1rem}
.tm-xhair-card{background:var(--bg2);border:1px solid var(--border);border-radius:8px;padding:1rem;transition:border-color .2s}
.tm-xhair-card:hover{border-color:var(--accent)}
.tm-xhair-player{display:flex;align-items:center;gap:.5rem;margin-bottom:.6rem}
.tm-xhair-player strong{font-size:.95rem;color:var(--text)}
.tm-xhair-row{display:flex;gap:.5rem;background:var(--bg);border:1px solid var(--border);border-radius:6px;padding:.4rem;align-items:center}
.tm-xhair-row code{flex:1;font-size:.75rem;color:var(--text2);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;padding:0 .4rem}

/* Responsive */
@media(max-width:1024px){
  .tm-hero-stats{grid-template-columns:repeat(3,1fr)}
  .tm-grid{grid-template-columns:repeat(auto-fill,minmax(340px,1fr))}
}
@media(max-width:768px){
  .tm-hero h1{font-size:1.6rem}
  .tm-hero-stats{grid-template-columns:repeat(2,1fr)}
  .tm-grid{grid-template-columns:1fr}
  .tm-stats{grid-template-columns:repeat(2,1fr)}
  .tm-gear{grid-template-columns:1fr}
  .tm-xhair-grid{grid-template-columns:1fr}
}
</style>

<script is:inline>
(function(){
  document.querySelectorAll('.tm-copy').forEach(function(btn){
    btn.addEventListener('click', function(e){
      e.preventDefault();
      e.stopPropagation();
      var code = btn.dataset.code;
      navigator.clipboard.writeText(code).then(function(){
        btn.textContent = 'Copied!';
        btn.classList.add('copied');
        setTimeout(function(){
          btn.textContent = 'Copy';
          btn.classList.remove('copied');
        }, 1500);
      });
    });
  });
})();
</script>
