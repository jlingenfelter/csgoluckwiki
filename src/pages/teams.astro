---
import Base from '../layouts/Base.astro';
import ExploreMore from '../components/ExploreMore.astro';
import { faqSchema } from '../lib/weapons';
import { getTeams, getAverageEdpi, getRoles, getCountries, getGearByType, type TeamInfo, type ProPlayer } from '../lib/pro-players';

const allTeams = getTeams();
const globalAvgEdpi = getAverageEdpi();

// Pre-compute per-team stats for cards & data attributes
const teamCards = allTeams.map(t => {
  const avgEdpi = Math.round(t.players.reduce((s, p) => s + p.edpi, 0) / t.players.length);

  // Most common mouse
  const mc: Record<string, number> = {};
  t.players.forEach(p => { if (p.mouse) mc[p.mouse] = (mc[p.mouse] || 0) + 1; });
  const topMouse = Object.entries(mc).sort((a, b) => b[1] - a[1])[0]?.[0] ?? '—';

  // Most common resolution
  const rc: Record<string, number> = {};
  t.players.forEach(p => rc[p.res] = (rc[p.res] || 0) + 1);
  const topRes = Object.entries(rc).sort((a, b) => b[1] - a[1])[0]?.[0] ?? '—';

  // Top player names (up to 5)
  const topNames = t.players.slice(0, 5).map(p => p.name);

  return { ...t, avgEdpi, topMouse, topRes, topNames };
});

const totalPlayers = allTeams.reduce((s, t) => s + t.players.length, 0);
const avgTeamSize = (totalPlayers / allTeams.length).toFixed(1);

// eDPI distribution across teams
const edpiRanges = { low: 0, mid: 0, high: 0 };
teamCards.forEach(t => {
  if (t.avgEdpi < 600) edpiRanges.low++;
  else if (t.avgEdpi < 900) edpiRanges.mid++;
  else edpiRanges.high++;
});

// Most common mouse across all teams
const teamMouseCounts: Record<string, number> = {};
teamCards.forEach(t => { if (t.topMouse !== '—') teamMouseCounts[t.topMouse] = (teamMouseCounts[t.topMouse] || 0) + 1; });
const topTeamMice = Object.entries(teamMouseCounts).sort((a, b) => b[1] - a[1]).slice(0, 5);

// Most common resolution across all teams
const teamResCounts: Record<string, number> = {};
teamCards.forEach(t => { if (t.topRes !== '—') teamResCounts[t.topRes] = (teamResCounts[t.topRes] || 0) + 1; });
const topTeamRes = Object.entries(teamResCounts).sort((a, b) => b[1] - a[1]).slice(0, 5);

const title = `CS2 Pro Teams — Settings, Gear & Configs | CSDB.gg`;
const description = `Browse ${allTeams.length} CS2 professional teams and their players' settings. Compare sensitivity, crosshair, resolution, and gear configs across ${totalPlayers}+ pro players.`;

const faqs = [
  { question: 'How many CS2 pro teams are tracked?', answer: `We currently track settings for ${allTeams.length} professional CS2 teams, covering ${totalPlayers}+ individual players. Teams range from Tier 1 organizations like Natus Vincere and FaZe Clan to rising Tier 2 and Tier 3 rosters.` },
  { question: 'What team has the lowest average sensitivity?', answer: `Team sensitivity varies significantly. Most professional teams average between 600 and 900 eDPI. Teams with AWPer-heavy rosters tend to have lower averages. Visit individual team pages to compare their exact settings.` },
  { question: 'Should I copy a pro team\'s settings?', answer: `Pro team settings are useful as reference ranges rather than exact targets. Each player on a team typically has unique settings optimized for their role and playstyle. Use the team average eDPI as a starting point, then adjust based on your personal comfort and desk space.` },
  { question: 'How often do team rosters change?', answer: `CS2 rosters change frequently, especially during transfer windows between Major cycles. We update player data regularly to reflect current rosters. Some players may appear on their most recent team even if they have since been benched or transferred.` },
];

// Browse sections
const topRoles = getRoles();
const topCountries = getCountries().slice(0, 12);
const topMice = getGearByType('mouse').slice(0, 8);
---

<Base {title} {description}>
<Fragment slot="head">
<script type="application/ld+json" set:html={JSON.stringify(faqSchema(faqs))} />
<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://csdb.gg/" },
    { "@type": "ListItem", "position": 2, "name": "Pro Players", "item": "https://csdb.gg/pro-players/" },
    { "@type": "ListItem", "position": 3, "name": "Teams" }
  ]
})} />
</Fragment>

<nav class="breadcrumb">
  <a href="/">Home</a> <span>/</span>
  <a href="/pro-players/">Pro Players</a> <span>/</span>
  <span>Teams</span>
</nav>

<section class="th-hero">
  <h1>CS2 Pro Teams</h1>
  <p>Browse {allTeams.length} professional CS2 teams — compare team settings, gear, and player configs. Search by name or sort by roster size and average sensitivity.</p>
  <div class="th-hero-stats">
    <div class="th-hstat"><span class="th-hval">{allTeams.length}</span><span class="th-hlbl">Teams</span></div>
    <div class="th-hstat"><span class="th-hval">{totalPlayers}</span><span class="th-hlbl">Total Players</span></div>
    <div class="th-hstat"><span class="th-hval">{avgTeamSize}</span><span class="th-hlbl">Avg Team Size</span></div>
    <div class="th-hstat"><span class="th-hval">{globalAvgEdpi}</span><span class="th-hlbl">Global Avg eDPI</span></div>
  </div>
</section>

<!-- Search & Sort -->
<section class="th-filters">
  <div class="th-filter-row">
    <div class="th-search">
      <input type="text" id="teamSearch" placeholder="Search teams..." />
    </div>
    <div class="th-sort-group">
      <span class="th-flabel">Sort:</span>
      <select id="teamSort">
        <option value="players">Most Players</option>
        <option value="name-az">Name A–Z</option>
        <option value="name-za">Name Z–A</option>
        <option value="edpi-low">Avg eDPI (Low–High)</option>
        <option value="edpi-high">Avg eDPI (High–Low)</option>
      </select>
    </div>
  </div>
  <div class="th-result-count"><span id="visibleCount">{allTeams.length}</span> of {allTeams.length} teams shown</div>
</section>

<!-- Team Cards -->
<section class="th-grid" id="thGrid">
  {teamCards.map((t, i) => (
    <a href={`/team/${t.slug}/`} class={`th-card${i >= 48 ? ' th-paginated' : ''}`}
       data-name={t.name.toLowerCase()} data-players={t.players.length}
       data-edpi={t.avgEdpi} data-idx={i}>
      <div class="th-card-top">
        <h3 class="th-name">{t.name}</h3>
        <span class="th-player-count">{t.players.length} player{t.players.length !== 1 ? 's' : ''}</span>
      </div>

      <div class="th-roster">
        {t.topNames.map(name => (
          <span class="th-player-tag">{name}</span>
        ))}
        {t.players.length > 5 && <span class="th-more">+{t.players.length - 5} more</span>}
      </div>

      <div class="th-stats">
        <div class="th-s"><span class="th-sv">{t.avgEdpi}</span><span class="th-sl">Avg eDPI</span></div>
        <div class="th-s"><span class="th-sv">{t.topRes}</span><span class="th-sl">Top Resolution</span></div>
        <div class="th-s th-s-wide"><span class="th-sv">{t.topMouse}</span><span class="th-sl">Top Mouse</span></div>
      </div>

      <div class="th-edpi-bar">
        <div class="th-ebar-fill" style={`width:${Math.min(100, Math.round(((t.avgEdpi - 400) / (1700 - 400)) * 100))}%`}></div>
        <span class="th-ebar-label">{t.avgEdpi} eDPI — {t.avgEdpi < 600 ? 'Low' : t.avgEdpi < 900 ? 'Medium' : 'High'} avg</span>
      </div>

      <div class="th-view-more">View Team Settings &rarr;</div>
    </a>
  ))}
</section>

<div class="th-loadmore-wrap" id="loadMoreWrap">
  <button class="th-loadmore-btn" id="loadMoreBtn">Load More Teams <span id="loadMoreCount"></span></button>
</div>

<!-- Analysis Section -->
<section class="th-analysis">
  <h2>Team Settings Overview</h2>
  <div class="th-analysis-grid">
    <div class="th-acard">
      <h3>Team eDPI Distribution</h3>
      <p>Average eDPI across team rosters</p>
      <div class="th-stretch-grid">
        <div class="th-stretch-item">
          <span class="th-stretch-val">{edpiRanges.low}</span>
          <span class="th-stretch-lbl">Low (&lt;600)</span>
        </div>
        <div class="th-stretch-item">
          <span class="th-stretch-val">{edpiRanges.mid}</span>
          <span class="th-stretch-lbl">Medium</span>
        </div>
        <div class="th-stretch-item">
          <span class="th-stretch-val">{edpiRanges.high}</span>
          <span class="th-stretch-lbl">High (&gt;900)</span>
        </div>
      </div>
    </div>
    <div class="th-acard">
      <h3>Most Common Team Mouse</h3>
      {topTeamMice.map(([name, count]) => (
        <div class="th-bar-row">
          <span class="th-bar-name">{name}</span>
          <div class="th-bar-fill" style={`width:${Math.round((count / allTeams.length) * 100)}%`}></div>
          <span class="th-bar-pct">{count} teams</span>
        </div>
      ))}
    </div>
    <div class="th-acard">
      <h3>Most Common Team Resolution</h3>
      {topTeamRes.map(([res, count]) => (
        <div class="th-bar-row">
          <span class="th-bar-name">{res}</span>
          <div class="th-bar-fill" style={`width:${Math.round((count / allTeams.length) * 100)}%`}></div>
          <span class="th-bar-pct">{count} teams</span>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- FAQ -->
<section class="th-section">
  <h2>Frequently Asked Questions</h2>
  <dl class="faq">
    {faqs.map(f => (
      <>
        <dt>{f.question}</dt>
        <dd>{f.answer}</dd>
      </>
    ))}
  </dl>
</section>

<!-- Browse by Role -->
<section class="th-browse-section">
  <h2>Browse by Role</h2>
  <div class="th-browse-grid">
    {topRoles.map(r => (
      <a href={`/players/role/${r.slug}/`} class="th-browse-pill">
        <span class="th-browse-name">{r.name}</span>
        <span class="th-browse-count">{r.players.length}</span>
      </a>
    ))}
  </div>
</section>

<!-- Browse by Country -->
<section class="th-browse-section">
  <h2>Browse by Country</h2>
  <div class="th-browse-grid">
    {topCountries.map(c => (
      <a href={`/players/country/${c.slug}/`} class="th-browse-pill">
        <span class="th-browse-flag">{c.flag}</span>
        <span class="th-browse-name">{c.name}</span>
        <span class="th-browse-count">{c.players.length}</span>
      </a>
    ))}
  </div>
</section>

<!-- Popular Mice -->
<section class="th-browse-section">
  <h2>Popular Mice</h2>
  <div class="th-browse-grid">
    {topMice.map(g => (
      <a href={`/gear/${g.slug}/`} class="th-browse-pill">
        <span class="th-browse-name">{g.name}</span>
        <span class="th-browse-count">{g.players.length} pros</span>
      </a>
    ))}
  </div>
</section>

<ExploreMore context="general" />

<div class="internal-links">
  <a href="/pro-players/">All Pro Players</a>
  <a href="/crosshair-codes/">Crosshair Codes</a>
  <a href="/sensitivity-converter/">Sensitivity Converter</a>
  <a href="/edpi-calculator/">eDPI Calculator</a>
  <a href="/cm360-calculator/">cm/360 Calculator</a>
  <a href="/weapons/">Weapon Stats</a>
</div>

</Base>

<style>
/* Hero */
.th-hero{background:linear-gradient(135deg,var(--bg2),var(--bg3));border:1px solid var(--border);border-radius:12px;padding:2rem;margin-bottom:2rem}
.th-hero h1{font-size:2.2rem;margin:0 0 .75rem}
.th-hero>p{color:var(--text2);font-size:1.05rem;margin:0 0 1.5rem}
.th-hero-stats{display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:.75rem}
.th-hstat{background:var(--bg);border:1px solid var(--border);border-radius:8px;padding:1rem;text-align:center}
.th-hval{display:block;font-size:1.4rem;font-weight:800;color:var(--accent)}
.th-hlbl{display:block;font-size:.75rem;color:var(--text2);margin-top:.25rem}

/* Filters */
.th-filters{background:var(--bg2);border:1px solid var(--border);border-radius:10px;padding:1.25rem;margin-bottom:1.5rem}
.th-filter-row{display:flex;gap:1rem;flex-wrap:wrap;align-items:center}
.th-search{flex:1;min-width:200px}
#teamSearch{width:100%;background:var(--bg3);color:var(--text);border:1px solid var(--border);padding:.5rem .75rem;border-radius:6px;font-size:.9rem;font-family:inherit}
#teamSearch:focus{border-color:var(--accent);outline:none}
.th-sort-group{display:flex;gap:.5rem;align-items:center}
.th-flabel{font-size:.85rem;font-weight:600;color:var(--text)}
#teamSort{background:var(--bg3);color:var(--text);border:1px solid var(--border);padding:.4rem .6rem;border-radius:6px;font-size:.85rem;font-family:inherit}
.th-result-count{font-size:.82rem;color:var(--text2);margin-top:.75rem}

/* Card Grid */
.th-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(320px,1fr));gap:1.25rem;margin-bottom:1rem}
.th-card{display:block;text-decoration:none;color:inherit;background:var(--bg2);border:1px solid var(--border);border-radius:10px;padding:1.25rem;transition:border-color .2s,transform .2s,box-shadow .2s}
.th-card:hover{border-color:var(--accent);transform:translateY(-2px);box-shadow:0 4px 16px rgba(212,149,110,.1)}
.th-card.hidden{display:none}

.th-card-top{display:flex;align-items:center;justify-content:space-between;margin-bottom:.75rem;gap:.75rem}
.th-name{margin:0;font-size:1.25rem;font-weight:800;color:var(--text)}
.th-player-count{font-size:.78rem;font-weight:700;background:var(--accent);color:#000;padding:.2rem .6rem;border-radius:4px;white-space:nowrap}

.th-roster{display:flex;flex-wrap:wrap;gap:.35rem;margin-bottom:.75rem}
.th-player-tag{font-size:.78rem;color:var(--text2);background:var(--bg);border:1px solid var(--border);padding:.15rem .5rem;border-radius:4px}
.th-more{font-size:.75rem;color:var(--text2);padding:.15rem .4rem}

.th-stats{display:grid;grid-template-columns:1fr 1fr;gap:.5rem;margin-bottom:.75rem}
.th-s{background:var(--bg);border:1px solid var(--border);border-radius:6px;padding:.5rem;text-align:center}
.th-s-wide{grid-column:1/-1}
.th-sv{display:block;font-size:1rem;font-weight:700;color:var(--text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.th-sl{display:block;font-size:.65rem;color:var(--text2);text-transform:uppercase;margin-top:.15rem}

.th-edpi-bar{position:relative;background:var(--bg);border:1px solid var(--border);border-radius:4px;height:22px;overflow:hidden;margin-bottom:.75rem}
.th-ebar-fill{position:absolute;top:0;left:0;height:100%;background:linear-gradient(90deg,var(--green),var(--accent),var(--red));opacity:.25;border-radius:4px}
.th-ebar-label{position:absolute;top:50%;left:.5rem;transform:translateY(-50%);font-size:.7rem;color:var(--text2);font-weight:600}

.th-view-more{text-align:center;color:var(--accent);font-size:.82rem;font-weight:700;padding-top:.5rem;border-top:1px solid var(--border)}

/* Load More */
.th-loadmore-wrap{text-align:center;padding:1.5rem 0}
.th-loadmore-btn{background:var(--accent);color:#000;border:none;padding:.75rem 2rem;border-radius:8px;font-size:1rem;font-weight:700;cursor:pointer;font-family:inherit;transition:opacity .2s,transform .2s}
.th-loadmore-btn:hover{opacity:.9;transform:translateY(-1px)}
.th-loadmore-btn span{font-weight:400;opacity:.8}
.th-paginated{display:none}
.th-card.th-paginated.th-revealed{display:block}

/* Analysis */
.th-analysis{margin-bottom:3rem}
.th-analysis h2{margin-bottom:1.25rem}
.th-analysis-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:1.25rem}
.th-acard{background:var(--bg2);border:1px solid var(--border);border-radius:10px;padding:1.25rem}
.th-acard h3{margin:0 0 .5rem;font-size:1.05rem}
.th-acard p{font-size:.88rem;color:var(--text2);margin:0 0 .75rem}

.th-stretch-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:.75rem;text-align:center}
.th-stretch-item{background:var(--bg);border:1px solid var(--border);border-radius:8px;padding:.75rem}
.th-stretch-val{display:block;font-size:1.6rem;font-weight:800;color:var(--accent)}
.th-stretch-lbl{display:block;font-size:.75rem;color:var(--text2);margin-top:.2rem}

.th-bar-row{display:flex;align-items:center;gap:.5rem;margin-bottom:.5rem}
.th-bar-name{min-width:100px;font-size:.82rem;color:var(--text);font-weight:600;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.th-bar-fill{height:20px;background:var(--accent);border-radius:3px;min-width:4px;opacity:.7}
.th-bar-pct{font-size:.78rem;color:var(--text2);font-weight:600;white-space:nowrap}

/* Sections */
.th-section{margin-bottom:2.5rem}
.th-section h2{margin-bottom:1rem}

/* Browse pills */
.th-browse-section{margin:2.5rem 0}
.th-browse-section h2{margin:0 0 1rem;font-size:1.25rem}
.th-browse-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:.6rem}
.th-browse-pill{display:flex;align-items:center;gap:.5rem;padding:.6rem 1rem;background:var(--bg2);border:1px solid var(--border);border-radius:8px;text-decoration:none;transition:all .15s;font-size:.88rem}
.th-browse-pill:hover{border-color:var(--accent);background:var(--bg3);transform:translateY(-1px)}
.th-browse-flag{font-size:1.1rem}
.th-browse-name{color:var(--text);font-weight:600;flex:1;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.th-browse-count{color:var(--text2);font-size:.75rem;font-weight:500;background:var(--bg3);padding:.15rem .5rem;border-radius:4px;white-space:nowrap}

/* Responsive */
@media(max-width:768px){
  .th-hero h1{font-size:1.6rem}
  .th-hero-stats{grid-template-columns:repeat(2,1fr)}
  .th-grid{grid-template-columns:1fr}
  .th-filter-row{flex-direction:column}
  .th-search{width:100%}
  .th-bar-name{min-width:80px}
  .th-browse-grid{grid-template-columns:repeat(2,1fr)}
}
</style>

<script is:inline>
(function(){
  var search = document.getElementById('teamSearch');
  var sortSel = document.getElementById('teamSort');
  var grid = document.getElementById('thGrid');
  var cards = Array.from(document.querySelectorAll('.th-card'));
  var countEl = document.getElementById('visibleCount');
  var loadMoreBtn = document.getElementById('loadMoreBtn');
  var loadMoreWrap = document.getElementById('loadMoreWrap');
  var loadMoreCount = document.getElementById('loadMoreCount');

  var BATCH = 48;
  var isFiltering = false;

  function updateLoadMore() {
    if (isFiltering) {
      loadMoreWrap.style.display = 'none';
      return;
    }
    var paginated = document.querySelectorAll('.th-card.th-paginated:not(.th-revealed)');
    if (paginated.length === 0) {
      loadMoreWrap.style.display = 'none';
    } else {
      loadMoreWrap.style.display = 'block';
      loadMoreCount.textContent = '(' + paginated.length + ' remaining)';
    }
  }

  function filterAndSort() {
    var q = search.value.toLowerCase().trim();
    var sortBy = sortSel.value;
    isFiltering = q !== '';

    // Filter
    var visible = [];
    cards.forEach(function(c) {
      var name = c.dataset.name;
      var match = !q || name.indexOf(q) > -1;
      c._match = match;
      if (match) visible.push(c);
    });

    // Sort visible cards
    visible.sort(function(a, b) {
      switch (sortBy) {
        case 'name-az': return a.dataset.name.localeCompare(b.dataset.name);
        case 'name-za': return b.dataset.name.localeCompare(a.dataset.name);
        case 'edpi-low': return Number(a.dataset.edpi) - Number(b.dataset.edpi);
        case 'edpi-high': return Number(b.dataset.edpi) - Number(a.dataset.edpi);
        default: return Number(b.dataset.players) - Number(a.dataset.players);
      }
    });

    // Re-append in sorted order
    cards.forEach(function(c) { c.style.display = 'none'; });
    visible.forEach(function(c, i) {
      grid.appendChild(c);
      if (isFiltering) {
        c.style.display = '';
      } else {
        // Respect pagination for non-filtered view
        var isPaginated = c.classList.contains('th-paginated') && !c.classList.contains('th-revealed');
        c.style.display = isPaginated ? 'none' : '';
      }
    });

    countEl.textContent = visible.length;
    updateLoadMore();
  }

  loadMoreBtn.addEventListener('click', function() {
    var hidden = document.querySelectorAll('.th-card.th-paginated:not(.th-revealed)');
    var count = 0;
    hidden.forEach(function(c) {
      if (count < BATCH) {
        c.classList.add('th-revealed');
        if (c._match !== false) c.style.display = '';
        count++;
      }
    });
    updateLoadMore();
  });

  search.addEventListener('input', filterAndSort);
  sortSel.addEventListener('change', filterAndSort);

  // Initial state
  updateLoadMore();
})();
</script>
