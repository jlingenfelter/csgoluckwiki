---
import Base from '../layouts/Base.astro';
import ExploreMore from '../components/ExploreMore.astro';
import { SKINS, RARITY_COLORS } from '../lib/skins';
import { faqSchema, breadcrumbSchema } from '../lib/weapons';

const title = 'CS2 Trade-Up Calculator — Expected Value & Probability | CSGOLuck Wiki';
const description = 'Calculate CS2 trade-up contract outcomes, probabilities, expected value, and ROI. Select skins visually, see possible results with images, and find profitable trade-up strategies.';

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Tools', url: '/cs2-tools/' },
  { name: 'Trade-Up Calculator', url: '/tradeup-calculator/' },
];

const faqs = [
  { question: 'How do CS2 trade-up contracts work?', answer: 'You submit 10 skins of the same rarity tier. The system returns one skin of the next-higher rarity from any of the collections represented in your 10 input skins. The output skin\'s float value is calculated from the average float of your inputs.' },
  { question: 'How is the output float calculated?', answer: 'The output float is based on the average float of your 10 input skins, scaled to the output skin\'s float range. Formula: Output Float = (Average Input Float) × (Max Float − Min Float) + Min Float. This means lower-float inputs produce lower-float outputs.' },
  { question: 'What determines which skin I get from a trade-up?', answer: 'Each input skin "votes" for its collection\'s next-rarity skins. If you input 7 skins from Collection A and 3 from Collection B, there\'s a 70% chance the output comes from Collection A and 30% from Collection B.' },
  { question: 'Can you profit from trade-up contracts?', answer: 'Yes, profitable trade-ups exist when the expected value of outputs exceeds the cost of inputs. The key is finding collections where the next-rarity tier contains high-value skins and manipulating collection ratios to increase odds of expensive outcomes.' },
  { question: 'What is the best rarity for trade-ups?', answer: 'Mil-Spec to Restricted trade-ups have the lowest entry cost. Classified to Covert trade-ups offer the highest potential profit but carry more risk. Industrial to Mil-Spec trade-ups are often overlooked but can be consistently profitable.' },
];

// Rarity progression for trade-ups
const RARITY_ORDER = ['Consumer', 'Industrial', 'Mil-Spec', 'Restricted', 'Classified', 'Covert'];

// Build trade-up skin database: group skins by rarity + collection
// Only include skins that have a collection (can be traded up)
const tradeUpSkins = SKINS.filter(s => s.collection && RARITY_ORDER.includes(s.rarity));

// Serialize skin data for client-side use (minimal fields for performance)
const skinDataForClient = tradeUpSkins.map(s => ({
  slug: s.slug,
  weapon: s.weapon,
  name: s.name,
  rarity: s.rarity,
  collection: s.collection || '',
  image: s.image || '',
  minFloat: s.minFloat,
  maxFloat: s.maxFloat,
  price: s.prices.length > 0 ? Math.round((Math.min(...s.prices.map(p => p.price).filter(p => p > 0)) || 0) * 100) : 0,
}));

const skinDataJson = JSON.stringify(skinDataForClient);

const toolSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": title,
  "description": description,
  "applicationCategory": "UtilityApplication",
  "operatingSystem": "Web",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
  "author": { "@type": "Organization", "name": "CSGOLuck Wiki", "url": "https://wiki.csgoluck.com" }
});
---

<Base title={title} description={description} currentNav="/cs2-tools/">
  <script type="application/ld+json" set:html={toolSchema}></script>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema(breadcrumbs))}></script>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema(faqs))}></script>

  <nav class="breadcrumb">
    <a href="/">Home</a> <span>/</span> <a href="/cs2-tools/">Tools</a> <span>/</span> <span>Trade-Up Calculator</span>
  </nav>

  <div class="tuc-hero">
    <h1 class="tuc-title">CS2 Trade-Up Calculator</h1>
    <p class="tuc-desc">Select 10 input skins to calculate trade-up outcomes, probabilities, and expected value. Use the <a href="/float-checker/" style="color:var(--accent)">float checker</a> to verify wear values and read the <a href="/cs2-guides/float-guide/" style="color:var(--accent)">float guide</a> to understand how output floats are determined.</p>
  </div>

  <!-- Rarity selector -->
  <div class="tu-rarity-bar">
    <span class="tu-rarity-label">Input Rarity:</span>
    <div class="tu-rarity-pills" id="rarityPills">
      <button class="tu-pill active" data-rarity="Mil-Spec" style="--rc:#4b69ff">Mil-Spec</button>
      <button class="tu-pill" data-rarity="Consumer" style="--rc:#b0c3d9">Consumer</button>
      <button class="tu-pill" data-rarity="Industrial" style="--rc:#5e98d9">Industrial</button>
      <button class="tu-pill" data-rarity="Restricted" style="--rc:#8847ff">Restricted</button>
      <button class="tu-pill" data-rarity="Classified" style="--rc:#d32ce6">Classified</button>
    </div>
  </div>

  <!-- Main layout -->
  <div class="tu-layout">
    <!-- Input slots -->
    <div class="tu-inputs-panel">
      <div class="tu-panel-head">
        <h2>Input Skins <span class="tu-slot-counter" id="slotCounter">0/10</span></h2>
        <button class="tu-clear-btn" id="clearAll">Clear All</button>
      </div>
      <div class="tu-slots" id="inputSlots">
        <!-- 10 input slots rendered by JS -->
      </div>
      <div class="tu-input-total" id="inputTotal">
        Total Cost: <strong>$0.00</strong>
      </div>
    </div>

    <!-- Arrow -->
    <div class="tu-arrow">
      <svg viewBox="0 0 24 24" width="36" height="36" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
    </div>

    <!-- Output / Results -->
    <div class="tu-output-panel">
      <h2>Possible Outcomes</h2>
      <div class="tu-outcomes" id="outputOutcomes">
        <div class="tu-empty-state">
          <p>Add skins to see possible outcomes</p>
        </div>
      </div>
    </div>
  </div>

  <!-- Stats -->
  <div class="tuc-stats" id="tuStats" style="display:none">
    <!-- EV Summary Banner -->
    <div class="tuc-ev-banner" id="evBanner">
      <div class="tuc-ev-banner-left">
        <div class="tuc-ev-verdict-label">Trade-Up Verdict</div>
        <div class="tuc-ev-verdict-text" id="verdictBanner">---</div>
      </div>
      <div class="tuc-ev-banner-right">
        <div class="tuc-ev-profit" id="evProfit">$0.00</div>
        <div class="tuc-ev-profit-label" id="evProfitLabel">Expected Profit/Loss</div>
      </div>
    </div>

    <!-- EV Comparison Bar -->
    <div class="tuc-ev-compare" id="evCompare">
      <div class="tuc-ev-compare-row">
        <span class="tuc-ev-compare-label">Input Cost</span>
        <div class="tuc-ev-bar-track">
          <div class="tuc-ev-bar input-bar" id="inputBar" style="width:50%"></div>
        </div>
        <span class="tuc-ev-compare-val" id="inputCostDisplay">$0.00</span>
      </div>
      <div class="tuc-ev-compare-row">
        <span class="tuc-ev-compare-label">Expected Output</span>
        <div class="tuc-ev-bar-track">
          <div class="tuc-ev-bar output-bar" id="outputBar" style="width:50%"></div>
        </div>
        <span class="tuc-ev-compare-val" id="outputEvDisplay">$0.00</span>
      </div>
    </div>

    <div class="tuc-stats-grid">
      <div class="tuc-stat-card" id="evCard">
        <div class="tuc-stat-val" id="evResult">$0.00</div>
        <div class="tuc-stat-label">Expected Value</div>
      </div>
      <div class="tuc-stat-card" id="roiCard">
        <div class="tuc-stat-val" id="roiResult">0%</div>
        <div class="tuc-stat-label">Expected ROI</div>
      </div>
      <div class="tuc-stat-card">
        <div class="tuc-stat-val" id="profitChance">0%</div>
        <div class="tuc-stat-label">Profit Probability</div>
      </div>
      <div class="tuc-stat-card" id="verdictCard">
        <div class="tuc-stat-val" id="verdict">---</div>
        <div class="tuc-stat-label">Verdict</div>
      </div>
    </div>

    <!-- EV Formula Explanation -->
    <div class="tuc-ev-formula" id="evFormula">
      <div class="tuc-ev-formula-title">EV Breakdown</div>
      <div class="tuc-ev-formula-text" id="evFormulaText">
        EV = sum of (output price x probability) for all possible outcomes
      </div>
    </div>
  </div>

  <!-- Float Calculator -->
  <div class="tuc-float-panel">
    <h2 class="tuc-section-title">Float Value Calculator</h2>
    <p class="tuc-float-desc">The average float of your input skins is auto-calculated when you add skins. You can also enter values manually.</p>
    <div class="tuc-float-fields">
      <div class="tuc-field">
        <label class="tuc-label" for="avgFloat">Average Input Float</label>
        <input type="number" id="avgFloat" min="0" max="1" step="0.0001" value="0.15" class="tuc-input" />
      </div>
      <div class="tuc-field">
        <label class="tuc-label" for="minFloat">Output Min Float</label>
        <input type="number" id="minFloat" min="0" max="1" step="0.01" value="0.00" class="tuc-input" />
      </div>
      <div class="tuc-field">
        <label class="tuc-label" for="maxFloat">Output Max Float</label>
        <input type="number" id="maxFloat" min="0" max="1" step="0.01" value="0.80" class="tuc-input" />
      </div>
    </div>
    <div class="tuc-float-result">
      <div class="tuc-float-big" id="outputFloat">0.1200</div>
      <p class="tuc-float-sublabel">Predicted Output Float</p>
      <p class="tuc-float-wear" id="wearLabel">Minimal Wear</p>
    </div>
  </div>

  <!-- Trade-Up Info -->
  <div class="tuc-guide">
    <h2 class="tuc-section-title">How Trade-Up Probability Works</h2>
    <p>
      The outcome of a trade-up is determined by the collections your 10 input skins belong to. Each input skin represents one "ticket" in a weighted lottery. If 6 of your skins come from the Fracture Collection and 4 from the Dreams & Nightmares Collection, the output has a 60% chance of being a Fracture skin and 40% chance of being a Dreams & Nightmares skin at the next rarity tier.
    </p>
    <p>
      Within each collection, the specific output skin is randomly selected from all available skins at the target rarity. If the Fracture Collection has 2 Restricted skins, each has an equal 50% chance of being selected (given the Fracture Collection is chosen). This means your effective probability for any specific skin is: <code>(collection tickets / 10) x (1 / skins at target rarity in that collection)</code>.
    </p>

    <h3>Float Value Manipulation</h3>
    <p>
      The output float is calculated using the average float of your 10 inputs, mapped to the output skin's float range. By carefully selecting input skins with very low floats, you can produce outputs in Factory New or Minimal Wear conditions that command premium prices.
    </p>

    <h3>Finding Profitable Trade-Ups</h3>
    <p>
      The most consistently profitable trade-ups share common patterns: cheap input skins from collections that contain high-value outputs at the next tier, combined with collections where the "miss" outcome still returns reasonable value.
    </p>
  </div>

  <!-- FAQ -->
  <section class="tuc-faq">
    <h2 class="tuc-section-title">Frequently Asked Questions</h2>
    {faqs.map(f => (
      <details class="tuc-faq-item">
        <summary class="tuc-faq-q">{f.question}</summary>
        <p class="tuc-faq-a">{f.answer}</p>
      </details>
    ))}
  </section>

  <div class="tuc-links">
    <strong>Related Tools & Guides:</strong>
    <a href="/case-odds-calculator/">Case Odds Calculator</a>
    <a href="/case-simulator/">Case Simulator</a>
    <a href="/cs2-skins/">Skin Database</a>
    <a href="/skin-compare/">Compare Skins</a>
    <a href="/float-checker/">Float Checker</a>
    <a href="/price-tracker/">Price Tracker</a>
    <a href="/market-trends/">Market Trends</a>
    <a href="/cs2-cases/">Cases & Collections</a>
    <a href="/inventory-lookup/">Inventory Lookup</a>
    <a href="/loadout-builder/">Loadout Builder</a>
    <a href="/cs2-weapons/">Weapon Database</a>
    <a href="/cs2-guides/float-guide/">Float Value Guide</a>
    <a href="/cs2-guides/trading-guide/">Trading Guide</a>
    <a href="/cs2-guides/skins-investing-guide/">Skins Investing Guide</a>
    <a href="/cs2-stickers/">Sticker Database</a>
    <a href="/cs2-agents/">Agents & Music Kits</a>
    <a href="/cs2-tools/">All Tools</a>
  </div>

  <!-- Skin Picker Modal -->
  <div class="tu-modal-overlay" id="skinModal">
    <div class="tu-modal">
      <div class="tu-modal-head">
        <h3>Select a Skin</h3>
        <button class="tu-modal-close" id="modalClose">
          <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
      </div>
      <div class="tu-modal-filters">
        <input type="text" id="skinSearch" placeholder="Search skins..." class="tu-modal-search" />
        <select id="collectionFilter" class="tu-modal-select">
          <option value="">All Collections</option>
        </select>
      </div>
      <div class="tu-modal-grid" id="skinGrid">
        <!-- Populated by JS -->
      </div>
    </div>
  </div>

  <ExploreMore context="skins" />
</Base>

<style is:inline>
.tuc-hero{padding:1.5rem 0;margin-bottom:1.5rem}
.tuc-title{font-size:2rem;font-weight:800;margin:0 0 .5rem;color:var(--text)}
.tuc-desc{color:var(--text2);font-size:.95rem;margin:0;max-width:640px;line-height:1.6}

.tu-rarity-bar{display:flex;align-items:center;gap:.75rem;flex-wrap:wrap;margin-bottom:1.5rem;padding:1rem;background:var(--bg2);border:1px solid var(--border);border-radius:4px}
.tu-rarity-label{font-weight:600;font-size:.9rem;color:var(--text)}
.tu-rarity-pills{display:flex;gap:.4rem;flex-wrap:wrap}
.tu-pill{background:var(--bg3);border:1px solid var(--border);color:var(--text2);padding:.35rem .75rem;border-radius:6px;font-size:.82rem;cursor:pointer;transition:all .2s;font-family:inherit}
.tu-pill:hover{border-color:var(--rc);color:var(--rc)}
.tu-pill.active{background:var(--rc);color:#1a1a2e;border-color:var(--rc);font-weight:600}

.tu-layout{display:grid;grid-template-columns:1fr auto 1fr;gap:1rem;align-items:start;margin-bottom:1.5rem}
.tu-arrow{display:flex;align-items:center;justify-content:center;padding-top:3rem;color:var(--accent)}

.tu-inputs-panel,.tu-output-panel{background:var(--bg2);border:1px solid var(--border);border-radius:4px;padding:1.25rem}
.tu-panel-head{display:flex;justify-content:space-between;align-items:center;margin-bottom:1rem}
.tu-panel-head h2{margin:0;font-size:1.15rem}
.tu-slot-counter{font-size:.85rem;color:var(--text2);font-weight:400;margin-left:.5rem}
.tu-clear-btn{background:var(--bg3);border:1px solid var(--border);color:var(--text2);padding:.3rem .6rem;border-radius:5px;font-size:.75rem;cursor:pointer;font-family:inherit;transition:all .15s}
.tu-clear-btn:hover{border-color:var(--accent);color:var(--text)}

.tu-slots{display:grid;grid-template-columns:repeat(5,1fr);gap:.5rem}
.tu-slot{background:var(--bg3);border:2px dashed var(--border);border-radius:4px;min-height:110px;display:flex;flex-direction:column;align-items:center;justify-content:center;cursor:pointer;transition:all .15s;position:relative;padding:.4rem;text-align:center;overflow:hidden}
.tu-slot:hover{border-color:var(--accent);background:rgba(46,204,113,.04)}
.tu-slot.filled{border-style:solid;border-color:var(--slot-color,var(--border))}
.tu-slot.filled:hover{border-color:#ef4444}
.tu-slot-num{position:absolute;top:4px;left:6px;font-size:.6rem;color:var(--text2);font-weight:600}
.tu-slot-add{font-size:1.5rem;color:var(--text2);opacity:.4;line-height:1}
.tu-slot-add-label{font-size:.65rem;color:var(--text2);opacity:.5;margin-top:.2rem}
.tu-slot-img{width:64px;height:48px;object-fit:contain;margin-bottom:.15rem}
.tu-slot-weapon{font-size:.65rem;font-weight:700;color:var(--text);line-height:1.2}
.tu-slot-skin{font-size:.58rem;color:var(--text2);line-height:1.2}
.tu-slot-price{font-size:.6rem;color:var(--accent);font-weight:600;margin-top:.15rem}
.tu-slot-remove{position:absolute;top:3px;right:3px;background:rgba(239,68,68,.8);color:#fff;border:none;border-radius:50%;width:16px;height:16px;font-size:.65rem;cursor:pointer;display:none;align-items:center;justify-content:center;line-height:1}
.tu-slot.filled:hover .tu-slot-remove{display:flex}

.tu-input-total{margin-top:.75rem;padding:.5rem .75rem;background:var(--bg3);border:1px solid var(--border);border-radius:6px;font-size:.88rem;color:var(--text2)}
.tu-input-total strong{color:var(--accent)}

.tu-output-panel h2{margin:0 0 1rem;font-size:1.15rem}
.tu-outcomes{display:flex;flex-direction:column;gap:.6rem}
.tu-empty-state{text-align:center;color:var(--text2);padding:2rem;font-size:.9rem}

.tu-outcome{display:flex;align-items:center;gap:.75rem;padding:.75rem;background:var(--bg3);border:1px solid var(--border);border-radius:4px;border-left:4px solid var(--oc,var(--border))}
.tu-outcome-img{width:64px;height:48px;object-fit:contain;flex-shrink:0;border-radius:4px}
.tu-outcome-info{flex:1;min-width:0}
.tu-outcome-weapon{font-weight:700;font-size:.88rem;color:var(--text)}
.tu-outcome-skin{font-size:.78rem;color:var(--text2)}
.tu-outcome-collection{font-size:.65rem;color:var(--text2);opacity:.7}
.tu-outcome-right{text-align:right;flex-shrink:0}
.tu-outcome-chance{font-size:1rem;font-weight:800;color:var(--accent)}
.tu-outcome-price{font-size:.8rem;color:var(--text2)}
.tu-outcome-ev{font-size:.7rem;margin-top:.15rem}
.tu-outcome-ev.profit{color:#4ade80}
.tu-outcome-ev.loss{color:#ef4444}

.tuc-stats{margin:1.5rem 0}

/* EV Banner */
.tuc-ev-banner{display:flex;justify-content:space-between;align-items:center;padding:1.25rem 1.5rem;border-radius:4px;margin-bottom:.75rem;border:1px solid var(--border);background:var(--bg2);transition:border-color .3s,background .3s}
.tuc-ev-banner.profitable{border-color:#4caf50;background:rgba(76,175,80,.06)}
.tuc-ev-banner.unprofitable{border-color:#ef5350;background:rgba(239,83,80,.06)}
.tuc-ev-banner-left{display:flex;flex-direction:column;gap:.2rem}
.tuc-ev-verdict-label{font-size:.7rem;color:var(--text2);text-transform:uppercase;letter-spacing:.06em;font-weight:600}
.tuc-ev-verdict-text{font-size:1.3rem;font-weight:800;color:var(--text);transition:color .3s}
.tuc-ev-banner.profitable .tuc-ev-verdict-text{color:#4caf50}
.tuc-ev-banner.unprofitable .tuc-ev-verdict-text{color:#ef5350}
.tuc-ev-banner-right{text-align:right}
.tuc-ev-profit{font-size:1.6rem;font-weight:800;transition:color .3s}
.tuc-ev-profit.profit{color:#4caf50}
.tuc-ev-profit.loss{color:#ef5350}
.tuc-ev-profit-label{font-size:.7rem;color:var(--text2);text-transform:uppercase;letter-spacing:.04em;margin-top:.15rem}

/* EV Comparison Bars */
.tuc-ev-compare{background:var(--bg2);border:1px solid var(--border);border-radius:4px;padding:1rem 1.25rem;margin-bottom:.75rem;display:flex;flex-direction:column;gap:.6rem}
.tuc-ev-compare-row{display:flex;align-items:center;gap:.75rem}
.tuc-ev-compare-label{width:110px;flex-shrink:0;font-size:.78rem;color:var(--text2);font-weight:600;text-transform:uppercase;letter-spacing:.03em}
.tuc-ev-bar-track{flex:1;height:22px;background:var(--bg3);border-radius:4px;overflow:hidden;position:relative}
.tuc-ev-bar{height:100%;border-radius:4px;transition:width .4s ease}
.tuc-ev-bar.input-bar{background:#ef5350}
.tuc-ev-bar.output-bar{background:#4caf50}
.tuc-ev-compare-val{width:80px;flex-shrink:0;font-size:.85rem;font-weight:700;color:var(--text);text-align:right}

.tuc-stats-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:.75rem}
.tuc-stat-card{background:var(--bg2);border:1px solid var(--border);border-radius:4px;padding:1rem;text-align:center;transition:border-color .3s}
.tuc-stat-card.stat-profit{border-color:#4caf50}
.tuc-stat-card.stat-loss{border-color:#ef5350}
.tuc-stat-val{font-size:1.5rem;font-weight:800;color:var(--accent)}
.tuc-stat-label{font-size:.75rem;color:var(--text2);text-transform:uppercase;letter-spacing:.04em;margin-top:.25rem}

/* EV Formula */
.tuc-ev-formula{background:var(--bg2);border:1px solid var(--border);border-left:3px solid var(--accent);border-radius:4px;padding:.75rem 1rem;margin-top:.75rem}
.tuc-ev-formula-title{font-size:.75rem;color:var(--text2);text-transform:uppercase;letter-spacing:.05em;font-weight:700;margin-bottom:.35rem}
.tuc-ev-formula-text{font-size:.8rem;color:var(--text2);line-height:1.6;font-family:'Courier New',monospace}

.tuc-float-panel{background:var(--bg2);border:1px solid var(--border);border-radius:4px;padding:1.5rem;margin-top:2rem}
.tuc-section-title{font-size:1.1rem;font-weight:700;color:var(--text);margin:0 0 .75rem}
.tuc-float-desc{color:var(--text2);font-size:.9rem;margin:0 0 1rem}
.tuc-float-fields{display:grid;grid-template-columns:1fr 1fr 1fr;gap:1rem;margin-bottom:1rem}
.tuc-field{display:flex;flex-direction:column;gap:.4rem}
.tuc-label{font-weight:600;color:var(--text2);font-size:.85rem;text-transform:uppercase;letter-spacing:.04em}
.tuc-input{padding:.6rem;background:var(--bg3);border:1px solid var(--border);border-radius:4px;color:var(--text);font-size:.95rem;font-family:inherit}
.tuc-input:focus{outline:none;border-color:var(--accent)}
.tuc-float-result{background:var(--bg);border:1px solid var(--border);border-left:3px solid var(--accent);border-radius:4px;padding:1.25rem;text-align:center}
.tuc-float-big{font-size:2rem;font-weight:800;color:var(--accent)}
.tuc-float-sublabel{margin:0;color:var(--text2);font-size:.85rem}
.tuc-float-wear{margin:.5rem 0 0;font-weight:600;color:#4caf50}

.tuc-guide{background:var(--bg2);border:1px solid var(--border);border-left:3px solid var(--accent);border-radius:4px;padding:1.5rem;margin:2rem 0}
.tuc-guide p{color:var(--text2);font-size:.9rem;line-height:1.65;margin:.75rem 0}
.tuc-guide h3{color:var(--text);font-size:1rem;margin:1.5rem 0 .5rem}
.tuc-guide code{background:var(--bg3);padding:.15rem .4rem;border-radius:4px;font-size:.85rem;color:var(--accent)}

.tuc-faq{margin:2rem 0}
.tuc-faq-item{background:var(--bg2);border:1px solid var(--border);border-radius:4px;margin-bottom:.5rem;overflow:hidden}
.tuc-faq-q{padding:.8rem 1rem;cursor:pointer;font-weight:600;font-size:.9rem;color:var(--text);list-style:none;display:flex;align-items:center;justify-content:space-between}
.tuc-faq-q::-webkit-details-marker{display:none}
.tuc-faq-q::after{content:'+';font-size:1.1rem;color:var(--accent);font-weight:700}
.tuc-faq-item[open] .tuc-faq-q::after{content:'-'}
.tuc-faq-item[open]{border-left:3px solid var(--accent)}
.tuc-faq-a{padding:0 1rem .8rem;margin:0;font-size:.88rem;color:var(--text2);line-height:1.6}

.tuc-links{display:flex;flex-wrap:wrap;gap:.5rem;align-items:center;padding:1rem;background:var(--bg2);border:1px solid var(--border);border-radius:4px;margin-bottom:1.5rem}
.tuc-links strong{width:100%;font-size:.85rem;color:var(--text);margin-bottom:.25rem}
.tuc-links a{font-size:.82rem;color:var(--accent);text-decoration:none;padding:.3rem .6rem;background:var(--bg3);border:1px solid var(--border);border-radius:4px;transition:border-color .15s}
.tuc-links a:hover{border-color:var(--accent)}

/* Skin Picker Modal */
.tu-modal-overlay{position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,.7);z-index:1000;display:none;align-items:center;justify-content:center;padding:1rem}
.tu-modal-overlay.open{display:flex}
.tu-modal{background:var(--bg);border:1px solid var(--border);border-radius:4px;width:100%;max-width:800px;max-height:80vh;display:flex;flex-direction:column;overflow:hidden}
.tu-modal-head{display:flex;justify-content:space-between;align-items:center;padding:1rem 1.25rem;border-bottom:1px solid var(--border)}
.tu-modal-head h3{margin:0;font-size:1.1rem}
.tu-modal-close{background:none;border:none;color:var(--text2);cursor:pointer;padding:.25rem;border-radius:4px}
.tu-modal-close:hover{color:var(--text)}
.tu-modal-filters{display:flex;gap:.5rem;padding:.75rem 1.25rem;border-bottom:1px solid var(--border)}
.tu-modal-search{flex:1;background:var(--bg2);color:var(--text);border:1px solid var(--border);padding:.5rem .75rem;border-radius:6px;font-size:.88rem;font-family:inherit}
.tu-modal-search:focus{outline:none;border-color:var(--accent)}
.tu-modal-select{background:var(--bg2);color:var(--text);border:1px solid var(--border);padding:.5rem .75rem;border-radius:6px;font-size:.82rem;font-family:inherit;max-width:220px}
.tu-modal-grid{overflow-y:auto;padding:1rem 1.25rem;display:grid;grid-template-columns:repeat(auto-fill,minmax(160px,1fr));gap:.5rem;max-height:60vh}
.tu-modal-skin{display:flex;flex-direction:column;align-items:center;padding:.6rem;background:var(--bg2);border:1px solid var(--border);border-radius:4px;cursor:pointer;transition:all .15s;text-align:center}
.tu-modal-skin:hover{border-color:var(--accent);}
.tu-modal-skin-img{width:80px;height:60px;object-fit:contain;margin-bottom:.3rem}
.tu-modal-skin-name{font-size:.72rem;font-weight:700;color:var(--text);line-height:1.2}
.tu-modal-skin-desc{font-size:.62rem;color:var(--text2);line-height:1.2;margin-top:.1rem}
.tu-modal-skin-price{font-size:.68rem;color:var(--accent);font-weight:600;margin-top:.2rem}
.tu-modal-skin-coll{font-size:.55rem;color:var(--text2);opacity:.6;margin-top:.1rem;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:100%}
.tu-modal-empty{grid-column:1/-1;text-align:center;color:var(--text2);padding:2rem;font-size:.9rem}

@media(max-width:900px){
  .tu-layout{grid-template-columns:1fr;gap:1rem}
  .tu-arrow{transform:rotate(90deg);padding:0}
  .tu-slots{grid-template-columns:repeat(5,1fr)}
}
@media(max-width:600px){
  .tu-slots{grid-template-columns:repeat(3,1fr)}
  .tu-slot{min-height:90px}
  .tu-modal-grid{grid-template-columns:repeat(2,1fr)}
  .tuc-stats-grid{grid-template-columns:1fr 1fr}
  .tuc-float-fields{grid-template-columns:1fr}
  .tuc-ev-banner{flex-direction:column;gap:.75rem;text-align:center}
  .tuc-ev-banner-right{text-align:center}
  .tuc-ev-compare-label{width:80px;font-size:.7rem}
  .tuc-ev-compare-val{width:65px;font-size:.78rem}
}
</style>

<script define:vars={{ skinDataJson }}>
(function(){
  const allSkins = JSON.parse(skinDataJson);
  const RARITY_ORDER = ['Consumer','Industrial','Mil-Spec','Restricted','Classified','Covert'];
  const RARITY_COLORS = {'Consumer':'#b0c3d9','Industrial':'#5e98d9','Mil-Spec':'#4b69ff','Restricted':'#8847ff','Classified':'#d32ce6','Covert':'#2ecc71'};
  const NEXT_RARITY = {'Consumer':'Industrial','Industrial':'Mil-Spec','Mil-Spec':'Restricted','Restricted':'Classified','Classified':'Covert'};

  let currentRarity = 'Mil-Spec';
  let inputSlots = new Array(10).fill(null); // each slot: skin object or null
  let activeSlotIndex = -1;

  const slotsEl = document.getElementById('inputSlots');
  const slotCounterEl = document.getElementById('slotCounter');
  const clearAllBtn = document.getElementById('clearAll');
  const outcomesEl = document.getElementById('outputOutcomes');
  const inputTotalEl = document.getElementById('inputTotal');
  const statsEl = document.getElementById('tuStats');
  const modalEl = document.getElementById('skinModal');
  const modalCloseBtn = document.getElementById('modalClose');
  const skinSearchEl = document.getElementById('skinSearch');
  const collectionFilterEl = document.getElementById('collectionFilter');
  const skinGridEl = document.getElementById('skinGrid');

  // Render input slots
  function renderSlots() {
    slotsEl.innerHTML = '';
    let filled = 0;
    let totalCost = 0;
    inputSlots.forEach((skin, i) => {
      const slot = document.createElement('div');
      slot.className = 'tu-slot' + (skin ? ' filled' : '');
      if (skin) {
        filled++;
        const price = skin.price ? (skin.price / 100) : 0;
        totalCost += price;
        const color = RARITY_COLORS[skin.rarity] || 'var(--border)';
        slot.style.setProperty('--slot-color', color);
        const imgHtml = skin.image
          ? `<img class="tu-slot-img" src="${skin.image}" alt="${skin.weapon}" loading="lazy" onerror="this.style.display='none'">`
          : '';
        slot.innerHTML = `
          <span class="tu-slot-num">${i+1}</span>
          <button class="tu-slot-remove" data-idx="${i}">&times;</button>
          ${imgHtml}
          <div class="tu-slot-weapon">${skin.weapon}</div>
          <div class="tu-slot-skin">${skin.name}</div>
          ${price > 0 ? `<div class="tu-slot-price">$${price.toFixed(2)}</div>` : ''}
        `;
      } else {
        slot.innerHTML = `
          <span class="tu-slot-num">${i+1}</span>
          <div class="tu-slot-add">+</div>
          <div class="tu-slot-add-label">Add Skin</div>
        `;
      }
      slot.addEventListener('click', (e) => {
        if (e.target.classList.contains('tu-slot-remove')) {
          inputSlots[i] = null;
          renderSlots();
          calculateOutcomes();
          return;
        }
        activeSlotIndex = i;
        openModal();
      });
      slotsEl.appendChild(slot);
    });

    slotCounterEl.textContent = `${filled}/10`;
    inputTotalEl.innerHTML = `Total Cost: <strong>$${totalCost.toFixed(2)}</strong>`;
  }

  // Open skin picker modal
  function openModal() {
    modalEl.classList.add('open');
    skinSearchEl.value = '';
    skinSearchEl.focus();
    populateCollections();
    renderSkinGrid();
  }

  function closeModal() {
    modalEl.classList.remove('open');
    activeSlotIndex = -1;
  }

  // Populate collection dropdown
  function populateCollections() {
    const skins = allSkins.filter(s => s.rarity === currentRarity);
    const collections = [...new Set(skins.map(s => s.collection).filter(Boolean))].sort();
    collectionFilterEl.innerHTML = '<option value="">All Collections</option>';
    collections.forEach(c => {
      const opt = document.createElement('option');
      opt.value = c;
      opt.textContent = c;
      collectionFilterEl.appendChild(opt);
    });
  }

  // Render skin grid in modal
  function renderSkinGrid() {
    const query = skinSearchEl.value.toLowerCase().trim();
    const collFilter = collectionFilterEl.value;
    let skins = allSkins.filter(s => s.rarity === currentRarity);

    if (query) {
      skins = skins.filter(s =>
        s.weapon.toLowerCase().includes(query) ||
        s.name.toLowerCase().includes(query) ||
        (s.collection || '').toLowerCase().includes(query)
      );
    }
    if (collFilter) {
      skins = skins.filter(s => s.collection === collFilter);
    }

    // Sort by price descending
    skins.sort((a, b) => (b.price || 0) - (a.price || 0));

    if (skins.length === 0) {
      skinGridEl.innerHTML = '<div class="tu-modal-empty">No skins found. Try a different search or rarity.</div>';
      return;
    }

    skinGridEl.innerHTML = skins.map(s => {
      const price = s.price ? `$${(s.price / 100).toFixed(2)}` : '';
      const imgHtml = s.image
        ? `<img class="tu-modal-skin-img" src="${s.image}" alt="${s.weapon} ${s.name}" loading="lazy" onerror="this.style.display='none'">`
        : `<div class="tu-modal-skin-img" style="display:flex;align-items:center;justify-content:center;color:var(--text2);font-size:.7rem">No image</div>`;
      return `<div class="tu-modal-skin" data-slug="${s.slug}">
        ${imgHtml}
        <div class="tu-modal-skin-name">${s.weapon}</div>
        <div class="tu-modal-skin-desc">${s.name}</div>
        ${price ? `<div class="tu-modal-skin-price">${price}</div>` : ''}
        <div class="tu-modal-skin-coll">${s.collection || ''}</div>
      </div>`;
    }).join('');

    // Click handlers
    skinGridEl.querySelectorAll('.tu-modal-skin').forEach(el => {
      el.addEventListener('click', () => {
        const slug = el.dataset.slug;
        const skin = allSkins.find(s => s.slug === slug);
        if (skin && activeSlotIndex >= 0) {
          inputSlots[activeSlotIndex] = { ...skin };
          closeModal();
          renderSlots();
          calculateOutcomes();
        }
      });
    });
  }

  // Calculate outcomes
  function calculateOutcomes() {
    const filled = inputSlots.filter(Boolean);
    if (filled.length === 0) {
      outcomesEl.innerHTML = '<div class="tu-empty-state"><p>Add skins to see possible outcomes</p></div>';
      statsEl.style.display = 'none';
      return;
    }

    const nextRarity = NEXT_RARITY[currentRarity];
    if (!nextRarity) {
      outcomesEl.innerHTML = '<div class="tu-empty-state"><p>Covert skins cannot be used in trade-ups</p></div>';
      statsEl.style.display = 'none';
      return;
    }

    // Count collections
    const collectionCounts = {};
    filled.forEach(s => {
      const coll = s.collection || 'Unknown';
      collectionCounts[coll] = (collectionCounts[coll] || 0) + 1;
    });

    const totalInputs = filled.length;

    // Find possible outputs from each collection at next rarity
    const outcomes = [];
    for (const [coll, count] of Object.entries(collectionCounts)) {
      const collectionChance = count / totalInputs;
      const outputSkins = allSkins.filter(s => s.collection === coll && s.rarity === nextRarity);
      if (outputSkins.length === 0) continue;
      const perSkinChance = collectionChance / outputSkins.length;
      outputSkins.forEach(s => {
        outcomes.push({
          ...s,
          chance: perSkinChance,
          collectionTickets: count,
          collectionTotal: outputSkins.length,
        });
      });
    }

    // Sort by chance descending
    outcomes.sort((a, b) => b.chance - a.chance);

    if (outcomes.length === 0) {
      outcomesEl.innerHTML = '<div class="tu-empty-state"><p>No matching output skins found in these collections at the next rarity tier. Try different skins or collections.</p></div>';
      statsEl.style.display = 'none';
      return;
    }

    // Calculate EV
    const totalCost = filled.reduce((sum, s) => sum + (s.price ? s.price / 100 : 0), 0);
    let ev = 0;
    let profitProb = 0;
    outcomes.forEach(o => {
      const price = o.price ? o.price / 100 : 0;
      ev += price * o.chance;
      if (price > totalCost) profitProb += o.chance;
    });

    // Render outcomes
    outcomesEl.innerHTML = outcomes.map(o => {
      const color = RARITY_COLORS[o.rarity] || 'var(--accent)';
      const price = o.price ? o.price / 100 : 0;
      const priceDiff = price - totalCost;
      const evClass = priceDiff >= 0 ? 'profit' : 'loss';
      const imgHtml = o.image
        ? `<img class="tu-outcome-img" src="${o.image}" alt="${o.weapon}" loading="lazy" onerror="this.style.display='none'">`
        : '';
      return `<div class="tu-outcome" style="--oc:${color}">
        ${imgHtml}
        <div class="tu-outcome-info">
          <div class="tu-outcome-weapon">${o.weapon}</div>
          <div class="tu-outcome-skin">${o.name}</div>
          <div class="tu-outcome-collection">${o.collection || ''}</div>
        </div>
        <div class="tu-outcome-right">
          <div class="tu-outcome-chance">${(o.chance * 100).toFixed(1)}%</div>
          ${price > 0 ? `<div class="tu-outcome-price">$${price.toFixed(2)}</div>` : ''}
          ${price > 0 && totalCost > 0 ? `<div class="tu-outcome-ev ${evClass}">${priceDiff >= 0 ? '+' : ''}$${priceDiff.toFixed(2)}</div>` : ''}
        </div>
      </div>`;
    }).join('');

    // Update stats
    statsEl.style.display = 'block';
    const profit = ev - totalCost;
    const roi = totalCost > 0 ? ((ev - totalCost) / totalCost * 100) : 0;
    const isProfitable = roi >= 0;

    // EV Banner
    const bannerEl = document.getElementById('evBanner');
    bannerEl.className = 'tuc-ev-banner ' + (isProfitable ? 'profitable' : 'unprofitable');
    const profitEl = document.getElementById('evProfit');
    profitEl.textContent = `${profit >= 0 ? '+' : ''}$${profit.toFixed(2)}`;
    profitEl.className = 'tuc-ev-profit ' + (isProfitable ? 'profit' : 'loss');
    const verdictBannerEl = document.getElementById('verdictBanner');
    if (roi > 20) { verdictBannerEl.textContent = 'Highly Profitable'; }
    else if (roi > 10) { verdictBannerEl.textContent = 'Strong Buy'; }
    else if (roi > 0) { verdictBannerEl.textContent = 'Marginal Profit'; }
    else if (roi > -10) { verdictBannerEl.textContent = 'Break Even'; }
    else if (roi > -25) { verdictBannerEl.textContent = 'Expected Loss'; }
    else { verdictBannerEl.textContent = 'Avoid This Trade-Up'; }

    // EV Comparison Bars
    const maxVal = Math.max(totalCost, ev, 0.01);
    document.getElementById('inputBar').style.width = `${(totalCost / maxVal * 100).toFixed(1)}%`;
    document.getElementById('outputBar').style.width = `${(ev / maxVal * 100).toFixed(1)}%`;
    document.getElementById('inputCostDisplay').textContent = `$${totalCost.toFixed(2)}`;
    document.getElementById('outputEvDisplay').textContent = `$${ev.toFixed(2)}`;

    // Stat cards
    document.getElementById('evResult').textContent = `$${ev.toFixed(2)}`;
    const evCard = document.getElementById('evCard');
    evCard.className = 'tuc-stat-card ' + (isProfitable ? 'stat-profit' : 'stat-loss');
    document.getElementById('evResult').style.color = isProfitable ? '#4caf50' : '#ef5350';

    const roiEl = document.getElementById('roiResult');
    roiEl.textContent = `${roi >= 0 ? '+' : ''}${roi.toFixed(1)}%`;
    roiEl.style.color = roi >= 0 ? '#4caf50' : '#ef5350';
    const roiCard = document.getElementById('roiCard');
    roiCard.className = 'tuc-stat-card ' + (isProfitable ? 'stat-profit' : 'stat-loss');

    document.getElementById('profitChance').textContent = `${(profitProb * 100).toFixed(1)}%`;

    const vEl = document.getElementById('verdict');
    const verdictCard = document.getElementById('verdictCard');
    if (roi > 20) { vEl.textContent = 'Highly Profitable'; vEl.style.color = '#4caf50'; verdictCard.className = 'tuc-stat-card stat-profit'; }
    else if (roi > 10) { vEl.textContent = 'Strong Buy'; vEl.style.color = '#4caf50'; verdictCard.className = 'tuc-stat-card stat-profit'; }
    else if (roi > 0) { vEl.textContent = 'Marginal Profit'; vEl.style.color = '#d4956e'; verdictCard.className = 'tuc-stat-card'; }
    else if (roi > -10) { vEl.textContent = 'Break Even'; vEl.style.color = '#d4956e'; verdictCard.className = 'tuc-stat-card'; }
    else { vEl.textContent = 'Expected Loss'; vEl.style.color = '#ef5350'; verdictCard.className = 'tuc-stat-card stat-loss'; }

    // EV Formula breakdown
    const formulaParts = outcomes.map(o => {
      const price = o.price ? (o.price / 100).toFixed(2) : '0.00';
      return `$${price} x ${(o.chance * 100).toFixed(1)}%`;
    });
    const formulaText = `EV = ${formulaParts.join(' + ')} = $${ev.toFixed(2)}`;
    const profitFormula = `Profit = $${ev.toFixed(2)} (EV) - $${totalCost.toFixed(2)} (cost) = ${profit >= 0 ? '+' : ''}$${profit.toFixed(2)} (${roi >= 0 ? '+' : ''}${roi.toFixed(1)}%)`;
    document.getElementById('evFormulaText').innerHTML = formulaText + '<br>' + profitFormula;
  }

  // Float calculator
  function calcFloat() {
    var avg = parseFloat(document.getElementById('avgFloat').value) || 0;
    var mn = parseFloat(document.getElementById('minFloat').value) || 0;
    var mx = parseFloat(document.getElementById('maxFloat').value) || 1;
    var out = avg * (mx - mn) + mn;
    document.getElementById('outputFloat').textContent = out.toFixed(4);
    var wear = '', col = '#4caf50';
    if (out < 0.07) { wear = 'Factory New'; col = '#4caf50'; }
    else if (out < 0.15) { wear = 'Minimal Wear'; col = '#26a69a'; }
    else if (out < 0.38) { wear = 'Field-Tested'; col = '#d4956e'; }
    else if (out < 0.45) { wear = 'Well-Worn'; col = '#ff9800'; }
    else { wear = 'Battle-Scarred'; col = '#ef5350'; }
    var el = document.getElementById('wearLabel');
    el.textContent = wear; el.style.color = col;
  }

  // Event listeners
  modalCloseBtn.addEventListener('click', closeModal);
  modalEl.addEventListener('click', (e) => { if (e.target === modalEl) closeModal(); });
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeModal(); });

  skinSearchEl.addEventListener('input', renderSkinGrid);
  collectionFilterEl.addEventListener('change', renderSkinGrid);

  // Rarity pills
  document.querySelectorAll('.tu-pill').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.tu-pill').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      currentRarity = btn.dataset.rarity;
      inputSlots = new Array(10).fill(null);
      renderSlots();
      calculateOutcomes();
    });
  });

  clearAllBtn.addEventListener('click', () => {
    inputSlots = new Array(10).fill(null);
    renderSlots();
    calculateOutcomes();
  });

  ['avgFloat', 'minFloat', 'maxFloat'].forEach(id => {
    document.getElementById(id).addEventListener('input', calcFloat);
  });

  // Init
  renderSlots();
  calcFloat();
})();
</script>
