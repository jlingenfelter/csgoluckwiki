---
import Base from '../../layouts/Base.astro';
import ExploreMore from '../../components/ExploreMore.astro';
import { tradingSites, getTradingSiteBySlug, faqSchema, breadcrumbSchema } from '../../lib/trading-sites';

export async function getStaticPaths() {
  return tradingSites.map(site => ({
    params: { slug: site.slug }
  }));
}

const { slug } = Astro.params;
const site = getTradingSiteBySlug(slug);

if (!site) {
  return Astro.redirect('/trading-sites/');
}

const relatedSites = tradingSites
  .filter(s => s.slug !== site.slug && s.type === site.type)
  .slice(0, 4);

const alternativeSites = tradingSites
  .filter(s => s.slug !== site.slug)
  .slice(0, 5);

// SEO
const pageTitle = `${site.name} Review — CS2 Skin Trading ${site.type === 'marketplace' ? 'Marketplace' : site.type === 'trading' ? 'Bot Trader' : 'Platform'} | CSDB.gg`;
const pageDesc = `Complete ${site.name} review for Counter-Strike 2 skins. Fees: ${site.fees}. Founded ${site.founded}. ${site.trustpilot ? `Trustpilot ${site.trustpilot}★. ` : ''}${site.description}`;

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Trading Sites', url: '/trading-sites/' },
  { name: site.name, url: `/trading-site/${site.slug}/` },
];

const typeLabel = site.type === 'marketplace' ? 'P2P Marketplace' : site.type === 'trading' ? 'Bot Trading' : 'Marketplace + Bot Trading';

const faqs = [
  {
    question: `How much does ${site.name} charge in fees?`,
    answer: `${site.name} charges ${site.fees}. Fees vary depending on whether you're buying or selling, and whether you use the marketplace or bot trading. Always check their website for the most current fee structure.`,
  },
  {
    question: `Is ${site.name} safe and trustworthy?`,
    answer: `${site.name} ${site.trustpilot ? `has a ${site.trustpilot}★ Trustpilot rating` : 'has customer reviews available'} and was founded in ${site.founded}. They ${site.type === 'marketplace' ? 'use P2P escrow' : 'operate automated bot trading'} for transaction security. Always use established platforms and never store more value than you can afford to lose.`,
  },
  {
    question: `What payment methods does ${site.name} accept?`,
    answer: `${site.name} accepts ${site.paymentMethods.join(', ')}. Payment options vary by region and account verification level. Check their website for your location's available methods.`,
  },
  {
    question: `How fast are trades on ${site.name}?`,
    answer: `${site.type === 'trading' ? 'Bot trades on ' + site.name + ' are instant, typically completing within seconds.' : site.type === 'marketplace' ? 'P2P trades on ' + site.name + ' depend on seller availability, typically ranging from minutes to hours.' : site.name + ' offers both instant bot trades and P2P marketplace options with different speeds.'}`,
  },
];
---

<Base title={pageTitle} description={pageDesc} currentNav="/trading-sites/">
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema(breadcrumbs))}></script>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema(faqs))}></script>

  <nav class="breadcrumb">
    <a href="/">Home</a> / <a href="/trading-sites/">Trading Sites</a> / <span>{site.name}</span>
  </nav>

  <!-- Hero Section -->
  <div class="hero-section">
    <div class="hero-left">
      <div class="hero-badges">
        <div class="logo-badge" style={`background-color: ${site.color}40; border: 2px solid ${site.color}`}>
          {site.logo}
        </div>
        <div class="badge-group">
          <span class="type-badge">{typeLabel}</span>
          {site.trustpilot && <span class="rating-badge">★ {site.trustpilot} Trustpilot</span>}
        </div>
      </div>
      <h1>{site.name}</h1>
      <p class="hero-desc">{site.description}</p>
    </div>
    <div class="hero-right">
      <div class="hero-cta-group">
        <a href={site.referralUrl || site.url} target="_blank" rel="noopener noreferrer nofollow" class="cta-button">Visit {site.name} →</a>
        <a href={`/trading-site/${site.slug}/promo-code/`} class="promo-link-btn">Promo Code {site.promoCode ? `"${site.promoCode}"` : '→'}</a>
      </div>
    </div>
  </div>

  <!-- Quick Stats -->
  <section class="stats-section">
    <div class="stat-card">
      <div class="stat-icon">💰</div>
      <div class="stat-label">Fees</div>
      <div class="val">{site.fees}</div>
    </div>
    <div class="stat-card">
      <div class="stat-icon">🏷️</div>
      <div class="stat-label">Type</div>
      <div class="val">{typeLabel}</div>
    </div>
    {site.trustpilot && (
      <div class="stat-card">
        <div class="stat-icon">⭐</div>
        <div class="stat-label">Trustpilot</div>
        <div class="val">{site.trustpilot}★</div>
      </div>
    )}
    <div class="stat-card">
      <div class="stat-icon">📅</div>
      <div class="stat-label">Founded</div>
      <div class="val">{site.founded}</div>
    </div>
  </section>

  <!-- Description Section -->
  <section class="description-section">
    <h2>About {site.name}</h2>
    <p>{site.description}</p>
    <p>Whether you're a casual trader or professional investor, {site.name} offers {site.type === 'marketplace' ? 'direct peer-to-peer trading for potentially better deals' : site.type === 'trading' ? 'fast instant trading for time-conscious traders' : 'both instant and peer-to-peer options'}. Understanding the platform\'s strengths and limitations will help you decide if it\'s the right choice for your trading needs.</p>
  </section>

  <!-- Pros & Cons -->
  <section class="pros-cons-section">
    <div class="pros-column">
      <h3>Pros</h3>
      <ul class="pros-list">
        {site.pros.map(pro => (
          <li>
            <span class="pro-icon">✓</span>
            {pro}
          </li>
        ))}
      </ul>
    </div>
    <div class="cons-column">
      <h3>Cons</h3>
      <ul class="cons-list">
        {site.cons.map(con => (
          <li>
            <span class="con-icon">✗</span>
            {con}
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- Features -->
  <section class="features-section">
    <h2>Key Features</h2>
    <div class="features-grid">
      {site.features.map(feature => (
        <div class="feature-item">
          <span class="feature-icon">⚡</span>
          <span class="feature-text">{feature}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- Payment Methods -->
  <section class="payment-section">
    <h2>Payment Methods</h2>
    <div class="payment-grid">
      {site.paymentMethods.map(method => (
        <div class="payment-method">
          <span class="payment-icon">💳</span>
          {method}
        </div>
      ))}
    </div>
    <p class="payment-note">Payment methods vary by region and account verification level. Check {site.name}'s website for your location's available options.</p>
  </section>

  <!-- How to Trade -->
  <section class="how-to-section">
    <h2>How to Trade on {site.name}</h2>
    <div class="steps-grid">
      <div class="step-card">
        <div class="step-number">1</div>
        <h3>Create Account</h3>
        <p>Sign up on {site.name}'s website with your email. Complete email verification and set up 2FA security. Verify your identity if required by the platform.</p>
      </div>
      <div class="step-card">
        <div class="step-number">2</div>
        <h3>Deposit Skins</h3>
        <p>{site.type === 'marketplace' ? 'List your skins for sale on the marketplace. Set your asking price and wait for buyers.' : site.type === 'trading' ? 'Deposit skins to your account through Steam trade offers. Complete skin verification.' : 'Choose between listing on marketplace or depositing for bot trades. Complete the relevant process.'}</p>
      </div>
      <div class="step-card">
        <div class="step-number">3</div>
        <h3>Browse & Trade</h3>
        <p>{site.type === 'marketplace' ? 'Browse available skins from other sellers. Make offers or accept seller prices. Negotiate if desired.' : site.type === 'trading' ? 'Select skins you want to trade. Accept bot prices and execute the trade instantly.' : 'Use either marketplace or bot trading options based on your preference.'}</p>
      </div>
      <div class="step-card">
        <div class="step-number">4</div>
        <h3>Withdraw Funds</h3>
        <p>Once skins are sold, withdraw proceeds to your preferred payment method. Processing times vary: crypto is fastest, bank transfers slowest (1-7 days).</p>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="faq-section">
    <h2>{site.name} FAQ</h2>
    <dl class="faq">
      <dt>How much does {site.name} charge in fees?</dt>
      <dd>{site.name} charges {site.fees}. Fees vary depending on whether you're buying or selling, and whether you use the marketplace or bot trading. Always check their website for the most current fee structure.</dd>

      <dt>Is {site.name} safe and trustworthy?</dt>
      <dd>{site.name} {site.trustpilot ? `has a ${site.trustpilot}★ Trustpilot rating` : 'has customer reviews available'} and was founded in {site.founded}. They {site.type === 'marketplace' ? 'use P2P escrow' : 'operate automated bot trading'} for transaction security. Always use established platforms and never store more value than you can afford to lose.</dd>

      <dt>What payment methods does {site.name} accept?</dt>
      <dd>{site.name} accepts {site.paymentMethods.join(', ')}. Payment options vary by region and account verification level. Check their website for your location's available methods.</dd>

      <dt>How fast are trades on {site.name}?</dt>
      <dd>{site.type === 'trading' ? `Bot trades on ${site.name} are instant, typically completing within seconds.` : site.type === 'marketplace' ? `P2P trades on ${site.name} depend on seller availability, typically ranging from minutes to hours.` : `${site.name} offers both instant bot trades and P2P marketplace options with different speeds.`}</dd>
    </dl>
  </section>

  <!-- Related Trading Sites -->
  {relatedSites.length > 0 && (
    <section class="related-section">
      <h2>Similar Trading Sites</h2>
      <div class="related-grid">
        {relatedSites.map(relSite => (
          <div class="related-card">
            <div class="related-header">
              <div class="related-logo" style={`background-color: ${relSite.color}40; border: 2px solid ${relSite.color}`}>
                {relSite.logo}
              </div>
              <h3>{relSite.name}</h3>
            </div>
            <p class="related-desc">{relSite.description.substring(0, 120)}...</p>
            <div class="related-meta">
              <span class="meta-item">{relSite.fees}</span>
              {relSite.trustpilot && <span class="meta-item">★ {relSite.trustpilot}</span>}
            </div>
            <a href={`/trading-site/${relSite.slug}/`} class="related-link">View Review →</a>
          </div>
        ))}
      </div>
    </section>
  )}

  <!-- Alternatives -->
  <section class="alternatives-section">
    <h2>Other Trading Platforms</h2>
    <div class="alternatives-grid">
      {alternativeSites.map(altSite => (
        <a href={`/trading-site/${altSite.slug}/`} class="alt-link">
          <span class="alt-name">{altSite.name}</span>
          <span class="alt-arrow">→</span>
        </a>
      ))}
    </div>
  </section>

  <!-- Internal Links -->
  <section class="internal-links-section">
    <h2>Related Resources</h2>
    <div class="internal-links">
      <a href="/trading-sites/">All Trading Sites</a>
      <a href="/guides/trading-guide/">Trading Guide</a>
      <a href="/skins/">Skin Database</a>
      <a href="/price-tracker/">Price Tracker</a>
      <a href="/guides/skins-investing-guide/">Investing Guide</a>
    </div>
  </section>

  <ExploreMore context="skins" />
</Base>

<style is:inline>
  .breadcrumb {
    font-size: 0.85rem;
    color: var(--text2);
    margin-bottom: 1.5rem;
  }

  .breadcrumb a {
    color: var(--accent);
  }

  .hero-section {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 2rem;
    align-items: start;
    margin: -2rem -1.5rem 3rem;
    padding: 3rem 1.5rem;
    background: linear-gradient(135deg, rgba(26, 115, 232, 0.1) 0%, rgba(156, 39, 176, 0.05) 100%);
    border-bottom: 2px solid var(--border);
  }

  .hero-badges {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    margin-bottom: 1rem;
  }

  .logo-badge {
    width: 80px;
    height: 80px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 12px;
    font-weight: 700;
    font-size: 0.9rem;
    flex-shrink: 0;
    color: var(--text);
  }

  .badge-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .type-badge,
  .rating-badge {
    display: inline-block;
    padding: 0.35rem 0.8rem;
    background: rgba(26, 115, 232, 0.2);
    color: #1a73e8;
    border-radius: 6px;
    font-size: 0.8rem;
    font-weight: 600;
    width: fit-content;
  }

  .rating-badge {
    background: rgba(255, 202, 40, 0.2);
    color: #ffca28;
  }

  .hero-left h1 {
    font-size: 2.2rem;
    margin: 0 0 1rem;
    background: linear-gradient(135deg, var(--accent) 0%, #1a73e8 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-desc {
    font-size: 1rem;
    color: var(--text2);
    margin: 0;
    max-width: 600px;
    line-height: 1.6;
  }

  .cta-button {
    display: inline-block;
    padding: 0.9rem 1.8rem;
    background: linear-gradient(135deg, var(--accent) 0%, #1a73e8 100%);
    color: #000;
    border: none;
    border-radius: 8px;
    font-weight: 700;
    font-size: 0.95rem;
    text-align: center;
    cursor: pointer;
    transition: all 0.3s;
    text-decoration: none;
    white-space: nowrap;
  }

  .cta-button:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(26, 115, 232, 0.3);
  }

  .hero-cta-group {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    align-items: flex-end;
  }

  .promo-link-btn {
    display: inline-block;
    padding: 0.5rem 1.2rem;
    background: rgba(74, 222, 128, 0.15);
    color: #4ade80;
    border: 1px solid rgba(74, 222, 128, 0.3);
    border-radius: 6px;
    font-weight: 600;
    font-size: 0.82rem;
    text-align: center;
    cursor: pointer;
    transition: all 0.2s;
    text-decoration: none;
    white-space: nowrap;
  }

  .promo-link-btn:hover {
    background: rgba(74, 222, 128, 0.25);
    border-color: #4ade80;
    transform: translateY(-1px);
  }

  .stats-section {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1.25rem;
    margin: 3rem 0;
  }

  .stat-card {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 1.5rem;
    text-align: center;
    transition: all 0.2s;
  }

  .stat-card:hover {
    border-color: var(--accent);
    transform: translateY(-2px);
  }

  .stat-icon {
    font-size: 1.8rem;
    margin-bottom: 0.75rem;
    display: block;
  }

  .stat-label {
    font-size: 0.8rem;
    color: var(--text2);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 0.5rem;
  }

  .val {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--accent);
  }

  .description-section {
    margin: 3rem 0;
    padding: 2rem;
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 12px;
  }

  .description-section h2 {
    margin: 0 0 1rem;
  }

  .description-section p {
    color: var(--text2);
    line-height: 1.7;
    margin: 0.75rem 0;
  }

  .pros-cons-section {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    margin: 3rem 0;
  }

  .pros-column,
  .cons-column {
    padding: 1.5rem;
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 10px;
  }

  .pros-column h3,
  .cons-column h3 {
    margin: 0 0 1.25rem;
    font-size: 1.1rem;
  }

  .pros-list,
  .cons-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .pros-list li,
  .cons-list li {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 0.75rem 0;
    color: var(--text2);
    line-height: 1.5;
    border-bottom: 1px solid var(--border);
    font-size: 0.9rem;
  }

  .pros-list li:last-child,
  .cons-list li:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .pro-icon {
    color: #4caf50;
    font-weight: 700;
    flex-shrink: 0;
    margin-top: 0.1rem;
  }

  .con-icon {
    color: #e53935;
    font-weight: 700;
    flex-shrink: 0;
    margin-top: 0.1rem;
  }

  .features-section {
    margin: 3rem 0;
  }

  .features-section h2 {
    margin-bottom: 1.5rem;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
    gap: 1rem;
  }

  .feature-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem;
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 8px;
    transition: all 0.2s;
  }

  .feature-item:hover {
    border-color: var(--accent);
    background: var(--bg3);
  }

  .feature-icon {
    font-size: 1.2rem;
    flex-shrink: 0;
  }

  .feature-text {
    font-size: 0.9rem;
    color: var(--text2);
  }

  .payment-section {
    margin: 3rem 0;
    padding: 2rem;
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 12px;
  }

  .payment-section h2 {
    margin: 0 0 1.5rem;
  }

  .payment-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .payment-method {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem;
    background: var(--bg3);
    border: 1px solid var(--border);
    border-radius: 8px;
    font-size: 0.9rem;
    color: var(--text);
  }

  .payment-icon {
    font-size: 1.1rem;
    flex-shrink: 0;
  }

  .payment-note {
    font-size: 0.85rem;
    color: var(--text2);
    margin: 0;
    font-style: italic;
  }

  .how-to-section {
    margin: 3rem 0;
  }

  .how-to-section h2 {
    margin-bottom: 2rem;
  }

  .steps-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1.5rem;
  }

  .step-card {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 1.5rem;
    transition: all 0.2s;
  }

  .step-card:hover {
    border-color: var(--accent);
    transform: translateY(-2px);
  }

  .step-number {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    background: var(--accent);
    color: #000;
    border-radius: 50%;
    font-weight: 700;
    font-size: 1.1rem;
    margin-bottom: 1rem;
  }

  .step-card h3 {
    margin: 0 0 0.75rem;
    font-size: 1rem;
  }

  .step-card p {
    margin: 0;
    font-size: 0.85rem;
    color: var(--text2);
    line-height: 1.6;
  }

  .faq-section {
    margin: 3rem 0;
    padding: 2rem;
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 12px;
  }

  .faq-section h2 {
    margin: 0 0 1.5rem;
    text-align: center;
  }

  .faq {
    margin: 0;
  }

  .faq dt {
    font-weight: 700;
    color: var(--accent);
    padding: 1rem 0 0.5rem;
    border-top: 1px solid var(--border);
    font-size: 0.95rem;
  }

  .faq dt:first-child {
    border-top: none;
    padding-top: 0;
  }

  .faq dd {
    color: var(--text2);
    padding: 0 0 1.25rem;
    margin: 0;
    font-size: 0.9rem;
    line-height: 1.6;
  }

  .related-section {
    margin: 3rem 0;
  }

  .related-section h2 {
    margin-bottom: 1.5rem;
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 1.25rem;
  }

  .related-card {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 1.25rem;
    transition: all 0.2s;
    display: flex;
    flex-direction: column;
  }

  .related-card:hover {
    border-color: var(--accent);
    transform: translateY(-2px);
  }

  .related-header {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
  }

  .related-logo {
    width: 50px;
    height: 50px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 8px;
    font-weight: 700;
    font-size: 0.75rem;
    flex-shrink: 0;
    color: var(--text);
  }

  .related-card h3 {
    margin: 0;
    font-size: 0.95rem;
  }

  .related-desc {
    font-size: 0.8rem;
    color: var(--text2);
    margin: 0.75rem 0;
    line-height: 1.4;
    flex: 1;
  }

  .related-meta {
    display: flex;
    gap: 0.75rem;
    margin-bottom: 1rem;
    font-size: 0.8rem;
    color: var(--text2);
  }

  .meta-item {
    padding: 0.2rem 0.5rem;
    background: var(--bg3);
    border-radius: 4px;
  }

  .related-link {
    color: var(--accent);
    font-weight: 600;
    font-size: 0.8rem;
    text-decoration: none;
    transition: color 0.2s;
  }

  .related-link:hover {
    color: var(--accent2);
  }

  .alternatives-section {
    margin: 3rem 0;
    padding: 2rem;
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 12px;
  }

  .alternatives-section h2 {
    margin: 0 0 1.5rem;
  }

