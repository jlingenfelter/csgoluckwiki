---
import Base from '../layouts/Base.astro';
import AuthorBox from '../components/AuthorBox.astro';
import ExploreMore from '../components/ExploreMore.astro';
import { tradingSites, getTradingSitesByType, getTradingSitesForComparison, faqSchema, breadcrumbSchema } from '../lib/trading-sites';

const title = 'Best CS2 Skin Trading Sites 2026 — Compare Marketplaces & Bot Traders | CSDB.gg';
const description = 'Compare the best CS2 skin trading platforms. Review fees, trustpilot ratings, payment methods, and features of 15+ marketplaces and bot traders like Buff163, Skinport, and CS.MONEY.';

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Trading Sites', url: '/trading-sites/' },
];

const faqs = [
  {
    question: 'Which CS2 trading site is safest?',
    answer: 'Skinport (4.3★), SkinBaron (4.4★), and Tradeit.gg (4.8★) have the highest Trustpilot ratings. Skinport offers custodial escrow for buyer/seller protection, while Tradeit.gg is known for instant execution and reliability. Always verify a site\'s security features and read recent reviews before trading.',
  },
  {
    question: 'Which marketplace has the lowest fees?',
    answer: 'Buff163 has the lowest fees at just 2.5% seller fee, and White Market has 0% buyer fees with only 5% seller fees. CSFloat charges 2% base fee. However, lower fees don\'t always mean better value—consider inventory size, speed, and trustworthiness when choosing a platform.',
  },
  {
    question: 'What\'s the difference between P2P and bot trading?',
    answer: 'P2P (peer-to-peer) marketplaces connect buyers and sellers directly; you negotiate prices and wait for matches. Bot trading offers instant trades at set prices from the platform\'s inventory. Bot trades are faster but typically have higher markups. P2P offers better prices but requires patience.',
  },
  {
    question: 'Can I use a credit card on CS2 trading sites?',
    answer: 'Most sites support bank transfers or PayPal rather than direct credit cards. Some accept crypto (Bitcoin, Ethereum, USDT). Always check the specific payment methods listed on each site. Payment options vary by region—EU sites often support SEPA transfers.',
  },
  {
    question: 'Are CS2 trading sites legal?',
    answer: 'CS2 trading platforms operate in a gray area legally. They are not officially licensed by Valve, and item skins remain Valve\'s intellectual property. Trading sites risk closure, so use established platforms with long histories. Never store large amounts of value on any trading platform.',
  },
  {
    question: 'How long do payouts take?',
    answer: 'Payouts vary: bot traders like Tradeit.gg offer instant crypto payouts; Skinport and P2P sites typically take 1-5 business days for bank transfers. Bank transfers are slowest (up to 7 days), while crypto is fastest. Check each site\'s payout speed before choosing.',
  },
  {
    question: 'Which sites work outside the US?',
    answer: 'Most global sites work worldwide: Buff163 (Asia-focused), CS.MONEY (global), DMarket (global). EU-based sites like Skinport, SkinBaron, and GamerPay work best in Europe. Some US-based restrictions apply to certain sites. Verify regional availability before signing up.',
  },
];

const articleSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "description": description,
  "author": { "@type": "Person", "name": "Josh Lingenfelter", "url": "https://www.linkedin.com/in/josh-lingenfelter-8157274b/", "jobTitle": "Director", "worksFor": { "@type": "Organization", "name": "Bettor Media" } },
  "publisher": { "@type": "Organization", "name": "CSDB.gg", "url": "https://csdb.gg" },
  "mainEntityOfPage": "https://csdb.gg/trading-sites/",
  "inLanguage": "en-US"
});
---

<Base title={title} description={description} currentNav="/trading-sites/">
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema(breadcrumbs))}></script>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema(faqs))}></script>
  <script type="application/ld+json" set:html={articleSchema}></script>

  <nav class="breadcrumb">
    <a href="/">Home</a> / <span>Trading Sites</span>
  </nav>

  <!-- Hero Section -->
  <div class="hero-section">
    <div class="hero-content">
      <h1>Best CS2 Skin Trading Sites 2026</h1>
      <p>Compare and review the top 15+ CS2 skin marketplaces and bot traders. Find the best fees, payment methods, trust ratings, and features to match your trading style.</p>
      <div class="hero-stats">
        <div class="stat">
          <span class="stat-value">{tradingSites.length}+</span>
          <span class="stat-label">Trading Platforms</span>
        </div>
        <div class="stat">
          <span class="stat-value">Fees</span>
          <span class="stat-label">2.5% - 12%</span>
        </div>
        <div class="stat">
          <span class="stat-value">4.8★</span>
          <span class="stat-label">Best Rating</span>
        </div>
      </div>
    </div>
    <div class="hero-gradient"></div>
  </div>

  <!-- Filter & Sort Section -->
  <section class="controls-section">
    <div class="controls-left">
      <h2>Filter by Type</h2>
      <div class="filter-pills">
        <button class="filter-pill active" data-filter="all">All Sites</button>
        <button class="filter-pill" data-filter="marketplace">Marketplaces</button>
        <button class="filter-pill" data-filter="trading">Trading Bots</button>
        <button class="filter-pill" data-filter="both">Both Types</button>
      </div>
    </div>
    <div class="controls-right">
      <h2>Sort By</h2>
      <div class="sort-buttons">
        <button class="sort-btn active" data-sort="recommended">Recommended</button>
        <button class="sort-btn" data-sort="fees">Lowest Fees</button>
        <button class="sort-btn" data-sort="rating">Highest Rated</button>
      </div>
    </div>
  </section>

  <!-- Trading Sites Table -->
  <section class="sites-grid-section">
    <div class="sites-table-header">
      <span>Platform</span>
      <span>Rating</span>
      <span>Fees</span>
      <span>Promo Code</span>
      <span class="header-actions">Actions</span>
    </div>
    <div class="sites-table" id="sitesGrid">
      {tradingSites.map(site => (
        <div class="site-row" data-type={site.type} data-rating={site.trustpilot || 0} data-fees={parseInt(site.fees)}>
          <div class="row-identity">
            <div class="row-logo" style={`background-color: ${site.color}20; border: 2px solid ${site.color}`}>
              <img src={`https://www.google.com/s2/favicons?domain=${new URL(site.url).hostname}&sz=32`} alt={site.name} width="32" height="32" loading="lazy" />
            </div>
            <div class="row-name-group">
              <span class="row-name">{site.name}</span>
              <span class="row-type-badge">{site.type === 'both' ? 'Marketplace + Bot' : site.type === 'marketplace' ? 'P2P Marketplace' : 'Bot Trading'}</span>
            </div>
          </div>

          <div class="row-rating">
            {site.trustpilot ? (
              <>
                <span class="row-star">★</span>
                <span class="row-rating-val">{site.trustpilot}</span>
                <span class="row-rating-label">Trustpilot</span>
              </>
            ) : (
              <span class="row-no-data">—</span>
            )}
          </div>

          <div class="row-fees">{site.fees}</div>

          <div class="row-promo">
            {site.promoCode ? (
              <div class="row-promo-chip">
                <span class="row-promo-code">{site.promoCode}</span>
                {site.promoBonus && <span class="row-promo-bonus">{site.promoBonus}</span>}
              </div>
            ) : (
              <span class="row-no-data">—</span>
            )}
          </div>

          <div class="row-actions">
            <a href={site.referralUrl || site.url} target="_blank" rel="noopener noreferrer nofollow" class="row-btn-visit">Visit Site →</a>
            <a href={`/trading-site/${site.slug}/`} class="row-btn-review">Review</a>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Comparison Table Section -->
  <section class="comparison-section">
    <h2>Trading Sites Comparison Table</h2>
    <div class="comparison-table-wrapper">
      <table class="comparison-table">
        <thead>
          <tr>
            <th>Site</th>
            <th>Type</th>
            <th>Fees</th>
            <th>Trustpilot</th>
            <th>Founded</th>
            <th>Payment Methods</th>
          </tr>
        </thead>
        <tbody>
          {getTradingSitesForComparison().map(site => (
            <tr>
              <td class="site-name">
                <img src={`https://www.google.com/s2/favicons?domain=${new URL(site.url).hostname}&sz=22`} alt="" width="22" height="22" loading="lazy" style="vertical-align:middle;margin-right:0.4rem;border-radius:3px" />
                <strong>{site.name}</strong>
              </td>
              <td class="site-type-col">
                {site.type === 'both' ? '🔄 Both' : site.type === 'marketplace' ? '💱 P2P' : '⚡ Bot'}
              </td>
              <td class="fees-col">{site.fees}</td>
              <td class="rating-col">
                {site.trustpilot ? `${site.trustpilot}★` : '—'}
              </td>
              <td class="founded-col">{site.founded}</td>
              <td class="payments-col">
                {site.paymentMethods.slice(0, 2).join(', ')}
                {site.paymentMethods.length > 2 && <span class="more-payments">+{site.paymentMethods.length - 2}</span>}
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <!-- How to Choose Guide -->
  <section class="guide-section">
    <h2>How to Choose the Right Trading Platform</h2>
    <div class="guide-grid">
      <div class="guide-card">
        <span class="guide-icon">🏠</span>
        <h3>If You Want Low Fees</h3>
        <p><strong>Choose:</strong> Buff163 (2.5%), CSFloat (2%), or White Market (0% buyer)</p>
        <p>Lower fees mean more money in your pocket, but factor in speed, inventory, and trustworthiness. The cheapest site isn't always the best value.</p>
      </div>
      <div class="guide-card">
        <span class="guide-icon">⚡</span>
        <h3>If You Want Speed</h3>
        <p><strong>Choose:</strong> Tradeit.gg (4.8s), SkinsMonkey (8.2s), or CS.MONEY bot trades</p>
        <p>Bot trading offers instant execution at preset prices. Perfect for traders who value speed over negotiating the best deal.</p>
      </div>
      <div class="guide-card">
        <span class="guide-icon">🔒</span>
        <h3>If You Want Safety</h3>
        <p><strong>Choose:</strong> Skinport (4.3★), Tradeit.gg (4.8★), or SkinBaron (4.4★)</p>
        <p>High Trustpilot ratings and established platforms with strong security features. Prioritize trust over saving 1-2% on fees.</p>
      </div>
      <div class="guide-card">
        <span class="guide-icon">🌍</span>
        <h3>If You're in EU</h3>
        <p><strong>Choose:</strong> SkinBaron, Skinport, or GamerPay</p>
        <p>EU-based platforms offer PayPal, SEPA transfers, and better compliance. Faster payouts and local support.</p>
      </div>
      <div class="guide-card">
        <span class="guide-icon">💰</span>
        <h3>If You Want Best Prices</h3>
        <p><strong>Choose:</strong> P2P Marketplaces (Buff163, CSFloat, Skinport)</p>
        <p>P2P lets you negotiate prices directly with sellers. More work than bot trading but potentially better deals for patient traders.</p>
      </div>
      <div class="guide-card">
        <span class="guide-icon">🎮</span>
        <h3>If You Trade Multiple Games</h3>
        <p><strong>Choose:</strong> CS.MONEY, Tradeit.gg, DMarket, or Loot.Farm</p>
        <p>Multi-game platforms let you trade skins across CS2, Dota 2, Rust, and other titles in one account.</p>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="faq-section">
    <h2>Trading Sites FAQ</h2>
    <dl class="faq">
      <dt>Which CS2 trading site is safest?</dt>
      <dd>Skinport (4.3★), SkinBaron (4.4★), and Tradeit.gg (4.8★) have the highest Trustpilot ratings. Skinport offers custodial escrow for buyer/seller protection, while Tradeit.gg is known for instant execution and reliability. Always verify a site's security features and read recent reviews before trading.</dd>

      <dt>Which marketplace has the lowest fees?</dt>
      <dd>Buff163 has the lowest fees at just 2.5% seller fee, and White Market has 0% buyer fees with only 5% seller fees. CSFloat charges 2% base fee. However, lower fees don't always mean better value—consider inventory size, speed, and trustworthiness when choosing a platform.</dd>

      <dt>What's the difference between P2P and bot trading?</dt>
      <dd>P2P (peer-to-peer) marketplaces connect buyers and sellers directly; you negotiate prices and wait for matches. Bot trading offers instant trades at set prices from the platform's inventory. Bot trades are faster but typically have higher markups. P2P offers better prices but requires patience.</dd>

      <dt>Can I use a credit card on CS2 trading sites?</dt>
      <dd>Most sites support bank transfers or PayPal rather than direct credit cards. Some accept crypto (Bitcoin, Ethereum, USDT). Always check the specific payment methods listed on each site. Payment options vary by region—EU sites often support SEPA transfers.</dd>

      <dt>Are CS2 trading sites legal?</dt>
      <dd>CS2 trading platforms operate in a gray area legally. They are not officially licensed by Valve, and item skins remain Valve's intellectual property. Trading sites risk closure, so use established platforms with long histories. Never store large amounts of value on any trading platform.</dd>

      <dt>How long do payouts take?</dt>
      <dd>Payouts vary: bot traders like Tradeit.gg offer instant crypto payouts; Skinport and P2P sites typically take 1-5 business days for bank transfers. Bank transfers are slowest (up to 7 days), while crypto is fastest. Check each site's payout speed before choosing.</dd>

      <dt>Which sites work outside the US?</dt>
      <dd>Most global sites work worldwide: Buff163 (Asia-focused), CS.MONEY (global), DMarket (global). EU-based sites like Skinport, SkinBaron, and GamerPay work best in Europe. Some US-based restrictions apply to certain sites. Verify regional availability before signing up.</dd>
    </dl>
  </section>

  <!-- Related Links -->
  <section class="related-section">
    <h2>Related Resources</h2>
    <div class="internal-links">
      <a href="/skins/">Skin Database</a>
      <a href="/guides/trading-guide/">Trading Guide</a>
      <a href="/price-tracker/">Price Tracker</a>
      <a href="/guides/skins-investing-guide/">Investing Guide</a>
      <a href="/weapons/">Weapons Database</a>
    </div>
  </section>

  <ExploreMore context="skins" />
  <AuthorBox updated="2026-03-02" />
</Base>

<style>
  .breadcrumb {
    font-size: 0.85rem;
    color: var(--text2);
    margin-bottom: 1.5rem;
  }

  .breadcrumb a {
    color: var(--accent);
  }

  .hero-section {
    position: relative;
    margin: -2rem -1.5rem 3rem;
    padding: 3rem 1.5rem;
    background: linear-gradient(135deg, rgba(26, 115, 232, 0.1) 0%, rgba(156, 39, 176, 0.05) 100%);
    border-bottom: 2px solid var(--border);
    overflow: hidden;
  }

  .hero-gradient {
    position: absolute;
    top: 0;
    right: -200px;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(26, 115, 232, 0.08) 0%, transparent 70%);
    pointer-events: none;
  }

  .hero-content {
    position: relative;
    z-index: 1;
    max-width: 900px;
  }

  .hero-content h1 {
    font-size: 2.5rem;
    margin-bottom: 1rem;
    background: linear-gradient(135deg, var(--accent) 0%, #1a73e8 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-content > p {
    font-size: 1.05rem;
    color: var(--text2);
    margin-bottom: 2rem;
    max-width: 700px;
  }

  .hero-stats {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: 1.5rem;
    margin-top: 2rem;
  }

  .stat {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .stat-value {
    font-size: 1.8rem;
    font-weight: 800;
    color: var(--accent);
  }

  .stat-label {
    font-size: 0.85rem;
    color: var(--text2);
  }

  .controls-section {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    margin: 2.5rem 0;
    padding: 1.5rem;
    background: var(--bg2);
    border-radius: 10px;
    border: 1px solid var(--border);
  }

  .controls-section h2 {
    margin: 0 0 1rem;
    font-size: 1rem;
  }

  .filter-pills,
  .sort-buttons {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .filter-pill,
  .sort-btn {
    background: var(--bg3);
    color: var(--text2);
    border: 1px solid var(--border);
    padding: 0.5rem 1rem;
    border-radius: 6px;
    cursor: pointer;
    font-size: 0.85rem;
    font-weight: 500;
    font-family: inherit;
    transition: all 0.2s;
  }

  .filter-pill:hover,
  .filter-pill.active,
  .sort-btn:hover,
  .sort-btn.active {
    background: var(--accent);
    color: #000;
    border-color: var(--accent);
  }

  .sites-grid-section {
    margin: 3rem 0;
  }

  /* ── Column Header ── */
  .sites-table-header {
    display: grid;
    grid-template-columns: minmax(200px, 1.5fr) 120px 140px 180px auto;
    gap: 1rem;
    padding: 0.6rem 1.25rem;
    font-size: 0.72rem;
    font-weight: 700;
    color: var(--text2);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-bottom: 2px solid var(--border);
    background: var(--bg3);
    border-radius: 10px 10px 0 0;
  }
  .header-actions { text-align: right; }

  /* ── Table Container ── */
  .sites-table {
    display: flex;
    flex-direction: column;
  }

  /* ── Row ── */
  .site-row {
    display: grid;
    grid-template-columns: minmax(200px, 1.5fr) 120px 140px 180px auto;
    align-items: center;
    gap: 1rem;
    padding: 0.9rem 1.25rem;
    background: var(--bg2);
    border: 1px solid var(--border);
    border-top: none;
    transition: background 0.15s;
  }
  .site-row:first-child { border-top: 1px solid var(--border); }
  .site-row:last-child { border-radius: 0 0 10px 10px; }
  .site-row:hover { background: var(--bg3); }

  /* Identity: logo + name + badge */
  .row-identity {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    min-width: 0;
  }
  .row-logo {
    width: 40px; height: 40px;
    display: flex; align-items: center; justify-content: center;
    border-radius: 8px; flex-shrink: 0;
  }
  .row-name-group {
    display: flex; flex-direction: column; gap: 0.2rem; min-width: 0;
  }
  .row-name {
    font-size: 0.95rem; font-weight: 700; color: var(--text);
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }
  .row-type-badge {
    display: inline-block; padding: 0.15rem 0.5rem;
    background: rgba(26, 115, 232, 0.15); color: #1a73e8;
    border-radius: 3px; font-size: 0.65rem; font-weight: 600; width: fit-content;
  }

  /* Rating */
  .row-rating { display: flex; align-items: center; gap: 0.3rem; }
  .row-star { color: #ffca28; font-size: 0.9rem; }
  .row-rating-val { font-size: 0.95rem; font-weight: 700; color: var(--text); }
  .row-rating-label { font-size: 0.7rem; color: var(--text2); }
  .row-no-data { color: var(--text2); font-size: 0.85rem; }

  /* Fees */
  .row-fees { font-size: 0.85rem; color: var(--accent); font-weight: 600; }

  /* Promo */
  .row-promo-chip { display: flex; flex-direction: column; gap: 0.15rem; }
  .row-promo-code {
    display: inline-block; padding: 0.2rem 0.5rem;
    background: rgba(76, 175, 80, 0.12); border: 1px solid rgba(76, 175, 80, 0.25);
    border-radius: 4px; font-size: 0.75rem; font-weight: 700;
    color: #81c784; font-family: monospace; width: fit-content;
  }
  .row-promo-bonus { font-size: 0.7rem; color: var(--accent); font-weight: 500; }

  /* Actions */
  .row-actions { display: flex; gap: 0.5rem; justify-content: flex-end; }
  .row-btn-visit {
    padding: 0.45rem 1rem; background: var(--accent); color: #000;
    border-radius: 6px; font-size: 0.82rem; font-weight: 700;
    text-decoration: none; white-space: nowrap; transition: all 0.2s;
  }
  .row-btn-visit:hover { transform: translateY(-1px); box-shadow: 0 4px 12px rgba(212, 149, 110, 0.3); }
  .row-btn-review {
    padding: 0.45rem 0.75rem; background: var(--bg3); color: var(--text2);
    border: 1px solid var(--border); border-radius: 6px; font-size: 0.82rem;
    font-weight: 600; text-decoration: none; white-space: nowrap; transition: all 0.2s;
  }
  .row-btn-review:hover { color: var(--accent); border-color: var(--accent); }

  /* ── Mobile: stack rows ── */
  @media (max-width: 768px) {
    .sites-table-header { display: none; }
    .site-row {
      grid-template-columns: 1fr 1fr;
      grid-template-rows: auto auto auto;
      gap: 0.5rem 1rem; padding: 1rem;
    }
    .row-identity { grid-column: 1 / -1; }
    .row-promo { grid-column: 1 / -1; }
    .row-actions { grid-column: 1 / -1; justify-content: stretch; }
    .row-btn-visit, .row-btn-review { flex: 1; text-align: center; }
  }

  .comparison-section {
    margin: 3rem 0;
    padding: 2rem;
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 12px;
  }

  .comparison-section h2 {
    margin: 0 0 1.5rem;
    text-align: center;
  }

  .comparison-table-wrapper {
    overflow-x: auto;
  }

  .comparison-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9rem;
  }

  .comparison-table thead {
    background: var(--bg3);
    border-bottom: 2px solid var(--border);
  }

  .comparison-table th {
    padding: 1rem;
    text-align: left;
    font-weight: 700;
    color: var(--text);
  }

  .comparison-table td {
    padding: 0.9rem 1rem;
    border-bottom: 1px solid var(--border);
    color: var(--text2);
  }

  .comparison-table tr:hover {
    background: var(--bg3);
  }

  .site-name {
    font-weight: 600;
    color: var(--text);
  }

  .site-type-col {
    text-align: center;
  }

  .fees-col {
    font-weight: 500;
    color: var(--accent);
  }

  .rating-col {
    text-align: center;
    font-weight: 600;
    color: #ffca28;
  }

  .founded-col {
    text-align: center;
  }

  .payments-col {
    font-size: 0.8rem;
  }

  .more-payments {
    display: block;
    margin-top: 0.2rem;
    color: var(--accent);
    font-weight: 600;
  }

  .guide-section {
    margin: 3rem 0;
  }

  .guide-section h2 {
    text-align: center;
    margin-bottom: 2rem;
  }

  .guide-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.5rem;
  }

  .guide-card {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 1.5rem;
    transition: all 0.2s;
  }

  .guide-card:hover {
    border-color: var(--accent);
    box-shadow: 0 8px 20px rgba(26, 115, 232, 0.1);
  }

