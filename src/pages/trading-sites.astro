<script is:inline>
  document.addEventListener('DOMContentLoaded', function() {
    const filterPills = document.querySelectorAll('.filter-pill');
    const sortBtns = document.querySelectorAll('.sort-btn');
    const rows = document.querySelectorAll('.site-row');

    let currentFilter = 'all';
    let currentSort = 'recommended';

    function applyFilterAndSort() {
      const filtered = Array.from(rows).filter(row => {
        const type = row.getAttribute('data-type');
        if (currentFilter === 'all') return true;
        return type === currentFilter;
      });

      filtered.sort((a, b) => {
        if (currentSort === 'fees') {
          const feesA = parseInt(a.getAttribute('data-fees')) || 0;
          const feesB = parseInt(b.getAttribute('data-fees')) || 0;
          return feesA - feesB;
        } else if (currentSort === 'rating') {
          const ratingA = parseFloat(a.getAttribute('data-rating')) || 0;
          const ratingB = parseFloat(b.getAttribute('data-rating')) || 0;
          return ratingB - ratingA;
        }
        return 0;
      });

      const grid = document.getElementById('sitesGrid');
      rows.forEach(row => (row.style.display = 'none'));
      filtered.forEach(row => (row.style.display = ''));

      grid.innerHTML = '';
      filtered.forEach(row => {
        const clone = row.cloneNode(true);
        grid.appendChild(clone);
      });
    }

    filterPills.forEach(pill => {
      pill.addEventListener('click', function() {
        filterPills.forEach(p => p.classList.remove('active'));
        this.classList.add('active');
        currentFilter = this.getAttribute('data-filter');
        applyFilterAndSort();
      });
    });

    sortBtns.forEach(btn => {
      btn.addEventListener('click', function() {
        sortBtns.forEach(b => b.classList.remove('active'));
        this.classList.add('active');
        currentSort = this.getAttribute('data-sort');
        applyFilterAndSort();
      });
    });
  });
</script>
