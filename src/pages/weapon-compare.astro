---
import Base from '../layouts/Base.astro';
import ExploreMore from '../components/ExploreMore.astro';
import { faqSchema, breadcrumbSchema, toolAppSchema } from '../lib/weapons';

const title = 'CS2 Weapon Compare';
const description = 'Compare CS2 weapons side-by-side. View damage, accuracy, fire rate, cost, and more.';

const weaponStats = [
  { 
    name: 'AK-47',
    cost: 2700,
    damage: 41,
    range: 3000,
    fireRate: 600,
    accuracy: 65,
    recoil: 85,
    armor: 0.75
  },
  {
    name: 'M4A4',
    cost: 3100,
    damage: 33,
    range: 3500,
    fireRate: 666,
    accuracy: 75,
    recoil: 50,
    armor: 0.74
  },
  {
    name: 'M4A1-S',
    cost: 2900,
    damage: 38,
    range: 3500,
    fireRate: 600,
    accuracy: 85,
    recoil: 45,
    armor: 0.8
  },
  {
    name: 'AWP Dragon Lore',
    cost: 4750,
    damage: 115,
    range: 5000,
    fireRate: 41,
    accuracy: 99,
    recoil: 120,
    armor: 0.85
  },
  {
    name: 'Deagle',
    cost: 700,
    damage: 55,
    range: 2000,
    fireRate: 111,
    accuracy: 70,
    recoil: 95,
    armor: 0.75
  },
  {
    name: 'Galil AR',
    cost: 1800,
    damage: 33,
    range: 3000,
    fireRate: 667,
    accuracy: 73,
    recoil: 65,
    armor: 0.75
  }
];

const faq = [
  {
    question: 'What is the best CS2 weapon?',
    answer: 'There is no universally "best" weapon - it depends on your play style, economy, and situation. The AK-47 is popular for T-side aggression, while the M4 weapons are favored for CT-side defense.'
  },
  {
    question: 'Should I use AK-47 or M4A4?',
    answer: 'AK-47 is more rewarding at long range but harder to control. M4A4 is more accurate and consistent. M4A1-S is even more accurate but has lower magazine capacity. Choose based on your aim and engagement range.'
  },
  {
    question: 'When should I buy the AWP?',
    answer: 'Buy the AWP when the team has full economy (over $16,000 total). Never force buy it alone. AWP requires good positioning and map knowledge to be effective.'
  }
];

const schemaData = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faq.map(item => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer
    }
  }))
};
---

<Base title={title} description={description}>
  <script type="application/ld+json" set:html={JSON.stringify(toolAppSchema({ name: 'CS2 Weapon Compare', url: 'https://wiki.csgoluck.com/weapon-compare/', description }))}></script>
  <script type="application/ld+json" set:html={JSON.stringify(schemaData)} />

  <nav class="breadcrumb"><a href="/">Home</a> <span>/</span> <a href="/cs2-tools/">Tools</a> <span>/</span> <span>Weapon Compare</span></nav>

  <div class="wpc-hero">
    <h1 class="wpc-title">CS2 Weapon Compare</h1>
    <p class="wpc-desc">Compare weapons side-by-side to find the best choice for your play style and economy.</p>
  </div>

  <section class="wpc-panel">
    <h2 class="wpc-section-title">Select Weapons</h2>
    <div class="wpc-controls">
      <div class="wpc-field">
        <label class="wpc-label" for="weapon1">Weapon 1</label>
        <select id="weapon1" class="wpc-select">
          {weaponStats.map(w => <option value={w.name} selected={w.name === 'AK-47'}>{w.name}</option>)}
        </select>
      </div>
      <div class="wpc-vs">VS</div>
      <div class="wpc-field">
        <label class="wpc-label" for="weapon2">Weapon 2</label>
        <select id="weapon2" class="wpc-select">
          {weaponStats.map(w => <option value={w.name} selected={w.name === 'M4A4'}>{w.name}</option>)}
        </select>
      </div>
    </div>

    <div class="wpc-table-wrap">
      <table class="wpc-table" id="comparisonTable">
        <thead>
          <tr>
            <th>Stat</th>
            <th id="weapon1Header">AK-47</th>
            <th id="weapon2Header">M4A4</th>
            <th>Difference</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td class="wpc-stat-name">Cost</td>
            <td id="cost1">$2,700</td>
            <td id="cost2">$3,100</td>
            <td class="wpc-diff" id="costDiff">-$400</td>
          </tr>
          <tr>
            <td class="wpc-stat-name">Damage</td>
            <td id="damage1">41</td>
            <td id="damage2">33</td>
            <td class="wpc-diff" id="damageDiff">+8</td>
          </tr>
          <tr>
            <td class="wpc-stat-name">Accuracy</td>
            <td id="accuracy1">65%</td>
            <td id="accuracy2">75%</td>
            <td class="wpc-diff" id="accuracyDiff">-10%</td>
          </tr>
          <tr>
            <td class="wpc-stat-name">Fire Rate</td>
            <td id="fireRate1">600 RPM</td>
            <td id="fireRate2">666 RPM</td>
            <td class="wpc-diff" id="fireRateDiff">-66 RPM</td>
          </tr>
          <tr>
            <td class="wpc-stat-name">Recoil</td>
            <td id="recoil1">85</td>
            <td id="recoil2">50</td>
            <td class="wpc-diff" id="recoilDiff">+35</td>
          </tr>
          <tr>
            <td class="wpc-stat-name">Armor Penetration</td>
            <td id="armor1">75%</td>
            <td id="armor2">74%</td>
            <td class="wpc-diff" id="armorDiff">+1%</td>
          </tr>
        </tbody>
      </table>
    </div>

    <div class="wpc-charts">
      <div class="wpc-chart">
        <h4 class="wpc-chart-title">Damage Comparison</h4>
        <div class="wpc-bar-row">
          <span class="wpc-bar-label" id="chartLabel1">AK-47</span>
          <div class="wpc-bar-track"><div class="wpc-bar-fill" id="damageBar1" style="width:36%"></div></div>
          <span class="wpc-bar-val" id="damageValue1">41</span>
        </div>
        <div class="wpc-bar-row">
          <span class="wpc-bar-label" id="chartLabel2">M4A4</span>
          <div class="wpc-bar-track"><div class="wpc-bar-fill" id="damageBar2" style="width:29%"></div></div>
          <span class="wpc-bar-val" id="damageValue2">33</span>
        </div>
      </div>
      <div class="wpc-chart">
        <h4 class="wpc-chart-title">Accuracy Comparison</h4>
        <div class="wpc-bar-row">
          <span class="wpc-bar-label" id="accuracyLabel1">AK-47</span>
          <div class="wpc-bar-track"><div class="wpc-bar-fill" id="accuracyBar1" style="width:65%"></div></div>
          <span class="wpc-bar-val" id="accuracyValue1">65%</span>
        </div>
        <div class="wpc-bar-row">
          <span class="wpc-bar-label" id="accuracyLabel2">M4A4</span>
          <div class="wpc-bar-track"><div class="wpc-bar-fill" id="accuracyBar2" style="width:75%"></div></div>
          <span class="wpc-bar-val" id="accuracyValue2">75%</span>
        </div>
      </div>
    </div>
  </section>

  <section class="wpc-section">
    <h2 class="wpc-section-title">Weapon Categories</h2>
    <div class="wpc-cat">
      <h3 class="wpc-cat-title">Rifles</h3>
      <div class="wpc-cat-grid">
        <div class="wpc-cat-item"><span>AK-47</span><small>$2,700</small></div>
        <div class="wpc-cat-item"><span>M4A4 / M4A1-S</span><small>$2,900-$3,100</small></div>
        <div class="wpc-cat-item"><span>Galil AR</span><small>$1,800</small></div>
      </div>
    </div>
    <div class="wpc-cat">
      <h3 class="wpc-cat-title">Sniper Rifles</h3>
      <div class="wpc-cat-grid">
        <div class="wpc-cat-item"><span>AWP Dragon Lore</span><small>$4,750</small></div>
      </div>
    </div>
    <div class="wpc-cat">
      <h3 class="wpc-cat-title">Pistols</h3>
      <div class="wpc-cat-grid">
        <div class="wpc-cat-item"><span>Deagle</span><small>$700</small></div>
      </div>
    </div>
  </section>

  <div class="wpc-links">
    <span class="wpc-links-label">Related Tools:</span>
    <a href="/damage-calculator/">Damage Calculator</a>
    <a href="/recoil-patterns/">Recoil Patterns</a>
    <a href="/economy-calculator/">Economy Calculator</a>
    <a href="/skin-compare/">Compare Skins</a>
    <a href="/sensitivity-converter/">Sensitivity Converter</a>
    <a href="/crosshair-generator/">Crosshair Generator</a>
    <a href="/cs2-weapons/">Weapon Database</a>
    <a href="/cs2-skins/">Skin Database</a>
    <a href="/pro-players/">Pro Player Settings</a>
    <a href="/cs2-tools/">All Tools</a>
  </div>

  <section class="wpc-section">
    <h2 class="wpc-section-title">Frequently Asked Questions</h2>
    {faq.map(item => (
      <details class="wpc-faq-item">
        <summary class="wpc-faq-q">{item.question}</summary>
        <div class="wpc-faq-a">{item.answer}</div>
      </details>
    ))}
  </section>

  <ExploreMore context="weapons" />
</Base>

<style>
  /* Hero */
  .wpc-hero{margin-bottom:1.5rem}
  .wpc-title{font-size:1.8rem;font-weight:800;margin:0 0 .5rem}
  .wpc-desc{color:var(--text2);font-size:.95rem;margin:0;line-height:1.6;max-width:700px}

  /* Sections */
  .wpc-panel,.wpc-section{background:var(--bg2);border:1px solid var(--border);border-radius:4px;padding:1.5rem;margin-bottom:1.5rem}
  .wpc-section-title{font-size:1.15rem;font-weight:700;margin:0 0 1rem}

  /* Controls */
  .wpc-controls{display:grid;grid-template-columns:1fr auto 1fr;gap:1rem;align-items:end;margin-bottom:1.5rem}
  .wpc-vs{display:flex;align-items:center;justify-content:center;font-size:1.3rem;font-weight:900;color:var(--accent);padding-bottom:.35rem}
  .wpc-field{display:flex;flex-direction:column;gap:.4rem}
  .wpc-label{font-size:.82rem;font-weight:600;color:var(--text2);text-transform:uppercase;letter-spacing:.03em}
  .wpc-select{padding:.55rem .7rem;background:var(--bg3);border:1px solid var(--border);border-radius:4px;color:var(--text);font-size:.95rem}
  .wpc-select:focus{outline:none;border-color:var(--accent)}

  /* Table */
  .wpc-table-wrap{overflow-x:auto;margin-bottom:1.5rem}
  .wpc-table{width:100%;border-collapse:collapse;font-size:.88rem}
  .wpc-table th{text-align:left;padding:.6rem .75rem;border-bottom:2px solid var(--border);color:var(--text2);font-weight:700;font-size:.8rem;text-transform:uppercase;letter-spacing:.03em}
  .wpc-table td{padding:.55rem .75rem;border-bottom:1px solid var(--border)}
  .wpc-table tbody tr:hover{background:var(--bg3)}
  .wpc-stat-name{font-weight:600;color:var(--text)}
  .wpc-diff{color:var(--accent);font-weight:700;text-align:center}
  .wpc-table th:last-child{text-align:center}

  /* Charts */
  .wpc-charts{display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-top:1rem}
  .wpc-chart{background:var(--bg3);border:1px solid var(--border);border-radius:4px;padding:1.25rem}
  .wpc-chart-title{font-size:.9rem;font-weight:700;margin:0 0 1rem;color:var(--text)}
  .wpc-bar-row{display:flex;align-items:center;gap:.75rem;margin-bottom:.75rem}
  .wpc-bar-row:last-child{margin-bottom:0}
  .wpc-bar-label{width:80px;color:var(--text2);font-size:.85rem;font-weight:600;flex-shrink:0}
  .wpc-bar-track{flex:1;height:12px;background:var(--bg2);border-radius:4px;overflow:hidden}
  .wpc-bar-fill{height:100%;background:var(--accent);border-radius:4px;transition:width .3s}
  .wpc-bar-val{width:50px;text-align:right;color:var(--accent);font-weight:700;font-size:.85rem;flex-shrink:0}

  /* Categories */
  .wpc-cat{margin-bottom:1.25rem}
  .wpc-cat:last-child{margin-bottom:0}
  .wpc-cat-title{font-size:.95rem;font-weight:700;margin:0 0 .6rem;color:var(--text)}
  .wpc-cat-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:.6rem}
  .wpc-cat-item{background:var(--bg3);border:1px solid var(--border);border-radius:4px;padding:.75rem 1rem;display:flex;flex-direction:column;gap:.25rem;transition:border-left .2s}
  .wpc-cat-item:hover{border-left:3px solid var(--accent)}
  .wpc-cat-item span{color:var(--text);font-weight:600;font-size:.9rem}
  .wpc-cat-item small{color:var(--text2);font-size:.82rem}

  /* Links */
  .wpc-links{display:flex;flex-wrap:wrap;gap:.5rem;align-items:center;margin-bottom:1.5rem;padding:1rem;background:var(--bg2);border:1px solid var(--border);border-radius:4px}
  .wpc-links-label{font-weight:700;font-size:.85rem;color:var(--text2);margin-right:.25rem}
  .wpc-links a{color:var(--accent);font-size:.85rem;text-decoration:none;padding:.25rem .5rem;border-radius:4px;border:1px solid var(--border);transition:border-color .2s}
  .wpc-links a:hover{border-color:var(--accent)}

  /* FAQ */
  .wpc-faq-item{background:var(--bg3);border:1px solid var(--border);border-radius:4px;margin-bottom:.5rem;overflow:hidden}
  .wpc-faq-q{padding:.8rem 1rem;cursor:pointer;font-weight:600;font-size:.9rem;color:var(--text);list-style:none;display:flex;align-items:center;justify-content:space-between}
  .wpc-faq-q::-webkit-details-marker{display:none}
  .wpc-faq-q::after{content:'+';font-size:1.1rem;color:var(--accent);font-weight:700}
  .wpc-faq-item[open] .wpc-faq-q::after{content:'-'}
  .wpc-faq-item[open]{border-left:3px solid var(--accent)}
  .wpc-faq-a{padding:0 1rem .8rem;font-size:.88rem;color:var(--text2);line-height:1.6}

  @media(max-width:768px){
    .wpc-controls{grid-template-columns:1fr;gap:.5rem}
    .wpc-vs{padding:0}
    .wpc-charts{grid-template-columns:1fr}
    .wpc-title{font-size:1.4rem}
    .wpc-cat-grid{grid-template-columns:1fr}
  }
</style>

<script>
  const weaponStats = [
    { 
      name: 'AK-47',
      cost: 2700,
      damage: 41,
      range: 3000,
      fireRate: 600,
      accuracy: 65,
      recoil: 85,
      armor: 0.75
    },
    {
      name: 'M4A4',
      cost: 3100,
      damage: 33,
      range: 3500,
      fireRate: 666,
      accuracy: 75,
      recoil: 50,
      armor: 0.74
    },
    {
      name: 'M4A1-S',
      cost: 2900,
      damage: 38,
      range: 3500,
      fireRate: 600,
      accuracy: 85,
      recoil: 45,
      armor: 0.8
    },
    {
      name: 'AWP Dragon Lore',
      cost: 4750,
      damage: 115,
      range: 5000,
      fireRate: 41,
      accuracy: 99,
      recoil: 120,
      armor: 0.85
    },
    {
      name: 'Deagle',
      cost: 700,
      damage: 55,
      range: 2000,
      fireRate: 111,
      accuracy: 70,
      recoil: 95,
      armor: 0.75
    },
    {
      name: 'Galil AR',
      cost: 1800,
      damage: 33,
      range: 3000,
      fireRate: 667,
      accuracy: 73,
      recoil: 65,
      armor: 0.75
    }
  ];

  const weapon1Select = document.getElementById('weapon1');
  const weapon2Select = document.getElementById('weapon2');

  function updateComparison() {
    const w1 = weaponStats.find(w => w.name === weapon1Select.value);
    const w2 = weaponStats.find(w => w.name === weapon2Select.value);

    document.getElementById('weapon1Header').textContent = w1.name;
    document.getElementById('weapon2Header').textContent = w2.name;

    document.getElementById('cost1').textContent = '$' + w1.cost.toLocaleString();
    document.getElementById('cost2').textContent = '$' + w2.cost.toLocaleString();
    document.getElementById('costDiff').textContent = (w1.cost > w2.cost ? '-$' : '+$') + Math.abs(w1.cost - w2.cost).toLocaleString();

    document.getElementById('damage1').textContent = w1.damage;
    document.getElementById('damage2').textContent = w2.damage;
    document.getElementById('damageDiff').textContent = (w1.damage > w2.damage ? '+' : '') + (w1.damage - w2.damage);

    document.getElementById('accuracy1').textContent = w1.accuracy + '%';
    document.getElementById('accuracy2').textContent = w2.accuracy + '%';
    document.getElementById('accuracyDiff').textContent = (w1.accuracy > w2.accuracy ? '+' : '') + (w1.accuracy - w2.accuracy) + '%';

    document.getElementById('fireRate1').textContent = w1.fireRate + ' RPM';
    document.getElementById('fireRate2').textContent = w2.fireRate + ' RPM';
    document.getElementById('fireRateDiff').textContent = (w1.fireRate > w2.fireRate ? '+' : '') + (w1.fireRate - w2.fireRate) + ' RPM';

    document.getElementById('recoil1').textContent = w1.recoil;
    document.getElementById('recoil2').textContent = w2.recoil;
    document.getElementById('recoilDiff').textContent = (w1.recoil > w2.recoil ? '+' : '') + (w1.recoil - w2.recoil);

    document.getElementById('armor1').textContent = (w1.armor * 100).toFixed(0) + '%';
    document.getElementById('armor2').textContent = (w2.armor * 100).toFixed(0) + '%';
    document.getElementById('armorDiff').textContent = (w1.armor > w2.armor ? '+' : '') + ((w1.armor - w2.armor) * 100).toFixed(0) + '%';

    document.getElementById('chartLabel1').textContent = w1.name;
    document.getElementById('chartLabel2').textContent = w2.name;
    document.getElementById('damageValue1').textContent = w1.damage;
    document.getElementById('damageValue2').textContent = w2.damage;
    document.getElementById('damageBar1').style.width = (w1.damage / 115 * 100) + '%';
    document.getElementById('damageBar2').style.width = (w2.damage / 115 * 100) + '%';

    document.getElementById('accuracyLabel1').textContent = w1.name;
    document.getElementById('accuracyLabel2').textContent = w2.name;
    document.getElementById('accuracyValue1').textContent = w1.accuracy + '%';
    document.getElementById('accuracyValue2').textContent = w2.accuracy + '%';
    document.getElementById('accuracyBar1').style.width = w1.accuracy + '%';
    document.getElementById('accuracyBar2').style.width = w2.accuracy + '%';
  }

  weapon1Select.addEventListener('change', updateComparison);
  weapon2Select.addEventListener('change', updateComparison);

  updateComparison();
</script>
