---
import Base from '../../layouts/Base.astro';
import ExploreMore from '../../components/ExploreMore.astro';
import { WEAPONS, WEAPON_CATEGORIES, getWeaponBySlug, getWeaponsByCategory, breadcrumbSchema, faqSchema } from '../../lib/weapons';
import { getSkinsByWeapon, RARITY_COLORS, RARITY_BG, getLowestPrice, getHighestPrice } from '../../lib/skins';
import { PRO_PLAYERS } from '../../lib/pro-players';

export async function getStaticPaths() {
  return WEAPONS.map(weapon => ({
    params: { slug: weapon.slug }
  }));
}

const { slug } = Astro.params;
const weapon = getWeaponBySlug(slug);

if (!weapon) {
  return Astro.redirect('/weapons/');
}

const skins = getSkinsByWeapon(weapon.slug);
const relatedWeapons = getWeaponsByCategory(weapon.category)
  .filter(w => w.slug !== weapon.slug)
  .slice(0, 5);

const categoryInfo = WEAPON_CATEGORIES.find(c => c.slug === weapon.category);
const categoryLabel = categoryInfo?.name || weapon.category.charAt(0).toUpperCase() + weapon.category.slice(1);

const teamLabels: Record<string, string> = { ct: 'Counter-Terrorist', t: 'Terrorist', both: 'Both Sides' };
const teamLabel = teamLabels[weapon.team] || weapon.team;

// Calculate derived stats
const isCosmetic = weapon.cosmetic === true;
const dps = isCosmetic ? 0 : Math.round((weapon.damage * weapon.rpm) / 60);
const ttk = !isCosmetic && weapon.rpm > 0 ? Math.round((60 / weapon.rpm) * 1000) : 0;
const hsKill = !isCosmetic && weapon.damage * weapon.headshotMult >= 100;

// SEO
const pageTitle = isCosmetic
  ? `${weapon.name} Skins — All ${skins.length} CS2 ${weapon.name} Skins & Prices | CSDB.gg`
  : `${weapon.name} — CS2 Stats, Damage, Recoil & ${skins.length} Skins | CSDB.gg`;
const pageDesc = isCosmetic
  ? `Browse all ${skins.length} ${weapon.name} skins in Counter-Strike 2. Compare prices across marketplaces, view all wear conditions, and find the best deals.`
  : `Complete ${weapon.name} guide for Counter-Strike 2. ${weapon.damage} damage, ${weapon.armorPen}% armor penetration, ${weapon.rpm} RPM. Browse ${skins.length} available skins with prices from all marketplaces.`;

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Weapons', url: '/weapons/' },
  { name: categoryLabel, url: `/weapons/${weapon.category}/` },
  { name: weapon.name, url: `/weapon/${weapon.slug}/` }
];

const faqs = isCosmetic ? [
  { question: `How many ${weapon.name} skins are there in CS2?`, answer: `There are currently ${skins.length} ${weapon.name} skins available in Counter-Strike 2. Each skin is available in up to five wear conditions: Factory New, Minimal Wear, Field-Tested, Well-Worn, and Battle-Scarred.` },
  { question: `How do you get ${weapon.name} in CS2?`, answer: `${weapon.category === 'knife' ? 'Knives' : 'Gloves'} can be obtained by opening weapon cases or by trading/purchasing on third-party marketplaces like Buff163, Skinport, or the Steam Community Market.` },
  { question: `Are ${weapon.name} rare in CS2?`, answer: `Yes, ${weapon.category === 'knife' ? 'knives' : 'gloves'} are among the rarest items in CS2. The chance of unboxing one from a case is approximately 0.26% (roughly 1 in 385 cases).` },
  { question: `What is the cheapest ${weapon.name} skin?`, answer: skins.length > 0 ? `${weapon.name} skin prices vary significantly based on the pattern and wear condition. Check our price listings above for current market prices across all major marketplaces.` : `No skins are currently listed for the ${weapon.name}. Check back soon for updated pricing.` },
] : [
  { question: `How much damage does the ${weapon.name} do in CS2?`, answer: `The ${weapon.name} deals ${weapon.damage} base damage per hit with ${weapon.armorPen}% armor penetration. Headshot multiplier is ${weapon.headshotMult}x, meaning a headshot deals ${Math.round(weapon.damage * weapon.headshotMult)} damage before armor reduction.` },
  { question: `How much does the ${weapon.name} cost in CS2?`, answer: `The ${weapon.name} costs $${weapon.price.toLocaleString()} to buy and gives a $${weapon.killReward.toLocaleString()} kill reward. It's available to ${teamLabel.toLowerCase()} players.` },
  { question: `What is the ${weapon.name} fire rate?`, answer: `The ${weapon.name} fires at ${weapon.rpm} rounds per minute (RPM) with a ${weapon.magSize}-round magazine. Reload time is ${weapon.reloadTime} seconds.` },
  { question: `How many skins does the ${weapon.name} have in CS2?`, answer: `The ${weapon.name} currently has ${skins.length} skins available in Counter-Strike 2, ranging across multiple rarity tiers from Consumer Grade to Covert.` },
  { question: `Is the ${weapon.name} good in CS2?`, answer: weapon.description },
];

// Pro players who use this weapon (match loadout skin slugs starting with weapon slug)
const weaponPros = PRO_PLAYERS.filter(p => {
  if (!p.loadout) return false;
  return Object.values(p.loadout).some(skinSlug => skinSlug && skinSlug.startsWith(weapon.slug));
}).slice(0, 8);

// Top skins by price tier
const skinsWithPrice = skins.filter(s => !s.phase).map(s => ({ ...s, low: getLowestPrice(s) }));
const budgetSkins = skinsWithPrice.filter(s => s.low > 0 && s.low <= 10).sort((a, b) => b.low - a.low).slice(0, 5);
const midSkins = skinsWithPrice.filter(s => s.low > 10 && s.low <= 50).sort((a, b) => b.low - a.low).slice(0, 5);
const premiumSkins = skinsWithPrice.filter(s => s.low > 50).sort((a, b) => b.low - a.low).slice(0, 5);
---

<Base title={pageTitle} description={pageDesc} currentNav="/weapons/">
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema(breadcrumbs))}></script>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema(faqs))}></script>

  <nav class="breadcrumb">
    <a href="/">Home</a> / <a href="/weapons/">Weapons</a> / <a href={`/weapons/${weapon.category}/`}>{categoryLabel}</a> / <span>{weapon.name}</span>
  </nav>

  <!-- Hero Header -->
  <div class="wp-hero">
    <div class="wp-hero-left">
      <div class="wp-hero-badges">
        <span class="wp-badge wp-badge-cat">{categoryLabel}</span>
        <span class={`wp-badge wp-badge-team wp-team-${weapon.team}`}>{teamLabel}</span>
        {weapon.subcategory && <span class="wp-badge wp-badge-sub">{weapon.subcategory}</span>}
      </div>
      <h1>{weapon.name}</h1>
      <p class="wp-hero-desc">{weapon.description}</p>
      <div class="wp-hero-tags">
        {weapon.tags.map(tag => (
          <span class="wp-tag">#{tag}</span>
        ))}
      </div>
    </div>
    {!isCosmetic && (
      <div class="wp-hero-right">
        <div class="wp-price-box">
          <div class="wp-price-label">Buy Price</div>
          <div class="wp-price-val">${weapon.price.toLocaleString()}</div>
        </div>
        <div class="wp-price-box small">
          <div class="wp-price-label">Kill Reward</div>
          <div class="wp-price-val">${weapon.killReward.toLocaleString()}</div>
        </div>
      </div>
    )}
    {isCosmetic && skins.length > 0 && (
      <div class="wp-hero-right">
        <div class="wp-price-box">
          <div class="wp-price-label">Available Skins</div>
          <div class="wp-price-val">{skins.length}</div>
        </div>
      </div>
    )}
  </div>

  {!isCosmetic && (
    <Fragment>
    <!-- Stats Cards -->
    <section class="wp-stats-section">
      <h2>Combat Statistics</h2>
      <div class="wp-stats-grid">
        <div class="wp-stat-card">
          <div class="wp-stat-icon">💥</div>
          <div class="wp-stat-val">{weapon.damage}</div>
          <div class="wp-stat-label">Base Damage</div>
        </div>
        <div class="wp-stat-card">
          <div class="wp-stat-icon">🛡️</div>
          <div class="wp-stat-val">{weapon.armorPen}%</div>
          <div class="wp-stat-label">Armor Pen</div>
        </div>
        <div class="wp-stat-card">
          <div class="wp-stat-icon">🎯</div>
          <div class="wp-stat-val">{weapon.headshotMult}x</div>
          <div class="wp-stat-label">HS Multiplier</div>
          {hsKill && <div class="wp-stat-note">1-tap kill</div>}
        </div>
        <div class="wp-stat-card">
          <div class="wp-stat-icon">⚡</div>
          <div class="wp-stat-val">{weapon.rpm}</div>
          <div class="wp-stat-label">Fire Rate (RPM)</div>
        </div>
        <div class="wp-stat-card">
          <div class="wp-stat-icon">📊</div>
          <div class="wp-stat-val">{dps}</div>
          <div class="wp-stat-label">DPS (Raw)</div>
        </div>
        <div class="wp-stat-card">
          <div class="wp-stat-icon">📦</div>
          <div class="wp-stat-val">{weapon.magSize} / {weapon.reserveAmmo}</div>
          <div class="wp-stat-label">Mag / Reserve</div>
        </div>
        <div class="wp-stat-card">
          <div class="wp-stat-icon">🔄</div>
          <div class="wp-stat-val">{weapon.reloadTime}s</div>
          <div class="wp-stat-label">Reload Time</div>
        </div>
        <div class="wp-stat-card">
          <div class="wp-stat-icon">🏃</div>
          <div class="wp-stat-val">{weapon.moveSpeed}</div>
          <div class="wp-stat-label">Move Speed (u/s)</div>
        </div>
        <div class="wp-stat-card">
          <div class="wp-stat-icon">📏</div>
          <div class="wp-stat-val">{weapon.rangeModifier}</div>
          <div class="wp-stat-label">Range Modifier</div>
        </div>
        <div class="wp-stat-card">
          <div class="wp-stat-icon">🔫</div>
          <div class="wp-stat-val">{weapon.penetration}</div>
          <div class="wp-stat-label">Wall Penetration</div>
        </div>
      </div>
    </section>

    <!-- Performance Bars -->
    <section class="wp-bars-section">
      <h2>Performance Overview</h2>
      <div class="wp-bars">
        <div class="wp-bar-row">
          <span class="wp-bar-label">Damage</span>
          <div class="wp-bar-track"><div class="wp-bar-fill" style={`width:${Math.min(weapon.damage / 115 * 100, 100)}%`}></div></div>
          <span class="wp-bar-val">{weapon.damage}</span>
        </div>
        <div class="wp-bar-row">
          <span class="wp-bar-label">Armor Pen</span>
          <div class="wp-bar-track"><div class="wp-bar-fill" style={`width:${weapon.armorPen}%`}></div></div>
          <span class="wp-bar-val">{weapon.armorPen}%</span>
        </div>
        <div class="wp-bar-row">
          <span class="wp-bar-label">Fire Rate</span>
          <div class="wp-bar-track"><div class="wp-bar-fill" style={`width:${Math.min(weapon.rpm / 1000 * 100, 100)}%`}></div></div>
          <span class="wp-bar-val">{weapon.rpm}</span>
        </div>
        <div class="wp-bar-row">
          <span class="wp-bar-label">Accuracy</span>
          <div class="wp-bar-track"><div class="wp-bar-fill" style={`width:${weapon.rangeModifier * 100}%`}></div></div>
          <span class="wp-bar-val">{weapon.rangeModifier}</span>
        </div>
        <div class="wp-bar-row">
          <span class="wp-bar-label">Mobility</span>
          <div class="wp-bar-track"><div class="wp-bar-fill" style={`width:${weapon.moveSpeed / 250 * 100}%`}></div></div>
          <span class="wp-bar-val">{weapon.moveSpeed}</span>
        </div>
      </div>
    </section>
    </Fragment>
  )}

  <!-- Tips -->
  {weapon.tips.length > 0 && (
    <section class="wp-tips-section">
      <h2>Pro Tips for the {weapon.name}</h2>
      <div class="wp-tips-grid">
        {weapon.tips.map((tip, i) => (
          <div class="wp-tip-card">
            <span class="wp-tip-num">{i + 1}</span>
            <p>{tip}</p>
          </div>
        ))}
      </div>
    </section>
  )}

  <!-- Skins -->
  <section class="wp-skins-section">
    <div class="wp-section-header">
      <h2>{skins.length} Available Skins</h2>
      <p>Browse all {weapon.name} skins with live market prices from major marketplaces.</p>
    </div>

    {skins.length > 0 ? (
      <div class="wp-skins-grid">
        {skins.map(skin => {
          const rc = RARITY_COLORS[skin.rarity] || '#d4956e';
          const rbg = RARITY_BG[skin.rarity] || 'rgba(255,255,255,0.05)';
          const low = getLowestPrice(skin);
          const high = getHighestPrice(skin);
          return (
            <a href={`/skin/${skin.slug}/`} class="wp-skin-card" style={`--rc:${rc}`}>
              <div class="wp-skin-img" style={`background:${rbg}`}>
                {skin.image
                  ? <img src={skin.image} alt={`${weapon.name} | ${skin.name}`} loading="lazy" width="256" height="192" />
                  : <div class="wp-skin-ph" style={`color:${rc}`}>{skin.name.substring(0, 2)}</div>
                }
                <span class="wp-skin-rarity" style={`background:${rc}`}>{skin.rarity}</span>
              </div>
              <div class="wp-skin-info">
                <h3>{skin.name}</h3>
                <div class="wp-skin-row">
                  <span class="wp-skin-wears">{skin.prices.length} wear{skin.prices.length !== 1 ? 's' : ''}</span>
                  <span class="wp-skin-price">${low.toFixed(2)}{low !== high ? ` – $${high.toFixed(2)}` : ''}</span>
                </div>
              </div>
            </a>
          );
        })}
      </div>
    ) : (
      <div class="wp-empty">
        <p>No skins available for the {weapon.name} yet. Check back soon!</p>
      </div>
    )}
  </section>

  <!-- Pro Players -->
  {weaponPros.length > 0 && (
    <section class="wp-pros-section">
      <h2>Pro Players Using the {weapon.name}</h2>
      <div class="wp-pros-grid">
        {weaponPros.map(p => (
          <a href={`/player/${p.slug}/`} class="wp-pro-card">
            {p.image && <img src={p.image} alt={p.name} width="40" height="40" loading="lazy" class="wp-pro-img" />}
            <div>
              <strong>{p.name}</strong>
              <span>{p.team} · {p.edpi} eDPI</span>
            </div>
          </a>
        ))}
      </div>
    </section>
  )}

  <!-- Best Skins by Price Tier -->
  {(budgetSkins.length > 0 || midSkins.length > 0 || premiumSkins.length > 0) && (
    <section class="wp-tiers-section">
      <h2>Best {weapon.name} Skins by Price</h2>
      {budgetSkins.length > 0 && (
        <div class="wp-tier">
          <h3>Budget (Under $10)</h3>
          <div class="wp-tier-grid">
            {budgetSkins.map(s => (
              <a href={`/skin/${s.slug}/`} class="wp-tier-card">
                <span class="wp-tier-name">{s.name}</span>
                <span class="wp-tier-price" style={`color:${RARITY_COLORS[s.rarity] || '#fff'}`}>From ${s.low.toFixed(2)}</span>
              </a>
            ))}
          </div>
        </div>
      )}
      {midSkins.length > 0 && (
        <div class="wp-tier">
          <h3>Mid-Range ($10–$50)</h3>
          <div class="wp-tier-grid">
            {midSkins.map(s => (
              <a href={`/skin/${s.slug}/`} class="wp-tier-card">
                <span class="wp-tier-name">{s.name}</span>
                <span class="wp-tier-price" style={`color:${RARITY_COLORS[s.rarity] || '#fff'}`}>From ${s.low.toFixed(2)}</span>
              </a>
            ))}
          </div>
        </div>
      )}
      {premiumSkins.length > 0 && (
        <div class="wp-tier">
          <h3>Premium ($50+)</h3>
          <div class="wp-tier-grid">
            {premiumSkins.map(s => (
              <a href={`/skin/${s.slug}/`} class="wp-tier-card">
                <span class="wp-tier-name">{s.name}</span>
                <span class="wp-tier-price" style={`color:${RARITY_COLORS[s.rarity] || '#fff'}`}>From ${s.low.toFixed(2)}</span>
              </a>
            ))}
          </div>
        </div>
      )}
    </section>
  )}

  <!-- Related Weapons -->
  {relatedWeapons.length > 0 && (
    <section class="wp-related-section">
      <h2>Other {categoryLabel}</h2>
      <div class="wp-related-grid">
        {relatedWeapons.map(rw => (
          <a href={`/weapon/${rw.slug}/`} class="wp-related-card">
            <h3>{rw.name}</h3>
            {!rw.cosmetic ? (
              <div class="wp-related-stats">
                <span>${rw.price.toLocaleString()}</span>
                <span class="wp-related-sep">·</span>
                <span>{rw.damage} dmg</span>
                <span class="wp-related-sep">·</span>
                <span>{rw.rpm} RPM</span>
              </div>
            ) : (
              <div class="wp-related-stats">
                <span>Cosmetic</span>
              </div>
            )}
            <p class="wp-related-desc">{rw.description.substring(0, 90)}…</p>
            <span class="wp-related-link">{rw.cosmetic ? 'View Skins' : 'View Stats'} →</span>
          </a>
        ))}
      </div>
    </section>
  )}

  <!-- Internal Links -->
  <div class="internal-links">
    <strong>Related Tools & Guides:</strong>
    <a href="/damage-calculator/">Damage Calculator</a>
    <a href="/weapon-compare/">Weapon Compare</a>
    <a href="/recoil-patterns/">Recoil Patterns</a>
    <a href="/economy-calculator/">Economy Calculator</a>
    <a href="/sensitivity-converter/">Sensitivity Converter</a>
    <a href="/skins/">Skin Database</a>
    <a href="/skin-compare/">Compare Skins</a>
    <a href="/pro-players/">Pro Player Settings</a>
    <a href={`/weapons/${weapon.category}/`}>All {categoryLabel}</a>
    <a href="/weapons/">Weapons Database</a>
    <a href="/tools/">All Tools</a>
    <a href="/guides/advanced-mechanics-guide/">Advanced Mechanics Guide</a>
    <a href="/guides/beginners-guide/">Beginner's Guide</a>
  </div>

  <!-- FAQ -->
  <section class="wp-faq-section">
    <h2>Frequently Asked Questions</h2>
    <dl class="faq">
      {faqs.map(f => (
        <Fragment>
          <dt>{f.question}</dt>
          <dd>{f.answer}</dd>
        </Fragment>
      ))}
    </dl>
  </section>

  <ExploreMore context="weapons" />
</Base>

<style>
  /* Hero */
  .wp-hero{display:flex;gap:2rem;align-items:flex-start;background:var(--bg2);border:1px solid var(--border);border-radius:12px;padding:2rem;margin-bottom:2rem}
  .wp-hero-left{flex:1}
  .wp-hero-badges{display:flex;gap:.5rem;flex-wrap:wrap;margin-bottom:.75rem}
  .wp-badge{display:inline-block;padding:.25rem .7rem;border-radius:4px;font-size:.78rem;font-weight:600}
  .wp-badge-cat{background:var(--bg3);border:1px solid var(--border);color:var(--text2)}
  .wp-badge-sub{background:var(--bg3);border:1px solid var(--border);color:var(--text2)}
  .wp-badge-team{color:#fff}
  .wp-team-ct{background:#4a8db7}
  .wp-team-t{background:#c44}
  .wp-team-both{background:var(--accent);color:#000}
  .wp-hero h1{margin:0 0 .75rem;font-size:2.2rem}
  .wp-hero-desc{margin:0 0 1rem;color:var(--text2);line-height:1.7;font-size:.95rem}
  .wp-hero-tags{display:flex;gap:.4rem;flex-wrap:wrap}
  .wp-tag{font-size:.75rem;color:var(--accent);background:rgba(0,180,255,.08);padding:.15rem .5rem;border-radius:3px}
  .wp-hero-right{display:flex;flex-direction:column;gap:.75rem;min-width:150px}
  .wp-price-box{background:var(--bg3);border:1px solid var(--border);border-radius:8px;padding:1rem 1.25rem;text-align:center}
  .wp-price-box.small .wp-price-val{font-size:1.1rem;color:var(--text)}
  .wp-price-label{font-size:.75rem;color:var(--text2);margin-bottom:.25rem;text-transform:uppercase;letter-spacing:.05em}
  .wp-price-val{font-size:1.6rem;font-weight:800;color:var(--accent)}

  /* Stats Cards */
  .wp-stats-section{margin-bottom:2.5rem}
  .wp-stats-section h2{margin:0 0 1.25rem}
  .wp-stats-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(150px,1fr));gap:.75rem}
  .wp-stat-card{background:var(--bg2);border:1px solid var(--border);border-radius:10px;padding:1rem;text-align:center;transition:border-color .2s}
  .wp-stat-card:hover{border-color:var(--accent)}
  .wp-stat-icon{font-size:1.3rem;margin-bottom:.4rem}
  .wp-stat-val{font-size:1.3rem;font-weight:800;color:var(--accent);margin-bottom:.15rem}
  .wp-stat-label{font-size:.75rem;color:var(--text2)}
  .wp-stat-note{font-size:.7rem;color:#4caf50;margin-top:.25rem;font-weight:600}

  /* Performance Bars */
  .wp-bars-section{margin-bottom:2.5rem;background:var(--bg2);border:1px solid var(--border);border-radius:12px;padding:1.5rem 2rem}
  .wp-bars-section h2{margin:0 0 1.25rem}
  .wp-bars{display:flex;flex-direction:column;gap:.75rem}
  .wp-bar-row{display:flex;align-items:center;gap:1rem}
  .wp-bar-label{width:90px;font-size:.85rem;color:var(--text2);flex-shrink:0}
  .wp-bar-track{flex:1;height:8px;background:var(--bg3);border-radius:4px;overflow:hidden}
  .wp-bar-fill{height:100%;background:linear-gradient(90deg,var(--accent),#00d4ff);border-radius:4px;transition:width .3s}
  .wp-bar-val{width:55px;text-align:right;font-size:.85rem;font-weight:700;color:var(--accent);flex-shrink:0}

  /* Tips */
  .wp-tips-section{margin-bottom:2.5rem}
  .wp-tips-section h2{margin:0 0 1.25rem}
  .wp-tips-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:.75rem}
  .wp-tip-card{display:flex;gap:.75rem;align-items:flex-start;background:var(--bg2);border:1px solid var(--border);border-radius:8px;padding:1rem 1.25rem}
  .wp-tip-num{display:flex;align-items:center;justify-content:center;min-width:28px;height:28px;background:var(--accent);color:#000;border-radius:50%;font-size:.8rem;font-weight:800;flex-shrink:0}
  .wp-tip-card p{margin:0;font-size:.88rem;line-height:1.5;color:var(--text2)}

  /* Skins */
  .wp-skins-section{margin-bottom:2.5rem}
  .wp-section-header{margin-bottom:1.5rem}
  .wp-section-header h2{margin:0 0 .3rem}
  .wp-section-header p{margin:0;color:var(--text2);font-size:.9rem}
  .wp-skins-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:1rem}
  .wp-skin-card{background:var(--bg2);border:1px solid var(--border);border-radius:10px;overflow:hidden;text-decoration:none;color:inherit;transition:border-color .2s,transform .2s}
