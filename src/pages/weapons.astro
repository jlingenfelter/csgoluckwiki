---
import Base from '../layouts/Base.astro';
import ExploreMore from '../components/ExploreMore.astro';
import { WEAPONS, WEAPON_CATEGORIES, getWeaponsByCategory, breadcrumbSchema } from '../lib/weapons';

const title = 'CS2 Weapons Database — All Guns, Stats & Skins | CSDB.gg';
const description = 'Complete Counter-Strike 2 weapons database. Browse all rifles, SMGs, pistols, heavy weapons, and grenades with damage stats, buy prices, and available skins.';

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Weapons', url: '/weapons/' },
];

const itemListSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "CS2 Weapon Categories",
  "description": "All weapon categories in Counter-Strike 2 including rifles, SMGs, pistols, heavy weapons, grenades, knives, and gloves.",
  "numberOfItems": WEAPON_CATEGORIES.length,
  "itemListElement": WEAPON_CATEGORIES.map((cat, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "name": cat.name,
    "description": cat.description,
    "url": `https://csdb.gg/weapons/${cat.slug}/`
  }))
});
---

<Base title={title} description={description} currentNav="/weapons/">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema(breadcrumbs))} />
    <script type="application/ld+json" set:html={itemListSchema} />
  </Fragment>
  <nav class="breadcrumb">
    <a href="/">Home</a> / <span>Weapons</span>
  </nav>

  <div class="hub-header">
    <h1>CS2 Weapons Database</h1>
    <p>Every weapon in Counter-Strike 2, organized by class. Explore detailed stats, compare loadouts, and browse available skins across {WEAPONS.length} weapons.</p>
  </div>

  <div class="cat-grid">
    {WEAPON_CATEGORIES.map(cat => {
      const weapons = getWeaponsByCategory(cat.slug);
      return (
        <a href={`/weapons/${cat.slug}/`} class="cat-card">
          <div class="cat-icon">{cat.icon}</div>
          <h2>{cat.name}</h2>
          <p class="cat-count">{weapons.length} weapons</p>
          <p class="cat-desc">{cat.description}</p>
          <div class="cat-weapons">
            {weapons.slice(0, 4).map(w => (
              <span class="cat-weapon-chip">{w.name}</span>
            ))}
            {weapons.length > 4 && <span class="cat-weapon-chip more">+{weapons.length - 4} more</span>}
          </div>
          <span class="cat-link">Browse {cat.name} →</span>
        </a>
      );
    })}
  </div>

  <section class="quick-links">
    <h2>Quick Access</h2>
    <div class="weapons-list">
      {WEAPON_CATEGORIES.map(cat => {
        const weapons = getWeaponsByCategory(cat.slug);
        return (
          <div class="wl-group">
            <h3><a href={`/weapons/${cat.slug}/`}>{cat.icon} {cat.name}</a></h3>
            <div class="wl-items">
              {weapons.map(w => (
                <a href={`/weapon/${w.slug}/`} class="wl-item">{w.name}</a>
              ))}
            </div>
          </div>
        );
      })}
    </div>
  </section>

  <section class="tools-cta">
    <h2>Weapon Tools</h2>
    <div class="tools-grid">
      <a href="/damage-calculator/" class="tool-card">
        <span class="tool-icon">💥</span>
        <h3>Damage Calculator</h3>
        <p>Calculate exact damage with armor, range, and penetration</p>
      </a>
      <a href="/weapon-compare/" class="tool-card">
        <span class="tool-icon">⚖️</span>
        <h3>Weapon Compare</h3>
        <p>Compare stats side-by-side between any two weapons</p>
      </a>
      <a href="/recoil-patterns/" class="tool-card">
        <span class="tool-icon">📊</span>
        <h3>Recoil Patterns</h3>
        <p>View and learn spray patterns for every weapon</p>
      </a>
      <a href="/economy-calculator/" class="tool-card">
        <span class="tool-icon">💰</span>
        <h3>Economy Calculator</h3>
        <p>Plan your buy rounds and optimise team economy</p>
      </a>
    </div>
  </section>

  <ExploreMore context="weapons" />
</Base>

<style>
  .hub-header{text-align:center;margin-bottom:2.5rem;padding-bottom:2rem;border-bottom:1px solid var(--border)}
  .hub-header h1{margin:0 0 .75rem;font-size:2.2rem}
  .hub-header p{max-width:650px;margin:0 auto;color:var(--text2);line-height:1.7}

  .cat-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(320px,1fr));gap:1.25rem;margin:2rem 0}
  .cat-card{display:flex;flex-direction:column;background:var(--bg2);border:1px solid var(--border);border-radius:12px;padding:1.5rem;text-decoration:none;color:inherit;transition:border-color .2s,transform .2s}
  .cat-card:hover{border-color:var(--accent);transform:translateY(-3px);box-shadow:0 8px 24px rgba(0,0,0,.3)}
  .cat-icon{font-size:2.5rem;margin-bottom:.75rem}
  .cat-card h2{margin:0 0 .25rem;font-size:1.3rem}
  .cat-count{margin:0 0 .5rem;font-size:.85rem;color:var(--accent);font-weight:600}
  .cat-desc{font-size:.88rem;color:var(--text2);line-height:1.5;flex:1;margin:0 0 1rem}
  .cat-weapons{display:flex;gap:.4rem;flex-wrap:wrap;margin-bottom:1rem}
  .cat-weapon-chip{padding:.2rem .5rem;background:var(--bg3);border:1px solid var(--border);border-radius:4px;font-size:.75rem;color:var(--text2)}
  .cat-weapon-chip.more{color:var(--accent);border-color:var(--accent)}
  .cat-link{color:var(--accent);font-weight:700;font-size:.9rem}

  .quick-links{margin:3rem 0;padding:2rem;background:var(--bg2);border:1px solid var(--border);border-radius:12px}
  .quick-links h2{margin:0 0 1.5rem;text-align:center}
  .weapons-list{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:1.5rem}
  .wl-group h3{margin:0 0 .5rem;font-size:.95rem}
  .wl-group h3 a{color:var(--accent)}
  .wl-items{display:flex;flex-direction:column;gap:.25rem}
  .wl-item{font-size:.85rem;color:var(--text2);text-decoration:none;padding:.2rem 0}
  .wl-item:hover{color:var(--accent)}

  .tools-cta{margin:3rem 0}
  .tools-cta h2{text-align:center;margin-bottom:1.5rem}
  .tools-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:1rem}
  .tool-card{background:var(--bg2);border:1px solid var(--border);border-radius:10px;padding:1.25rem;text-decoration:none;color:inherit;transition:border-color .2s}
  .tool-card:hover{border-color:var(--accent)}
  .tool-icon{font-size:1.8rem;display:block;margin-bottom:.5rem}
  .tool-card h3{margin:0 0 .3rem;font-size:1rem}
  .tool-card p{margin:0;font-size:.82rem;color:var(--text2)}

  @media(max-width:768px){
    .cat-grid{grid-template-columns:1fr}
    .weapons-list{grid-template-columns:repeat(2,1fr)}
    .tools-grid{grid-template-columns:1fr 1fr}
  }
</style>
